ho \"$description\" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//')\n\n        local original_branch\n        original_branch=$(command git -c core.hooksPath=/dev/null branch --show-current)\n\n        local timestamp\n        timestamp=$(date +'%Y-%m-%d-%H-%M-%S')\n\n        local backup_branch=\"${original_branch}-backup-${sanitized_description}-${timestamp}\"\n\n        if [[ -z $(command git -c core.hooksPath=/dev/null status --porcelain) ]]; then\n            command git -c core.hooksPath=/dev/null branch \"${backup_branch}\"\n            echo \"Restore point created on clean branch: ${backup_branch}\"\n        else\n            command git -c core.hooksPath=/dev/null add .\n            command git -c core.hooksPath=/dev/null commit -m \"backup: ${description}\"\n            command git -c core.hooksPath=/dev/null branch \"${backup_branch}\"\n            command git -c core.hooksPath=/dev/null reset --soft HEAD~1\n            command git -c core.hooksPath=/dev/null reset HEAD .\n            echo \"\\nBackup created at: ${backup_branch}\"\n        fi\n    else\n        command git -c core.hooksPath=/dev/null \"$@\"\n    fi\n}\n\n# Completions - fpath ANTES do compinit\nfpath=($HOME/.docker/completions $fpath)\nfpath=($HOME/.zsh/completions $fpath)\n\n# Inicializa completion system\nautoload -Uz compinit && compinit\n\n# Completion settings\nsetopt MENU_COMPLETE                                  # Tab cicla inline pelas opções\nzstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'   # Case-insensitive\nzstyle ':completion:*' list-colors 'di=34:ln=35:so=32:pi=33:ex=31:bd=34;46:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43'\nzstyle ':completion:*' special-dirs true              # Completa . e ..\nzstyle ':completion:*:descriptions' format '%F{green}-- %d --%f'\nzstyle ':completion:*:warnings' format '%F{red}-- sem matches --%f'\n\n# Fish-style path abbreviation\n_fish_path() {\n  local p=${PWD/#$HOME/\\~}\n  local parts=(${(s:/:)p})\n  local len=${#parts[@]}\n  if (( len <= 1 )); then echo \"$p\"; return; fi\n  local result=\"\"\n  for (( i=1; i<len; i++ )); do\n    local part=${parts[i]}\n    if [[ $part == .* ]]; then\n      result+=\"${part:0:2}/\"\n    else\n      result+=\"${part:0:1}/\"\n    fi\n  done\n  echo \"${result}${parts[-1]}\"\n}\n\n# Prompt: nome curto (verde) : path abreviado (azul) $\nsetopt PROMPT_SUBST\nPROMPT='%F{green}$%f:%F{blue}$(_fish_path)%f $ '\n\n# Plugins (syntax-highlighting deve ser o último)\n#source ~/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh\n# source ~/.zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh\n\n# bun completions\n[ -s \"/Users/anotonio.silva/.bun/_bun\" ] && source \"/Users/anotonio.silva/.bun/_bun\"\n\n. \"$HOME/.atuin/bin/env\"\n\neval \"$(atuin init zsh)\"\n","structuredPatch":[{"oldStart":246,"oldLines":6,"newStart":246,"newLines":3,"lines":[" # bun completions"," [ -s \"/Users/anotonio.silva/.bun/_bun\" ] && source \"/Users/anotonio.silva/.bun/_bun\""," ","-. \"$HOME/.atuin/bin/env\"","-","-eval \"$(atuin init zsh)\""]}],"userModified":false,"replaceAll":false}}
