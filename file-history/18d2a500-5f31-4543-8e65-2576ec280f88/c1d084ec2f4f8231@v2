{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "context-knowledge-base.xml",
    "style": "xml",
    "headerText": "Dubai Metro MMS - Stable Documentation Context\n\nThis file contains ONLY stable reference documentation.\nFor current code, Claude CLI reads files directly on-demand.\n\nSee: docs/CONTEXT_STRATEGY.md for rationale.\n\nGenerated: {{date}}",
    "removeComments": false,
    "showLineNumbers": true,
    "copyToClipboard": false
  },
  "include": [
    "CLAUDE.md",
    "README.md",
    "docs/@start-here/*.md",
    "docs/knowledge-base/**/*.md",
    "docs/RESEARCH_MAINTENANCE_SCHEDULING.md"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/.git/**",
      "**/.turbo/**",
      "**/__pycache__/**",
      "**/*.pyc",
      ".archive/**",
      "docs/internal/**",
      "**/*.lock",
      "**/*.lockb",
      "**/coverage/**",
      "**/.venv/**",
      "context-knowledge-base.xml"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}