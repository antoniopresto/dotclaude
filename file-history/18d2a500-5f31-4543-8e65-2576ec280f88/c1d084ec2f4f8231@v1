{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "context-knowledge-base.xml",
    "style": "xml",
    "headerText": "Dubai Metro MMS - Mileage Management System\n\nThis context contains the complete knowledge base for the maintenance scheduling system.\nUse this for RAG, code generation, and architectural decisions.\n\nGenerated: {{date}}",
    "removeComments": false,
    "showLineNumbers": true,
    "copyToClipboard": false
  },
  "include": [
    "CLAUDE.md",
    "README.md",
    "TODO.md",
    "docs/@start-here/*.md",
    "docs/knowledge-base/**/*.md",
    "docs/RESEARCH_MAINTENANCE_SCHEDULING.md",
    "packages/solver/src/**/*.py",
    "packages/solver/tests/**/*.py",
    "packages/types/src/**/*.ts",
    "apps/mms/app/**/*.{ts,tsx}",
    "turbo.json"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/.git/**",
      "**/.turbo/**",
      "**/__pycache__/**",
      "**/*.pyc",
      ".archive/**",
      "docs/internal/**",
      "**/*.lock",
      "**/*.lockb",
      "**/coverage/**",
      "**/.venv/**",
      "context-knowledge-base.xml"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
