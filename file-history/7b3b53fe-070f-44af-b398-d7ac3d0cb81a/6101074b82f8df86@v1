{
  "name": "@belt/cli",
  "version": "0.1.0",
  "description": "Belt CLI - Developer toolkit command line interface",
  "type": "module",
  "bin": {
    "belt": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/bin.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@belt/core": "workspace:*",
    "@belt/plugin-sync-types": "workspace:*",
    "@belt/plugin-typecheck": "workspace:*",
    "ink": "^6.5.1",
    "ink-spinner": "^5.0.0",
    "meow": "^13.2.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3"
  }
}
