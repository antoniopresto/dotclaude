/**
 * Integration with the harness workflow
 *
 * Visual testing should be triggered:
 * 1. Before marking a feature as complete
 * 2. After implementing UI changes
 * 3. As part of the verify command
 * 4. Through the 'harness test' command
 */
export interface VisualTestingWorkflow {
  /** Whether visual testing is enabled */
  enabled: boolean;
  /** Auto-start dev server if not running */
  autoStartDevServer: boolean;
  /** Take screenshot on every test */
  captureScreenshots: boolean;
  /** Directory for screenshots */
  screenshotDir: string;
  /** Features that require visual testing (by category) */
  requiredCategories: string[];
}

export const DEFAULT_WORKFLOW: VisualTestingWorkflow = {
  enabled: true,
  autoStartDevServer: true,
  captureScreenshots: true,
  screenshotDir: 'screenshots',
  requiredCategories: ['ui', 'canvas', 'rendering', 'layout', 'styling', 'visualization'],
};

