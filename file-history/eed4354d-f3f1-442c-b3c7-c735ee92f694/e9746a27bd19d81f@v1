#!/usr/bin/env node
/**
 * Harness Orchestrator CLI
 *
 * Command-line interface for the harness orchestrator.
 */

import { Command } from 'commander';
import chalk from 'chalk';
import ora from 'ora';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

import { DependencyGraph } from '../graph/DependencyGraph.js';
import { CriticalPath } from '../graph/CriticalPath.js';
import { StateManager } from '../state/StateManager.js';
import { AIManager } from '../ai/AIManager.js';
import { Orchestrator } from '../orchestrator/Orchestrator.js';
import { Dashboard } from '../dashboard/Dashboard.js';
import { Verifier } from '../verification/Verifier.js';
import {
  getAllHookTemplates,
  getSettingsTemplate,
} from '../hooks/HookTemplates.js';
import type { HarnessConfig, ModelType } from '../types.js';

const program = new Command();

program
  .name('harness')
  .alias('h')
  .description('AI Project Manager for harness task orchestration')
  .version('0.1.0');

// Default features path
const DEFAULT_FEATURES_PATH = 'features.json';

/**
 * Resolve features path, using default if not provided
 */
function resolveFeaturesPath(path?: string): string {
  return resolve(path || DEFAULT_FEATURES_PATH);
}

// Analyze command
program
  .command('analyze [features-path]')
  .description('Analyze dependency graph and show execution plan')
  .action((featuresPath?: string) => {
    const resolvedPath = resolveFeaturesPath(featuresPath);
    const content = readFileSync(resolvedPath, 'utf-8');
    const config: HarnessConfig = JSON.parse(content);

    const graph = new DependencyGraph(config);
    const criticalPath = new CriticalPath(graph);

    console.log(chalk.bold('\n📊 Dependency Analysis\n'));

    // Check for cycles
    const cycle = graph.detectCycles();
    if (cycle) {
      console.log(chalk.red('❌ Cycle detected:'), cycle.join(' → '));
      process.exit(1);
    }
    console.log(chalk.green('✓ No cycles detected\n'));

    // Show features by status
    const pending = graph.getPendingFeatures();
    const completed = graph.getAllFeatures().filter((f) => f.passes);

    console.log(chalk.bold('Status:'));
    console.log(`  Completed: ${chalk.green(completed.length)}`);
    console.log(`  Pending: ${chalk.yellow(pending.length)}`);
    console.log();

    // Show ready tasks
    const ready = graph.getReadyTasks();
    console.log(chalk.bold('Ready to run (parallelizable):'));
    if (ready.length === 0) {
      console.log(chalk.dim('  None'));
    } else {
      for (const f of ready) {
        const priority = criticalPath.getPriorityScore(f.id);
        const onCritical = criticalPath.getCriticalPath().includes(f.id);
        const critical = onCritical ? chalk.red(' [CRITICAL]') : '';
        console.log(`  ${chalk.cyan(f.id)}: ${f.description}${critical} (priority: ${priority})`);
      }
    }
    console.log();

    // Show critical path
    const path = criticalPath.getCriticalPath();
    console.log(chalk.bold('Critical Path:'));
    console.log(`  ${path.map((id) => chalk.red(id)).join(' → ')}`);
    console.log();

    // Show execution order
    const order = graph.topologicalSort();
    console.log(chalk.bold('Topological Order:'));
    console.log(`  ${order.map((id) => graph.getFeature(id)?.passes ? chalk.green(id) : chalk.yellow(id)).join(' → ')}`);
  });

// Status command
program
  .command('status [features-path]')
  .description('Show current progress status')
  .action((featuresPath?: string) => {
    const resolvedPath = resolveFeaturesPath(featuresPath);
    const stateManager = new StateManager(resolvedPath);
    const aiManager = new AIManager();

    const config = stateManager.load();
    const progress = stateManager.getProgress();

    console.log(chalk.bold('\n📈 Harness Status\n'));
    console.log(`Project: ${chalk.cyan(config.project)}`);
    console.log(`Version: ${config.version}`);
    console.log(`Last Updated: ${config.lastUpdated}`);
    console.log();

    // Progress bar
    const pct = Math.round((progress.completed / progress.total) * 100);
    const filled = Math.round(pct / 5);
    const bar = '█'.repeat(filled) + '░'.repeat(20 - filled);
    console.log(`Progress: [${bar}] ${pct}%`);
    console.log(`  ${chalk.green(progress.completed)} completed / ${chalk.yellow(progress.pending)} pending`);
    console.log();

    // Features list
    console.log(chalk.bold('Features:'));
    for (const f of config.features) {
      const status = f.passes ? chalk.green('✓') : chalk.yellow('○');
      const blockedBy = f.blockedBy
        ? chalk.dim(` (blocked by: ${Array.isArray(f.blockedBy) ? f.blockedBy.join(', ') : f.blockedBy})`)
        : '';
      console.log(`  ${status} ${f.id}: ${f.description}${blockedBy}`);
    }

    // AI summary
    console.log('\n' + aiManager.generateProgressSummary(config.features));
  });

// Orchestrate command
program
  .command('orchestrate [features-path]')
  .description('Run full orchestration with parallel agents')
  .option('-n, --max-agents <number>', 'Maximum concurrent agents', '3')
  .option('-m, --model <model>', 'Default model (haiku, sonnet, opus)', 'sonnet')
  .option('--dry-run', 'Show plan without executing')
  .option('--timeout <ms>', 'Timeout per task in milliseconds', '600000')
  .option('-d, --dashboard', 'Enable real-time dashboard UI')
  .option('--no-costs', 'Disable cost estimates in dashboard')
  .action(async (featuresPath: string | undefined, options) => {
    const spinner = ora('Loading harness configuration...').start();

    try {
      const resolvedPath = resolveFeaturesPath(featuresPath);
      const stateManager = new StateManager(resolvedPath);
      const config = stateManager.load();

      spinner.succeed('Configuration loaded');

      const pending = config.features.filter((f) => !f.passes).length;

      if (options.dryRun) {
        console.log(chalk.yellow('\n🔍 Dry Run Mode\n'));
        console.log('Would orchestrate with:');
        console.log(`  Max agents: ${options.maxAgents}`);
        console.log(`  Model: ${options.model}`);
        console.log(`  Features: ${pending} pending`);
        console.log(`  Dashboard: ${options.dashboard ? 'enabled' : 'disabled'}`);
        return;
      }

      if (pending === 0) {
        console.log(chalk.green('\n✅ All features are already complete!'));
        return;
      }

      const orchestrator = new Orchestrator(resolvedPath, {
        maxAgents: parseInt(options.maxAgents, 10),
        model: options.model as ModelType,
        timeout: parseInt(options.timeout, 10),
      });

      if (options.dashboard) {
        // Use real-time dashboard
        const dashboard = new Dashboard(config, {
          liveRefresh: true,
          showCosts: options.costs !== false,
          maxAgents: parseInt(options.maxAgents, 10),
        });
        dashboard.setModel(options.model as 'haiku' | 'sonnet' | 'opus');
        dashboard.attach(orchestrator);

        const result = await orchestrator.run();
        dashboard.renderFinalSummary();

        if (result.failed > 0) {
          process.exit(1);
        }
      } else {
        // Classic output mode
        console.log(chalk.bold('\n🚀 Starting Orchestration\n'));
        console.log(`  Max agents: ${chalk.cyan(options.maxAgents)}`);
        console.log(`  Model: ${chalk.cyan(options.model)}`);
        console.log(`  Pending: ${chalk.yellow(pending)} features`);
        console.log();

        // Event handlers for progress display
        orchestrator.on('taskDispatched', ({ taskId, feature }) => {
          console.log(chalk.blue(`▶ Started ${taskId}: ${feature.description}`));
        });

        orchestrator.on('taskSucceeded', ({ taskId }) => {
          console.log(chalk.green(`✓ Completed ${taskId}`));
        });

        orchestrator.on('taskFailed', ({ taskId, error }) => {
          console.log(chalk.red(`✗ Failed ${taskId}: ${error}`));
        });

        orchestrator.on('deadlock', ({ pending }) => {
          console.log(chalk.red(`\n⚠️  Deadlock detected! ${pending} tasks stuck.`));
        });

        orchestrator.on('shutdown', ({ signal }) => {
          console.log(chalk.yellow(`\n⚠️  Received ${signal}, shutting down gracefully...`));
        });

        const runSpinner = ora('Running orchestration...').start();
        const result = await orchestrator.run();
        runSpinner.stop();

        console.log(chalk.bold('\n📊 Results\n'));
        console.log(`  Completed: ${chalk.green(result.completed)}`);
        console.log(`  Failed: ${chalk.red(result.failed)}`);

        if (result.failed === 0) {
          console.log(chalk.green('\n✅ Orchestration completed successfully!'));
        } else {
          console.log(chalk.yellow(`\n⚠️  ${result.failed} task(s) failed.`));
          process.exit(1);
        }
      }
    } catch (error) {
      spinner.fail('Orchestration failed');
      console.error(error);
      process.exit(1);
    }
  });

// Dashboard command (standalone)
program
  .command('dashboard [features-path]')
  .description('Show real-time dashboard (attaches to running orchestration)')
  .option('--no-costs', 'Disable cost estimates')
  .action((featuresPath: string | undefined, options) => {
    const resolvedPath = resolveFeaturesPath(featuresPath);
    const stateManager = new StateManager(resolvedPath);
    const config = stateManager.load();

    const dashboard = new Dashboard(config, {
      liveRefresh: false,
      showCosts: options.costs !== false,
    });

    dashboard.render();
  });

// Verify command
program
  .command('verify [features-path]')
  .description('Verify feature completion and show verification status')
  .option('-f, --feature <id>', 'Verify a specific feature')
  .option('--all', 'Verify all completed features')
  .action(async (featuresPath: string | undefined, options) => {
    const resolvedPath = resolveFeaturesPath(featuresPath);
    const verifier = new Verifier(resolvedPath);
    const stateManager = new StateManager(resolvedPath);
    const config = stateManager.load();

    console.log(chalk.bold('\n🔍 Feature Verification\n'));

    // Get git status
    const gitStatus = verifier.getGitStatus();
    if (gitStatus) {
      console.log(chalk.bold('Git Status:'));
      console.log(`  Branch: ${chalk.cyan(gitStatus.branch)}`);
      console.log(`  Clean: ${gitStatus.isClean ? chalk.green('Yes') : chalk.yellow('No')}`);
      if (gitStatus.ahead > 0 || gitStatus.behind > 0) {
        console.log(`  Ahead: ${gitStatus.ahead}, Behind: ${gitStatus.behind}`);
      }
      console.log();
    }

    // List feature branches
    const branches = verifier.listFeatureBranches();
    if (branches.length > 0) {
      console.log(chalk.bold('Feature Branches:'));
      for (const branch of branches) {
        const status = branch.isMerged ? chalk.green('merged') : chalk.yellow('pending');
        console.log(`  ${branch.name} (${branch.featureId}) - ${status}`);
      }
      console.log();
    }

    // Verify features
    const featuresToVerify = options.feature
      ? config.features.filter(f => f.id === options.feature)
      : options.all
        ? config.features.filter(f => f.passes)
        : config.features.filter(f => f.passes).slice(0, 5);

    if (featuresToVerify.length === 0) {
      console.log(chalk.dim('No features to verify'));
      return;
    }

    console.log(chalk.bold('Verification Results:'));
    for (const feature of featuresToVerify) {
      const result = await verifier.verifyFeature(feature);
      const icon = result.passed ? chalk.green('✓') : chalk.red('✗');
      console.log(`\n${icon} ${chalk.bold(result.featureId)}: ${feature.description}`);
      for (const check of result.checks) {
        const checkIcon = check.passed ? chalk.green('✓') : chalk.red('✗');
        console.log(`    ${checkIcon} ${check.name}: ${chalk.dim(check.details || '')}`);
      }
    }
  });

// Rollback command
program
  .command('rollback [features-path]')
  .description('Rollback a feature to its previous state')
  .requiredOption('-f, --feature <id>', 'Feature ID to rollback')
  .option('--delete-remote', 'Also delete remote branch')
  .action(async (featuresPath: string | undefined, options) => {
    const resolvedPath = resolveFeaturesPath(featuresPath);
    const verifier = new Verifier(resolvedPath);
    const stateManager = new StateManager(resolvedPath);

    const featureId = options.feature.toUpperCase();

    console.log(chalk.bold(`\n🔄 Rolling back feature ${featureId}\n`));

    const gitStatus = verifier.getGitStatus();
    if (!gitStatus) {
      console.log(chalk.red('Not a git repository. Cannot rollback.'));
      process.exit(1);
    }

    const branches = verifier.listFeatureBranches();
    const branch = branches.find(b => b.featureId === featureId);

    if (!branch) {
      console.log(chalk.yellow(`No branch found for feature ${featureId}`));
      console.log('Available feature branches:');
      for (const b of branches) {
        console.log(`  - ${b.name} (${b.featureId})`);
      }
      return;
    }

    console.log(`Branch: ${chalk.cyan(branch.name)}`);
    console.log(`Merged: ${branch.isMerged ? chalk.green('Yes') : chalk.yellow('No')}`);
    console.log();

    // Update state to mark as not complete
    const config = stateManager.load();
    const feature = config.features.find(f => f.id === featureId);
    if (feature) {
      feature.passes = false;
      await stateManager.save(config);
      console.log(chalk.green(`✓ Marked ${featureId} as incomplete in features.json`));
    }

    // Note: In a real implementation, we'd use the GitManager to delete the branch
    console.log(chalk.dim(`To delete the branch manually: git branch -D ${branch.name}`));

    console.log(chalk.green('\n✓ Rollback complete'));
  });

// Branches command
program
  .command('branches [features-path]')
  .description('List and manage feature branches')
  .option('--cleanup', 'Delete merged feature branches')
  .action((featuresPath: string | undefined, options) => {
    const resolvedPath = resolveFeaturesPath(featuresPath);
    const verifier = new Verifier(resolvedPath);

    const gitStatus = verifier.getGitStatus();
    if (!gitStatus) {
      console.log(chalk.red('Not a git repository.'));
      process.exit(1);
    }

    console.log(chalk.bold('\n🌿 Feature Branches\n'));
    console.log(`Current branch: ${chalk.cyan(gitStatus.branch)}`);
    console.log();

    const branches = verifier.listFeatureBranches();

    if (branches.length === 0) {
      console.log(chalk.dim('No feature branches found'));
      return;
    }

    const merged = branches.filter(b => b.isMerged);
    const pending = branches.filter(b => !b.isMerged);

    if (pending.length > 0) {
      console.log(chalk.bold('Pending (not merged):'));
      for (const branch of pending) {
        console.log(`  ${chalk.yellow('○')} ${branch.name} (${branch.featureId})`);
      }
      console.log();
    }

    if (merged.length > 0) {
      console.log(chalk.bold('Merged:'));
      for (const branch of merged) {
        console.log(`  ${chalk.green('✓')} ${branch.name} (${branch.featureId})`);
      }
      console.log();
    }

    if (options.cleanup && merged.length > 0) {
      console.log(chalk.bold('Cleaning up merged branches...'));
      const deleted = verifier.cleanupMergedBranches();
      console.log(chalk.green(`✓ Deleted ${deleted.length} branch(es)`));
    } else if (merged.length > 0) {
      console.log(chalk.dim(`Run with --cleanup to delete ${merged.length} merged branch(es)`));
    }
  });

// Init command - bootstrap a new harness project
program
  .command('init [project-path]')
  .description('Initialize a new harness project with standard structure')
  .option('-n, --name <name>', 'Project name')
  .option('--no-hooks', 'Skip generating hooks')
  .option('--no-git', 'Skip git initialization')
  .action(async (projectPath: string | undefined, options) => {
    const targetDir = resolve(projectPath || '.');
    const projectName = options.name || targetDir.split('/').pop() || 'my-project';

    console.log(chalk.bold(`\n🚀 Initializing Harness Project: ${projectName}\n`));

    const { existsSync, mkdirSync, writeFileSync } = await import('node:fs');

    // Create directory if needed
    if (!existsSync(targetDir)) {
      mkdirSync(targetDir, { recursive: true });
      console.log(chalk.green(`✓ Created directory: ${targetDir}`));
    }

    // 1. Generate features.json
    const featuresPath = resolve(targetDir, 'features.json');
    if (!existsSync(featuresPath)) {
      const featuresTemplate = {
        project: projectName,
        version: '0.1.0',
        description: `Harness configuration for ${projectName}`,
        lastUpdated: new Date().toISOString().split('T')[0],
        features: [
          {
            id: 'F001',
            category: 'setup',
            description: 'Project initialization and environment setup',
            steps: [
              'Verify development environment',
              'Install dependencies',
              'Configure build tools',
              'Run initial build'
            ],
            passes: false,
            blockedBy: null,
            notes: 'First feature - no dependencies'
          }
        ]
      };
      writeFileSync(featuresPath, JSON.stringify(featuresTemplate, null, 2));
      console.log(chalk.green('✓ Created features.json'));
    } else {
      console.log(chalk.yellow('○ features.json already exists, skipping'));
    }

    // 2. Generate claude-progress.txt
    const progressPath = resolve(targetDir, 'claude-progress.txt');
    if (!existsSync(progressPath)) {
      const today = new Date().toISOString().split('T')[0];
      const progressTemplate = `# ${projectName} - Progress Log

## Project Goal
[Describe the main objective of this project]

---

## Session 1 - ${today} - Project Initialization

### Context
Initial harness setup.

### Completed ✅
- Created harness structure with \`harness init\`
- Generated features.json with initial feature

### Current State
| Feature | Status | Notes |
|---------|--------|-------|
| F001 | ○ Pending | Project setup |

### Next Session Priorities
1. Complete F001: Project initialization
2. Add more features to features.json

---

## Quick Start for New Session

\`\`\`bash
# 1. Read current state
harness status

# 2. Work on next feature
# ... implement ...

# 3. Mark complete and commit
# Update features.json: passes: true
git add . && git commit -m "feat: F001 - description"

# 4. Update this progress file
\`\`\`
`;
      writeFileSync(progressPath, progressTemplate);
      console.log(chalk.green('✓ Created claude-progress.txt'));
    } else {
      console.log(chalk.yellow('○ claude-progress.txt already exists, skipping'));
    }

    // 3. Generate CLAUDE.md
    const claudeMdPath = resolve(targetDir, 'CLAUDE.md');
    if (!existsSync(claudeMdPath)) {
      const claudeMdTemplate = `# ${projectName} - AI Instructions

## What is This?

This project uses a **Harness** - a framework that enables AI agents to work on long tasks across multiple context windows/sessions.

**Problem:** Each new Claude Code session starts with NO memory of previous sessions.
**Solution:** State files persist context between sessions.

---

## Harness Protocol

\`\`\`
1. READ claude-progress.txt → understand current state
2. READ features.json → find next feature (passes: false)
3. IMPLEMENT the feature
4. TEST the implementation
5. UPDATE features.json → set passes: true
6. UPDATE claude-progress.txt → add session notes
7. COMMIT changes
\`\`\`

---

## Key Files

| File | Purpose |
|------|---------|
| \`features.json\` | Feature definitions and status |
| \`claude-progress.txt\` | Session history and notes |
| \`CLAUDE.md\` | This file - AI instructions |

---

## Commands

\`\`\`bash
# Check status
harness status

# Analyze dependencies
harness analyze

# View dashboard
harness dashboard
\`\`\`

---

## Rules

1. **One Feature Per Session**: Focus on a single feature to prevent context overflow
2. **Always Update Progress**: Log what you did before ending session
3. **Commit After Completion**: Each feature should result in a commit
4. **Visual Testing**: Use Playwright MCP to verify UI changes
`;
      writeFileSync(claudeMdPath, claudeMdTemplate);
      console.log(chalk.green('✓ Created CLAUDE.md'));
    } else {
      console.log(chalk.yellow('○ CLAUDE.md already exists, skipping'));
    }

    // 4. Generate init.sh
    const initShPath = resolve(targetDir, 'init.sh');
    if (!existsSync(initShPath)) {
      const initShTemplate = `#!/bin/bash
# ${projectName} - Development Environment Initialization
# This script is run at the start of each harness session

set -e

echo "🚀 Initializing ${projectName} development environment..."

# Check for required tools
command -v node >/dev/null 2>&1 || { echo "❌ Node.js is required"; exit 1; }
command -v git >/dev/null 2>&1 || { echo "❌ Git is required"; exit 1; }

# Install dependencies if needed
if [ -f "package.json" ] && [ ! -d "node_modules" ]; then
  echo "📦 Installing dependencies..."
  npm install || bun install || yarn install
fi

# Start development server (customize as needed)
# npm run dev &

echo "✅ Environment ready!"
`;
      writeFileSync(initShPath, initShTemplate);
      // Make executable
      const { chmodSync } = await import('node:fs');
      chmodSync(initShPath, '755');
      console.log(chalk.green('✓ Created init.sh (executable)'));
    } else {
      console.log(chalk.yellow('○ init.sh already exists, skipping'));
    }

    // 5. Generate .claude directory with hooks (if not --no-hooks)
    if (options.hooks !== false) {
      const claudeDir = resolve(targetDir, '.claude');
      const hooksDir = resolve(claudeDir, 'hooks');

      if (!existsSync(claudeDir)) {
        mkdirSync(claudeDir, { recursive: true });
      }
      if (!existsSync(hooksDir)) {
        mkdirSync(hooksDir, { recursive: true });
      }

      // Generate settings.json using template
      const settingsPath = resolve(claudeDir, 'settings.json');
      if (!existsSync(settingsPath)) {
        const settingsTemplate = getSettingsTemplate();
        writeFileSync(settingsPath, JSON.stringify(settingsTemplate, null, 2));
        console.log(chalk.green('✓ Created .claude/settings.json'));
      }

      // Generate all hooks using templates
      const { chmodSync } = await import('node:fs');
      const hookTemplates = getAllHookTemplates(projectName);

      for (const hook of hookTemplates) {
        const hookPath = resolve(hooksDir, hook.filename);
        if (!existsSync(hookPath)) {
          writeFileSync(hookPath, hook.content);
          chmodSync(hookPath, '755');
          console.log(chalk.green(`✓ Created .claude/hooks/${hook.filename}`));
        } else {
          console.log(chalk.yellow(`○ .claude/hooks/${hook.filename} already exists, skipping`));
        }
      }
    }

    // 6. Initialize git (if not --no-git)
    if (options.git !== false) {
      const gitDir = resolve(targetDir, '.git');
      if (!existsSync(gitDir)) {
        const { execSync } = await import('node:child_process');
        try {
          execSync('git init', { cwd: targetDir, stdio: 'pipe' });
          console.log(chalk.green('✓ Initialized git repository'));
        } catch {
          console.log(chalk.yellow('○ Could not initialize git'));
        }
      } else {
        console.log(chalk.yellow('○ Git already initialized'));
      }
    }

    console.log(chalk.bold.green('\n✅ Harness initialized successfully!\n'));
    console.log('Next steps:');
    console.log(`  1. ${chalk.cyan('cd ' + (projectPath || '.'))}`)
    console.log(`  2. ${chalk.cyan('harness status')} - View current state`);
    console.log(`  3. Edit ${chalk.cyan('features.json')} to add your features`);
    console.log(`  4. ${chalk.cyan('harness continue')} - Start working on features`);
    console.log();
  });

// Continue command - the CORE harness command per Anthropic protocol
program
  .command('continue [project-path]')
  .description('Continue working on the harness (Two-Agent Architecture per Anthropic)')
  .option('-m, --model <model>', 'Model to use (haiku, sonnet, opus)', 'sonnet')
  .option('--timeout <ms>', 'Timeout per feature in milliseconds', '600000')
  .option('--dry-run', 'Show what would be done without executing')
  .option('--init-only', 'Only run initializer, do not start coding agent')
  .action(async (projectPath: string | undefined, options) => {
    const targetDir = resolve(projectPath || '.');
    const progressPath = resolve(targetDir, 'claude-progress.txt');
    const featuresPath = resolve(targetDir, 'features.json');
    const initShPath = resolve(targetDir, 'init.sh');

    const { existsSync, readFileSync } = await import('node:fs');
    const { execSync, spawn } = await import('node:child_process');

    console.log(chalk.bold('\n🚀 Harness Continue\n'));
    console.log(chalk.dim(`Project: ${targetDir}`));
    console.log(chalk.dim(`Model: ${options.model}`));
    console.log();

    // Determine if this is first run (Initializer) or subsequent (Coding Agent)
    const isFirstRun = !existsSync(progressPath);

    if (isFirstRun) {
      console.log(chalk.yellow('📋 First run detected - Initializer Agent mode\n'));

      if (options.dryRun) {
