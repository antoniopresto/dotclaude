import { test, expect } from '@playwright/test';

test.describe('Maintenance Page', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/maintenance');
  });

  test('should render maintenance page', async ({ page }) => {
    await expect(page).toHaveTitle(/MMS/);
  });

  test('should display maintenance heading', async ({ page }) => {
    await expect(page.getByRole('heading', { name: /Maintenance/i })).toBeVisible();
  });

  test('should display Maintenance Timeline section', async ({ page }) => {
    await page.waitForTimeout(2000);
    await expect(page.getByRole('heading', { name: /Maintenance Timeline/i })).toBeVisible();
  });

  test('should display Depot Capacity section', async ({ page }) => {
    await page.waitForTimeout(2000);
    await expect(page.getByRole('heading', { name: /Depot Capacity/i })).toBeVisible();
  });

  test('should have week filter controls', async ({ page }) => {
    await page.waitForTimeout(2000);

    // Should have 1 Week, 2 Weeks, 4 Weeks buttons
    await expect(page.getByRole('button', { name: '1 Week' })).toBeVisible();
    await expect(page.getByRole('button', { name: '2 Weeks' })).toBeVisible();
    await expect(page.getByRole('button', { name: '4 Weeks' })).toBeVisible();
  });

  test('should have fleet filter dropdown', async ({ page }) => {
    await page.waitForTimeout(2000);

    const fleetFilter = page.getByRole('combobox');
    if (await fleetFilter.isVisible()) {
      await expect(fleetFilter).toBeVisible();
    }
  });

  test('should display train list when API is available', async ({ page }) => {
    await page.waitForTimeout(3000);

    // Look for train IDs in the page
    const trainRows = page.locator('text=/UME-|UTE-|UQE-/i');
    const count = await trainRows.count();

    // If API is running, we should have train data
    if (count > 0) {
      expect(count).toBeGreaterThan(0);
    }
  });

  test('should show depot utilization percentages', async ({ page }) => {
    await page.waitForTimeout(3000);

    // Look for percentage values
    const percentages = page.locator('text=/%/');
    const count = await percentages.count();

    // Should have depot utilization percentages
    expect(count).toBeGreaterThan(0);
  });
});
