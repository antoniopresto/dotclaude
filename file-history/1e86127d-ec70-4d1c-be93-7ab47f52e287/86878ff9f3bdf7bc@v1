import { test, expect } from '@playwright/test';

test.describe('Fleet Page', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/fleet');
  });

  test('should render fleet page', async ({ page }) => {
    await expect(page).toHaveTitle(/MMS/);
  });

  test('should display fleet heading', async ({ page }) => {
    await expect(page.getByRole('heading', { name: /Fleet/i })).toBeVisible();
  });

  test('should not have console errors', async ({ page }) => {
    const errors: string[] = [];
    page.on('console', msg => {
      if (msg.type() === 'error') {
        errors.push(msg.text());
      }
    });

    await page.waitForTimeout(2000);

    // Filter out known non-critical errors
    const criticalErrors = errors.filter(e =>
      !e.includes('Download the React DevTools') &&
      !e.includes('favicon')
    );

    expect(criticalErrors).toHaveLength(0);
  });
});
