/**
 * MMS - Viewport Store for Semantic Zoom Canvas
 *
 * State management for the schedule canvas using @zazcart/toolkit
 * Manages zoom level, pan position, LOD (Level of Detail), and selection
 */

import { createMachine, interpret } from '@zazcart/toolkit';

// LOD Level definitions
export type LODLevel = 0 | 1 | 2 | 3;

export const LOD_THRESHOLDS = {
  STRATEGIC: { min: 0.05, max: 0.2 },   // LOD 0: 10-12 years
  TACTICAL: { min: 0.2, max: 0.5 },      // LOD 1: 1-3 years
  OPERATIONAL: { min: 0.5, max: 1.0 },   // LOD 2: 1-6 months
  EXECUTION: { min: 1.0, max: 4.0 },     // LOD 3: 1-4 weeks
} as const;

// Determine LOD level from scale
export function getLODFromScale(scale: number): LODLevel {
  if (scale < LOD_THRESHOLDS.TACTICAL.min) return 0;
  if (scale < LOD_THRESHOLDS.OPERATIONAL.min) return 1;
  if (scale < LOD_THRESHOLDS.EXECUTION.min) return 2;
  return 3;
}

// State interface
export interface ViewportState {
  scale: number;
  translateX: number;
  translateY: number;
  currentLOD: LODLevel;
  visibleStartDate: Date;
  visibleEndDate: Date;
  isZooming: boolean;
  isPanning: boolean;
  selectedItems: Set<string>;
  hoveredItem: string | null;
}

// Events
type ViewportEvent =
  | { type: 'ZOOM'; scale: number; centerX: number; centerY: number }
  | { type: 'PAN'; deltaX: number; deltaY: number }
  | { type: 'ZOOM_START' }
  | { type: 'ZOOM_END' }
  | { type: 'PAN_START' }
  | { type: 'PAN_END' }
  | { type: 'SET_VISIBLE_RANGE'; startDate: Date; endDate: Date }
  | { type: 'SELECT_ITEM'; itemId: string; additive: boolean }
  | { type: 'DESELECT_ITEM'; itemId: string }
  | { type: 'CLEAR_SELECTION' }
  | { type: 'HOVER_ITEM'; itemId: string | null }
  | { type: 'RESET' };

// Initial state
const initialState: ViewportState = {
  scale: 0.5, // Start at Operational level
  translateX: 0,
  translateY: 0,
  currentLOD: 2,
  visibleStartDate: new Date(),
  visibleEndDate: new Date(Date.now() + 180 * 24 * 60 * 60 * 1000), // 6 months
  isZooming: false,
  isPanning: false,
  selectedItems: new Set(),
  hoveredItem: null,
};

// State machine definition
const viewportMachine = createMachine<ViewportState, ViewportEvent>({
  id: 'viewport',
  initial: 'idle',
  context: initialState,
  states: {
    idle: {
      on: {
        ZOOM_START: 'zooming',
        PAN_START: 'panning',
        ZOOM: {
          actions: ['updateZoom'],
        },
        PAN: {
          actions: ['updatePan'],
        },
        SELECT_ITEM: {
          actions: ['selectItem'],
        },
        DESELECT_ITEM: {
          actions: ['deselectItem'],
        },
        CLEAR_SELECTION: {
          actions: ['clearSelection'],
        },
        HOVER_ITEM: {
          actions: ['setHoveredItem'],
        },
        SET_VISIBLE_RANGE: {
          actions: ['setVisibleRange'],
        },
        RESET: {
          actions: ['resetViewport'],
        },
      },
    },
    zooming: {
      on: {
        ZOOM: {
          actions: ['updateZoom'],
        },
        ZOOM_END: 'idle',
      },
    },
    panning: {
      on: {
        PAN: {
          actions: ['updatePan'],
        },
        PAN_END: 'idle',
      },
    },
  },
});

// Actions
const actions = {
  updateZoom: (context: ViewportState, event: ViewportEvent) => {
    if (event.type !== 'ZOOM') return context;

    const newScale = Math.max(0.05, Math.min(4.0, event.scale));
    const newLOD = getLODFromScale(newScale);

    return {
      ...context,
      scale: newScale,
      currentLOD: newLOD,
      isZooming: true,
    };
  },

  updatePan: (context: ViewportState, event: ViewportEvent) => {
    if (event.type !== 'PAN') return context;

    return {
      ...context,
      translateX: context.translateX + event.deltaX,
      translateY: context.translateY + event.deltaY,
      isPanning: true,
    };
  },

  selectItem: (context: ViewportState, event: ViewportEvent) => {
    if (event.type !== 'SELECT_ITEM') return context;

    const newSelection = new Set(event.additive ? context.selectedItems : []);
    newSelection.add(event.itemId);

    return {
      ...context,
      selectedItems: newSelection,
    };
  },

  deselectItem: (context: ViewportState, event: ViewportEvent) => {
    if (event.type !== 'DESELECT_ITEM') return context;

    const newSelection = new Set(context.selectedItems);
    newSelection.delete(event.itemId);

    return {
      ...context,
      selectedItems: newSelection,
    };
  },

  clearSelection: (context: ViewportState) => ({
    ...context,
    selectedItems: new Set<string>(),
  }),

  setHoveredItem: (context: ViewportState, event: ViewportEvent) => {
    if (event.type !== 'HOVER_ITEM') return context;

    return {
      ...context,
      hoveredItem: event.itemId,
    };
  },

  setVisibleRange: (context: ViewportState, event: ViewportEvent) => {
    if (event.type !== 'SET_VISIBLE_RANGE') return context;

    return {
      ...context,
      visibleStartDate: event.startDate,
      visibleEndDate: event.endDate,
    };
  },

  resetViewport: () => initialState,
};

// Create interpreter (singleton pattern)
let interpreterInstance: ReturnType<typeof interpret> | null = null;

export function getViewportService() {
  if (!interpreterInstance) {
    interpreterInstance = interpret(viewportMachine, { actions });
    interpreterInstance.start();
  }
  return interpreterInstance;
}

// Helper functions for common operations
export const viewportActions = {
  zoom: (scale: number, centerX = 0, centerY = 0) => {
    getViewportService().send({ type: 'ZOOM', scale, centerX, centerY });
  },

  pan: (deltaX: number, deltaY: number) => {
    getViewportService().send({ type: 'PAN', deltaX, deltaY });
  },

  zoomIn: () => {
    const current = getViewportService().getSnapshot().context.scale;
    viewportActions.zoom(current * 1.2);
  },

  zoomOut: () => {
    const current = getViewportService().getSnapshot().context.scale;
    viewportActions.zoom(current / 1.2);
  },

  selectItem: (itemId: string, additive = false) => {
    getViewportService().send({ type: 'SELECT_ITEM', itemId, additive });
  },

  deselectItem: (itemId: string) => {
    getViewportService().send({ type: 'DESELECT_ITEM', itemId });
  },

  clearSelection: () => {
    getViewportService().send({ type: 'CLEAR_SELECTION' });
  },

  hoverItem: (itemId: string | null) => {
    getViewportService().send({ type: 'HOVER_ITEM', itemId });
  },

  reset: () => {
    getViewportService().send({ type: 'RESET' });
  },
};

// React hook for subscribing to viewport state
export function useViewportState(): ViewportState {
  // This is a simplified version - in production use the toolkit's useMachine/useSelector
  return getViewportService().getSnapshot().context;
}
