{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "check:types": {
      "dependsOn": ["^build"]
    },
    "check:prettier": {},
    "clean": {
      "cache": false
    }
  }
}
