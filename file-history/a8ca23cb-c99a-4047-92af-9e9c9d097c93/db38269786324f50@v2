/**
 * MMS API Server
 *
 * Hono + Bun HTTP server providing:
 * - Solver endpoints for optimization
 * - Fleet management (CRUD)
 * - Scenario management (What-If results)
 * - Health checks
 * - CORS support for frontend
 */

import { Hono } from "hono";
import { cors } from "hono/cors";
import { logger } from "hono/logger";
import { solver } from "./routes/solver";
import { fleet } from "./routes/fleet";
import { scenarios } from "./routes/scenarios";
import { connectDb, getDb } from "./db/connection";

const app = new Hono();

// Middleware
app.use("*", logger());
app.use(
  "*",
  cors({
    origin: ["http://localhost:3000", "http://localhost:5173"],
    allowMethods: ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    allowHeaders: ["Content-Type", "Authorization"],
  })
);

// Routes
app.route("/api/solver", solver);
app.route("/api/fleet", fleet);
app.route("/api/scenarios", scenarios);

// Root health check
app.get("/", (c) => {
  return c.json({
    name: "@uptime/api",
    version: "1.0.0",
    status: "running",
    timestamp: new Date().toISOString(),
  });
});

app.get("/health", async (c) => {
  try {
    const db = getDb();
    await db.command({ ping: 1 });
    return c.json({ status: "ok", database: "connected" });
  } catch {
    return c.json({ status: "ok", database: "disconnected" });
  }
});

// Start server with database connection
const port = Number(process.env.PORT) || 3001;

console.log(`Starting server on port ${port}...`);

// Connect to MongoDB on startup
connectDb()
  .then(() => {
    console.log("Database connected successfully");
  })
  .catch((err) => {
    console.warn("Failed to connect to database:", err.message);
    console.warn("Server will run without database - some features disabled");
  });

export default {
  port,
  fetch: app.fetch,
};

export { app };
