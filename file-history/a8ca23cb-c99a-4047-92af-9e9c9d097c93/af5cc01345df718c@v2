import { useRef, useEffect, useState, useMemo, useCallback } from "react";
import { Card, Elevation, Tag, Intent, Slider, Button, Icon } from "@blueprintjs/core";
import type { SolverInput, SolverOutput, EventAssignment } from "@uptime/types";

// ============================================================================
// LIVE METRO SYSTEM VISUALIZATION
// Shows the Dubai Metro as a living, breathing system
// ============================================================================

interface LiveMetroSystemProps {
  input: SolverInput;
  output: SolverOutput;
  capacity: number;
}

// Planning levels following Fraunhofer IVI model
type PlanningLevel = "strategic" | "tactical" | "operational" | "daily";

interface PlanningView {
  level: PlanningLevel;
  label: string;
  timeframe: string;
  description: string;
  weeksPerUnit: number;
}

const PLANNING_LEVELS: PlanningView[] = [
  { level: "strategic", label: "Strategic", timeframe: "12 Years", description: "Long-term fleet lifecycle", weeksPerUnit: 52 },
  { level: "tactical", label: "Tactical", timeframe: "Quarterly", description: "Major overhauls & C-Checks", weeksPerUnit: 13 },
  { level: "operational", label: "Operational", timeframe: "Monthly", description: "B-Checks & A-Checks", weeksPerUnit: 4 },
  { level: "daily", label: "Daily", timeframe: "This Week", description: "Today's maintenance", weeksPerUnit: 1 },
];

// Depot configuration (Dubai Metro)
const DEPOTS = [
  { id: "al-rashidiya", name: "Al Rashidiya Depot", tracks: 5, line: "red", x: 0.75, y: 0.15 },
  { id: "jebel-ali", name: "Jebel Ali Depot", tracks: 4, line: "red", x: 0.15, y: 0.15 },
];

// Line configuration
const METRO_LINES = [
  { id: "red", name: "Red Line", color: "#E53935", trains: 79, stations: 29 },
  { id: "green", name: "Green Line", color: "#43A047", trains: 49, stations: 20 },
];

// Maintenance type colors
const MT_COLORS: Record<string, string> = {
  "mt-a": "#2196F3",
  "mt-b": "#4CAF50",
  "mt-c": "#FF9800",
  "mt-d": "#F44336",
};

export function LiveMetroSystem({ input, output, capacity }: LiveMetroSystemProps) {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const [selectedWeek, setSelectedWeek] = useState(0);
  const [planningLevel, setPlanningLevel] = useState<PlanningLevel>("operational");
  const [animationFrame, setAnimationFrame] = useState(0);
  const [isPlaying, setIsPlaying] = useState(true);

  const horizonWeeks = input.planningHorizonWeeks;

  // Process assignments into week-based view
  const weeklyData = useMemo(() => {
    if (!output.solution) return [];

    const eventMap = new Map(input.events.map(e => [e.id, e]));
    const assetMap = new Map(input.assets.map(a => [a.id, a]));

    const weeks: Array<{
      week: number;
      events: Array<{
        assetId: string;
        assetType: string;
        maintenanceType: string;
        manHours: number;
      }>;
      totalManHours: number;
      utilization: number;
      alstomCount: number;
      kinkiCount: number;
    }> = [];

    for (let w = 0; w < horizonWeeks; w++) {
      const weekEvents = output.solution.assignments
        .filter(a => a.assignedPeriod === w)
        .map(a => {
          const event = eventMap.get(a.eventId);
          const asset = event ? assetMap.get(event.assetId) : null;
          return {
            assetId: event?.assetId || "",
            assetType: asset?.assetType || "Unknown",
            maintenanceType: event?.maintenanceTypeId || "",
            manHours: event?.manHours || 0,
          };
        });

      const totalManHours = weekEvents.reduce((sum, e) => sum + e.manHours, 0);

      weeks.push({
        week: w,
        events: weekEvents,
        totalManHours,
        utilization: capacity > 0 ? totalManHours / capacity : 0,
        alstomCount: weekEvents.filter(e => e.assetType === "ALSTOM").length,
        kinkiCount: weekEvents.filter(e => e.assetType === "KINKI").length,
      });
    }

    return weeks;
  }, [input, output, horizonWeeks, capacity]);

  // Animation loop
  useEffect(() => {
    if (!isPlaying) return;

    const interval = setInterval(() => {
      setAnimationFrame(f => (f + 1) % 360);
    }, 50);

    return () => clearInterval(interval);
  }, [isPlaying]);

  // Canvas rendering
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const width = canvas.width;
    const height = canvas.height;

    // Clear
    ctx.fillStyle = "#1C2127";
    ctx.fillRect(0, 0, width, height);

    // Draw metro lines
    drawMetroLines(ctx, width, height, animationFrame);

    // Draw depots
    drawDepots(ctx, width, height, weeklyData[selectedWeek], animationFrame);

    // Draw trains in depot
    if (weeklyData[selectedWeek]) {
      drawTrainsInDepot(ctx, width, height, weeklyData[selectedWeek], animationFrame);
    }

    // Draw resource indicators
    drawResourceIndicators(ctx, width, height, weeklyData[selectedWeek], capacity);

  }, [canvasRef, animationFrame, selectedWeek, weeklyData, capacity]);

  const currentWeekData = weeklyData[selectedWeek];
  const currentLevel = PLANNING_LEVELS.find(p => p.level === planningLevel)!;

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: "16px" }}>
      {/* Header with planning level selector */}
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
        <div>
          <h3 style={{ margin: 0 }}>Dubai Metro - Live System View</h3>
          <p style={{ margin: "4px 0 0", color: "#8A9BA8", fontSize: "12px" }}>
            12-year planning horizon | 128 trains | 2 depots
          </p>
        </div>

        <div style={{ display: "flex", gap: "8px" }}>
          {PLANNING_LEVELS.map(level => (
            <Button
              key={level.level}
              minimal
              active={planningLevel === level.level}
              onClick={() => setPlanningLevel(level.level)}
              style={{
                backgroundColor: planningLevel === level.level ? "#394B59" : "transparent",
              }}
            >
              {level.label}
            </Button>
          ))}
        </div>
      </div>

      {/* Main visualization */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 300px", gap: "16px" }}>
        {/* Canvas area */}
        <Card elevation={Elevation.TWO} style={{ padding: 0, overflow: "hidden", backgroundColor: "#1C2127" }}>
          <canvas
            ref={canvasRef}
            width={800}
            height={400}
            style={{ width: "100%", height: "400px" }}
          />
        </Card>

        {/* Side panel - Current state */}
        <div style={{ display: "flex", flexDirection: "column", gap: "12px" }}>
          {/* Planning level info */}
          <Card elevation={Elevation.ONE} style={{ backgroundColor: "#252A31", color: "#F5F8FA" }}>
            <div style={{ fontSize: "10px", color: "#8A9BA8", marginBottom: "4px" }}>
              {currentLevel.timeframe} View
            </div>
            <div style={{ fontSize: "16px", fontWeight: 600 }}>{currentLevel.label} Planning</div>
            <div style={{ fontSize: "11px", color: "#ABB3BF", marginTop: "4px" }}>
              {currentLevel.description}
            </div>
          </Card>

          {/* Week selector */}
          <Card elevation={Elevation.ONE}>
            <div style={{ fontSize: "12px", color: "#5F6B7C", marginBottom: "8px" }}>
              Week {selectedWeek + 1} of {horizonWeeks}
            </div>
            <Slider
              min={0}
              max={horizonWeeks - 1}
              value={selectedWeek}
              onChange={setSelectedWeek}
              labelRenderer={v => `W${v + 1}`}
              labelStepSize={Math.ceil(horizonWeeks / 6)}
            />
          </Card>

          {/* Current week stats */}
          {currentWeekData && (
            <Card elevation={Elevation.ONE}>
              <div style={{ fontSize: "12px", fontWeight: 600, marginBottom: "12px" }}>
                Week {selectedWeek + 1} Activity
              </div>

              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "8px" }}>
                <div>
                  <div style={{ fontSize: "24px", fontWeight: 700 }}>
                    {currentWeekData.events.length}
                  </div>
                  <div style={{ fontSize: "10px", color: "#8A9BA8" }}>Events</div>
                </div>
                <div>
                  <div style={{ fontSize: "24px", fontWeight: 700 }}>
                    {currentWeekData.totalManHours.toLocaleString()}
                  </div>
                  <div style={{ fontSize: "10px", color: "#8A9BA8" }}>Man-Hours</div>
                </div>
              </div>

              {/* Utilization bar */}
              <div style={{ marginTop: "12px" }}>
                <div style={{ display: "flex", justifyContent: "space-between", fontSize: "10px", marginBottom: "4px" }}>
                  <span>Capacity Utilization</span>
                  <span>{(currentWeekData.utilization * 100).toFixed(0)}%</span>
                </div>
                <div style={{
                  height: "8px",
                  backgroundColor: "#394B59",
                  borderRadius: "4px",
                  overflow: "hidden"
                }}>
                  <div style={{
                    height: "100%",
                    width: `${Math.min(currentWeekData.utilization * 100, 100)}%`,
                    backgroundColor: currentWeekData.utilization > 0.95 ? "#F55656" :
                                    currentWeekData.utilization > 0.8 ? "#FFB366" : "#3DCC91",
                    transition: "width 0.3s"
                  }} />
                </div>
              </div>

              {/* Fleet breakdown */}
              <div style={{ marginTop: "12px", display: "flex", gap: "8px" }}>
                <Tag minimal intent={Intent.PRIMARY}>
                  {currentWeekData.alstomCount} Alstom
                </Tag>
                <Tag minimal intent={Intent.SUCCESS}>
                  {currentWeekData.kinkiCount} Kinki
                </Tag>
              </div>
            </Card>
          )}

          {/* Depot status */}
          <Card elevation={Elevation.ONE}>
            <div style={{ fontSize: "12px", fontWeight: 600, marginBottom: "8px" }}>
              Depot Status
            </div>
            {DEPOTS.map(depot => {
              const depotEvents = currentWeekData?.events.length || 0;
              const tracksUsed = Math.min(Math.ceil(depotEvents / 2), depot.tracks);

              return (
                <div key={depot.id} style={{ marginBottom: "8px" }}>
                  <div style={{ fontSize: "11px", marginBottom: "4px" }}>{depot.name}</div>
                  <div style={{ display: "flex", gap: "4px" }}>
                    {Array.from({ length: depot.tracks }).map((_, i) => (
                      <div
                        key={i}
                        style={{
                          width: "24px",
                          height: "8px",
                          backgroundColor: i < tracksUsed ? "#3DCC91" : "#394B59",
                          borderRadius: "2px",
                        }}
                        title={`Track ${i + 1}: ${i < tracksUsed ? "In Use" : "Available"}`}
                      />
                    ))}
                  </div>
                </div>
              );
            })}
          </Card>

          {/* Play/Pause */}
          <Button
            icon={isPlaying ? "pause" : "play"}
            onClick={() => setIsPlaying(!isPlaying)}
            fill
          >
            {isPlaying ? "Pause Animation" : "Play Animation"}
          </Button>
        </div>
      </div>

      {/* Timeline showing planning cascade */}
      <Card elevation={Elevation.TWO}>
        <div style={{ fontSize: "12px", fontWeight: 600, marginBottom: "12px" }}>
          Hierarchical Planning Timeline (12 Years → This Week)
        </div>

        <PlanningCascade
          weeklyData={weeklyData}
          selectedWeek={selectedWeek}
          onSelectWeek={setSelectedWeek}
          planningLevel={planningLevel}
          capacity={capacity}
        />
      </Card>
    </div>
  );
}

// ============================================================================
// PLANNING CASCADE VISUALIZATION
// Shows how planning flows from strategic to daily
// ============================================================================

interface PlanningCascadeProps {
  weeklyData: Array<{
    week: number;
    totalManHours: number;
    utilization: number;
    events: Array<{ maintenanceType: string }>;
  }>;
  selectedWeek: number;
  onSelectWeek: (week: number) => void;
  planningLevel: PlanningLevel;
  capacity: number;
}

function PlanningCascade({ weeklyData, selectedWeek, onSelectWeek, planningLevel, capacity }: PlanningCascadeProps) {
  const horizonWeeks = weeklyData.length;

  // Aggregate data based on planning level
  const aggregatedData = useMemo(() => {
    const level = PLANNING_LEVELS.find(p => p.level === planningLevel)!;
    const unitsPerView = Math.ceil(horizonWeeks / level.weeksPerUnit);

    const units: Array<{
      startWeek: number;
      endWeek: number;
      label: string;
      totalManHours: number;
      avgUtilization: number;
      events: number;
      dCheckCount: number;
      cCheckCount: number;
      bCheckCount: number;
      aCheckCount: number;
    }> = [];

    for (let u = 0; u < unitsPerView; u++) {
      const startWeek = u * level.weeksPerUnit;
      const endWeek = Math.min(startWeek + level.weeksPerUnit - 1, horizonWeeks - 1);

      const weeksInUnit = weeklyData.slice(startWeek, endWeek + 1);
      const totalManHours = weeksInUnit.reduce((sum, w) => sum + w.totalManHours, 0);
      const avgUtilization = weeksInUnit.length > 0
        ? weeksInUnit.reduce((sum, w) => sum + w.utilization, 0) / weeksInUnit.length
        : 0;

      const allEvents = weeksInUnit.flatMap(w => w.events);

      let label = "";
      if (planningLevel === "strategic") {
        label = `Year ${u + 1}`;
      } else if (planningLevel === "tactical") {
        label = `Q${(u % 4) + 1}`;
      } else if (planningLevel === "operational") {
        label = `M${u + 1}`;
      } else {
        label = `W${startWeek + 1}`;
      }

      units.push({
        startWeek,
        endWeek,
        label,
        totalManHours,
        avgUtilization,
        events: allEvents.length,
        dCheckCount: allEvents.filter(e => e.maintenanceType === "mt-d").length,
        cCheckCount: allEvents.filter(e => e.maintenanceType === "mt-c").length,
        bCheckCount: allEvents.filter(e => e.maintenanceType === "mt-b").length,
        aCheckCount: allEvents.filter(e => e.maintenanceType === "mt-a").length,
      });
    }

    return units;
  }, [weeklyData, planningLevel, horizonWeeks]);

  const maxManHours = Math.max(...aggregatedData.map(d => d.totalManHours));

  return (
    <div>
      {/* Level indicator */}
      <div style={{ display: "flex", gap: "8px", marginBottom: "16px", fontSize: "10px" }}>
        <span style={{ color: "#8A9BA8" }}>Planning Flow:</span>
        {PLANNING_LEVELS.map((level, idx) => (
          <span key={level.level} style={{ display: "flex", alignItems: "center", gap: "4px" }}>
            <span style={{
              fontWeight: planningLevel === level.level ? 600 : 400,
              color: planningLevel === level.level ? "#48AFF0" : "#ABB3BF"
            }}>
              {level.label}
            </span>
            {idx < PLANNING_LEVELS.length - 1 && <span style={{ color: "#5F6B7C" }}>→</span>}
          </span>
        ))}
      </div>

      {/* Cascade bars */}
      <div style={{
        display: "flex",
        gap: "2px",
        height: "120px",
        alignItems: "flex-end",
        backgroundColor: "#252A31",
        padding: "8px",
        borderRadius: "4px",
      }}>
        {aggregatedData.map((unit, idx) => {
          const heightPercent = maxManHours > 0 ? (unit.totalManHours / maxManHours) * 100 : 0;
          const isSelected = selectedWeek >= unit.startWeek && selectedWeek <= unit.endWeek;

          // Stacked bar showing maintenance type breakdown
          const dHeight = unit.dCheckCount > 0 ? (unit.dCheckCount / unit.events) * heightPercent : 0;
          const cHeight = unit.cCheckCount > 0 ? (unit.cCheckCount / unit.events) * heightPercent : 0;
          const bHeight = unit.bCheckCount > 0 ? (unit.bCheckCount / unit.events) * heightPercent : 0;
          const aHeight = heightPercent - dHeight - cHeight - bHeight;

          return (
            <div
              key={idx}
              onClick={() => onSelectWeek(unit.startWeek)}
              style={{
                flex: 1,
                display: "flex",
                flexDirection: "column-reverse",
                cursor: "pointer",
                opacity: isSelected ? 1 : 0.7,
                border: isSelected ? "2px solid #48AFF0" : "2px solid transparent",
                borderRadius: "2px",
                transition: "all 0.2s",
              }}
              title={`${unit.label}: ${unit.events} events, ${unit.totalManHours.toLocaleString()} man-hours`}
            >
              {aHeight > 0 && <div style={{ height: `${aHeight}%`, backgroundColor: MT_COLORS["mt-a"], minHeight: "2px" }} />}
              {bHeight > 0 && <div style={{ height: `${bHeight}%`, backgroundColor: MT_COLORS["mt-b"], minHeight: "2px" }} />}
              {cHeight > 0 && <div style={{ height: `${cHeight}%`, backgroundColor: MT_COLORS["mt-c"], minHeight: "2px" }} />}
              {dHeight > 0 && <div style={{ height: `${dHeight}%`, backgroundColor: MT_COLORS["mt-d"], minHeight: "2px" }} />}
            </div>
          );
        })}
      </div>

      {/* Labels */}
      <div style={{
        display: "flex",
        gap: "2px",
        marginTop: "4px",
        padding: "0 8px",
      }}>
        {aggregatedData.map((unit, idx) => {
          const showLabel = aggregatedData.length <= 20 || idx % Math.ceil(aggregatedData.length / 20) === 0;
          return (
            <div
              key={idx}
              style={{
                flex: 1,
                textAlign: "center",
                fontSize: "8px",
                color: "#8A9BA8",
              }}
            >
              {showLabel ? unit.label : ""}
            </div>
          );
        })}
      </div>

      {/* Legend */}
      <div style={{ display: "flex", gap: "16px", marginTop: "12px", fontSize: "10px" }}>
        <div style={{ display: "flex", alignItems: "center", gap: "4px" }}>
          <div style={{ width: "12px", height: "12px", backgroundColor: MT_COLORS["mt-d"], borderRadius: "2px" }} />
          <span>D-Overhaul (1200h)</span>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: "4px" }}>
          <div style={{ width: "12px", height: "12px", backgroundColor: MT_COLORS["mt-c"], borderRadius: "2px" }} />
          <span>C-Check (160h)</span>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: "4px" }}>
          <div style={{ width: "12px", height: "12px", backgroundColor: MT_COLORS["mt-b"], borderRadius: "2px" }} />
          <span>B-Check (32h)</span>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: "4px" }}>
          <div style={{ width: "12px", height: "12px", backgroundColor: MT_COLORS["mt-a"], borderRadius: "2px" }} />
          <span>A-Check (8h)</span>
        </div>
      </div>
    </div>
  );
}

// ============================================================================
// CANVAS DRAWING FUNCTIONS
// ============================================================================

function drawMetroLines(ctx: CanvasRenderingContext2D, width: number, height: number, frame: number) {
  // Red Line
  ctx.strokeStyle = "#E53935";
  ctx.lineWidth = 6;
  ctx.beginPath();
  ctx.moveTo(width * 0.1, height * 0.35);
  ctx.lineTo(width * 0.9, height * 0.35);
  ctx.stroke();

  // Green Line
  ctx.strokeStyle = "#43A047";
  ctx.beginPath();
  ctx.moveTo(width * 0.3, height * 0.55);
  ctx.lineTo(width * 0.7, height * 0.55);
  ctx.stroke();

  // Draw moving trains on lines
  const trainCount = 12;
  for (let i = 0; i < trainCount; i++) {
    const progress = ((frame / 360) + (i / trainCount)) % 1;

    // Red line trains
    const redX = width * 0.1 + (width * 0.8) * progress;
    ctx.fillStyle = "#FFCDD2";
    ctx.beginPath();
    ctx.arc(redX, height * 0.35, 4, 0, Math.PI * 2);
    ctx.fill();
  }

  for (let i = 0; i < 8; i++) {
    const progress = ((frame / 360) + (i / 8)) % 1;

    // Green line trains
    const greenX = width * 0.3 + (width * 0.4) * progress;
    ctx.fillStyle = "#C8E6C9";
    ctx.beginPath();
    ctx.arc(greenX, height * 0.55, 4, 0, Math.PI * 2);
    ctx.fill();
  }

  // Line labels
  ctx.fillStyle = "#E53935";
  ctx.font = "bold 11px sans-serif";
  ctx.fillText("RED LINE (79 trains)", width * 0.1, height * 0.32);

  ctx.fillStyle = "#43A047";
  ctx.fillText("GREEN LINE (49 trains)", width * 0.3, height * 0.52);
}

function drawDepots(ctx: CanvasRenderingContext2D, width: number, height: number, weekData: any, frame: number) {
  DEPOTS.forEach((depot, idx) => {
    const x = depot.x * width;
    const y = height * 0.7;

    // Depot building
    ctx.fillStyle = "#394B59";
    ctx.fillRect(x - 60, y, 120, 60);

    // Depot roof
    ctx.fillStyle = "#2D3A44";
    ctx.beginPath();
    ctx.moveTo(x - 70, y);
    ctx.lineTo(x, y - 20);
    ctx.lineTo(x + 70, y);
    ctx.closePath();
    ctx.fill();

    // Track lines
    ctx.strokeStyle = "#5F6B7C";
    ctx.lineWidth = 2;
    for (let t = 0; t < depot.tracks; t++) {
      const trackY = y + 15 + t * 10;
      ctx.beginPath();
      ctx.moveTo(x - 50, trackY);
      ctx.lineTo(x + 50, trackY);
      ctx.stroke();
    }

    // Depot name
    ctx.fillStyle = "#F5F8FA";
    ctx.font = "bold 10px sans-serif";
    ctx.textAlign = "center";
    ctx.fillText(depot.name, x, y + 75);
    ctx.textAlign = "left";
  });
}

function drawTrainsInDepot(ctx: CanvasRenderingContext2D, width: number, height: number, weekData: any, frame: number) {
  if (!weekData) return;

  const depotX = DEPOTS[0].x * width;
  const depotY = height * 0.7;

  weekData.events.slice(0, 10).forEach((event: any, idx: number) => {
    const trackIdx = idx % 5;
    const posInTrack = Math.floor(idx / 5);

    const trainX = depotX - 40 + posInTrack * 30;
    const trainY = depotY + 15 + trackIdx * 10;

    // Train rectangle
    const color = event.assetType === "ALSTOM" ? "#1976D2" : "#388E3C";
    ctx.fillStyle = color;
    ctx.fillRect(trainX - 8, trainY - 3, 16, 6);

    // Maintenance type indicator
    const mtColor = MT_COLORS[event.maintenanceType] || "#9E9E9E";
    ctx.fillStyle = mtColor;
    ctx.beginPath();
    ctx.arc(trainX, trainY - 6, 3, 0, Math.PI * 2);
    ctx.fill();
  });
}

function drawResourceIndicators(ctx: CanvasRenderingContext2D, width: number, height: number, weekData: any, capacity: number) {
  const x = width * 0.05;
  const y = height * 0.05;

  // Background panel
  ctx.fillStyle = "rgba(37, 42, 49, 0.9)";
  ctx.fillRect(x, y, 140, 80);

  // Title
  ctx.fillStyle = "#F5F8FA";
  ctx.font = "bold 10px sans-serif";
  ctx.fillText("RESOURCES", x + 8, y + 16);

  if (weekData) {
    const utilization = weekData.utilization;

    // Man-hours
    ctx.fillStyle = "#8A9BA8";
    ctx.font = "9px sans-serif";
    ctx.fillText("Man-Hours:", x + 8, y + 35);
    ctx.fillStyle = utilization > 0.95 ? "#F55656" : utilization > 0.8 ? "#FFB366" : "#3DCC91";
    ctx.fillText(`${weekData.totalManHours.toLocaleString()} / ${capacity.toLocaleString()}`, x + 70, y + 35);

    // Events
    ctx.fillStyle = "#8A9BA8";
    ctx.fillText("Events:", x + 8, y + 50);
    ctx.fillStyle = "#F5F8FA";
    ctx.fillText(`${weekData.events.length}`, x + 70, y + 50);

    // Utilization bar
    ctx.fillStyle = "#394B59";
    ctx.fillRect(x + 8, y + 60, 124, 8);
    ctx.fillStyle = utilization > 0.95 ? "#F55656" : utilization > 0.8 ? "#FFB366" : "#3DCC91";
    ctx.fillRect(x + 8, y + 60, 124 * Math.min(utilization, 1), 8);
  }
}
