import ReactECharts from 'echarts-for-react';

function ScheduleGantt({ events }: { events: ScheduledEvent[] }) {
  const option = {
    tooltip: { trigger: 'item' },
    xAxis: {
      type: 'time',
      min: startDate,
      max: endDate
    },
    yAxis: {
      type: 'category',
      data: assets.map(a => a.name)
    },
    series: [{
      type: 'custom',
      renderItem: renderGanttBar,
      encode: { x: [0, 1], y: 2 },
      data: events.map(e => [
        e.startDate,
        e.endDate,
        e.assetIndex,
        e.maintenanceType
      ])
    }]
  };

  return <ReactECharts option={option} style={{ height: 600 }} />;
}
