{
  "name": "@belt/ai",
  "description": "Belt utilities to work with AI - AgentRC cascade rules for Claude Code",
  "type": "module",
  "sideEffects": false,
  "version": "0.0.4",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "belt-ai": "./dist/cli/setup.mjs",
    "belt-ai-setup": "./dist/cli/setup.mjs"
  },
  "exports": {
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.mjs",
      "require": "./dist/hooks.cjs"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./cli": {
      "types": "./dist/cli/setup.d.ts",
      "import": "./dist/cli/setup.mjs",
      "require": "./dist/cli/setup.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "coverage": "vitest --coverage",
    "check": "run-s check:*",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint src --fix",
    "check:format": "prettier --write ."
  },
  "dependencies": {
    "@belt/tools": "latest"
  },
  "devDependencies": {
    "@belt/prettier-plugin": "latest",
    "@eslint/js": "^9.39.2",
    "@types/lodash": "^4.17.21",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rollup-plugin-node-externals": "^8.1.2",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-externalize-deps": "^0.10.0",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.16"
  }
}