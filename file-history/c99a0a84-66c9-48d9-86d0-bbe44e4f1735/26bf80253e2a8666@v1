/**
 * DeckCanvas - deck.gl-based canvas for semantic zoom visualization
 *
 * Replaces InfiniteCanvas (R3F-based) with deck.gl for:
 * - Native semantic zoom via CompositeLayer
 * - Built-in aggregation layers for heatmaps
 * - OrthographicView for non-geo timeline visualization
 * - Better bundle size and performance
 *
 * DECK-MIGRATE-001: Foundation component
 */

import { useState, useCallback, useEffect, useRef } from 'react';
import DeckGL from '@deck.gl/react';
import { OrthographicView, OrthographicViewState } from '@deck.gl/core';
import type { PickingInfo, MapViewState } from '@deck.gl/core';
import type { TaskRender, Train } from '../data/types';
import { DEFAULT_VIEW_CONFIG } from '../data/types';
import { useCanvasSelector, canvasStore, canvasActions } from '../state';

// Types for deck.gl view state
interface DeckViewState extends OrthographicViewState {
  target: [number, number];
  zoom: number;
  minZoom: number;
  maxZoom: number;
}

export interface DeckCanvasProps {
  tasks: TaskRender[];
  trains: Train[];
  width: number;
  height: number;
  onZoomChange?: (zoom: number) => void;
  onViewportChange?: (x: number, y: number) => void;
}

// Constants matching original InfiniteCanvas
const { pxPerDay, pxPerTrain, minZoom, maxZoom } = DEFAULT_VIEW_CONFIG;

// Convert deck.gl zoom to our zoom scale
// deck.gl uses log2 scale: zoom 0 = 1x, zoom 1 = 2x, zoom -1 = 0.5x
function deckZoomToLinear(deckZoom: number): number {
  return Math.pow(2, deckZoom);
}

function linearZoomToDeck(linearZoom: number): number {
  return Math.log2(linearZoom);
}

// Initial view state - centered on the data
function getInitialViewState(
  tasks: TaskRender[],
  trains: Train[],
  width: number,
  height: number
): DeckViewState {
  // Calculate data bounds
  const totalDays = tasks.length > 0
    ? Math.max(...tasks.map(t => t.startDay + t.duration)) + 30
    : 365 * 10;
  const totalWidth = totalDays * pxPerDay;
  const totalHeight = trains.length * pxPerTrain;

  // Center the view initially
  const centerX = totalWidth / 2;
  const centerY = -totalHeight / 2; // Negative Y (trains go down)

  return {
    target: [centerX, centerY],
    zoom: 0, // 1x zoom in deck.gl scale
    minZoom: linearZoomToDeck(minZoom),
    maxZoom: linearZoomToDeck(maxZoom),
  };
}

/**
 * DeckCanvas Component
 *
 * Main deck.gl canvas with OrthographicView for timeline visualization.
 */
export function DeckCanvas({
  tasks,
  trains,
  width,
  height,
  onZoomChange,
  onViewportChange,
}: DeckCanvasProps) {
  // View state managed by deck.gl
  const [viewState, setViewState] = useState<DeckViewState>(() =>
    getInitialViewState(tasks, trains, width, height)
  );

  // Ref for container element
  const containerRef = useRef<HTMLDivElement>(null);

  // Get interaction state from @mms/toolkit
  const hoveredTaskId = useCanvasSelector(s => s.interaction.hoveredTaskId);
  const selectedTaskId = useCanvasSelector(s => s.interaction.selectedTaskId);

  // Handle view state changes from deck.gl controller
  const handleViewStateChange = useCallback(
    ({ viewState: newViewState }: { viewState: DeckViewState }) => {
      setViewState(newViewState);

      // Convert deck.gl zoom to linear and notify parent
      const linearZoom = deckZoomToLinear(newViewState.zoom);
      onZoomChange?.(linearZoom);

      // Notify viewport change
      onViewportChange?.(newViewState.target[0], newViewState.target[1]);

      // Update @mms/toolkit state for sidebar/timeline sync
      canvasStore.dispatch(
        canvasActions.viewport.setCamera({
          x: newViewState.target[0],
          y: newViewState.target[1],
          zoom: linearZoom,
        })
      );
    },
    [onZoomChange, onViewportChange]
  );

  // Handle hover on tasks
  const handleHover = useCallback((info: PickingInfo) => {
    if (info.object) {
      const task = info.object as TaskRender;
      canvasStore.dispatch(canvasActions.interaction.setHoveredTask(task.id));
    } else {
      canvasStore.dispatch(canvasActions.interaction.clearHover());
    }
  }, []);

  // Handle click on tasks
  const handleClick = useCallback((info: PickingInfo) => {
    if (info.object) {
      const task = info.object as TaskRender;
      const currentSelected = canvasStore.getState().interaction.selectedTaskId;
      if (currentSelected === task.id) {
        // Toggle off if clicking same task
        canvasStore.dispatch(canvasActions.interaction.clearSelection());
      } else {
        canvasStore.dispatch(canvasActions.interaction.setSelectedTask(task.id));
      }
    } else {
      // Click on background clears selection
      canvasStore.dispatch(canvasActions.interaction.clearSelection());
    }
  }, []);

  // Calculate LOD level from zoom
  const linearZoom = deckZoomToLinear(viewState.zoom);
  const lodLevel = linearZoom < 0.5 ? 'MACRO' : linearZoom > 2.0 ? 'MICRO' : 'MESO';

  // Create the OrthographicView
  const views = new OrthographicView({
    id: 'timeline',
    flipY: false,
    controller: {
      scrollZoom: true,
      dragPan: true,
      doubleClickZoom: true,
      touchRotate: false,
      keyboard: true,
    },
  });

  // TODO: Add layers in DECK-MIGRATE-002
  // For now, render empty canvas to verify setup
  const layers: any[] = [];

  return (
    <div
      ref={containerRef}
      style={{
        width: '100%',
        height: '100%',
        position: 'relative',
        background: '#f4f4f5', // zinc-100, matching original
      }}
    >
      <DeckGL
        views={views}
        viewState={viewState}
        onViewStateChange={handleViewStateChange}
        controller={true}
        layers={layers}
        onHover={handleHover}
        onClick={handleClick}
        width={width}
        height={height}
        style={{ position: 'absolute', top: 0, left: 0 }}
        getCursor={({ isDragging, isHovering }) =>
          isDragging ? 'grabbing' : isHovering ? 'pointer' : 'grab'
        }
      />

      {/* Debug overlay - remove in production */}
      <div
        style={{
          position: 'absolute',
          bottom: 8,
          right: 8,
          background: 'rgba(0,0,0,0.7)',
          color: 'white',
          padding: '4px 8px',
          borderRadius: 4,
          fontSize: 11,
          fontFamily: 'monospace',
          pointerEvents: 'none',
        }}
      >
        deck.gl | LOD: {lodLevel} | Zoom: {linearZoom.toFixed(2)}x
      </div>
    </div>
  );
}

export default DeckCanvas;
