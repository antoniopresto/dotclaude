// =============================================================================
// LOD (Level of Detail) THRESHOLDS
// =============================================================================

export type LODLevel = 'strategic' | 'tactical' | 'operational' | 'execution';

export const LOD_THRESHOLDS = {
  strategic: 0.3,    // zoom < 0.3
  tactical: 1.0,     // 0.3 <= zoom < 1.0
  operational: 3.0,  // 1.0 <= zoom < 3.0
  execution: Infinity, // zoom >= 3.0
};

export function getLODLevel(zoom: number): LODLevel {
  if (zoom < LOD_THRESHOLDS.strategic) return 'strategic';
  if (zoom < LOD_THRESHOLDS.tactical) return 'tactical';
  if (zoom < LOD_THRESHOLDS.operational) return 'operational';
  return 'execution';
}

// =============================================================================
// TIMELINE GRANULARITY
// =============================================================================

export type TimeGranularity = 'year' | 'quarter' | 'month' | 'week' | 'day';

export function getTimeGranularity(lod: LODLevel): TimeGranularity {
  switch (lod) {
    case 'strategic': return 'year';
    case 'tactical': return 'quarter';
    case 'operational': return 'week';
    case 'execution': return 'day';
  }
}

