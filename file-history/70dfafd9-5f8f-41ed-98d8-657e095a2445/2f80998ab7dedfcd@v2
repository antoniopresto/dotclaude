{
  "project": "MMS V1.0 GENESIS",
  "version": "2.0",
  "created": "2026-01-05",
  "philosophy": {
    "autonomy": "FULL - research, decide, document. Only escalate TRUE blockers.",
    "agents": "UNLIMITED - use 20+ parallel agents, quality is the only metric.",
    "cleanup": "AGGRESSIVE - delete everything not useful, git is backup.",
    "architecture": "Teach concepts to agents and delegate work."
  },
  "immutable_decisions": {
    "canvas_technology": "R3F (already implemented, working)",
    "ui_framework": "PatternFly v6 (replacing BlueprintJS 6)",
    "state_management": "@belt/tools (replacing @zazcart/tools)",
    "scope": "Canvas first, solver later"
  },
  "phases": [
    {
      "id": "PHASE_0",
      "name": "Meta-Harness Setup",
      "status": "completed",
      "description": "Create migration harness before any analysis",
      "tasks": [
        {
          "id": "M001",
          "name": "Backup existing harness",
          "passes": true,
          "description": "Copy .harness/* to .harness/BACKUP_PROJECT_HARNESS/"
        },
        {
          "id": "M002",
          "name": "Create _extraction/ folder",
          "passes": true,
          "description": "Folder for knowledge artifacts (renamed from _migration_memory/)"
        },
        {
          "id": "M003",
          "name": "Create MIGRATION_MANIFEST.md",
          "passes": true,
          "description": "Master document teaching complete context"
        },
        {
          "id": "M004",
          "name": "Create MIGRATION_FEATURES.json",
          "passes": true,
          "description": "Detailed task tracking"
        }
      ]
    },
    {
      "id": "PHASE_1",
      "name": "Knowledge Extraction",
      "status": "completed",
      "description": "Extract all knowledge from 6 repositories into _extraction/ artifacts",
      "methodology": "MAP phase - parallel agents extracting specific aspects",
      "tasks": [
        {"id": "E001", "name": "Territory mapping", "passes": true, "artifact": "00_TERRITORY_MAP.md"},
        {"id": "E002", "name": "Canvas implementation", "passes": true, "artifact": "01_canvas.md"},
        {"id": "E003", "name": "Domain knowledge", "passes": true, "artifact": "02_domain.md"},
        {"id": "E004", "name": "Decision history (ADRs)", "passes": true, "artifact": "03_decisions.md"},
        {"id": "E005", "name": "Solver engine", "passes": true, "artifact": "04_solver.md"},
        {"id": "E006", "name": "Visualization research", "passes": true, "artifact": "05_visualization.md"},
        {"id": "E007", "name": "Historical experiments", "passes": true, "artifact": "06_experiments.md"},
        {"id": "E008", "name": "Visual specification", "passes": true, "artifact": "07_visual_spec.md"},
        {"id": "E009", "name": "Market research", "passes": true, "artifact": "08_market.md"},
        {"id": "E010", "name": "PatternFly v6 research", "passes": true, "artifact": "10_patternfly.md"},
        {"id": "E011", "name": "@belt/tools API", "passes": true, "artifact": "11_belt_tools.md"},
        {"id": "E012", "name": "Canvas tech comparison", "passes": true, "artifact": "12_canvas_tech.md"}
      ]
    },
    {
      "id": "PHASE_2",
      "name": "Specification Writing",
      "status": "pending",
      "description": "Synthesize _extraction/ artifacts into definitive SPECIFICATION.md",
      "methodology": "REDUCE + REFINE phases - synthesize parallel outputs into coherent document",
      "output": "docs/SPECIFICATION.md",
      "tasks": [
        {
          "id": "S001",
          "name": "Write Executive Summary",
          "passes": false,
          "description": "1-page summary: what MMS is, what problem it solves, key differentiators",
          "sources": ["00_TERRITORY_MAP.md", "08_market.md"],
          "acceptance": "Clear value proposition in <500 words"
        },
        {
          "id": "S002",
          "name": "Write Domain Model section",
          "passes": false,
          "description": "All entities, relationships, business rules, constraints",
          "sources": ["02_domain.md"],
          "acceptance": "TypeScript interfaces, entity relationships, hard/soft constraints documented"
        },
        {
          "id": "S003",
          "name": "Write Architecture section",
          "passes": false,
          "description": "System architecture, component diagram, data flow",
          "sources": ["01_canvas.md", "03_decisions.md"],
          "acceptance": "Clear architecture diagram (ASCII or description), ADRs summarized"
        },
        {
          "id": "S004",
          "name": "Write Canvas Implementation section",
          "passes": false,
          "description": "LOD system, layers, EntityStore, RBush, performance patterns",
          "sources": ["01_canvas.md", "12_canvas_tech.md"],
          "acceptance": "Code patterns documented, performance requirements clear"
        },
        {
          "id": "S005",
          "name": "Write State Management section",
          "passes": false,
          "description": "@belt/tools usage patterns, slice architecture, hooks",
          "sources": ["11_belt_tools.md", "03_decisions.md"],
          "acceptance": "Clear examples of createSlice, createMachine usage"
        },
        {
          "id": "S006",
          "name": "Write UI Components section",
          "passes": false,
          "description": "PatternFly v6 component mappings, layout patterns",
          "sources": ["10_patternfly.md"],
          "acceptance": "BlueprintJS to PatternFly mapping table, key component examples"
        },
        {
          "id": "S007",
          "name": "Write Solver Engine section",
          "passes": false,
          "description": "OR-Tools CP-SAT, math formulas (EXACT preservation), constraints",
          "sources": ["04_solver.md"],
          "acceptance": "All math formulas preserved EXACTLY, solver architecture documented"
        },
        {
          "id": "S008",
          "name": "Write API Specification section",
          "passes": false,
          "description": "FastAPI endpoints, request/response schemas",
          "sources": ["04_solver.md"],
          "acceptance": "OpenAPI-style endpoint documentation"
        },
        {
          "id": "S009",
          "name": "Write Performance Requirements section",
          "passes": false,
          "description": "60fps target, memory budgets, query time limits",
          "sources": ["01_canvas.md"],
          "acceptance": "Quantified metrics table"
        },
        {
          "id": "S010",
          "name": "Final editing and validation",
          "passes": false,
          "description": "Review complete document, ensure coherence, no TODOs",
          "acceptance": "Document is production-ready, no historical notes, no placeholders"
        }
      ]
    },
    {
      "id": "PHASE_3",
      "name": "Repository Cleanup",
      "status": "pending",
      "description": "Clean repository to production-ready V1.0 state",
      "methodology": "Sequential execution - each step depends on previous",
      "tasks": [
        {
          "id": "R001",
          "name": "Remove packages/ folder",
          "passes": false,
          "command": "rm -rf packages/",
          "description": "Delete local packages folder entirely"
        },
        {
          "id": "R002",
          "name": "Install @belt/tools",
          "passes": false,
          "command": "bun add @belt/tools",
          "description": "Add npm public package"
        },
        {
          "id": "R003",
          "name": "Install PatternFly v6",
          "passes": false,
          "command": "bun add @patternfly/react-core @patternfly/react-icons @patternfly/react-table",
          "description": "Add PatternFly packages"
        },
        {
          "id": "R004",
          "name": "Update state management imports",
          "passes": false,
          "description": "Replace all @zazcart/tools imports with @belt/tools",
          "pattern": "find . -name '*.ts' -o -name '*.tsx' | xargs sed -i '' 's/@zazcart\\/tools/@belt\\/tools/g'"
        },
        {
          "id": "R005",
          "name": "Update UI component imports",
          "passes": false,
          "description": "Replace BlueprintJS imports with PatternFly equivalents",
          "note": "This requires component-by-component migration, not just sed"
        },
        {
          "id": "R006",
          "name": "Remove unused documentation",
          "passes": false,
          "description": "Delete docs that are now superseded by SPECIFICATION.md",
          "candidates": ["docs/MMS_COMPLETE_SPECIFICATION.md", "docs/REVIEW_PLAN.md", "CLAUDE_NOTES.md"]
        },
        {
          "id": "R007",
          "name": "Delete _extraction/ folder",
          "passes": false,
          "command": "rm -rf _extraction/",
          "description": "Knowledge now lives in SPECIFICATION.md"
        },
        {
          "id": "R008",
          "name": "Update CLAUDE.md for V1.0",
          "passes": false,
          "description": "Simplify CLAUDE.md to reflect V1.0 clean state"
        },
        {
          "id": "R009",
          "name": "Commit V1.0 baseline",
          "passes": false,
          "command": "git add -A && git commit -m 'chore: MMS V1.0 Genesis - clean baseline'",
          "description": "Single commit with all changes"
        }
      ]
    },
    {
      "id": "PHASE_4",
      "name": "Visual Validation",
      "status": "pending",
      "description": "Verify app works after migration",
      "methodology": "Playwright MCP visual testing",
      "tasks": [
        {
          "id": "V001",
          "name": "Start dev server",
          "passes": false,
          "command": "cd apps/canvas && bun run dev",
          "description": "Verify build succeeds"
        },
        {
          "id": "V002",
          "name": "Screenshot MACRO level",
          "passes": false,
          "description": "Zoom < 0.5, verify heatmap renders"
        },
        {
          "id": "V003",
          "name": "Screenshot MESO level",
          "passes": false,
          "description": "Zoom 0.5-2.0, verify task blocks render"
        },
        {
          "id": "V004",
          "name": "Screenshot MICRO level",
          "passes": false,
          "description": "Zoom > 2.0, verify detailed cards render"
        },
        {
          "id": "V005",
          "name": "Verify console clean",
          "passes": false,
          "description": "No red errors in browser console"
        },
        {
          "id": "V006",
          "name": "Verify 60fps",
          "passes": false,
          "description": "Check stats.js or performance panel shows <16ms frames"
        }
      ]
    }
  ],
  "artifacts": {
    "_extraction/": "Knowledge artifacts (to be deleted after Phase 2)",
    "docs/SPECIFICATION.md": "Final specification (created in Phase 2)",
    ".harness/MIGRATION_MANIFEST.md": "Master context document",
    ".harness/MIGRATION_PROGRESS.md": "Session history",
    ".harness/MIGRATION_FEATURES.json": "This file",
    ".harness/BACKUP_PROJECT_HARNESS/": "Backup of original harness"
  }
}
