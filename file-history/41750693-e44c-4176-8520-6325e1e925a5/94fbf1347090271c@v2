import { describe, it, expect, beforeEach } from 'vitest';
import { simulationStore, BlockType } from '../store/simulationStore';

describe('simulationStore', () => {
  beforeEach(() => {
    simulationStore.getState().initializeSchedule(1000);
  });

  describe('initializeSchedule', () => {
    it('should create empty schedule with given capacity', () => {
      const { schedule } = simulationStore.getState();
      expect(schedule.capacity).toBe(1000);
      expect(schedule.count).toBe(0);
      expect(schedule.startTimes).toBeInstanceOf(Float64Array);
      expect(schedule.endTimes).toBeInstanceOf(Float64Array);
      expect(schedule.trainIds).toBeInstanceOf(Int32Array);
      expect(schedule.types).toBeInstanceOf(Uint8Array);
      expect(schedule.trackIds).toBeInstanceOf(Int16Array);
      expect(schedule.flags).toBeInstanceOf(Uint8Array);
    });
  });

  describe('addBlock', () => {
    it('should add a block and increment count', () => {
      const state = simulationStore.getState();
      const startTime = Date.now();
      const endTime = startTime + 3600000;

      const index = state.addBlock(startTime, endTime, 1, BlockType.PM, 0);

      const { schedule } = simulationStore.getState();
      expect(index).toBe(0);
      expect(schedule.count).toBe(1);
      expect(schedule.startTimes[0]).toBe(startTime);
      expect(schedule.endTimes[0]).toBe(endTime);
      expect(schedule.trainIds[0]).toBe(1);
      expect(schedule.types[0]).toBe(BlockType.PM);
      expect(schedule.trackIds[0]).toBe(0);
    });

    it('should add multiple blocks sequentially', () => {
      const state = simulationStore.getState();
      const now = Date.now();

      state.addBlock(now, now + 1000, 1, BlockType.PM, 0);
      state.addBlock(now + 2000, now + 3000, 2, BlockType.OVERHAUL, 1);
      state.addBlock(now + 4000, now + 5000, 3, BlockType.INSPECTION, 2);

      const { schedule } = simulationStore.getState();
      expect(schedule.count).toBe(3);
    });

    it('should return -1 when capacity exceeded', () => {
      simulationStore.getState().initializeSchedule(2);
      const state = simulationStore.getState();
      const now = Date.now();

      state.addBlock(now, now + 1000, 1, BlockType.PM, 0);
      state.addBlock(now + 2000, now + 3000, 2, BlockType.PM, 0);
      const index = state.addBlock(now + 4000, now + 5000, 3, BlockType.PM, 0);

      expect(index).toBe(-1);
    });
  });

  describe('updateBlockTimes', () => {
    it('should update block start and end times', () => {
      const state = simulationStore.getState();
      const now = Date.now();
      state.addBlock(now, now + 1000, 1, BlockType.PM, 0);

      const newStart = now + 5000;
      const newEnd = now + 6000;
      simulationStore.getState().updateBlockTimes(0, newStart, newEnd);

      const { schedule } = simulationStore.getState();
      expect(schedule.startTimes[0]).toBe(newStart);
      expect(schedule.endTimes[0]).toBe(newEnd);
    });

    it('should not crash on invalid index', () => {
      const state = simulationStore.getState();
      expect(() => state.updateBlockTimes(-1, 0, 0)).not.toThrow();
      expect(() => state.updateBlockTimes(999, 0, 0)).not.toThrow();
    });
  });

  describe('selection', () => {
    it('should toggle block selection', () => {
      const state = simulationStore.getState();
      const now = Date.now();
      state.addBlock(now, now + 1000, 1, BlockType.PM, 0);

      simulationStore.getState().toggleBlockSelection(0);
      expect(simulationStore.getState().selectedBlocks.has(0)).toBe(true);
      expect(simulationStore.getState().schedule.flags[0] & 1).toBe(1);

      simulationStore.getState().toggleBlockSelection(0);
      expect(simulationStore.getState().selectedBlocks.has(0)).toBe(false);
      expect(simulationStore.getState().schedule.flags[0] & 1).toBe(0);
    });

    it('should clear all selections', () => {
      const state = simulationStore.getState();
      const now = Date.now();
      state.addBlock(now, now + 1000, 1, BlockType.PM, 0);
      state.addBlock(now + 2000, now + 3000, 2, BlockType.PM, 0);

      simulationStore.getState().toggleBlockSelection(0);
      simulationStore.getState().toggleBlockSelection(1);
      simulationStore.getState().clearSelection();

      const { selectedBlocks, schedule } = simulationStore.getState();
      expect(selectedBlocks.size).toBe(0);
      expect(schedule.flags[0] & 1).toBe(0);
      expect(schedule.flags[1] & 1).toBe(0);
    });
  });

  describe('drag operations', () => {
    it('should start and stop drag', () => {
      const state = simulationStore.getState();
      const now = Date.now();
      state.addBlock(now, now + 1000, 1, BlockType.PM, 0);

      simulationStore.getState().startDrag(0);
      expect(simulationStore.getState().draggingBlock).toBe(0);
      expect(simulationStore.getState().schedule.flags[0] & 2).toBe(2);

      simulationStore.getState().stopDrag();
      expect(simulationStore.getState().draggingBlock).toBe(-1);
      expect(simulationStore.getState().schedule.flags[0] & 2).toBe(0);
    });
  });
});
