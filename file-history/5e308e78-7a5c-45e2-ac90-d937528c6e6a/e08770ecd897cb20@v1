/**
 * Fleet List Page
 *
 * Displays list of trains with filtering capabilities.
 * Can be filtered by status (fit/unfit) or depot.
 */

import { Card, Elevation, Tag, Intent } from '@blueprintjs/core';

interface FleetPageProps {
  searchParams: Promise<{ status?: string; depot?: string }>;
}

export default async function FleetPage({ searchParams }: FleetPageProps) {
  const params = await searchParams;
  const { status, depot } = params;

  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 'var(--mms-space-lg)' }}>
      <Card elevation={Elevation.ONE} style={{ padding: 'var(--mms-space-lg)' }}>
        <h1 style={{ margin: 0, fontSize: 'var(--mms-text-2xl)', fontWeight: 'var(--mms-font-bold)', color: 'var(--mms-text-primary)' }}>Fleet Overview</h1>
        <p style={{ marginTop: 'var(--mms-space-sm)', color: 'var(--mms-text-secondary)' }}>
          Train list with status and mileage information
        </p>
      </Card>

      {/* Filter Indicators */}
      <div style={{ display: 'flex', flexWrap: 'wrap', gap: 'var(--mms-space-sm)' }}>
        {status && (
          <Tag intent={Intent.PRIMARY} round>
            Filter: Status = {status}
          </Tag>
        )}
        {depot && (
          <Tag intent={Intent.NONE} round style={{ backgroundColor: 'var(--mms-epic-tag)', color: 'var(--mms-epic-tag-text)' }}>
            Filter: Depot = {depot}
          </Tag>
        )}
      </div>

      {/* Placeholder for train list - Epic 3 */}
      <Card elevation={Elevation.ZERO} style={{ padding: 'var(--mms-space-xl)', textAlign: 'center', backgroundColor: 'var(--mms-bg-surface)' }}>
        <p style={{ marginBottom: 'var(--mms-space-sm)', color: 'var(--mms-text-secondary)' }}>Train list will be implemented in Epic 3</p>
        <p style={{ fontSize: 'var(--mms-text-base)', color: 'var(--mms-text-muted)' }}>Showing trains with filters: {JSON.stringify({ status, depot })}</p>
      </Card>
    </div>
  );
}
