'use client';

import React from 'react';
import { Card, Elevation, Button, Icon } from '@blueprintjs/core';
import { LODLevel } from '@/stores/viewportStore';

interface ViewportControlsProps {
  currentLOD: LODLevel;
  scale: number;
  onZoomIn: () => void;
  onZoomOut: () => void;
  onFit: () => void;
  onReset: () => void;
  onJumpToLOD: (lod: LODLevel) => void;
}

const LOD_INFO = [
  { lod: 0 as LODLevel, label: 'Strategic', span: '10-12 years' },
  { lod: 1 as LODLevel, label: 'Tactical', span: '1-3 years' },
  { lod: 2 as LODLevel, label: 'Operational', span: '1-6 months' },
  { lod: 3 as LODLevel, label: 'Execution', span: '1-4 weeks' },
];

const MAINTENANCE_LEGEND = [
  { type: 'PM1', color: 'var(--mms-maint-pm1)', label: 'Preventive Minor' },
  { type: 'PM2', color: 'var(--mms-maint-pm2)', label: 'Preventive Major' },
  { type: 'HM', color: 'var(--mms-maint-hm)', label: 'Heavy Maintenance' },
  { type: 'OVH', color: 'var(--mms-maint-ovh)', label: 'Overhaul' },
];

export function ViewportControls({
  currentLOD,
  scale,
  onZoomIn,
  onZoomOut,
  onFit,
  onReset,
  onJumpToLOD,
}: ViewportControlsProps) {
  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 'var(--mms-space-md)' }}>
      {/* LOD Indicator */}
      <Card elevation={Elevation.ONE} style={{ padding: 'var(--mms-space-md)' }}>
        <div style={{ fontSize: 'var(--mms-text-xs)', color: 'var(--mms-text-muted)', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 'var(--mms-space-sm)' }}>
          Level of Detail
        </div>

        <div style={{ display: 'flex', flexDirection: 'column', gap: 'var(--mms-space-sm)' }}>
          {LOD_INFO.map(({ lod, label, span }) => (
            <button
              key={lod}
              onClick={() => onJumpToLOD(lod)}
              style={{
                width: '100%',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'space-between',
                padding: 'var(--mms-space-sm) var(--mms-space-sm)',
                borderRadius: 'var(--mms-radius-sm)',
                border: 'none',
                cursor: 'pointer',
                transition: 'var(--mms-transition-normal)',
                backgroundColor: currentLOD === lod ? 'var(--mms-primary)' : 'var(--mms-bg-surface)',
                color: currentLOD === lod ? '#ffffff' : 'var(--mms-text-secondary)',
              }}
            >
              <span style={{ fontSize: 'var(--mms-text-base)', fontWeight: 'var(--mms-font-medium)' }}>{label}</span>
              <span style={{ fontSize: 'var(--mms-text-sm)', opacity: 0.7 }}>{span}</span>
            </button>
          ))}
        </div>
      </Card>

      {/* Zoom Controls */}
      <Card elevation={Elevation.ONE} style={{ padding: 'var(--mms-space-md)' }}>
        <div style={{ fontSize: 'var(--mms-text-xs)', color: 'var(--mms-text-muted)', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 'var(--mms-space-sm)' }}>
          Zoom
        </div>

        <div style={{ display: 'flex', alignItems: 'center', gap: 'var(--mms-space-sm)' }}>
          <Button onClick={onZoomOut} icon="minus" minimal />

          <div style={{ flex: 1, textAlign: 'center' }}>
            <span style={{ fontSize: 'var(--mms-text-base)', fontFamily: 'var(--mms-font-mono)', color: 'var(--mms-text-primary)' }}>
              {(scale * 100).toFixed(0)}%
            </span>
          </div>

          <Button onClick={onZoomIn} icon="plus" minimal />
        </div>

        {/* Zoom slider */}
        <input
          type="range"
          min={5}
          max={400}
          value={scale * 100}
          onChange={() => onZoomIn()} // Simplified - use onZoomIn/onZoomOut for now
          style={{
            width: '100%',
            height: 'var(--mms-space-sm)',
            marginTop: 'var(--mms-space-sm)',
            borderRadius: 'var(--mms-radius-sm)',
            cursor: 'pointer',
          }}
        />

        <div style={{ display: 'flex', gap: 'var(--mms-space-sm)', marginTop: 'var(--mms-space-sm)' }}>
          <Button small fill onClick={onFit}>
            Fit View
          </Button>
          <Button small fill onClick={onReset}>
            Reset
          </Button>
        </div>
      </Card>

      {/* Minimap placeholder */}
      <Card elevation={Elevation.ONE} style={{ padding: 'var(--mms-space-md)' }}>
        <div style={{ fontSize: 'var(--mms-text-xs)', color: 'var(--mms-text-muted)', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 'var(--mms-space-sm)' }}>
          Minimap
        </div>
        <div
          style={{
            width: '100%',
            height: 96,
            backgroundColor: 'var(--mms-bg-surface)',
            borderRadius: 'var(--mms-radius-sm)',
            border: '1px solid var(--mms-border-default)',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
          }}
        >
          <span style={{ fontSize: 'var(--mms-text-sm)', color: 'var(--mms-text-muted)' }}>Preview</span>
        </div>
      </Card>

      {/* Legend */}
      <Card elevation={Elevation.ONE} style={{ padding: 'var(--mms-space-md)' }}>
        <div style={{ fontSize: 'var(--mms-text-xs)', color: 'var(--mms-text-muted)', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 'var(--mms-space-sm)' }}>
          Maintenance Types
        </div>
        <div style={{ display: 'flex', flexDirection: 'column', gap: 'var(--mms-space-sm)' }}>
          {MAINTENANCE_LEGEND.map(({ type, color, label }) => (
            <div key={type} style={{ display: 'flex', alignItems: 'center', gap: 'var(--mms-space-sm)' }}>
              <div
                style={{
                  width: 'var(--mms-space-sm)',
                  height: 'var(--mms-space-sm)',
                  borderRadius: 3,
                  backgroundColor: color,
                }}
              />
              <span style={{ fontSize: 'var(--mms-text-sm)', color: 'var(--mms-text-secondary)' }}>{type}</span>
              <span style={{ fontSize: 'var(--mms-text-sm)', color: 'var(--mms-text-muted)', flex: 1, textAlign: 'right' }}>{label}</span>
            </div>
          ))}
        </div>
      </Card>
    </div>
  );
}

export default ViewportControls;
