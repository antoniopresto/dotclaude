'use client';

import React from 'react';
import { Card, Elevation, Button, Tag, Intent, Classes } from '@blueprintjs/core';
import { LODLevel } from '@/stores/viewportStore';

interface ViewportControlsProps {
  currentLOD: LODLevel;
  scale: number;
  onZoomIn: () => void;
  onZoomOut: () => void;
  onFit: () => void;
  onReset: () => void;
  onJumpToLOD: (lod: LODLevel) => void;
}

const LOD_INFO = [
  { lod: 0 as LODLevel, label: 'Strategic', span: '10-12 years' },
  { lod: 1 as LODLevel, label: 'Tactical', span: '1-3 years' },
  { lod: 2 as LODLevel, label: 'Operational', span: '1-6 months' },
  { lod: 3 as LODLevel, label: 'Execution', span: '1-4 weeks' },
];

const MAINTENANCE_LEGEND = [
  { type: 'PM1', intent: Intent.SUCCESS, label: 'Preventive Minor' },
  { type: 'PM2', intent: Intent.PRIMARY, label: 'Preventive Major' },
  { type: 'HM', intent: Intent.WARNING, label: 'Heavy Maintenance' },
  { type: 'OVH', intent: Intent.DANGER, label: 'Overhaul' },
];

export function ViewportControls({
  currentLOD,
  scale,
  onZoomIn,
  onZoomOut,
  onFit,
  onReset,
  onJumpToLOD,
}: ViewportControlsProps) {
  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
      {/* LOD Indicator */}
      <Card elevation={Elevation.ONE}>
        <div className={Classes.TEXT_SMALL + ' ' + Classes.TEXT_MUTED} style={{ textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 8 }}>
          Level of Detail
        </div>

        <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
          {LOD_INFO.map(({ lod, label, span }) => (
            <Button
              key={lod}
              onClick={() => onJumpToLOD(lod)}
              fill
              intent={currentLOD === lod ? Intent.PRIMARY : Intent.NONE}
              minimal={currentLOD !== lod}
            >
              <div style={{ display: 'flex', justifyContent: 'space-between', width: '100%' }}>
                <span>{label}</span>
                <span className={Classes.TEXT_MUTED} style={{ fontSize: 12 }}>{span}</span>
              </div>
            </Button>
          ))}
        </div>
      </Card>

      {/* Zoom Controls */}
      <Card elevation={Elevation.ONE}>
        <div className={Classes.TEXT_SMALL + ' ' + Classes.TEXT_MUTED} style={{ textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 8 }}>
          Zoom
        </div>

        <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
          <Button onClick={onZoomOut} icon="minus" minimal />

          <div style={{ flex: 1, textAlign: 'center' }}>
            <span style={{ fontFamily: 'monospace' }}>
              {(scale * 100).toFixed(0)}%
            </span>
          </div>

          <Button onClick={onZoomIn} icon="plus" minimal />
        </div>

        {/* Zoom slider */}
        <input
          type="range"
          min={5}
          max={400}
          value={scale * 100}
          onChange={() => onZoomIn()} // Simplified - use onZoomIn/onZoomOut for now
          style={{
            width: '100%',
            height: 8,
            marginTop: 8,
            cursor: 'pointer',
          }}
        />

        <div style={{ display: 'flex', gap: 8, marginTop: 8 }}>
          <Button small fill onClick={onFit}>
            Fit View
          </Button>
          <Button small fill onClick={onReset}>
            Reset
          </Button>
        </div>
      </Card>

      {/* Minimap placeholder */}
      <Card elevation={Elevation.ONE}>
        <div className={Classes.TEXT_SMALL + ' ' + Classes.TEXT_MUTED} style={{ textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 8 }}>
          Minimap
        </div>
        <div
          style={{
            width: '100%',
            height: 96,
            borderRadius: 4,
            border: '1px solid rgba(128, 128, 128, 0.3)',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
          }}
        >
          <span className={Classes.TEXT_MUTED} style={{ fontSize: 12 }}>Preview</span>
        </div>
      </Card>

      {/* Legend */}
      <Card elevation={Elevation.ONE}>
        <div className={Classes.TEXT_SMALL + ' ' + Classes.TEXT_MUTED} style={{ textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 8 }}>
          Maintenance Types
        </div>
        <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
          {MAINTENANCE_LEGEND.map(({ type, intent, label }) => (
            <div key={type} style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
              <Tag intent={intent} minimal style={{ minWidth: 40 }}>{type}</Tag>
              <span className={Classes.TEXT_MUTED} style={{ fontSize: 12 }}>{label}</span>
            </div>
          ))}
        </div>
      </Card>
    </div>
  );
}

export default ViewportControls;
