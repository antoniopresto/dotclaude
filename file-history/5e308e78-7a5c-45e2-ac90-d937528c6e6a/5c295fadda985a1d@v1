'use client';

import React from 'react';
import { Card, Elevation, Button, Icon } from '@blueprintjs/core';
import { LODLevel } from '@/stores/viewportStore';

interface ViewportControlsProps {
  currentLOD: LODLevel;
  scale: number;
  onZoomIn: () => void;
  onZoomOut: () => void;
  onFit: () => void;
  onReset: () => void;
  onJumpToLOD: (lod: LODLevel) => void;
}

const LOD_INFO = [
  { lod: 0 as LODLevel, label: 'Strategic', span: '10-12 years' },
  { lod: 1 as LODLevel, label: 'Tactical', span: '1-3 years' },
  { lod: 2 as LODLevel, label: 'Operational', span: '1-6 months' },
  { lod: 3 as LODLevel, label: 'Execution', span: '1-4 weeks' },
];

const MAINTENANCE_LEGEND = [
  { type: 'PM1', color: 'var(--mms-maint-pm1)', label: 'Preventive Minor' },
  { type: 'PM2', color: 'var(--mms-maint-pm2)', label: 'Preventive Major' },
  { type: 'HM', color: 'var(--mms-maint-hm)', label: 'Heavy Maintenance' },
  { type: 'OVH', color: 'var(--mms-maint-ovh)', label: 'Overhaul' },
];

export function ViewportControls({
  currentLOD,
  scale,
  onZoomIn,
  onZoomOut,
  onFit,
  onReset,
  onJumpToLOD,
}: ViewportControlsProps) {
  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
      {/* LOD Indicator */}
      <Card elevation={Elevation.ONE} style={{ padding: 16 }}>
        <div style={{ fontSize: 11, color: '#8a9ba8', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 12 }}>
          Level of Detail
        </div>

        <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
          {LOD_INFO.map(({ lod, label, span }) => (
            <button
              key={lod}
              onClick={() => onJumpToLOD(lod)}
              style={{
                width: '100%',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'space-between',
                padding: '8px 12px',
                borderRadius: 4,
                border: 'none',
                cursor: 'pointer',
                transition: 'background-color 0.2s',
                backgroundColor: currentLOD === lod ? '#2563eb' : '#f5f8fa',
                color: currentLOD === lod ? '#ffffff' : '#5c7080',
              }}
            >
              <span style={{ fontSize: 14, fontWeight: 500 }}>{label}</span>
              <span style={{ fontSize: 12, opacity: 0.7 }}>{span}</span>
            </button>
          ))}
        </div>
      </Card>

      {/* Zoom Controls */}
      <Card elevation={Elevation.ONE} style={{ padding: 16 }}>
        <div style={{ fontSize: 11, color: '#8a9ba8', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 12 }}>
          Zoom
        </div>

        <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
          <Button onClick={onZoomOut} icon="minus" minimal />

          <div style={{ flex: 1, textAlign: 'center' }}>
            <span style={{ fontSize: 14, fontFamily: 'monospace', color: '#182026' }}>
              {(scale * 100).toFixed(0)}%
            </span>
          </div>

          <Button onClick={onZoomIn} icon="plus" minimal />
        </div>

        {/* Zoom slider */}
        <input
          type="range"
          min={5}
          max={400}
          value={scale * 100}
          onChange={() => onZoomIn()} // Simplified - use onZoomIn/onZoomOut for now
          style={{
            width: '100%',
            height: 8,
            marginTop: 12,
            borderRadius: 4,
            cursor: 'pointer',
          }}
        />

        <div style={{ display: 'flex', gap: 8, marginTop: 12 }}>
          <Button small fill onClick={onFit}>
            Fit View
          </Button>
          <Button small fill onClick={onReset}>
            Reset
          </Button>
        </div>
      </Card>

      {/* Minimap placeholder */}
      <Card elevation={Elevation.ONE} style={{ padding: 16 }}>
        <div style={{ fontSize: 11, color: '#8a9ba8', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 12 }}>
          Minimap
        </div>
        <div
          style={{
            width: '100%',
            height: 96,
            backgroundColor: '#f5f8fa',
            borderRadius: 4,
            border: '1px solid #e1e8ed',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
          }}
        >
          <span style={{ fontSize: 12, color: '#8a9ba8' }}>Preview</span>
        </div>
      </Card>

      {/* Legend */}
      <Card elevation={Elevation.ONE} style={{ padding: 16 }}>
        <div style={{ fontSize: 11, color: '#8a9ba8', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: 12 }}>
          Maintenance Types
        </div>
        <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
          {MAINTENANCE_LEGEND.map(({ type, color, label }) => (
            <div key={type} style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
              <div
                style={{
                  width: 12,
                  height: 12,
                  borderRadius: 3,
                  backgroundColor: color,
                }}
              />
              <span style={{ fontSize: 12, color: '#5c7080' }}>{type}</span>
              <span style={{ fontSize: 12, color: '#8a9ba8', flex: 1, textAlign: 'right' }}>{label}</span>
            </div>
          ))}
        </div>
      </Card>
    </div>
  );
}

export default ViewportControls;
