    tooltip: { trigger: 'item' },
    xAxis: {
      type: 'time',
      min: startDate,
      max: endDate
    },
    yAxis: {
      type: 'category',
      data: assets.map(a => a.name)
    },
    series: [{
      type: 'custom',
      renderItem: renderGanttBar,
