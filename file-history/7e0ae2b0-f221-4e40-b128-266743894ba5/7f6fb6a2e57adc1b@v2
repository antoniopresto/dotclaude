<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Advanced Gantt - Scenario Comparison</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Custom styles that Tailwind can't handle */
        .conflict-zone {
            background: repeating-linear-gradient(
                45deg,
                transparent,
                transparent 4px,
                rgba(239, 68, 68, 0.15) 4px,
                rgba(239, 68, 68, 0.15) 8px
            );
        }
        .task-block.original {
            background: linear-gradient(135deg, #ef4444, #dc2626);
        }
        .task-block.resolved {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
        }
        .legend-color.conflict {
            background: repeating-linear-gradient(
                45deg,
                transparent,
                transparent 2px,
                rgba(239, 68, 68, 0.3) 2px,
                rgba(239, 68, 68, 0.3) 4px
            );
        }
    </style>
</head>
<body class="m-0 p-0 box-border font-sans bg-white h-screen flex flex-col">
    <!-- Header -->
    <div class="flex items-center px-4 py-2 bg-white border-b border-gray-200 h-11 gap-3">
        <span class="text-lg text-gray-500 cursor-pointer">☰</span>
        <span class="text-base text-gray-500 cursor-pointer">≡</span>
        <div class="flex items-center gap-1.5 text-sm font-medium text-gray-700 cursor-pointer hover:text-gray-900">
            Advanced Gantt - Diff View: Scenario Comparison
            <span>▾</span>
        </div>
        <div class="ml-auto flex items-center gap-3">
            <span class="p-1.5 text-gray-500 cursor-pointer text-base">⬚</span>
            <span class="p-1.5 text-gray-500 cursor-pointer text-base">↗</span>
        </div>
    </div>

    <!-- Main Container -->
    <div class="flex flex-1 overflow-hidden">
        <!-- Sidebar -->
        <div class="w-20 bg-white border-r border-gray-200 flex flex-col">
            <div class="p-3 text-xs font-semibold text-gray-500 border-b border-gray-200">Train ID</div>
            <div class="flex-1">
                <div class="px-3 text-xs text-gray-700 h-[55px] flex items-center border-b border-gray-100">T001</div>
                <div class="px-3 text-xs text-gray-700 h-[55px] flex items-center border-b border-gray-100">T002</div>
                <div class="px-3 text-xs text-gray-700 h-[55px] flex items-center border-b border-gray-100">T003</div>
                <div class="px-3 text-xs text-gray-700 h-[55px] flex items-center border-b border-gray-100">T004</div>
                <div class="px-3 text-xs text-gray-700 h-[55px] flex items-center border-b border-gray-100">T005</div>
            </div>
        </div>

        <!-- Gantt Container -->
        <div class="flex-1 flex flex-col relative overflow-hidden">
            <!-- Timeline Header -->
            <div class="flex flex-col bg-white border-b border-gray-200">
                <div class="text-right px-3 py-1 text-xs text-gray-400">Timeline</div>
                <div class="flex h-7" id="timelineHeader"></div>
            </div>
            <!-- Gantt Wrapper -->
            <div class="flex-1 relative overflow-hidden bg-white">
                <div class="relative w-full h-full" id="ganttContent">
                    <svg class="absolute pointer-events-none" id="resolutionArrow" width="100%" height="100%">
                        <defs>
                            <marker id="arrowhead" markerWidth="10" markerHeight="7"
                                    refX="9" refY="3.5" orient="auto">
                                <polygon points="0 0, 10 3.5, 0 7" fill="#6b7280"/>
                            </marker>
                        </defs>
                    </svg>
                </div>
                <!-- Legend -->
                <div class="absolute bottom-4 left-4 bg-white border border-gray-200 rounded-lg p-3 px-4 text-xs shadow-md">
                    <div class="font-semibold text-gray-700 mb-2">Scenario Comparison</div>
                    <div class="flex items-center gap-2 mb-1">
                        <div class="w-4 h-4 rounded-sm border border-dashed border-red-500 legend-color conflict"></div>
                        <span>Conflict Zone</span>
                    </div>
                    <div class="flex items-center gap-2 mb-1">
                        <div class="w-4 h-4 rounded-sm bg-red-500 opacity-60"></div>
                        <span>Original Position (Conflict)</span>
                    </div>
                    <div class="flex items-center gap-2 mb-1">
                        <div class="w-4 h-4 rounded-sm bg-blue-500"></div>
                        <span>Resolved Position</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="w-4 h-4 rounded-sm bg-gray-300"></div>
                        <span>Unchanged Tasks</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const DAYS = 8;
        const TRAINS = 5;
        const DAY_WIDTH = 80;
        const ROW_HEIGHT = 55;
        const START_DATE = new Date(2032, 9, 1); // Oct 1, 2032

        // Generate timeline
        function generateTimeline() {
            const header = document.getElementById('timelineHeader');
            const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            let html = '';

            for (let i = 0; i < DAYS; i++) {
                const date = new Date(START_DATE);
                date.setDate(date.getDate() + i);
                html += `<div class="w-20 min-w-[80px] flex items-center justify-center text-xs text-gray-500 border-r border-gray-100">${monthNames[date.getMonth()]} ${date.getDate()}</div>`;
            }

            header.innerHTML = html;
        }

        // Render Gantt content
        function renderGantt() {
            const content = document.getElementById('ganttContent');
            const svg = document.getElementById('resolutionArrow');

            // Row backgrounds
            let html = '';
            for (let i = 0; i < TRAINS; i++) {
                html += `<div class="absolute left-0 right-0 h-[55px] border-b border-gray-100" style="top: ${i * ROW_HEIGHT}px;"></div>`;
            }

            // Grid lines
            for (let i = 0; i <= DAYS; i++) {
                html += `<div class="absolute top-0 bottom-0 w-px bg-gray-100" style="left: ${i * DAY_WIDTH}px;"></div>`;
            }

            // Conflict zone (covering Oct 1-3 for T001 and T002 rows)
            html += `
                <div class="conflict-zone absolute border-2 border-dashed border-red-500 rounded" style="
                    left: 0px;
                    top: 6px;
                    width: ${3 * DAY_WIDTH}px;
                    height: ${2 * ROW_HEIGHT - 12}px;
                "></div>
            `;

            // Warning icon
            html += `
                <div class="absolute w-5 h-5 bg-red-500 rounded-full flex items-center justify-center text-white text-xs font-bold shadow" style="left: 8px; top: 12px;">!</div>
            `;

            // Task blocks
            const tasks = [
                // T001 - Original conflict position (faded red)
                { train: 0, start: 0, duration: 3, label: 'T001: Brake Overhaul (8h)', type: 'original' },
                // T001 - Resolved position (blue)
                { train: 0, start: 5, duration: 2, label: 'T001: Brake Overhaul (8h)', type: 'resolved' },

                // T003 - unchanged task
                { train: 2, start: 1, duration: 2, label: 'T002: Brake Overhaul (8h)', type: 'unchanged' },

                // T004 - unchanged task
                { train: 3, start: 4, duration: 2, label: 'T002: Brake Overhaul (8h)', type: 'unchanged' },

                // T005 - unchanged task
                { train: 4, start: 4, duration: 2, label: 'T003: Brake Overhaul (8h)', type: 'unchanged' },
            ];

            // Task type to Tailwind classes mapping
            const typeClasses = {
                original: 'task-block original text-white opacity-60',
                resolved: 'task-block resolved text-white',
                unchanged: 'bg-gray-300 text-gray-700'
            };

            tasks.forEach(task => {
                const x = task.start * DAY_WIDTH + 4;
                const y = task.train * ROW_HEIGHT + 12;
                const width = task.duration * DAY_WIDTH - 8;

                html += `
                    <div class="absolute h-8 rounded px-2.5 py-1.5 text-xs flex items-center cursor-pointer transition-all duration-150 hover:scale-[1.02] hover:shadow-lg ${typeClasses[task.type]}" style="
                        left: ${x}px;
                        top: ${y}px;
                        width: ${width}px;
                    ">
                        ${task.label}
                    </div>
                `;
            });

            // Resolution arrow
            const arrowStartX = 3 * DAY_WIDTH - 20;
            const arrowStartY = ROW_HEIGHT / 2 + 12;
            const arrowEndX = 5 * DAY_WIDTH + 10;
            const arrowEndY = ROW_HEIGHT / 2 + 12;
            const midX = (arrowStartX + arrowEndX) / 2;
            const controlY = arrowStartY + 45;

            svg.innerHTML += `
                <path d="M ${arrowStartX} ${arrowStartY}
                         Q ${midX} ${controlY}
                         ${arrowEndX} ${arrowEndY}"
                      fill="none"
                      stroke="#6b7280"
                      stroke-width="2"
                      marker-end="url(#arrowhead)"/>
            `;

            content.innerHTML = html + svg.outerHTML;
        }

        // Initialize
        generateTimeline();
        renderGantt();
    </script>
</body>
</html>
