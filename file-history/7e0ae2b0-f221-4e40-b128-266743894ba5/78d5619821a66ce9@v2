<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meso View - Tactical 2-5 Year DNA Strip</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Tooltip visibility toggle */
        .tooltip.visible { display: block; }
    </style>
</head>
<body class="font-sans bg-zinc-100 h-screen flex flex-col">
    <!-- Header -->
    <div class="flex items-center justify-between px-4 py-2 bg-white border-b border-gray-200 h-11">
        <div class="flex items-center gap-3">
            <span class="text-xl text-gray-500 cursor-pointer">☰</span>
            <span class="text-[15px] font-semibold text-gray-900">Metro Integrated Planning System</span>
        </div>
        <div class="flex items-center gap-3">
            <div class="px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-md text-xs cursor-pointer">Fleet: 128 Trains</div>
            <div class="px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-md text-xs cursor-pointer">Availability: 98.5%</div>
            <div class="px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-md text-xs cursor-pointer">Light Mode ▾</div>
        </div>
    </div>

    <!-- Main Container -->
    <div class="flex flex-1 overflow-hidden">
        <!-- Sidebar -->
        <div class="w-[70px] bg-white border-r border-gray-200 flex flex-col">
            <div class="p-2 text-[10px] font-semibold text-gray-500 border-b border-gray-200 text-center">TRAIN</div>
            <div class="flex-1 overflow-y-auto" id="sidebarList"></div>
        </div>

        <!-- Canvas Container -->
        <div class="flex-1 flex flex-col relative">
            <div class="flex bg-white border-b border-gray-200 h-7" id="timelineHeader"></div>
            <div class="flex-1 relative overflow-hidden">
                <canvas id="dnaCanvas" class="w-full h-full block"></canvas>
                <div class="absolute bg-blue-300/15 border-l-2 border-r-2 border-blue-300 pointer-events-none" id="selectionHighlight"></div>
                <div class="absolute top-2 right-2 bg-white/90 px-2 py-1 rounded text-xs text-gray-500 shadow-sm">Meso View: 2-Year Tactical | Zoom: 1.2x</div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="h-[50px] bg-white border-t border-gray-200 flex items-center px-4">
        <div class="flex-1 h-6 bg-gray-100 rounded relative overflow-hidden">
            <canvas class="w-full h-full" id="scrubberMinimap"></canvas>
            <div class="absolute w-[20%] h-full bg-indigo-500/30 border-2 border-indigo-500 rounded cursor-grab" style="left: 35%;"></div>
        </div>
    </div>

    <!-- Tooltip -->
    <div class="tooltip absolute bg-white border border-gray-200 rounded-md px-3 py-2 text-xs shadow-lg pointer-events-none z-50 hidden" id="tooltip">
        <div class="font-semibold mb-1" id="tooltipTitle">B-Check | ALT-015</div>
        <div class="flex justify-between gap-4">
            <span class="text-gray-500">Duration:</span>
            <span>16 hours</span>
        </div>
        <div class="flex justify-between gap-4">
            <span class="text-gray-500">Type:</span>
            <span>Preventive Maintenance</span>
        </div>
    </div>

    <script>
        const TRAIN_COUNT = 80;
        const MONTHS = 24;
        const ROW_HEIGHT = 16;
        const START_YEAR = 2032;

        // Generate sidebar
        function generateSidebar() {
            const list = document.getElementById('sidebarList');
            const trains = [];

            for (let i = 0; i < TRAIN_COUNT; i++) {
                const type = i < 50 ? 'ALT' : 'KNK';
                const num = String((i % 50) + 1).padStart(3, '0');
                trains.push(`${type}-${num}`);
            }

            list.innerHTML = trains.map(t => `<div class="px-1.5 py-0.5 text-[9px] text-gray-700 border-b border-gray-100 h-4 flex items-center">${t}</div>`).join('');
        }

        // Generate timeline
        function generateTimeline() {
            const header = document.getElementById('timelineHeader');
            const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            const cells = [];

            for (let i = 0; i < MONTHS; i++) {
                const monthIndex = i % 12;
                const year = START_YEAR + Math.floor(i / 12);
                const isYearMarker = monthIndex === 0;
                const baseClasses = 'flex-1 min-w-[60px] flex items-center justify-center text-[10px] text-gray-500 border-r border-gray-100';
                const yearClasses = isYearMarker ? ' bg-blue-100 font-semibold text-blue-700' : '';

                cells.push(`<div class="${baseClasses}${yearClasses}">${isYearMarker ? year : monthNames[monthIndex]}</div>`);
            }

            header.innerHTML = cells.join('');
        }

        // Render DNA strips
        function renderDNA() {
            const canvas = document.getElementById('dnaCanvas');
            const ctx = canvas.getContext('2d');
            const container = canvas.parentElement;

            canvas.width = container.clientWidth;
            canvas.height = container.clientHeight;

            const w = canvas.width;
            const h = canvas.height;

            // Background
            ctx.fillStyle = '#f8f9fa';
            ctx.fillRect(0, 0, w, h);

            // Task parameters
            const taskHeight = 12;
            const taskGap = 4;
            const angle = -25 * Math.PI / 180;

            // Color palette for tasks
            const colors = {
                blue: { fill: '#3b82f6', stroke: '#1d4ed8' },      // Routine maintenance
                orange: { fill: '#f59e0b', stroke: '#d97706' },    // Overhaul
                gray: { fill: '#9ca3af', stroke: '#6b7280' }       // Inspection
            };

            // Generate task data
            const tasks = [];
            for (let row = 0; row < TRAIN_COUNT; row++) {
                const y = row * ROW_HEIGHT;

                // Generate tasks for this train
                let x = Math.random() * 50; // Random start offset

                while (x < w + 100) {
                    const taskWidth = 30 + Math.random() * 50;
                    const colorType = Math.random() < 0.6 ? 'blue' : (Math.random() < 0.7 ? 'orange' : 'gray');

                    tasks.push({
                        x: x,
                        y: y,
                        width: taskWidth,
                        color: colors[colorType],
                        row: row
                    });

                    x += taskWidth + 10 + Math.random() * 30;
                }
            }

            // Draw tasks with diagonal pattern
            tasks.forEach(task => {
                ctx.save();

                // Calculate diagonal offset based on row
                const diagonalOffset = task.row * 8;

                ctx.translate(task.x + diagonalOffset, task.y + ROW_HEIGHT / 2);
                ctx.rotate(angle);

                // Draw rounded rectangle
                const w = task.width;
                const h = taskHeight;
                const r = 3;

                ctx.beginPath();
                ctx.moveTo(r, 0);
                ctx.lineTo(w - r, 0);
                ctx.quadraticCurveTo(w, 0, w, r);
                ctx.lineTo(w, h - r);
                ctx.quadraticCurveTo(w, h, w - r, h);
                ctx.lineTo(r, h);
                ctx.quadraticCurveTo(0, h, 0, h - r);
                ctx.lineTo(0, r);
                ctx.quadraticCurveTo(0, 0, r, 0);
                ctx.closePath();

                // Fill with gradient
                const gradient = ctx.createLinearGradient(0, 0, w, h);
                gradient.addColorStop(0, task.color.fill);
                gradient.addColorStop(1, task.color.stroke);
                ctx.fillStyle = gradient;
                ctx.fill();

                // Stroke
                ctx.strokeStyle = task.color.stroke;
                ctx.lineWidth = 1;
                ctx.stroke();

                ctx.restore();
            });

            // Selection highlight
            const highlight = document.getElementById('selectionHighlight');
            highlight.style.left = (w * 0.35) + 'px';
            highlight.style.top = '0';
            highlight.style.width = (w * 0.15) + 'px';
            highlight.style.height = h + 'px';
        }

        // Render minimap
        function renderScrubber() {
            const canvas = document.getElementById('scrubberMinimap');
            const ctx = canvas.getContext('2d');

            canvas.width = canvas.parentElement.clientWidth;
            canvas.height = 24;

            const w = canvas.width;
            const h = canvas.height;

            // Draw mini DNA pattern
            for (let x = 0; x < w; x += 3) {
                for (let y = 2; y < h - 2; y += 4) {
                    if (Math.random() > 0.4) {
                        ctx.fillStyle = Math.random() > 0.5 ? '#3b82f6' : '#f59e0b';
                        ctx.fillRect(x + (y * 0.2), y, 2, 3);
                    }
                }
            }
        }

        // Tooltip handling
        const canvas = document.getElementById('dnaCanvas');
        const tooltip = document.getElementById('tooltip');

        canvas.addEventListener('mousemove', (e) => {
            const rect = canvas.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;

            // Show tooltip near cursor
            tooltip.style.left = (e.clientX + 15) + 'px';
            tooltip.style.top = (e.clientY - 30) + 'px';

            // Simulate task detection
            const row = Math.floor(y / ROW_HEIGHT);
            const trainType = row < 50 ? 'ALT' : 'KNK';
            const trainNum = String((row % 50) + 1).padStart(3, '0');

            const taskTypes = ['A-Check', 'B-Check', 'C-Check', 'D-Overhaul'];
            const taskType = taskTypes[Math.floor(Math.random() * 4)];

            document.getElementById('tooltipTitle').textContent = `${taskType} | ${trainType}-${trainNum}`;
            tooltip.classList.add('visible');
        });

        canvas.addEventListener('mouseleave', () => {
            tooltip.classList.remove('visible');
        });

        // Initialize
        generateSidebar();
        generateTimeline();
        renderDNA();
        renderScrubber();

        window.addEventListener('resize', () => {
            renderDNA();
            renderScrubber();
        });
    </script>
</body>
</html>
