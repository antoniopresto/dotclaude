<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Micro View - Operational 4-8 Week Gantt</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Tooltip visibility and task gradients */
        .tooltip.visible { display: block; }
        .task-card.maintenance { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
        .task-card.overhaul { background: linear-gradient(135deg, #f59e0b, #d97706); }
        .task-card.inspection { background: linear-gradient(135deg, #10b981, #059669); }
    </style>
</head>
<body class="font-sans bg-zinc-100 h-screen flex flex-col">
    <!-- Header -->
    <div class="flex items-center justify-between px-4 py-2 bg-white border-b border-gray-200 h-11">
        <div class="flex items-center gap-3">
            <span class="text-xl text-gray-500 cursor-pointer">☰</span>
            <span class="text-[15px] font-semibold text-gray-900">Metro Integrated Planning System</span>
        </div>
        <div class="flex items-center gap-3">
            <div class="px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-md text-xs cursor-pointer">Fleet: 128 Trains</div>
            <div class="px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-md text-xs cursor-pointer">Availability: 98.5%</div>
            <div class="px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-md text-xs cursor-pointer">Light Mode ▾</div>
        </div>
    </div>

    <!-- Main Container -->
    <div class="flex flex-1 overflow-hidden">
        <!-- Sidebar -->
        <div class="w-[100px] bg-white border-r border-gray-200 flex flex-col">
            <div class="p-2 text-[10px] font-semibold text-gray-500 border-b border-gray-200 text-center">TRAIN</div>
            <div class="flex-1 overflow-y-auto" id="sidebarList"></div>
        </div>

        <!-- Canvas Container -->
        <div class="flex-1 flex flex-col relative">
            <div class="flex bg-white border-b border-gray-200 h-10" id="timelineHeader"></div>
            <div class="flex-1 relative overflow-auto bg-gray-50">
                <div class="relative min-h-full" id="ganttContent">
                    <svg class="absolute top-0 left-0 pointer-events-none" id="dependencyLines"></svg>
                </div>
                <div class="absolute top-2 right-2 bg-white/95 px-2.5 py-1.5 rounded text-xs text-gray-500 shadow-sm z-20">Micro View: 6-Week Operational | Zoom: 3.2x</div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="h-[50px] bg-white border-t border-gray-200 flex items-center px-4">
        <div class="flex-1 h-6 bg-gray-100 rounded relative overflow-hidden">
            <canvas class="w-full h-full" id="scrubberMinimap"></canvas>
            <div class="absolute w-[10%] h-full bg-indigo-500/30 border-2 border-indigo-500 rounded cursor-grab" style="left: 45%;"></div>
        </div>
    </div>

    <!-- Tooltip -->
    <div class="tooltip fixed bg-white border border-gray-200 rounded-lg px-4 py-3 text-xs shadow-xl pointer-events-none z-[1000] hidden min-w-[200px]" id="tooltip">
        <div class="flex items-center gap-2 mb-2">
            <span class="px-1.5 py-0.5 rounded text-[10px] font-semibold text-white" id="tooltipBadge">B-Check</span>
            <span class="font-semibold text-gray-900" id="tooltipTitle">ALT-015</span>
        </div>
        <div class="flex justify-between py-1 border-t border-gray-100">
            <span class="text-gray-500">Start:</span>
            <span class="font-medium text-gray-700" id="tooltipStart">Jan 15, 2032</span>
        </div>
        <div class="flex justify-between py-1 border-t border-gray-100">
            <span class="text-gray-500">End:</span>
            <span class="font-medium text-gray-700" id="tooltipEnd">Jan 16, 2032</span>
        </div>
        <div class="flex justify-between py-1 border-t border-gray-100">
            <span class="text-gray-500">Duration:</span>
            <span class="font-medium text-gray-700" id="tooltipDuration">16 hours</span>
        </div>
        <div class="flex justify-between py-1 border-t border-gray-100">
            <span class="text-gray-500">Man-Hours:</span>
            <span class="font-medium text-gray-700" id="tooltipManHours">32</span>
        </div>
        <div class="mt-2 px-2 py-1.5 bg-red-50 border border-red-200 rounded text-red-600 text-xs" id="tooltipConflict" style="display: none;">
            ⚠ Resource conflict with ALT-016
        </div>
    </div>

    <script>
        const TRAIN_COUNT = 20;
        const DAYS = 42; // 6 weeks
        const ROW_HEIGHT = 50;
        const DAY_WIDTH = 80;
        const START_DATE = new Date(2032, 0, 12); // Jan 12, 2032 (Monday)

        // Task types
        const TASK_TYPES = [
            { name: 'A-Check', type: 'maintenance', duration: [1, 1], manHours: 8 },
            { name: 'B-Check', type: 'maintenance', duration: [1, 2], manHours: 32 },
            { name: 'C-Check', type: 'overhaul', duration: [3, 5], manHours: 160 },
            { name: 'D-Overhaul', type: 'overhaul', duration: [15, 20], manHours: 1200 },
            { name: 'Safety Inspection', type: 'inspection', duration: [1, 1], manHours: 4 },
            { name: 'Wheel Profile', type: 'inspection', duration: [1, 2], manHours: 8 }
        ];

        // Generate train data
        const trains = [];
        for (let i = 0; i < TRAIN_COUNT; i++) {
            const type = i < 12 ? 'ALT' : 'KNK';
            const num = String((i % 12) + 1).padStart(3, '0');
            trains.push(`${type}-${num}`);
        }

        // Generate tasks
        const tasks = [];
        let taskId = 0;

        for (let row = 0; row < TRAIN_COUNT; row++) {
            let dayOffset = Math.floor(Math.random() * 5);

            while (dayOffset < DAYS - 3) {
                const taskType = TASK_TYPES[Math.floor(Math.random() * TASK_TYPES.length)];
                const duration = taskType.duration[0] + Math.floor(Math.random() * (taskType.duration[1] - taskType.duration[0] + 1));

                // Random conflict (10% chance)
                const hasConflict = Math.random() < 0.1;

                tasks.push({
                    id: taskId++,
                    trainIndex: row,
                    trainId: trains[row],
                    startDay: dayOffset,
                    duration: duration,
                    taskType: taskType,
                    conflict: hasConflict,
                    dependencies: []
                });

                dayOffset += duration + 2 + Math.floor(Math.random() * 5);
            }
        }

        // Add some dependencies
        for (let i = 1; i < tasks.length; i++) {
            if (Math.random() < 0.15 && i > 0) {
                // Find a task in a different row that ends before this one starts
                const candidates = tasks.filter((t, idx) =>
                    idx < i &&
                    t.trainIndex !== tasks[i].trainIndex &&
                    t.startDay + t.duration < tasks[i].startDay
                );
                if (candidates.length > 0) {
                    const dep = candidates[Math.floor(Math.random() * candidates.length)];
                    tasks[i].dependencies.push(dep.id);
                }
            }
        }

        // Generate sidebar
        function generateSidebar() {
            const list = document.getElementById('sidebarList');
            list.innerHTML = trains.map(t => `<div class="px-3 py-2 text-xs text-gray-700 border-b border-gray-100 h-[50px] flex items-center hover:bg-gray-50">${t}</div>`).join('');
        }

        // Generate timeline
        function generateTimeline() {
            const header = document.getElementById('timelineHeader');
            const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
            const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

            let html = '';

            for (let i = 0; i < DAYS; i++) {
                const date = new Date(START_DATE);
                date.setDate(date.getDate() + i);

                const dayOfWeek = date.getDay();
                const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
                const isToday = i === 5; // Mark day 5 as "today" for demo

                let bgClass = '';
                if (isWeekend) bgClass = 'bg-amber-100';
                if (isToday) bgClass = 'bg-blue-100 border-b-2 border-blue-500';

                html += `
                    <div class="w-20 min-w-[80px] flex flex-col items-center justify-center text-[10px] text-gray-500 border-r border-gray-100 ${bgClass}">
                        <span class="font-semibold text-gray-700">${dayNames[dayOfWeek]}</span>
                        <span>${monthNames[date.getMonth()]} ${date.getDate()}</span>
                    </div>
                `;
            }

            header.innerHTML = html;
        }

        // Render Gantt chart
        function renderGantt() {
            const content = document.getElementById('ganttContent');
            const svg = document.getElementById('dependencyLines');

            const totalWidth = DAYS * DAY_WIDTH;
            const totalHeight = TRAIN_COUNT * ROW_HEIGHT;

            content.style.width = totalWidth + 'px';
            content.style.height = totalHeight + 'px';

            svg.setAttribute('width', totalWidth);
            svg.setAttribute('height', totalHeight);

            // Create row backgrounds
            let rowsHtml = '';
            for (let i = 0; i < TRAIN_COUNT; i++) {
                const evenClass = i % 2 === 0 ? '' : 'bg-gray-50/50';
                rowsHtml += `<div class="absolute left-0 right-0 h-[50px] border-b border-gray-100 ${evenClass}" style="top: ${i * ROW_HEIGHT}px;"></div>`;
            }

            // Create grid lines
            let gridHtml = '';
            for (let i = 0; i <= DAYS; i++) {
                const date = new Date(START_DATE);
                date.setDate(date.getDate() + i);
                const dayOfWeek = date.getDay();
                const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;

                if (isWeekend) {
                    gridHtml += `<div class="absolute top-0 bottom-0 w-20 bg-amber-100 opacity-50" style="left: ${i * DAY_WIDTH}px;"></div>`;
                } else {
                    gridHtml += `<div class="absolute top-0 bottom-0 w-px bg-gray-200" style="left: ${i * DAY_WIDTH}px;"></div>`;
                }
            }

            // Create task cards
            let tasksHtml = '';
            tasks.forEach(task => {
                const x = task.startDay * DAY_WIDTH + 4;
                const y = task.trainIndex * ROW_HEIGHT + 7;
                const width = task.duration * DAY_WIDTH - 8;

                const conflictClass = task.conflict ? 'border-2 border-red-500 shadow-[0_0_8px_rgba(239,68,68,0.4)]' : '';

                tasksHtml += `
                    <div class="task-card ${task.taskType.type} absolute h-9 rounded-md px-2 py-1 text-[10px] cursor-pointer transition-all duration-100 flex flex-col justify-center overflow-hidden text-white hover:-translate-y-0.5 hover:shadow-lg hover:z-10 ${conflictClass}"
                         style="left: ${x}px; top: ${y}px; width: ${width}px;"
                         data-task-id="${task.id}">
                        <span class="font-semibold whitespace-nowrap overflow-hidden text-ellipsis">${task.taskType.name}</span>
                        <span class="text-[9px] opacity-90">${task.duration}d • ${task.taskType.manHours}h</span>
                    </div>
                `;
            });

            // Create dependency lines
            let linesHtml = '';
            tasks.forEach(task => {
                task.dependencies.forEach(depId => {
                    const depTask = tasks.find(t => t.id === depId);
                    if (depTask) {
                        const x1 = (depTask.startDay + depTask.duration) * DAY_WIDTH;
                        const y1 = depTask.trainIndex * ROW_HEIGHT + ROW_HEIGHT / 2;
                        const x2 = task.startDay * DAY_WIDTH;
                        const y2 = task.trainIndex * ROW_HEIGHT + ROW_HEIGHT / 2;

                        // Create bezier curve
                        const midX = (x1 + x2) / 2;

                        linesHtml += `
                            <path d="M ${x1} ${y1} C ${midX} ${y1}, ${midX} ${y2}, ${x2} ${y2}"
                                  fill="none"
                                  stroke="#94a3b8"
                                  stroke-width="2"
                                  stroke-dasharray="4,4"
                                  marker-end="url(#arrowhead)"/>
                        `;
                    }
                });
            });

            // Add arrowhead marker definition
            svg.innerHTML = `
                <defs>
                    <marker id="arrowhead" markerWidth="10" markerHeight="7"
                            refX="9" refY="3.5" orient="auto">
                        <polygon points="0 0, 10 3.5, 0 7" fill="#94a3b8"/>
                    </marker>
                </defs>
                ${linesHtml}
            `;

            content.innerHTML = rowsHtml + gridHtml + tasksHtml + svg.outerHTML;
        }

        // Render minimap
        function renderScrubber() {
            const canvas = document.getElementById('scrubberMinimap');
            const ctx = canvas.getContext('2d');

            canvas.width = canvas.parentElement.clientWidth;
            canvas.height = 24;

            const w = canvas.width;
            const h = canvas.height;

            // Draw mini task representation
            tasks.forEach(task => {
                const x = (task.startDay / DAYS) * w;
                const barWidth = (task.duration / DAYS) * w;
                const y = (task.trainIndex / TRAIN_COUNT) * (h - 4) + 2;

                ctx.fillStyle = task.taskType.type === 'maintenance' ? '#3b82f6' :
                               task.taskType.type === 'overhaul' ? '#f59e0b' : '#10b981';
                ctx.fillRect(x, y, Math.max(barWidth, 2), 2);
            });
        }

        // Tooltip handling
        const tooltip = document.getElementById('tooltip');

        document.getElementById('ganttContent').addEventListener('mousemove', (e) => {
            const taskCard = e.target.closest('.task-card');

            if (taskCard) {
                const taskId = parseInt(taskCard.dataset.taskId);
                const task = tasks.find(t => t.id === taskId);

                if (task) {
                    // Update tooltip content
                    document.getElementById('tooltipBadge').textContent = task.taskType.name;
                    const badgeColors = { maintenance: 'bg-blue-500', overhaul: 'bg-amber-500', inspection: 'bg-emerald-500' };
                    document.getElementById('tooltipBadge').className = `px-1.5 py-0.5 rounded text-[10px] font-semibold text-white ${badgeColors[task.taskType.type]}`;
                    document.getElementById('tooltipTitle').textContent = task.trainId;

                    const startDate = new Date(START_DATE);
                    startDate.setDate(startDate.getDate() + task.startDay);
                    const endDate = new Date(startDate);
                    endDate.setDate(endDate.getDate() + task.duration);

                    const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                    document.getElementById('tooltipStart').textContent = `${monthNames[startDate.getMonth()]} ${startDate.getDate()}, ${startDate.getFullYear()}`;
                    document.getElementById('tooltipEnd').textContent = `${monthNames[endDate.getMonth()]} ${endDate.getDate()}, ${endDate.getFullYear()}`;
                    document.getElementById('tooltipDuration').textContent = `${task.duration * 24} hours`;
                    document.getElementById('tooltipManHours').textContent = task.taskType.manHours;

                    const conflictEl = document.getElementById('tooltipConflict');
                    if (task.conflict) {
                        conflictEl.style.display = 'block';
                        conflictEl.textContent = `⚠ Resource conflict detected`;
                    } else {
                        conflictEl.style.display = 'none';
                    }

                    // Position tooltip
                    tooltip.style.left = (e.clientX + 15) + 'px';
                    tooltip.style.top = (e.clientY - 10) + 'px';
                    tooltip.classList.add('visible');
                }
            } else {
                tooltip.classList.remove('visible');
            }
        });

        document.getElementById('ganttContent').addEventListener('mouseleave', () => {
            tooltip.classList.remove('visible');
        });

        // Initialize
        generateSidebar();
        generateTimeline();
        renderGantt();
        renderScrubber();

        window.addEventListener('resize', () => {
            renderScrubber();
        });
    </script>
</body>
</html>
