<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Macro View - Strategic 10-20 Year Heatmap</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="font-sans bg-zinc-100 h-screen flex flex-col">
    <!-- Header -->
    <div class="flex items-center justify-between px-4 py-2 bg-white border-b border-gray-200 h-11">
        <div class="flex items-center gap-3">
            <span class="text-xl text-gray-500 cursor-pointer">☰</span>
            <span class="text-[15px] font-semibold text-gray-900">Metro Integrated Planning System</span>
        </div>
        <div class="flex items-center gap-3">
            <div class="px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-md text-xs cursor-pointer flex items-center gap-1">Fleet: 128 Trains</div>
            <div class="px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-md text-xs cursor-pointer flex items-center gap-1">Availability: 98.5%</div>
            <div class="px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-md text-xs cursor-pointer flex items-center gap-1">Light Mode ▾</div>
        </div>
    </div>

    <!-- Main Container -->
    <div class="flex flex-1 overflow-hidden">
        <!-- Sidebar -->
        <div class="w-[60px] bg-white border-r border-gray-200 flex flex-col">
            <div class="p-2 text-[10px] font-semibold text-gray-500 border-b border-gray-200 text-center">TRAIN</div>
            <div class="flex-1 overflow-y-auto" id="sidebarList"></div>
        </div>

        <!-- Canvas Container -->
        <div class="flex-1 flex flex-col relative">
            <div class="flex bg-white border-b border-gray-200 h-7" id="timelineHeader"></div>
            <div class="flex-1 relative overflow-hidden">
                <canvas id="heatmapCanvas" class="w-full h-full block"></canvas>
                <div class="absolute border-2 border-slate-500 bg-slate-500/5 pointer-events-none" id="selectionOverlay"></div>
                <div class="absolute top-2 right-2 bg-white/90 px-2 py-1 rounded text-xs text-gray-500 shadow-sm">Macro View: 10-Year Overview | Zoom: 0.3x</div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="h-[50px] bg-white border-t border-gray-200 flex items-center px-4">
        <div class="flex-1 h-[30px] flex items-center">
            <div class="flex-1 h-5 bg-gray-100 rounded relative overflow-hidden">
                <canvas class="w-full h-full" id="scrubberMinimap"></canvas>
                <div class="absolute w-[15%] h-full bg-indigo-500/30 border-2 border-indigo-500 rounded cursor-grab" style="left: 60%;"></div>
            </div>
        </div>
    </div>

    <script>
        // Configuration
        const TRAIN_COUNT = 50;
        const YEARS = 12;
        const START_YEAR = 2024;
        const ROW_HEIGHT = 20;

        // Generate sidebar train list
        function generateSidebar() {
            const list = document.getElementById('sidebarList');
            const trains = [];

            for (let i = 0; i < TRAIN_COUNT; i++) {
                const type = i < 30 ? 'ALT' : 'KNK';
                const num = String(i + 1).padStart(3, '0');
                trains.push(`${type}-${num}`);
            }

            list.innerHTML = trains.map(t => `<div class="px-2 py-1 text-[10px] text-gray-700 border-b border-gray-100 h-5 flex items-center hover:bg-gray-50">${t}</div>`).join('');
        }

        // Generate timeline header
        function generateTimeline() {
            const header = document.getElementById('timelineHeader');
            const years = [];

            for (let i = 0; i < YEARS; i++) {
                const year = START_YEAR + i;
                const isHighlight = year >= 2032 && year <= 2034;
                const baseClasses = 'flex-1 min-w-[80px] flex items-center justify-center text-[10px] text-gray-500 border-r border-gray-100';
                const highlightClasses = isHighlight ? ' bg-blue-100 font-semibold text-blue-700' : '';
                years.push(`<div class="${baseClasses}${highlightClasses}">${year}</div>`);
            }

            header.innerHTML = years.join('');
        }

        // Render heatmap
        function renderHeatmap() {
            const canvas = document.getElementById('heatmapCanvas');
            const ctx = canvas.getContext('2d');
            const container = canvas.parentElement;

            canvas.width = container.clientWidth;
            canvas.height = container.clientHeight;

            const w = canvas.width;
            const h = canvas.height;
            const cellW = 6;
            const cellH = ROW_HEIGHT;

            // Create concentrated hotspots like in the design
            // The design shows dark red "blob" concentrations, especially on the right side
            const hotspots = [
                // Right side concentration (main maintenance peaks)
                { x: 0.70, y: 0.20, radius: 0.12, intensity: 1.0 },
                { x: 0.75, y: 0.35, radius: 0.15, intensity: 1.0 },
                { x: 0.82, y: 0.50, radius: 0.18, intensity: 1.0 },
                { x: 0.78, y: 0.65, radius: 0.14, intensity: 1.0 },
                { x: 0.85, y: 0.80, radius: 0.12, intensity: 0.9 },
                // Center area (secondary peaks)
                { x: 0.45, y: 0.30, radius: 0.08, intensity: 0.6 },
                { x: 0.50, y: 0.55, radius: 0.10, intensity: 0.5 },
                { x: 0.40, y: 0.75, radius: 0.07, intensity: 0.5 },
                // Scattered smaller spots
                { x: 0.25, y: 0.40, radius: 0.05, intensity: 0.3 },
                { x: 0.30, y: 0.60, radius: 0.06, intensity: 0.35 },
                { x: 0.60, y: 0.25, radius: 0.06, intensity: 0.4 },
            ];

            // Noise function for texture
            function noise(x, y, seed) {
                const n = Math.sin(x * 12.9898 + y * 78.233 + seed) * 43758.5453;
                return n - Math.floor(n);
            }

            // Gaussian function for blob falloff
            function gaussian(x, y, cx, cy, radius) {
                const dx = x - cx;
                const dy = y - cy;
                const d2 = (dx * dx + dy * dy) / (radius * radius);
                return Math.exp(-d2 * 2.5);
            }

            // Color ramp: Yellow → Orange → Dark Red
            function getHeatColor(value) {
                value = Math.min(1, Math.max(0, value));

                if (value < 0.25) {
                    // Light yellow to yellow-orange
                    const t = value / 0.25;
                    return `rgb(255, ${Math.floor(248 - t * 30)}, ${Math.floor(200 - t * 120)})`;
                } else if (value < 0.5) {
                    // Yellow-orange to orange
                    const t = (value - 0.25) / 0.25;
                    return `rgb(255, ${Math.floor(218 - t * 60)}, ${Math.floor(80 - t * 50)})`;
                } else if (value < 0.75) {
                    // Orange to dark orange-red
                    const t = (value - 0.5) / 0.25;
                    return `rgb(${Math.floor(255 - t * 40)}, ${Math.floor(158 - t * 80)}, ${Math.floor(30 - t * 20)})`;
                } else {
                    // Dark orange-red to dark red
                    const t = (value - 0.75) / 0.25;
                    return `rgb(${Math.floor(215 - t * 55)}, ${Math.floor(78 - t * 50)}, ${Math.floor(10 + t * 20)})`;
                }
            }

            // Render each cell
            for (let x = 0; x < w; x += cellW) {
                for (let y = 0; y < h; y += cellH) {
                    const nx = x / w;
                    const ny = y / h;

                    // Base value with some noise texture
                    let value = noise(nx * 20, ny * 15, 42) * 0.15;

                    // Add gaussian blob influence from each hotspot
                    hotspots.forEach(hs => {
                        const blobValue = gaussian(nx, ny, hs.x, hs.y, hs.radius) * hs.intensity;
                        value += blobValue * 0.85;
                    });

                    // Small random noise for texture
                    value += noise(x * 0.3, y * 0.3, 123) * 0.05;

                    ctx.fillStyle = getHeatColor(value);
                    ctx.fillRect(x, y, cellW - 0.5, cellH - 0.5);
                }
            }

            // Update selection overlay position
            const overlay = document.getElementById('selectionOverlay');
            overlay.style.left = (w * 0.65) + 'px';
            overlay.style.top = '10px';
            overlay.style.width = (w * 0.30) + 'px';
            overlay.style.height = (h - 20) + 'px';
        }

        // Render minimap scrubber
        function renderScrubber() {
            const canvas = document.getElementById('scrubberMinimap');
            const ctx = canvas.getContext('2d');

            canvas.width = canvas.parentElement.clientWidth;
            canvas.height = 20;

            const w = canvas.width;
            const h = canvas.height;

            // Simple minimap representation
            for (let x = 0; x < w; x++) {
                const intensity = Math.sin(x / w * Math.PI * 4) * 0.3 +
                                 Math.random() * 0.2 +
                                 (x / w > 0.6 ? 0.4 : 0.1);

                const barHeight = intensity * h;

                ctx.fillStyle = intensity > 0.5 ? '#dc2626' : intensity > 0.3 ? '#f59e0b' : '#fbbf24';
                ctx.fillRect(x, h - barHeight, 1, barHeight);
            }
        }

        // Initialize
        generateSidebar();
        generateTimeline();
        renderHeatmap();
        renderScrubber();

        // Handle resize
        window.addEventListener('resize', () => {
            renderHeatmap();
            renderScrubber();
        });
    </script>
</body>
</html>
