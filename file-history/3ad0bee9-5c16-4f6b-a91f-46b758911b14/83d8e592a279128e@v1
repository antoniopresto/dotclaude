}
```

### 8.2 Task Entity

```typescript
interface Task {
  id: string;
  trainId: string;
  startDate: string;             // ISO 8601
  endDate: string;               // ISO 8601
  type: 'A-Check' | 'B-Check' | 'C-Check' | 'D-Overhaul';
  status: 'scheduled' | 'in-progress' | 'completed' | 'cancelled';
  manHours: number;
  track: number;
  hasConflict: boolean;
  conflictReason?: string;
  dependencies?: string[];       // Task IDs this depends on
  estimatedCost: number;
}
```

### 8.3 Scenario Entity (Sandbox)

```typescript
interface Scenario {
  id: string;
  name: string;
  description?: string;
  createdAt: string;
  modifiedAt: string;
  changes: ScenarioChange[];
  metrics: {
    opexDelta: number;
    overrunRiskDelta: number;
    trackUtilizationDelta: number;
  };
}

interface ScenarioChange {
  type: 'move' | 'resize' | 'create' | 'delete' | 'modify';
  taskId: string;
  before: Partial<Task>;
  after: Partial<Task>;
}
```

