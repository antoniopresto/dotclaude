import { getFleet, getKPIs, getSchedules, type Train } from "../lib/demo-data";

export function meta() {
  return [
    { title: "Dashboard | Dubai Metro MMS" },
    { name: "description", content: "Mileage Management System Dashboard" },
  ];
}

function KPICard({
  title,
  value,
  subtitle,
  trend,
  color = "blue",
}: {
  title: string;
  value: string | number;
  subtitle?: string;
  trend?: { value: number; label: string };
  color?: "blue" | "green" | "yellow" | "red";
}) {
  const colorClasses = {
    blue: "bg-blue-50 border-blue-200",
    green: "bg-green-50 border-green-200",
    yellow: "bg-yellow-50 border-yellow-200",
    red: "bg-red-50 border-red-200",
  };

  const trendColors = {
    blue: "text-blue-600",
    green: "text-green-600",
    yellow: "text-yellow-600",
    red: "text-red-600",
  };

  return (
    <div
      className={`p-6 rounded-xl border-2 ${colorClasses[color]} transition-transform hover:scale-[1.02]`}
    >
      <p className="text-sm font-medium text-gray-600 mb-1">{title}</p>
      <p className="text-3xl font-bold text-gray-900">{value}</p>
      {subtitle && <p className="text-sm text-gray-500 mt-1">{subtitle}</p>}
      {trend && (
        <p className={`text-sm font-medium mt-2 ${trendColors[color]}`}>
          {trend.value > 0 ? "↑" : "↓"} {Math.abs(trend.value)}% {trend.label}
        </p>
      )}
    </div>
  );
}

function StatusBadge({ status }: { status: Train["status"] }) {
  const styles = {
    operational: "bg-green-100 text-green-800",
    maintenance: "bg-yellow-100 text-yellow-800",
    standby: "bg-gray-100 text-gray-800",
  };

  return (
    <span
      className={`px-2 py-1 rounded-full text-xs font-medium ${styles[status]}`}
    >
      {status}
    </span>
  );
}

export default function Dashboard() {
  const kpis = getKPIs();
  const fleet = getFleet();
  const schedules = getSchedules();

  // Trains needing attention
  const urgentTrains = fleet
    .filter((t) => {
      const kmToNextA = t.nextMaintenanceDue.A - t.currentMileageKm;
      return kmToNextA < 5000;
    })
    .slice(0, 5);

  // Upcoming events
  const upcomingEvents = schedules
    .flatMap((s) => s.events)
    .filter((e) => e.status === "scheduled")
    .slice(0, 5);

  return (
    <div className="space-y-6">
      {/* Page Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold text-gray-900">Dashboard</h1>
          <p className="text-gray-500">
            Real-time fleet overview and maintenance insights
          </p>
        </div>
        <div className="flex items-center gap-2">
          <span className="flex items-center gap-2 px-3 py-1.5 bg-green-100 text-green-800 rounded-full text-sm font-medium">
            <span className="w-2 h-2 bg-green-500 rounded-full animate-pulse" />
            System Online
          </span>
        </div>
      </div>

      {/* KPI Grid */}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <KPICard
          title="Fleet Availability"
          value={`${kpis.fleetAvailability}%`}
          subtitle={`${kpis.operational} of ${kpis.totalFleet} operational`}
          trend={{ value: 2.3, label: "vs last week" }}
          color="green"
        />
        <KPICard
          title="In Maintenance"
          value={kpis.inMaintenance}
          subtitle="Trains currently serviced"
          color="yellow"
        />
        <KPICard
          title="Capacity Utilization"
          value={`${kpis.avgUtilization}%`}
          subtitle="Workshop efficiency"
          trend={{ value: 5.1, label: "optimized" }}
          color="blue"
        />
        <KPICard
          title="Urgent Attention"
          value={kpis.urgentCount}
          subtitle="Maintenance due soon"
          color={kpis.urgentCount > 10 ? "red" : "yellow"}
        />
      </div>

      {/* Two Column Layout */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {/* Trains Needing Attention */}
        <div className="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div className="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 className="font-semibold text-gray-900">
              Trains Needing Attention
            </h2>
            <p className="text-sm text-gray-500">
              Within 5,000 km of next service
            </p>
          </div>
          <div className="divide-y divide-gray-100">
            {urgentTrains.map((train) => {
              const kmToNext = train.nextMaintenanceDue.A - train.currentMileageKm;
              return (
                <div
                  key={train.id}
                  className="px-6 py-4 flex items-center justify-between hover:bg-gray-50"
                >
                  <div className="flex items-center gap-4">
                    <div
                      className={`w-10 h-10 rounded-lg flex items-center justify-center ${
                        train.fleet === "Alstom"
                          ? "bg-blue-100 text-blue-700"
                          : "bg-purple-100 text-purple-700"
                      }`}
                    >
                      <span className="text-lg">🚇</span>
                    </div>
                    <div>
                      <p className="font-medium text-gray-900">{train.id}</p>
                      <p className="text-sm text-gray-500">{train.fleet}</p>
                    </div>
                  </div>
                  <div className="text-right">
                    <p className="font-medium text-red-600">
                      {kmToNext.toLocaleString()} km
                    </p>
                    <p className="text-sm text-gray-500">to A-check</p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        {/* Upcoming Maintenance */}
        <div className="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div className="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 className="font-semibold text-gray-900">
              Upcoming Maintenance
            </h2>
            <p className="text-sm text-gray-500">Next scheduled events</p>
          </div>
          <div className="divide-y divide-gray-100">
            {upcomingEvents.map((event) => {
              const typeColors = {
                A: "bg-green-100 text-green-800",
                B: "bg-blue-100 text-blue-800",
                C: "bg-orange-100 text-orange-800",
                D: "bg-red-100 text-red-800",
              };
              return (
                <div
                  key={event.id}
                  className="px-6 py-4 flex items-center justify-between hover:bg-gray-50"
                >
                  <div className="flex items-center gap-4">
                    <span
                      className={`w-8 h-8 rounded-lg flex items-center justify-center font-bold ${typeColors[event.type]}`}
                    >
                      {event.type}
                    </span>
                    <div>
                      <p className="font-medium text-gray-900">
                        {event.trainId}
                      </p>
                      <p className="text-sm text-gray-500">
                        {event.durationDays} day
                        {event.durationDays > 1 ? "s" : ""}
                      </p>
                    </div>
                  </div>
                  <div className="text-right">
                    <p className="font-medium text-gray-900">
                      {new Date(event.scheduledDate).toLocaleDateString(
                        "en-GB",
                        { day: "numeric", month: "short" }
                      )}
                    </p>
                    <p className="text-sm text-gray-500">scheduled</p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>

      {/* Capacity Chart Placeholder */}
      <div className="bg-white rounded-xl border border-gray-200 p-6">
        <h2 className="font-semibold text-gray-900 mb-4">
          12-Week Capacity Forecast
        </h2>
        <div className="flex items-end gap-2 h-40">
          {schedules.map((week) => (
            <div
              key={week.weekNumber}
              className="flex-1 flex flex-col items-center gap-2"
            >
              <div
                className={`w-full rounded-t transition-all ${
                  week.capacityUtilization > 90
                    ? "bg-red-400"
                    : week.capacityUtilization > 70
                      ? "bg-yellow-400"
                      : "bg-blue-400"
                }`}
                style={{ height: `${week.capacityUtilization}%` }}
              />
              <span className="text-xs text-gray-500">W{week.weekNumber}</span>
            </div>
          ))}
        </div>
        <div className="flex items-center gap-6 mt-4 text-sm">
          <span className="flex items-center gap-2">
            <span className="w-3 h-3 rounded bg-blue-400" /> Normal
          </span>
          <span className="flex items-center gap-2">
            <span className="w-3 h-3 rounded bg-yellow-400" /> High
          </span>
          <span className="flex items-center gap-2">
            <span className="w-3 h-3 rounded bg-red-400" /> Critical
          </span>
        </div>
      </div>
    </div>
  );
}
