```yaml
# sprint-status.yaml
current_sprint:
  number: 1
  name: "Sprint 1 - Core Solver"
  start_date: "2025-01-06"
  end_date: "2025-01-17"
  goal: "Implement core allocation solver"
  capacity: 40  # story points

stories:
  - id: "S-001"
    title: "Setup PostgreSQL database"
    epic: "E1-Infrastructure"
    status: "done"
    points: 3
    assignee: "dev"

  - id: "S-002"
    title: "Create train entity model"
    epic: "E1-Infrastructure"
    status: "in-progress"
    points: 5
    assignee: "dev"

velocity:
  sprint_1: 35
  sprint_2: 38
  average: 36.5

backlog:
  - id: "S-010"
    title: "Implement dashboard KPIs"
    epic: "E2-Dashboard"
    status: "ready"
    points: 8
```

