{
  "name": "@mms/toolkit",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "test-watch": "vitest --watch",
    "build": "vite build",
    "coverage": "vitest --coverage",
    "test": "vitest",
    "bench": "vitest bench",
    "check": "run-p check:* && run-s coverage",
    "check:types": "tsc --noEmit -p tsconfig.lint.json",
    "check:prettier": "prettier \"./**/*{.ts,.js,.json}\" --write",
    "DISABLED:check:lint": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/lodash": "4.17.20",
    "@types/node": "24.10.0",
    "@types/react": "19.2.3",
    "@vitejs/plugin-react-swc": "4.2.0",
    "@vitest/coverage-v8": "4.0.8",
    "ajv": "8.17.1",
    "conditional-type-checks": "1.0.6",
    "eslint": "9.39.1",
    "npm-run-all": "4.1.5",
    "prettier": "3.6.2",
    "prettier-plugin-organize-imports": "4.3.0",
    "rollup-plugin-node-externals": "8.1.1",
    "terser": "5.44.1",
    "ts-node": "10.9.2",
    "ts-toolbelt": "9.6.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.3",
    "vite": "7.2.2",
    "vite-plugin-dts": "4.5.4",
    "vite-plugin-externalize-deps": "0.10.0",
    "vite-plugin-svgr": "4.5.0",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.0.8"
  },
  "peerDependencies": {
    "react": "*"
  },
  "dependencies": {
    "date-fns": "4.1.0",
    "immer": "10.2.0",
    "lodash": "4.17.21",
    "lru-cache": "11.2.2",
    "minimatch": "10.1.1",
    "typebox": "1.0.50"
  }
}
