import SwiftUI

struct ContentView: View {
    @EnvironmentObject var appState: AppState

    var body: some View {
        NavigationSplitView {
            SidebarView()
                .frame(minWidth: 150)
        } detail: {
            HSplitView {
                FileListView()
                    .frame(minWidth: 300)

                TerminalView()
                    .frame(minWidth: 250, idealWidth: appState.terminalWidth)
            }
        }
        .toolbar {
            ToolbarItemGroup(placement: .navigation) {
                Button(action: goBack) {
                    Image(systemName: "chevron.left")
                }
                .disabled(!canGoBack)

                Button(action: goForward) {
                    Image(systemName: "chevron.right")
                }
                .disabled(!canGoForward)
            }

            ToolbarItem(placement: .principal) {
                PathBarView(path: appState.currentPath)
            }
        }
        .navigationTitle("")
    }

    // TODO: Implement navigation history
    private var canGoBack: Bool { false }
    private var canGoForward: Bool { false }
    private func goBack() {}
    private func goForward() {}
}

struct PathBarView: View {
    let path: URL

    var body: some View {
        HStack(spacing: 4) {
            ForEach(pathComponents, id: \.self) { component in
                if component != pathComponents.first {
                    Image(systemName: "chevron.right")
                        .font(.caption)
                        .foregroundColor(.secondary)
                }
                Text(component.lastPathComponent)
                    .font(.system(size: 12))
            }
        }
        .padding(.horizontal, 8)
        .padding(.vertical, 4)
        .background(Color.gray.opacity(0.1))
        .cornerRadius(6)
    }

    private var pathComponents: [URL] {
        var components: [URL] = []
        var current = path
        while current.path != "/" {
            components.insert(current, at: 0)
            current = current.deletingLastPathComponent()
        }
        return components
    }
}

