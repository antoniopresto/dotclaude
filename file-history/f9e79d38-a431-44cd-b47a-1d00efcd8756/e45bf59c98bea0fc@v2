/**
 * Integration Tests - AgentRC Runner
 *
 * These tests create real temporary projects and execute the agentrc-runner
 * to verify the complete flow works as expected.
 */

import { describe, it, expect, beforeAll, afterAll, beforeEach, afterEach } from 'vitest';
import { execSync } from 'child_process';
import {
  createTestProject,
  createConfiguredTestProject,
  isBunAvailable,
  DEFAULT_AGENTRC,
  DEFAULT_RUNNER,
  DEFAULT_WRAPPER,
  type TestProject,
} from './test-utils';

describe('AgentRC Runner Integration', () => {
  let bunAvailable: boolean;

  beforeAll(() => {
    bunAvailable = isBunAvailable();
    if (!bunAvailable) {
      console.warn('⚠️ Bun not available, some tests will be skipped');
    }
  });

  describe('blocking rules', () => {
    let project: TestProject;

    beforeEach(() => {
      project = createConfiguredTestProject('block-test');
    });

    afterEach(() => {
      project.cleanup();
    });

    it('should block .forbidden files with exit code 2', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'test.forbidden');

      expect(result.exitCode).toBe(2);
      expect(result.stderr).toContain('RULE VIOLATION');
      expect(result.stderr).toContain('NO-FORBIDDEN-FILES');
      expect(result.stderr).toContain('.forbidden');
    });

    it('should block nested .forbidden files', async () => {
      if (!bunAvailable) return;

      project.createDir('src/deep/nested');
      const result = await project.runAgentrcRunner('Write', 'src/deep/nested/file.forbidden');

      expect(result.exitCode).toBe(2);
      expect(result.stderr).toContain('NO-FORBIDDEN-FILES');
    });

    it('should allow regular files', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'src/component.ts');

      expect(result.exitCode).toBe(0);
      expect(result.stderr).not.toContain('RULE VIOLATION');
    });

    it('should block with custom rule message', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'test.forbidden');

      expect(result.stderr).toContain('Cannot create .forbidden files');
    });
  });

  describe('warning rules', () => {
    let project: TestProject;

    beforeEach(() => {
      project = createConfiguredTestProject('warn-test');
    });

    afterEach(() => {
      project.cleanup();
    });

    it('should warn on sensitive paths but allow (exit 0)', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'config/secret.json');

      expect(result.exitCode).toBe(0);
      expect(result.stderr).toContain('WARNING');
      expect(result.stderr).toContain('WARN-SENSITIVE');
      expect(result.stderr).toContain('Sensitive path detected');
    });

    it('should warn on password files', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'passwords.txt');

      expect(result.exitCode).toBe(0);
      expect(result.stderr).toContain('WARNING');
    });

    it('should warn on credential files', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'credentials.json');

      expect(result.exitCode).toBe(0);
      expect(result.stderr).toContain('WARNING');
    });

    it('should not warn on normal files', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'src/utils.ts');

      expect(result.exitCode).toBe(0);
      expect(result.stderr).not.toContain('WARNING');
    });
  });

  describe('hook execution', () => {
    let project: TestProject;

    beforeEach(() => {
      project = createConfiguredTestProject('hook-test');
    });

    afterEach(() => {
      project.cleanup();
    });

    it('should execute PreToolUse hook and inject content', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'src/file.ts');

      expect(result.exitCode).toBe(0);
      expect(result.stdout).toContain('[TEST] Tool: Write');
      expect(result.stdout).toContain('src/file.ts');
    });

    it('should pass correct tool name to hook', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Edit', 'src/file.ts');

      expect(result.stdout).toContain('Tool: Edit');
    });
  });

  describe('cascade hierarchy', () => {
    let project: TestProject;

    beforeEach(() => {
      project = createConfiguredTestProject('cascade-test');
    });

    afterEach(() => {
      project.cleanup();
    });

    it('should load root .agentrc.ts for root files', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'root-file.ts');

      expect(result.exitCode).toBe(0);
      expect(result.stdout).toContain('[TEST]');
    });

    it('should load root .agentrc.ts for nested files', async () => {
      if (!bunAvailable) return;

      project.createDir('src/deep/nested');
      const result = await project.runAgentrcRunner('Write', 'src/deep/nested/file.ts');

      expect(result.exitCode).toBe(0);
      expect(result.stdout).toContain('[TEST]');
    });

    it('should merge child .agentrc.ts with parent', async () => {
      if (!bunAvailable) return;

      // Create child .agentrc.ts that adds a rule (self-contained, no imports)
      project.writeFile(
        'src/.agentrc.ts',
        `
export default {
  rules: [
    {
      id: 'SRC-NO-INDEX',
      match: 'index.ts',
      action: 'block',
      message: 'No index.ts in src',
    },
  ],
  hooks: {
    PreToolUse: ({ inject }) => {
      inject('[SRC] Child hook executed');
    },
  },
};
`
      );

      // Should block index.ts in src (child rule)
      const indexResult = await project.runAgentrcRunner('Write', 'src/index.ts');
      expect(indexResult.exitCode).toBe(2);
      expect(indexResult.stderr).toContain('SRC-NO-INDEX');

      // Should still block .forbidden (parent rule)
      const forbiddenResult = await project.runAgentrcRunner('Write', 'src/test.forbidden');
      expect(forbiddenResult.exitCode).toBe(2);
      expect(forbiddenResult.stderr).toContain('NO-FORBIDDEN-FILES');
    });

    it('should allow child to extend parent config', async () => {
      if (!bunAvailable) return;

      project.writeFile(
        'src/.agentrc.ts',
        `
export default {
  extend: (parent) => ({
    rules: [
      ...(parent.rules || []),
      { id: 'EXTENDED-RULE', match: '.extended', action: 'block' },
    ],
    hooks: parent.hooks,
  }),
};
`
      );

      // Extended rule should work
      const extResult = await project.runAgentrcRunner('Write', 'src/file.extended');
      expect(extResult.exitCode).toBe(2);
      expect(extResult.stderr).toContain('EXTENDED-RULE');

      // Parent rules should still work
      const forbiddenResult = await project.runAgentrcRunner('Write', 'src/file.forbidden');
      expect(forbiddenResult.exitCode).toBe(2);
    });
  });

  describe('no agentrc files', () => {
    let project: TestProject;

    beforeEach(() => {
      // Create project without .agentrc.ts
      project = createTestProject('no-agentrc', {
        '.claude': {
          hooks: {
            'agentrc-runner.ts': DEFAULT_RUNNER,
            'agentrc-wrapper.sh': DEFAULT_WRAPPER,
          },
        },
        'src': {
          'file.ts': '// content',
        },
      });
      execSync(`chmod +x "${project.root}/.claude/hooks/agentrc-wrapper.sh"`);
    });

    afterEach(() => {
      project.cleanup();
    });

    it('should allow all files when no .agentrc.ts exists', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'src/any-file.forbidden');

      // Without .agentrc.ts, nothing is blocked
      expect(result.exitCode).toBe(0);
    });
  });

  describe('tool types', () => {
    let project: TestProject;

    beforeEach(() => {
      project = createConfiguredTestProject('tool-test');
    });

    afterEach(() => {
      project.cleanup();
    });

    it('should handle Write tool', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'src/file.ts');
      expect(result.stdout).toContain('Tool: Write');
    });

    it('should handle Edit tool', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Edit', 'src/file.ts');
      expect(result.stdout).toContain('Tool: Edit');
    });

    it('should handle Bash tool', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Bash', 'src/file.ts');
      expect(result.stdout).toContain('Tool: Bash');
    });
  });

  describe('error handling', () => {
    let project: TestProject;

    beforeEach(() => {
      project = createConfiguredTestProject('error-test');
    });

    afterEach(() => {
      project.cleanup();
    });

    it('should handle malformed .agentrc.ts gracefully', async () => {
      if (!bunAvailable) return;

      project.writeFile('.agentrc.ts', 'this is not valid typescript {{{');

      // Should not crash, just allow the action
      const result = await project.runAgentrcRunner('Write', 'src/file.ts');

      // Runner should handle the error gracefully
      expect(result.exitCode).not.toBe(2); // Not blocked
    });

    it('should handle missing file_path in input', async () => {
      if (!bunAvailable) return;

      // This tests the runner's handling of missing input
      // We can't easily test this through runAgentrcRunner, but the runner
      // should exit 0 when file_path is missing
    });
  });

  describe('rule priority', () => {
    let project: TestProject;

    beforeEach(() => {
      project = createTestProject('priority-test', {
        '.agentrc.ts': `
export default {
  rules: [
    { id: 'ALLOW-TS', match: '.ts', action: 'allow' },
    { id: 'WARN-SRC', match: '/src/', action: 'warn' },
    { id: 'BLOCK-SECRET', match: 'secret', action: 'block' },
  ],
};
`,
        '.claude': {
          hooks: {
            'agentrc-runner.ts': DEFAULT_RUNNER,
            'agentrc-wrapper.sh': DEFAULT_WRAPPER,
          },
        },
      });
      execSync(`chmod +x "${project.root}/.claude/hooks/agentrc-wrapper.sh"`);
    });

    afterEach(() => {
      project.cleanup();
    });

    it('should block when block rule matches, even if allow also matches', async () => {
      if (!bunAvailable) return;

      // Matches both .ts (allow) and secret (block)
      const result = await project.runAgentrcRunner('Write', 'src/secret.ts');

      expect(result.exitCode).toBe(2);
      expect(result.stderr).toContain('BLOCK-SECRET');
    });

    it('should warn when warn rule matches and no block', async () => {
      if (!bunAvailable) return;

      // Matches both .ts (allow) and /src/ (warn)
      const result = await project.runAgentrcRunner('Write', 'src/normal.ts');

      expect(result.exitCode).toBe(0);
      expect(result.stderr).toContain('WARNING');
    });
  });

  describe('async rules', () => {
    let project: TestProject;

    beforeEach(() => {
      project = createTestProject('async-test', {
        '.agentrc.ts': `
export default {
  rules: [
    {
      id: 'ASYNC-RULE',
      match: async (path) => {
        await new Promise(r => setTimeout(r, 50));
        return path.includes('blocked-async');
      },
      action: 'block',
      message: 'Blocked by async rule',
    },
  ],
};
`,
        '.claude': {
          hooks: {
            'agentrc-runner.ts': DEFAULT_RUNNER,
            'agentrc-wrapper.sh': DEFAULT_WRAPPER,
          },
        },
      });
      execSync(`chmod +x "${project.root}/.claude/hooks/agentrc-wrapper.sh"`);
    });

    afterEach(() => {
      project.cleanup();
    });

    it('should handle async match functions', async () => {
      if (!bunAvailable) return;

      const blockedResult = await project.runAgentrcRunner('Write', 'blocked-async-file.ts');
      expect(blockedResult.exitCode).toBe(2);
      expect(blockedResult.stderr).toContain('ASYNC-RULE');

      const allowedResult = await project.runAgentrcRunner('Write', 'normal-file.ts');
      expect(allowedResult.exitCode).toBe(0);
    });
  });

  describe('hook blocking', () => {
    let project: TestProject;

    beforeEach(() => {
      project = createTestProject('hook-block-test', {
        '.agentrc.ts': `
export default {
  hooks: {
    PreToolUse: ({ filePath, block }) => {
      if (filePath.includes('hook-blocked')) {
        block('Blocked by hook logic');
      }
    },
  },
};
`,
        '.claude': {
          hooks: {
            'agentrc-runner.ts': DEFAULT_RUNNER,
            'agentrc-wrapper.sh': DEFAULT_WRAPPER,
          },
        },
      });
      execSync(`chmod +x "${project.root}/.claude/hooks/agentrc-wrapper.sh"`);
    });

    afterEach(() => {
      project.cleanup();
    });

    it('should block when hook calls block()', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'hook-blocked-file.ts');

      expect(result.exitCode).toBe(2);
      expect(result.stderr).toContain('BLOCKED');
      expect(result.stderr).toContain('Blocked by hook logic');
    });

    it('should allow when hook does not call block()', async () => {
      if (!bunAvailable) return;

      const result = await project.runAgentrcRunner('Write', 'normal-file.ts');

      expect(result.exitCode).toBe(0);
    });
  });
});
