```python
def generate_justification(train: Train, service: Service, context: dict) -> list[str]:
    reasons = []
    
    fleet_avg_km = context['fleet_avg_km']
    km_diff_pct = (train.total_km - fleet_avg_km) / fleet_avg_km * 100
    
    if km_diff_pct < -10:
        reasons.append(f"Km {abs(km_diff_pct):.0f}% abaixo da mГ©dia (prioridade para balanceamento)")
    elif km_diff_pct > 10:
        reasons.append(f"вҡ пёҸ Km {km_diff_pct:.0f}% acima da mГ©dia")
    
    if service.destination_depot_id == train.next_maintenance_depot_id:
        reasons.append("ServiГ§o termina prГіximo ao depot de manutenГ§ГЈo")
    
    if train.days_to_maintenance <= 7:
        reasons.append(f"ManutenГ§ГЈo prevista em {train.days_to_maintenance} dias")
    
    return reasons
```

