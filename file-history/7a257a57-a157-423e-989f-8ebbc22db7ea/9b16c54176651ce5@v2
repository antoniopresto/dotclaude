import { useState, useCallback, type ReactNode } from 'react';
import {
  Button,
  Nav,
  NavItem,
  NavList,
  Label,
  Title,
  Tooltip,
} from '@patternfly/react-core';
import {
  FolderOpenIcon,
  CogIcon,
  BarsIcon,
  TimesIcon,
  AngleDoubleLeftIcon,
  AngleDoubleRightIcon,
  PlusIcon,
  ListIcon,
  TerminalIcon,
} from '@patternfly/react-icons';
import { motion, AnimatePresence } from 'motion/react';
import type { Project } from '../state/store';

interface AppLayoutProps {
  children: ReactNode;
  projects: Project[];
  activeProjectId: string | null;
  isConnected: boolean;
  onSelectProject: (id: string) => void;
  onCloseProject: (id: string) => void;
  onAddProject: () => void;
  onOpenSettings: () => void;
  bottomPanel?: ReactNode;
  showBottomPanel?: boolean;
  onToggleBottomPanel?: () => void;
}

export function AppLayout({
  children,
  projects,
  activeProjectId,
  isConnected,
  onSelectProject,
  onCloseProject,
  onAddProject,
  onOpenSettings,
  bottomPanel,
  showBottomPanel = true,
  onToggleBottomPanel,
}: AppLayoutProps) {
  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);

  const toggleSidebar = useCallback(() => {
    setSidebarCollapsed((prev) => !prev);
  }, []);

  const activeProject = projects.find((p) => p.id === activeProjectId);

  return (
    <div className="app-layout">
      {/* Sidebar */}
      <motion.aside
        className={`app-sidebar ${sidebarCollapsed ? 'collapsed' : ''}`}
        initial={false}
        animate={{ width: sidebarCollapsed ? 48 : 240 }}
        transition={{ type: 'spring', stiffness: 400, damping: 30 }}
      >
        {/* Sidebar Header */}
        <div className="sidebar-header">
          {!sidebarCollapsed && (
            <motion.div
              className="sidebar-brand"
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
            >
              <Title headingLevel="h1" size="lg">HQ</Title>
              <Label
                color={isConnected ? 'green' : 'red'}
                isCompact
              >
                {isConnected ? 'Connected' : 'Offline'}
              </Label>
            </motion.div>
          )}
          <Tooltip content={sidebarCollapsed ? 'Expand sidebar' : 'Collapse sidebar'}>
            <Button
              variant="plain"
              onClick={toggleSidebar}
              className="sidebar-toggle"
              aria-label={sidebarCollapsed ? 'Expand sidebar' : 'Collapse sidebar'}
            >
              {sidebarCollapsed ? <AngleDoubleRightIcon /> : <AngleDoubleLeftIcon />}
            </Button>
          </Tooltip>
        </div>

        {/* Projects Navigation */}
        <div className="sidebar-section">
          {!sidebarCollapsed && (
            <div className="sidebar-section-header">
              <span className="sidebar-section-title">Projects</span>
              <Tooltip content="Open project">
                <Button
                  variant="plain"
                  onClick={onAddProject}
                  aria-label="Open project"
                  isSmall
                >
                  <PlusIcon />
                </Button>
              </Tooltip>
            </div>
          )}
          <Nav aria-label="Projects navigation">
            <NavList>
              {projects.map((project) => (
                <NavItem
                  key={project.id}
                  isActive={project.id === activeProjectId}
                  onClick={() => onSelectProject(project.id)}
                  className="project-nav-item"
                >
                  {sidebarCollapsed ? (
                    <Tooltip content={project.name} position="right">
                      <span className="project-icon">
                        <FolderOpenIcon />
                      </span>
                    </Tooltip>
                  ) : (
                    <div className="project-nav-content">
                      <FolderOpenIcon className="project-folder-icon" />
                      <span className="project-name">{project.name}</span>
                      {projects.length > 1 && (
                        <Button
                          variant="plain"
                          onClick={(e) => {
                            e.stopPropagation();
                            onCloseProject(project.id);
                          }}
                          className="project-close-btn"
                          aria-label={`Close ${project.name}`}
                          isSmall
                        >
                          <TimesIcon />
                        </Button>
                      )}
                    </div>
                  )}
                </NavItem>
              ))}
              {projects.length === 0 && !sidebarCollapsed && (
                <div className="sidebar-empty">
                  <span>No projects open</span>
                </div>
              )}
            </NavList>
          </Nav>
          {sidebarCollapsed && (
            <Tooltip content="Open project" position="right">
              <Button
                variant="plain"
                onClick={onAddProject}
                className="sidebar-action-btn"
                aria-label="Open project"
              >
                <PlusIcon />
              </Button>
            </Tooltip>
          )}
        </div>

        {/* Sidebar Footer */}
        <div className="sidebar-footer">
          {sidebarCollapsed ? (
            <Tooltip content="Settings" position="right">
              <Button
                variant="plain"
                onClick={onOpenSettings}
                className="sidebar-action-btn"
                aria-label="Settings"
              >
                <CogIcon />
              </Button>
            </Tooltip>
          ) : (
            <Button
              variant="plain"
              onClick={onOpenSettings}
              className="sidebar-settings-btn"
            >
              <CogIcon />
              <span>Settings</span>
            </Button>
          )}
        </div>
      </motion.aside>

      {/* Main Content Area */}
      <div className="app-main">
        {/* Main Header - Project info */}
        {activeProject && (
          <header className="main-header">
            <div className="header-left">
              <Title headingLevel="h2" size="lg">{activeProject.name}</Title>
              <span className="header-path">{activeProject.path}</span>
            </div>
            <div className="header-actions">
              {onToggleBottomPanel && (
                <Tooltip content={showBottomPanel ? 'Hide panel' : 'Show panel'}>
                  <Button
                    variant="plain"
                    onClick={onToggleBottomPanel}
                    aria-label={showBottomPanel ? 'Hide panel' : 'Show panel'}
                  >
                    {showBottomPanel ? <AngleDoubleLeftIcon style={{ transform: 'rotate(-90deg)' }} /> : <TerminalIcon />}
                  </Button>
                </Tooltip>
              )}
            </div>
          </header>
        )}

        {/* Main Content */}
        <main className="main-content">
          {children}
        </main>

        {/* Bottom Panel - Logs & Terminal */}
        <AnimatePresence>
          {showBottomPanel && bottomPanel && (
            <motion.div
              className="bottom-panel"
              initial={{ height: 0, opacity: 0 }}
              animate={{ height: 280, opacity: 1 }}
              exit={{ height: 0, opacity: 0 }}
              transition={{ type: 'spring', stiffness: 300, damping: 30 }}
            >
              {bottomPanel}
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </div>
  );
}

export default AppLayout;
