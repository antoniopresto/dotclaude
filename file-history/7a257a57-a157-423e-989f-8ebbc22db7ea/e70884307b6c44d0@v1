/* =============================================================================
   HQ - Minimal CSS Reset

   This file should contain ONLY essential resets that PatternFly doesn't provide.
   All styling MUST use PatternFly components and props.

   DO NOT ADD:
   - Custom classes
   - Inline styles alternatives
   - Layout CSS
   - Spacing CSS
   - Color CSS
   ============================================================================= */

/* Root element setup */
#root {
  min-height: 100vh;
}

/* Prevent overscroll bounce on macOS */
html,
body {
  overscroll-behavior: none;
}
