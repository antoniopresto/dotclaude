import { useState, useCallback } from 'react';
import {
  Card,
  CardBody,
  CardTitle,
  CardExpandableContent,
  CardHeader,
  Label,
  Flex,
  FlexItem,
  List,
  ListItem,
  Icon,
  Button,
  Tooltip,
  Content,
  Stack,
  StackItem,
} from '@patternfly/react-core';
import {
  CheckCircleIcon,
  OutlinedCircleIcon,
  PencilAltIcon,
  TrashIcon,
  PlayIcon,
} from '@patternfly/react-icons';
import type { Feature } from '../state/store';

export type KanbanCardProps = {
  feature: Feature;
  onEdit?: () => void;
  onDelete?: () => void;
  onPlay?: () => void;
  onDragStart?: (e: React.DragEvent) => void;
  draggable?: boolean;
};

const priorityColors: Record<string, 'red' | 'orange' | 'blue' | 'grey'> = {
  critical: 'red',
  high: 'orange',
  medium: 'blue',
  low: 'grey',
};

const categoryColors: Record<string, 'purple' | 'teal' | 'green' | 'grey'> = {
  core: 'purple',
  ui: 'teal',
  setup: 'green',
};

export function KanbanCard({
  feature,
  onEdit,
  onDelete,
  onPlay,
  onDragStart,
  draggable = false,
}: KanbanCardProps) {
  const [isExpanded, setIsExpanded] = useState(false);

  const handleExpand = useCallback(() => {
    setIsExpanded((prev) => !prev);
  }, []);

  const priorityColor = priorityColors[feature.priority] || 'grey';
  const categoryColor = categoryColors[feature.category] || 'grey';

  // Show Play button only for TODO tasks
  const isTodo = feature.status.toLowerCase() === 'todo' || feature.status.toLowerCase() === 'pending';

  return (
    <Card
      id={`kanban-card-${feature.id}`}
      isExpanded={isExpanded}
      isCompact
      draggable={draggable}
      onDragStart={onDragStart}
    >
      <CardHeader
        onExpand={handleExpand}
        isToggleRightAligned
        toggleButtonProps={{
          id: `toggle-${feature.id}`,
          'aria-label': isExpanded ? 'Collapse' : 'Expand',
        }}
        actions={{
          actions: (
            <Flex spaceItems={{ default: 'spaceItemsNone' }}>
              {isTodo && onPlay && (
                <FlexItem>
                  <Tooltip content="Execute task with Claude Code">
                    <Button
                      variant="link"
                      aria-label="Execute task"
                      onClick={(e) => {
                        e.stopPropagation();
                        onPlay();
                      }}
                    >
                      <PlayIcon />
                    </Button>
                  </Tooltip>
                </FlexItem>
              )}
              {onEdit && (
                <FlexItem>
                  <Tooltip content="Edit task">
                    <Button
                      variant="plain"
                      aria-label="Edit task"
                      onClick={(e) => {
                        e.stopPropagation();
                        onEdit();
                      }}
                    >
                      <PencilAltIcon />
                    </Button>
                  </Tooltip>
                </FlexItem>
              )}
              {onDelete && (
                <FlexItem>
                  <Tooltip content="Delete task">
                    <Button
                      variant="plain"
                      aria-label="Delete task"
                      onClick={(e) => {
                        e.stopPropagation();
                        onDelete();
                      }}
                    >
                      <TrashIcon />
                    </Button>
                  </Tooltip>
                </FlexItem>
              )}
            </Flex>
          ),
        }}
      >
        <CardTitle>
          <Stack hasGutter>
            <StackItem>
              <Flex spaceItems={{ default: 'spaceItemsSm' }}>
                <FlexItem>
                  <Label color={feature.passes ? 'green' : 'yellow'} isCompact>
                    {feature.id}
                  </Label>
                </FlexItem>
                <FlexItem>
                  <Label color={priorityColor} isCompact>
                    {feature.priority}
                  </Label>
                </FlexItem>
                <FlexItem>
                  <Label color={categoryColor} isCompact>
                    {feature.category}
                  </Label>
                </FlexItem>
              </Flex>
            </StackItem>
            <StackItem>
              <Content component="small">
                <strong>{feature.description.split(' - ')[0]}</strong>
              </Content>
            </StackItem>
          </Stack>
        </CardTitle>
      </CardHeader>
      <CardExpandableContent>
        <CardBody>
          <Stack hasGutter>
            <StackItem>
              <Content component="p">{feature.description}</Content>
            </StackItem>
            <StackItem>
              <Content component="p"><strong>Steps:</strong></Content>
            </StackItem>
            <StackItem>
              <List isPlain>
                {feature.steps.map((step, idx) => (
                  <ListItem key={idx} icon={<StepIcon passes={feature.passes} />}>
                    {step}
                  </ListItem>
                ))}
              </List>
            </StackItem>
          </Stack>
        </CardBody>
      </CardExpandableContent>
    </Card>
  );
}

function StepIcon({ passes }: { passes: boolean }) {
  if (passes) {
    return (
      <Icon status="success">
        <CheckCircleIcon />
      </Icon>
    );
  }
  return (
    <Icon status="warning">
      <OutlinedCircleIcon />
    </Icon>
  );
}

export default KanbanCard;
