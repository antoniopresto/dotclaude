import {
  Menu,
  MenuContent,
  MenuGroup,
  MenuItem,
  MenuList,
  Flex,
  FlexItem,
  Content,
} from '@patternfly/react-core';
import { useCallback, useEffect, useRef, useState } from 'react';

// =============================================================================
// Types
// =============================================================================

export interface ContextMenuItemConfig {
  id: string;
  label: string;
  icon?: React.ReactNode;
  shortcut?: string;
  disabled?: boolean;
  danger?: boolean;
  onClick?: () => void;
}

export interface ContextMenuGroupConfig {
  id: string;
  label?: string;
  items: ContextMenuItemConfig[];
}

export interface ContextMenuConfig {
  groups: ContextMenuGroupConfig[];
}

interface ContextMenuPosition {
  x: number;
  y: number;
}

interface ContextMenuProps {
  config: ContextMenuConfig;
  isOpen: boolean;
  position: ContextMenuPosition;
  onClose: () => void;
}

// =============================================================================
// Context Menu Hook
// =============================================================================

export interface UseContextMenuReturn {
  isOpen: boolean;
  position: ContextMenuPosition;
  openContextMenu: (event: React.MouseEvent, config?: ContextMenuConfig) => void;
  closeContextMenu: () => void;
  contextMenuProps: {
    isOpen: boolean;
    position: ContextMenuPosition;
    onClose: () => void;
  };
}

export function useContextMenu(): UseContextMenuReturn {
  const [isOpen, setIsOpen] = useState(false);
  const [position, setPosition] = useState<ContextMenuPosition>({ x: 0, y: 0 });

  const openContextMenu = useCallback((event: React.MouseEvent) => {
    event.preventDefault();
    event.stopPropagation();

    // Get viewport dimensions
    const viewportWidth = window.innerWidth;
    const viewportHeight = window.innerHeight;

    // Calculate position, ensuring menu stays within viewport
    // Assume menu is ~200px wide and ~300px max height
    let x = event.clientX;
    let y = event.clientY;

    // Adjust if too close to right edge
    if (x + 200 > viewportWidth) {
      x = viewportWidth - 210;
    }

    // Adjust if too close to bottom edge
    if (y + 300 > viewportHeight) {
      y = viewportHeight - 310;
    }

    setPosition({ x, y });
    setIsOpen(true);
  }, []);

  const closeContextMenu = useCallback(() => {
    setIsOpen(false);
  }, []);

  return {
    isOpen,
    position,
    openContextMenu,
    closeContextMenu,
    contextMenuProps: {
      isOpen,
      position,
      onClose: closeContextMenu,
    },
  };
}

// =============================================================================
// Shortcut Display Component
// =============================================================================

function ShortcutDisplay({ shortcut }: { shortcut: string }) {
  // Convert shortcuts to macOS symbols
  const formatted = shortcut
    .replace(/Cmd\+/g, '⌘')
    .replace(/Ctrl\+/g, '⌃')
    .replace(/Alt\+/g, '⌥')
    .replace(/Shift\+/g, '⇧')
    .replace(/Enter/g, '↵')
    .replace(/Backspace/g, '⌫')
    .replace(/Delete/g, '⌦')
    .replace(/Escape/g, '⎋')
    .replace(/Tab/g, '⇥');

  return (
    <Content component="small">
      <code>{formatted}</code>
    </Content>
  );
}

// =============================================================================
// Context Menu Component
// =============================================================================

export function ContextMenu({ config, isOpen, position, onClose }: ContextMenuProps) {
  const menuRef = useRef<HTMLDivElement>(null);

  // Handle click outside
  useEffect(() => {
    if (!isOpen) return;

    const handleClickOutside = (event: MouseEvent) => {
      if (menuRef.current && !menuRef.current.contains(event.target as Node)) {
        onClose();
      }
    };

    const handleEscape = (event: KeyboardEvent) => {
      if (event.key === 'Escape') {
        onClose();
      }
    };

    // Add listeners with a slight delay to avoid immediate close
    const timeoutId = setTimeout(() => {
      document.addEventListener('mousedown', handleClickOutside);
      document.addEventListener('keydown', handleEscape);
    }, 0);

    return () => {
      clearTimeout(timeoutId);
      document.removeEventListener('mousedown', handleClickOutside);
      document.removeEventListener('keydown', handleEscape);
    };
  }, [isOpen, onClose]);

  // Handle menu item click
  const handleItemClick = useCallback(
    (item: ContextMenuItemConfig) => {
      if (item.disabled) return;
      item.onClick?.();
      onClose();
    },
    [onClose]
  );

  if (!isOpen) return null;

  // Use PatternFly's Popper pattern - position is still needed for context menus
  // The menu positioning is inherent to context menu behavior
  return (
    <div
      ref={menuRef}
      className="pf-v6-c-menu pf-m-plain context-menu-container"
      data-popper-placement="bottom-start"
    >
      <Menu isPlain>
        <MenuContent>
          {config.groups.map((group) => (
            <MenuGroup
              key={group.id}
              label={group.label}
            >
              <MenuList>
                {group.items.map((item) => (
                  <MenuItem
                    key={item.id}
                    isDisabled={item.disabled}
                    isDanger={item.danger}
                    onClick={() => handleItemClick(item)}
                    icon={item.icon}
                  >
                    <Flex
                      alignItems={{ default: 'alignItemsCenter' }}
                      justifyContent={{ default: 'justifyContentSpaceBetween' }}
                    >
                      <FlexItem>{item.label}</FlexItem>
                      {item.shortcut && (
                        <FlexItem>
                          <ShortcutDisplay shortcut={item.shortcut} />
                        </FlexItem>
                      )}
                    </Flex>
                  </MenuItem>
                ))}
              </MenuList>
            </MenuGroup>
          ))}
        </MenuContent>
      </Menu>

      <style>{`
        .context-menu-container {
          position: fixed;
          top: ${position.y}px;
          left: ${position.x}px;
          z-index: var(--pf-t--global--z-index--2xl, 9999);
        }
      `}</style>
    </div>
  );
}

