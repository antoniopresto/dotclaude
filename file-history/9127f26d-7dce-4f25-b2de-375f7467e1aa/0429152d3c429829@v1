            "cmd+w": "tab.close",
            "cmd+shift+[": "tab.previous",
            "cmd+shift+]": "tab.next",
            "cmd+,": "settings.open",
            "cmd+k": "commandPalette.open",
            "cmd+\\": "sidebar.toggle",
            "cmd+j": "logs.toggle",
            "cmd+o": "project.open",
            "escape": "modal.close (when: modalOpen)"
