import { rewardsAccountSettingsApi } from '../api';
import {
  RewardsAccountSettings,
  RewardsAccountSettingsDocument,
  RewardsGetAccountSettingsParams,
} from '../models';

export class RewardsAccountSettingsRepository {
  async consultAccountSettings(
    params: RewardsGetAccountSettingsParams
  ): Promise<RewardsAccountSettings> {
    const result = await rewardsAccountSettingsApi.consultAccountSettings(params);
    return result?.value ?? null;
  }

  async upsertAccountSettings(
    document: RewardsAccountSettingsDocument
  ): Promise<RewardsAccountSettingsDocument> {
    return rewardsAccountSettingsApi.upsertAccountSettings(document);
  }
}

export const rewardsAccountSettingsRepository = new RewardsAccountSettingsRepository();
