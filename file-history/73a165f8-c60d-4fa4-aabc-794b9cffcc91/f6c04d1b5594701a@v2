<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Video Downloader</title>
  <link rel="stylesheet" href="./style.css">
</head>
<body>
  <div class="container">
    <header class="header">
      <h1>Video Downloader</h1>
      <p class="subtitle">Download videos for personal use</p>
    </header>

    <main id="main-content">
      <div id="loading" class="loading">
        <div class="spinner"></div>
        <p>Scanning for videos...</p>
      </div>

      <div id="video-list" class="video-list" style="display: none;"></div>

      <div id="no-videos" class="no-videos" style="display: none;">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="23 7 16 12 23 17 23 7"></polygon>
          <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
        </svg>
        <p>No downloadable videos found on this page</p>
        <button id="refresh-btn" class="btn btn-secondary">Scan Again</button>
      </div>

      <div id="error" class="error" style="display: none;">
        <p id="error-message"></p>
        <button id="retry-btn" class="btn btn-secondary">Retry</button>
      </div>
    </main>

    <footer class="footer">
      <p>For personal use and study purposes only</p>
    </footer>
  </div>

  <script type="module" src="./main.ts"></script>
</body>
</html>
