{
  "name": "video-downloader-extension",
  "version": "1.0.0",
  "description": "Chrome extension for downloading videos for personal use and study purposes",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "icons": "node scripts/generate-icons.js",
    "chrome:install": "node scripts/install-chrome.js",
    "chrome:install:clean": "node scripts/install-chrome.js --clean",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "keywords": [
    "chrome-extension",
    "video-downloader",
    "browser-extension",
    "manifest-v3"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/chrome": "^0.0.287",
    "playwright": "^1.57.0",
    "sharp": "^0.33.0",
    "typescript": "^5.7.3",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "wxt": "^0.20.0"
  }
}
