/**
 * KPICard Component
 *
 * Displays key performance indicators in a compact card format.
 * Used in the sidebar or header to show fleet/maintenance statistics.
 */

import React from 'react';
import { Card, Tag, Intent, Icon, ProgressBar } from '@blueprintjs/core';
import type { IconName } from '@blueprintjs/icons';

// =============================================================================
// TYPES
// =============================================================================

export type KPITrend = 'up' | 'down' | 'stable';

export interface KPICardProps {
  /** KPI title/label */
  title: string;
  /** Main value to display */
  value: string | number;
  /** Optional unit suffix */
  unit?: string;
  /** Optional subtitle/description */
  subtitle?: string;
  /** Icon name from BlueprintJS */
  icon?: IconName;
  /** Intent for color coding */
  intent?: Intent;
  /** Trend direction */
  trend?: KPITrend;
  /** Trend percentage change */
  trendValue?: number;
  /** Progress value (0-1) for progress bar */
  progress?: number;
  /** Progress bar intent */
  progressIntent?: Intent;
  /** Compact mode (smaller) */
  compact?: boolean;
  /** Click handler */
  onClick?: () => void;
  /** Additional CSS class */
  className?: string;
}

// =============================================================================
// STYLES
// =============================================================================

const cardStyle: React.CSSProperties = {
  padding: '12px 16px',
  marginBottom: '8px',
  transition: 'all 0.2s ease',
};

const compactCardStyle: React.CSSProperties = {
  ...cardStyle,
  padding: '8px 12px',
  marginBottom: '4px',
};

const headerStyle: React.CSSProperties = {
  display: 'flex',
  alignItems: 'center',
  justifyContent: 'space-between',
  marginBottom: '8px',
};

const titleStyle: React.CSSProperties = {
  fontSize: '12px',
  fontWeight: 500,
  color: '#5c7080',
  textTransform: 'uppercase',
  letterSpacing: '0.5px',
};

const valueContainerStyle: React.CSSProperties = {
  display: 'flex',
  alignItems: 'baseline',
  gap: '4px',
};

const valueStyle: React.CSSProperties = {
  fontSize: '24px',
  fontWeight: 600,
  color: '#182026',
  lineHeight: 1.2,
};

const compactValueStyle: React.CSSProperties = {
  ...valueStyle,
  fontSize: '18px',
};

const unitStyle: React.CSSProperties = {
  fontSize: '14px',
  fontWeight: 400,
  color: '#5c7080',
};

const subtitleStyle: React.CSSProperties = {
  fontSize: '12px',
  color: '#8a9ba8',
  marginTop: '4px',
};

const trendStyle: React.CSSProperties = {
  display: 'flex',
  alignItems: 'center',
  gap: '4px',
  fontSize: '12px',
  fontWeight: 500,
};

// =============================================================================
// HELPERS
// =============================================================================

const getTrendIcon = (trend: KPITrend): IconName => {
  switch (trend) {
    case 'up':
      return 'trending-up';
    case 'down':
      return 'trending-down';
    default:
      return 'minus';
  }
};

const getTrendIntent = (trend: KPITrend): Intent => {
  switch (trend) {
    case 'up':
      return Intent.SUCCESS;
    case 'down':
      return Intent.DANGER;
    default:
      return Intent.NONE;
  }
};

const formatValue = (value: string | number): string => {
  if (typeof value === 'number') {
    if (value >= 1000000) {
      return `${(value / 1000000).toFixed(1)}M`;
    }
    if (value >= 1000) {
      return `${(value / 1000).toFixed(1)}K`;
    }
    return value.toLocaleString();
  }
  return value;
};

// =============================================================================
// COMPONENT
// =============================================================================

export const KPICard: React.FC<KPICardProps> = ({
  title,
  value,
  unit,
  subtitle,
  icon,
  intent = Intent.NONE,
  trend,
  trendValue,
  progress,
  progressIntent = Intent.PRIMARY,
  compact = false,
  onClick,
  className,
}) => {
  const formattedValue = formatValue(value);

  return (
    <Card
      style={compact ? compactCardStyle : cardStyle}
      interactive={!!onClick}
      onClick={onClick}
      className={className}
      elevation={onClick ? 1 : 0}
    >
      {/* Header with title and icon */}
      <div style={headerStyle}>
        <span style={titleStyle}>{title}</span>
        {icon && <Icon icon={icon} size={16} intent={intent} />}
      </div>

      {/* Value display */}
      <div style={valueContainerStyle}>
        <span style={compact ? compactValueStyle : valueStyle}>
          {formattedValue}
        </span>
        {unit && <span style={unitStyle}>{unit}</span>}

        {/* Trend indicator */}
        {trend && (
          <Tag
            intent={getTrendIntent(trend)}
            minimal
            style={trendStyle}
          >
            <Icon icon={getTrendIcon(trend)} size={12} />
            {trendValue !== undefined && (
              <span>{trendValue > 0 ? '+' : ''}{trendValue}%</span>
            )}
          </Tag>
        )}
      </div>

      {/* Subtitle */}
      {subtitle && <div style={subtitleStyle}>{subtitle}</div>}

      {/* Progress bar */}
      {progress !== undefined && (
        <ProgressBar
          value={progress}
          intent={progressIntent}
          stripes={false}
          animate={false}
          style={{ marginTop: '8px', height: '4px' }}
        />
      )}
    </Card>
  );
};

// =============================================================================
// PRESET KPIS
// =============================================================================

export interface FleetKPIProps {
  totalTrains: number;
  operational: number;
  inMaintenance: number;
  onClick?: () => void;
}

export const FleetAvailabilityKPI: React.FC<FleetKPIProps> = ({
  totalTrains,
  operational,
  inMaintenance,
  onClick,
}) => {
  const availability = (operational / totalTrains) * 100;
  const progressIntent =
    availability >= 95 ? Intent.SUCCESS :
    availability >= 90 ? Intent.WARNING :
    Intent.DANGER;

  return (
    <KPICard
      title="Fleet Availability"
      value={availability.toFixed(1)}
      unit="%"
      icon="train"
      intent={progressIntent}
      subtitle={`${operational} operational, ${inMaintenance} in maintenance`}
      progress={availability / 100}
      progressIntent={progressIntent}
      onClick={onClick}
    />
  );
};

export interface MaintenanceKPIProps {
  completedTasks: number;
  totalTasks: number;
  overdueTasks: number;
  onClick?: () => void;
}

export const MaintenanceComplianceKPI: React.FC<MaintenanceKPIProps> = ({
  completedTasks,
  totalTasks,
  overdueTasks,
  onClick,
}) => {
  const compliance = (completedTasks / totalTasks) * 100;
  const trend: KPITrend = overdueTasks > 0 ? 'down' : 'stable';

  return (
    <KPICard
      title="Maintenance Compliance"
      value={compliance.toFixed(1)}
      unit="%"
      icon="tick-circle"
      intent={overdueTasks > 0 ? Intent.WARNING : Intent.SUCCESS}
      trend={trend}
      trendValue={overdueTasks > 0 ? -overdueTasks : undefined}
      subtitle={`${completedTasks}/${totalTasks} tasks completed`}
      progress={compliance / 100}
      progressIntent={overdueTasks > 0 ? Intent.WARNING : Intent.SUCCESS}
      onClick={onClick}
    />
  );
};

export interface CostKPIProps {
  actualCost: number;
  budgetCost: number;
  currency?: string;
  onClick?: () => void;
}

export const CostVarianceKPI: React.FC<CostKPIProps> = ({
  actualCost,
  budgetCost,
  currency = 'AED',
  onClick,
}) => {
  const variance = ((actualCost - budgetCost) / budgetCost) * 100;
  const trend: KPITrend = variance > 5 ? 'up' : variance < -5 ? 'down' : 'stable';
  const intent = variance > 10 ? Intent.DANGER : variance > 0 ? Intent.WARNING : Intent.SUCCESS;

  return (
    <KPICard
      title="Cost vs Budget"
      value={actualCost}
      unit={currency}
      icon="dollar"
      intent={intent}
      trend={trend}
      trendValue={Math.round(variance)}
      subtitle={`Budget: ${formatValue(budgetCost)} ${currency}`}
      onClick={onClick}
    />
  );
};

export default KPICard;
