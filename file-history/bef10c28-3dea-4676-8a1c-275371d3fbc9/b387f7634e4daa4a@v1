type Story = StoryObj<typeof GestureRecognizerDemo>;

export const Default: Story = {};

export const NoMomentum: Story = {
  render: () => {
    const [viewport, setViewport] = useState<ViewportState>({ x: 0, y: 0, zoom: 1 });
    const containerRef = useRef<HTMLDivElement>(null);
    const [dimensions, setDimensions] = useState({ width: 800, height: 600 });

    useEffect(() => {
      const updateDimensions = () => {
        if (containerRef.current) {
          setDimensions({
            width: containerRef.current.clientWidth,
            height: containerRef.current.clientHeight,
          });
        }
      };
      updateDimensions();
      window.addEventListener('resize', updateDimensions);
      return () => window.removeEventListener('resize', updateDimensions);
    }, []);

    const bind = useGesture({
      onDrag: ({ movement: [mx, my], memo }) => {
        const initial = memo ?? { x: viewport.x, y: viewport.y };
        setViewport((prev) => ({
          ...prev,
          x: initial.x + mx / prev.zoom,
          y: initial.y + my / prev.zoom,
        }));
        return initial;
      },
      onWheel: ({ delta: [, dy], event }) => {
        event.preventDefault();
        setViewport((prev) => ({
          ...prev,
          zoom: clamp(prev.zoom * (1 - dy * 0.002), 0.1, 10),
        }));
      },
    });

    return (
      <div
        ref={containerRef}
        {...bind()}
        style={{
          width: '100%',
          height: '100vh',
          position: 'relative',
          background: COLORS.bg.secondary,
          overflow: 'hidden',
          cursor: 'grab',
          touchAction: 'none',
        }}
      >
        <Grid viewport={viewport} width={dimensions.width} height={dimensions.height} />
        <Card style={{ position: 'absolute', top: 10, left: 10, padding: 8 }}>
          <Tag intent={Intent.WARNING}>No Momentum Mode</Tag>
          <div style={{ fontSize: 10, marginTop: 4, color: COLORS.text.secondary }}>
            Pan stops immediately on release
          </div>
        </Card>
      </div>
    );
  },
};

export const HighFriction: Story = {
  render: () => {
    const [viewport, setViewport] = useState<ViewportState>({ x: 0, y: 0, zoom: 1 });
    const momentumRef = useRef<MomentumState>({ vx: 0, vy: 0, active: false });
    const [momentum, setMomentum] = useState<MomentumState>({ vx: 0, vy: 0, active: false });
    const containerRef = useRef<HTMLDivElement>(null);
    const [dimensions, setDimensions] = useState({ width: 800, height: 600 });

    const friction = 0.85; // High friction = quick stop

    useEffect(() => {
      const updateDimensions = () => {
        if (containerRef.current) {
          setDimensions({
            width: containerRef.current.clientWidth,
            height: containerRef.current.clientHeight,
          });
        }
      };
      updateDimensions();
      window.addEventListener('resize', updateDimensions);
      return () => window.removeEventListener('resize', updateDimensions);
    }, []);

    useEffect(() => {
      let animationFrame: number;
      const animate = () => {
        const m = momentumRef.current;
        if (m.active && (Math.abs(m.vx) > 0.1 || Math.abs(m.vy) > 0.1)) {
          setViewport((prev) => ({
            ...prev,
            x: prev.x + m.vx,
            y: prev.y + m.vy,
          }));
          m.vx *= friction;
          m.vy *= friction;
          setMomentum({ ...m });
          animationFrame = requestAnimationFrame(animate);
        } else {
          m.active = false;
          setMomentum({ ...m });
        }
      };
      if (momentumRef.current.active) {
        animationFrame = requestAnimationFrame(animate);
      }
      return () => cancelAnimationFrame(animationFrame);
    }, [momentum.active]);

    const bind = useGesture({
      onDrag: ({ movement: [mx, my], velocity: [vx, vy], down, memo }) => {
        if (down) momentumRef.current.active = false;
        const initial = memo ?? { x: viewport.x, y: viewport.y };
        setViewport((prev) => ({
          ...prev,
          x: initial.x + mx / prev.zoom,
          y: initial.y + my / prev.zoom,
        }));
        if (!down && (Math.abs(vx) > 0.5 || Math.abs(vy) > 0.5)) {
          momentumRef.current = { vx: vx * 10 / viewport.zoom, vy: vy * 10 / viewport.zoom, active: true };
          setMomentum(momentumRef.current);
        }
        return initial;
      },
      onWheel: ({ delta: [, dy], event }) => {
        event.preventDefault();
        setViewport((prev) => ({
          ...prev,
          zoom: clamp(prev.zoom * (1 - dy * 0.002), 0.1, 10),
        }));
      },
    });

    return (
      <div
        ref={containerRef}
        {...bind()}
        style={{
          width: '100%',
          height: '100vh',
          position: 'relative',
          background: COLORS.bg.secondary,
          overflow: 'hidden',
          cursor: 'grab',
          touchAction: 'none',
        }}
      >
        <Grid viewport={viewport} width={dimensions.width} height={dimensions.height} />
        <Card style={{ position: 'absolute', top: 10, left: 10, padding: 8 }}>
          <Tag intent={Intent.PRIMARY}>High Friction (0.85)</Tag>
          <div style={{ fontSize: 10, marginTop: 4, color: COLORS.text.secondary }}>
            Momentum decays quickly
          </div>
        </Card>
      </div>
    );
  },
};
