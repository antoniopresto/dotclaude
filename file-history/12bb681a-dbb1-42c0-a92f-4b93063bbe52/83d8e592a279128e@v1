### 9.2 Train Entity

```typescript
interface Train {
  id: string;                    // "ALT-001" or "KNK-001"
  type: 'ALSTOM' | 'KINKI';
  name: string;
  depot: 'AL_RASHIDIYA' | 'JEBEL_ALI';
