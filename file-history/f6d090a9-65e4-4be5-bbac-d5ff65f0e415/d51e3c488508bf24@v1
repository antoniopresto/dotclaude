{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat | ~/.claude/hooks/block-forbidden-packages.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "cat | ~/.claude/hooks/block-forbidden-imports.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cat | ~/.claude/hooks/block-forbidden-imports.sh"
          }
        ]
      }
    ]
  }
}
