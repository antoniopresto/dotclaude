#!/bin/bash
# HOOK: PostToolUse:Write, PostToolUse:Edit
# PURPOSE: Block writing files that import forbidden packages
# EXIT 2 = BLOCK action

FORBIDDEN_IMPORTS=(
    "@blueprintjs"
    "@zazcart"
    "from 'xstate'"
    "from \"xstate\""
    "from 'next"
    "from \"next"
    "from 'zustand'"
    "from \"zustand\""
    "from 'redux'"
    "from \"redux\""
    "from 'mobx'"
    "from \"mobx\""
)

# Read the file content from stdin
INPUT=$(cat)

for import in "${FORBIDDEN_IMPORTS[@]}"; do
    if echo "$INPUT" | grep -qF "$import"; then
        echo "BLOCKED: Attempted to write file with forbidden import: $import" >&2
        echo "" >&2
        echo "FORBIDDEN IMPORTS:" >&2
        echo "  - @blueprintjs/* → use @patternfly/react-core" >&2
        echo "  - @zazcart/* → doesn't exist on npm" >&2
        echo "  - xstate → over-engineered for this use case" >&2
        echo "  - next → need SPA, not SSR" >&2
        echo "  - zustand/redux/mobx → use @belt/tools" >&2
        echo "" >&2
        echo "This hook exists because AI hallucinated these imports in previous attempts." >&2
        exit 2
    fi
done

exit 0
