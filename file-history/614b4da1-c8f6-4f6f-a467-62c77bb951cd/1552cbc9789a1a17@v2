import { HTMLTable, Tag, Intent } from "@blueprintjs/core";
import { generateFleet, TOTAL_FLEET } from "../lib/demo-data";
import { useMemo } from "react";

export function FleetTable() {
  const fleet = useMemo(() => generateFleet(TOTAL_FLEET), []);

  return (
    <div style={{ overflowX: "auto" }}>
      <HTMLTable striped interactive style={{ width: "100%" }}>
        <thead>
          <tr>
            <th>Train ID</th>
            <th>Fleet</th>
            <th>Cars</th>
            <th>Current Mileage</th>
            <th>Avg Daily (km)</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {fleet.map((asset) => (
            <tr key={asset.id}>
              <td><strong>{asset.id}</strong></td>
              <td>
                <Tag intent={asset.assetType === "ALSTOM" ? Intent.PRIMARY : Intent.SUCCESS}>
                  {asset.assetType === "ALSTOM" ? "Alstom" : "Kinki Sharyo"}
                </Tag>
              </td>
              <td>{asset.carsCount}</td>
              <td>{asset.currentMileageKm.toLocaleString()} km</td>
              <td>{asset.avgDailyMileageKm} km</td>
              <td>
                <Tag intent={Intent.SUCCESS} minimal>
                  Operational
                </Tag>
              </td>
            </tr>
          ))}
        </tbody>
      </HTMLTable>
    </div>
  );
}
