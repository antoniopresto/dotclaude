          </div>

          <div style={{ fontSize: 11, color: '#666' }}>
            <div>Visible Tasks: {demoTasks.length.toLocaleString()}</div>
            <div>Year: 2030</div>
          </div>
        </Card>

        {/* Hover info */}
        {hoveredTask && (
          <div
            style={{
              position: 'absolute',
              bottom: 16,
              left: 16,
              background: 'white',
              padding: 12,
              borderRadius: 8,
              boxShadow: '0 2px 8px rgba(0,0,0,0.15)',
              fontSize: 12,
            }}
          >
            <div style={{ fontWeight: 600 }}>{hoveredTask.name}</div>
            <div style={{ color: '#666' }}>{hoveredTask.trainId} • {hoveredTask.durationHours}h</div>
          </div>
        )}
      </div>
    );
  },
};

export const ConflictHighlight: Story = {
  name: 'Conflict Highlight',
  render: () => {
    const [hoveredTask, setHoveredTask] = useState<Task | null>(null);
    const [showOnlyConflicts, setShowOnlyConflicts] = useState(false);

    // Filter for conflict tasks if needed
    const displayTasks = useMemo(() => {
      if (showOnlyConflicts) {
        return demoTasks.filter(t => t.hasConflict);
      }
      return demoTasks;
    }, [showOnlyConflicts]);

    const conflictCount = demoTasks.filter(t => t.hasConflict).length;

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f8fafc' }}>
        <OperationalLayer
          tasks={displayTasks}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight}
          cameraX={2300}
          zoom={1.5}
          hoveredTaskId={hoveredTask?.id}
          onTaskHover={setHoveredTask}
        />

        {/* Conflict filter */}
        <Card
          style={{
            position: 'absolute',
            top: 16,
            left: '50%',
            transform: 'translateX(-50%)',
            padding: 12,
          }}
        >
          <div style={{ display: 'flex', alignItems: 'center', gap: 16 }}>
            <div>
              <Tag intent={Intent.DANGER} large>
                {conflictCount} Conflicts
              </Tag>
            </div>
            <ButtonGroup>
              <Button
                active={!showOnlyConflicts}
                onClick={() => setShowOnlyConflicts(false)}
              >
                All Tasks
              </Button>
              <Button
                active={showOnlyConflicts}
                onClick={() => setShowOnlyConflicts(true)}
                intent={showOnlyConflicts ? Intent.DANGER : Intent.NONE}
              >
                Conflicts Only
              </Button>
            </ButtonGroup>
          </div>
        </Card>

        {/* Conflict info */}
        {hoveredTask?.hasConflict && (
          <Card
            style={{
              position: 'absolute',
              bottom: 16,
              left: 16,
              padding: 12,
              background: '#fef2f2',
              border: '1px solid #fecaca',
            }}
          >
            <div style={{ color: '#991b1b', fontWeight: 600 }}>
              ⚠️ Conflict Detected
            </div>
            <div style={{ marginTop: 8, fontSize: 12 }}>
              <div>{hoveredTask.name}</div>
              <div>{hoveredTask.trainId}</div>
              <div>{hoveredTask.startDate.toLocaleDateString()} - {hoveredTask.endDate.toLocaleDateString()}</div>
            </div>
          </Card>
        )}
      </div>
    );
  },
};

export const TaskDensity: Story = {
  name: 'Task Density View',
  render: () => {
    const [selectedYear, setSelectedYear] = useState(2027);
    const [hoveredTask, setHoveredTask] = useState<Task | null>(null);

    // Get tasks for selected year
    const yearTasks = useMemo(() => {
      return getTasksInRange(
        mockData,
        new Date(`${selectedYear}-01-01`),
        new Date(`${selectedYear}-12-31`)
      );
    }, [selectedYear]);

    // Calculate stats
    const stats = {
      total: yearTasks.length,
      conflicts: yearTasks.filter(t => t.hasConflict).length,
      manHours: yearTasks.reduce((sum, t) => sum + t.manHours, 0),
      cost: yearTasks.reduce((sum, t) => sum + t.costAed, 0),
    };

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f8fafc' }}>
        <OperationalLayer
          tasks={yearTasks}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight - 100}
          zoom={1.2}
          hoveredTaskId={hoveredTask?.id}
          onTaskHover={setHoveredTask}
          showTodayLine={selectedYear === 2030}
        />

        {/* Year selector */}
        <div
          style={{
            position: 'absolute',
            top: 16,
            left: '50%',
            transform: 'translateX(-50%)',
            background: 'white',
            padding: 12,
            borderRadius: 8,
            boxShadow: '0 2px 8px rgba(0,0,0,0.15)',
            display: 'flex',
            gap: 4,
          }}
        >
          {Array.from({ length: 12 }, (_, i) => 2024 + i).map((year) => (
            <button
              key={year}
              onClick={() => setSelectedYear(year)}
              style={{
                padding: '6px 10px',
                border: selectedYear === year ? '2px solid #1d4ed8' : '1px solid #e2e8f0',
                borderRadius: 4,
                background: selectedYear === year ? '#dbeafe' : 'white',
                cursor: 'pointer',
                fontSize: 12,
                fontWeight: selectedYear === year ? 600 : 400,
              }}
            >
              {year}
            </button>
          ))}
        </div>

        {/* Year stats */}
        <Card
          style={{
            position: 'absolute',
            bottom: 16,
            left: '50%',
            transform: 'translateX(-50)',
            padding: 16,
          }}
        >
          <div style={{ fontWeight: 600, textAlign: 'center', marginBottom: 12 }}>
            {selectedYear} Summary
          </div>
          <div style={{ display: 'flex', gap: 24 }}>
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontSize: 20, fontWeight: 600 }}>{stats.total.toLocaleString()}</div>
              <div style={{ fontSize: 11, color: '#666' }}>Tasks</div>
            </div>
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontSize: 20, fontWeight: 600, color: stats.conflicts > 0 ? '#ef4444' : 'inherit' }}>
                {stats.conflicts}
              </div>
              <div style={{ fontSize: 11, color: '#666' }}>Conflicts</div>
            </div>
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontSize: 20, fontWeight: 600 }}>{(stats.manHours / 1000).toFixed(0)}K</div>
              <div style={{ fontSize: 11, color: '#666' }}>Man-Hours</div>
            </div>
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontSize: 20, fontWeight: 600 }}>{(stats.cost / 1000000).toFixed(1)}M</div>
              <div style={{ fontSize: 11, color: '#666' }}>AED</div>
            </div>
          </div>
        </Card>
      </div>
    );
  },
};
