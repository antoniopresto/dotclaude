/**
 * Operational Layer Stories
 *
 * Demonstrates the DNA-style Gantt view for operational planning.
 * Shows individual tasks as colored blocks on train rows.
 */

import type { Meta, StoryObj } from '@storybook/react';
import React, { useState, useMemo } from 'react';
import { Card, Slider, Tag, Intent, Button, ButtonGroup } from '@blueprintjs/core';
import { OperationalLayer } from './OperationalLayer';
import { generateMockData, getTasksInRange } from '../../data/mock-generator';
import type { Task } from '../../data/mock-generator';

// =============================================================================
// META
// =============================================================================

const meta: Meta<typeof OperationalLayer> = {
  title: '02-Layers/Operational',
  component: OperationalLayer,
  parameters: {
    layout: 'fullscreen',
  },
};

export default meta;
type Story = StoryObj<typeof OperationalLayer>;

// =============================================================================
// MOCK DATA
// =============================================================================

const mockData = generateMockData();

// Get tasks for a specific time range (2030 Q2 for demo)
const demoTasks = getTasksInRange(
  mockData,
  new Date('2030-01-01'),
  new Date('2030-12-31')
);

// =============================================================================
// STORIES
// =============================================================================

export const Default: Story = {
  name: 'Default View',
  render: () => {
    const [hoveredTask, setHoveredTask] = useState<Task | null>(null);
    const [selectedTask, setSelectedTask] = useState<Task | null>(null);

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f8fafc' }}>
        <OperationalLayer
          tasks={demoTasks}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight}
          hoveredTaskId={hoveredTask?.id}
          selectedTaskId={selectedTask?.id}
          onTaskHover={setHoveredTask}
          onTaskClick={setSelectedTask}
          cameraX={2300} // Start near mid-2030
          zoom={1.5}
        />

        {/* Hover tooltip */}
        {hoveredTask && !selectedTask && (
          <div
            style={{
              position: 'absolute',
              top: 16,
              left: 16,
              background: 'white',
              padding: 12,
              borderRadius: 8,
              boxShadow: '0 4px 12px rgba(0,0,0,0.15)',
              fontSize: 12,
              minWidth: 200,
            }}
          >
            <div style={{ fontWeight: 600, marginBottom: 4 }}>{hoveredTask.name}</div>
            <div style={{ color: '#666', fontSize: 11, marginBottom: 8 }}>
              {hoveredTask.trainId}
            </div>
            <div>Status: <Tag minimal intent={
              hoveredTask.status === 'completed' ? Intent.SUCCESS :
              hoveredTask.status === 'in-progress' ? Intent.PRIMARY :
              hoveredTask.status === 'overdue' ? Intent.DANGER :
              Intent.NONE
            }>{hoveredTask.status}</Tag></div>
            <div style={{ marginTop: 4 }}>Duration: {hoveredTask.durationHours}h</div>
            <div>Man-Hours: {hoveredTask.manHours}</div>
            {hoveredTask.hasConflict && (
              <div style={{ color: '#ef4444', marginTop: 4, fontWeight: 500 }}>
                ⚠️ Has Conflict
              </div>
            )}
          </div>
        )}

        {/* Selected task detail */}
        {selectedTask && (
          <Card
            style={{
              position: 'absolute',
              bottom: 16,
              left: 16,
              width: 320,
              padding: 16,
            }}
          >
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'start' }}>
              <div>
                <div style={{ fontWeight: 600, fontSize: 14 }}>{selectedTask.name}</div>
                <div style={{ color: '#666', fontSize: 12 }}>{selectedTask.id}</div>
              </div>
              <Button minimal icon="cross" onClick={() => setSelectedTask(null)} />
            </div>

            <div style={{ marginTop: 12, fontSize: 12 }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
                <span>Train:</span>
                <span style={{ fontWeight: 500 }}>{selectedTask.trainId}</span>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
                <span>Start:</span>
                <span style={{ fontWeight: 500 }}>{selectedTask.startDate.toLocaleDateString()}</span>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
                <span>End:</span>
                <span style={{ fontWeight: 500 }}>{selectedTask.endDate.toLocaleDateString()}</span>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
                <span>Duration:</span>
                <span style={{ fontWeight: 500 }}>{selectedTask.durationHours} hours</span>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
                <span>Man-Hours:</span>
                <span style={{ fontWeight: 500 }}>{selectedTask.manHours}</span>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
                <span>Cost:</span>
                <span style={{ fontWeight: 500 }}>{selectedTask.costAed.toLocaleString()} AED</span>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
                <span>Status:</span>
                <Tag minimal intent={
                  selectedTask.status === 'completed' ? Intent.SUCCESS :
                  selectedTask.status === 'in-progress' ? Intent.PRIMARY :
                  selectedTask.status === 'overdue' ? Intent.DANGER :
                  Intent.NONE
                }>{selectedTask.status}</Tag>
              </div>
              {selectedTask.pitId && (
                <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
                  <span>Pit:</span>
                  <span style={{ fontWeight: 500 }}>#{selectedTask.pitId}</span>
                </div>
              )}
              {selectedTask.hasConflict && (
                <div style={{ marginTop: 8, padding: 8, background: '#fef2f2', borderRadius: 4, color: '#991b1b' }}>
                  ⚠️ This task has a scheduling conflict
                </div>
              )}
            </div>
          </Card>
        )}
      </div>
    );
  },
};

export const WithControls: Story = {
  name: 'With Pan/Zoom Controls',
  render: () => {
    const [cameraX, setCameraX] = useState(2300);
    const [cameraY, setCameraY] = useState(0);
    const [zoom, setZoom] = useState(1.5);
    const [hoveredTask, setHoveredTask] = useState<Task | null>(null);

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f8fafc' }}>
        <OperationalLayer
          tasks={demoTasks}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight - 80}
          cameraX={cameraX}
          cameraY={cameraY}
          zoom={zoom}
          hoveredTaskId={hoveredTask?.id}
          onTaskHover={setHoveredTask}
        />

        {/* Controls */}
        <Card
          style={{
            position: 'absolute',
            top: 16,
            left: 16,
            width: 300,
            padding: 16,
          }}
        >
          <div style={{ marginBottom: 16 }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
              <span style={{ fontWeight: 500, fontSize: 12 }}>Time Position (days)</span>
              <span style={{ fontSize: 11, color: '#666' }}>Day {cameraX}</span>
            </div>
            <Slider
              min={0}
              max={4380}
              stepSize={10}
              value={cameraX}
              onChange={setCameraX}
              labelRenderer={false}
            />
          </div>

          <div style={{ marginBottom: 16 }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
              <span style={{ fontWeight: 500, fontSize: 12 }}>Train Position</span>
              <span style={{ fontSize: 11, color: '#666' }}>Train {Math.floor(cameraY)}</span>
            </div>
            <Slider
              min={0}
              max={128}
              stepSize={1}
              value={cameraY}
              onChange={setCameraY}
              labelRenderer={false}
            />
          </div>

          <div style={{ marginBottom: 16 }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
              <span style={{ fontWeight: 500, fontSize: 12 }}>Zoom</span>
              <Tag
                intent={zoom >= 1.0 && zoom <= 3.0 ? Intent.WARNING : Intent.NONE}
