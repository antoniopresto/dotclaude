export const StatusFilter: Story = {
  name: 'Status Filter',
  render: () => {
    const [statusFilter, setStatusFilter] = useState<string | null>(null);
    const [selectedTask, setSelectedTask] = useState<Task | null>(null);

    const filteredTasks = useMemo(() => {
      if (!statusFilter) return demoTasks;
      return demoTasks.filter(t => t.status === statusFilter);
    }, [statusFilter]);

    // Count tasks by status
    const statusCounts = useMemo(() => ({
      scheduled: demoTasks.filter(t => t.status === 'scheduled').length,
      'in-progress': demoTasks.filter(t => t.status === 'in-progress').length,
      completed: demoTasks.filter(t => t.status === 'completed').length,
      overdue: demoTasks.filter(t => t.status === 'overdue').length,
    }), []);

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f8fafc' }}>
        <ExecutionLayer
          tasks={filteredTasks}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight}
          cameraX={2345}
          zoom={3.5}
          selectedTaskId={selectedTask?.id}
          onTaskClick={setSelectedTask}
        />

        {/* Status filter buttons */}
        <Card
          style={{
            position: 'absolute',
            top: 60,
            left: '50%',
            transform: 'translateX(-50%)',
            padding: 12,
          }}
        >
          <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
            <span style={{ fontWeight: 500, fontSize: 12 }}>Filter by Status:</span>
            <ButtonGroup>
              <Button
                active={statusFilter === null}
                onClick={() => setStatusFilter(null)}
              >
                All ({demoTasks.length})
              </Button>
              <Button
                active={statusFilter === 'scheduled'}
                onClick={() => setStatusFilter('scheduled')}
              >
                Scheduled ({statusCounts.scheduled})
              </Button>
              <Button
                active={statusFilter === 'in-progress'}
                onClick={() => setStatusFilter('in-progress')}
                intent={statusFilter === 'in-progress' ? Intent.PRIMARY : Intent.NONE}
              >
                In Progress ({statusCounts['in-progress']})
              </Button>
              <Button
                active={statusFilter === 'completed'}
                onClick={() => setStatusFilter('completed')}
                intent={statusFilter === 'completed' ? Intent.SUCCESS : Intent.NONE}
              >
                Completed ({statusCounts.completed})
              </Button>
              <Button
                active={statusFilter === 'overdue'}
                onClick={() => setStatusFilter('overdue')}
                intent={statusFilter === 'overdue' ? Intent.DANGER : Intent.NONE}
              >
                Overdue ({statusCounts.overdue})
              </Button>
            </ButtonGroup>
          </div>
        </Card>
      </div>
    );
  },
};

export const WeekView: Story = {
  name: 'Week View',
  render: () => {
    const [selectedWeek, setSelectedWeek] = useState(0);
    const [selectedTask, setSelectedTask] = useState<Task | null>(null);

    // Get tasks for the selected week
    const weekStart = new Date('2030-06-01');
    weekStart.setDate(weekStart.getDate() + selectedWeek * 7);
    const weekEnd = new Date(weekStart);
    weekEnd.setDate(weekEnd.getDate() + 6);

    const weekTasks = useMemo(() => {
      return getTasksInRange(mockData, weekStart, weekEnd);
    }, [selectedWeek]);

    // Calculate week day offset
    const baseDay = 2345; // June 1, 2030
    const cameraX = baseDay + selectedWeek * 7;

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f8fafc' }}>
        <ExecutionLayer
          tasks={weekTasks}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight - 60}
          cameraX={cameraX}
          zoom={4}
          selectedTaskId={selectedTask?.id}
          onTaskClick={setSelectedTask}
        />

        {/* Week selector */}
        <div
          style={{
            position: 'absolute',
            bottom: 0,
            left: 0,
            right: 0,
            height: 60,
            background: 'white',
            borderTop: '1px solid #e2e8f0',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            gap: 8,
          }}
        >
          <Button
            icon="chevron-left"
            minimal
            disabled={selectedWeek <= 0}
            onClick={() => setSelectedWeek(w => w - 1)}
          />

          {Array.from({ length: 5 }, (_, i) => {
            const weekDate = new Date('2030-06-01');
            weekDate.setDate(weekDate.getDate() + i * 7);
            const weekEndDate = new Date(weekDate);
            weekEndDate.setDate(weekEndDate.getDate() + 6);

            return (
              <Button
                key={i}
                active={selectedWeek === i}
                intent={selectedWeek === i ? Intent.PRIMARY : Intent.NONE}
                onClick={() => setSelectedWeek(i)}
                style={{ minWidth: 140 }}
              >
                {weekDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' })} - {weekEndDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' })}
              </Button>
            );
          })}

          <Button
            icon="chevron-right"
            minimal
            disabled={selectedWeek >= 4}
            onClick={() => setSelectedWeek(w => w + 1)}
          />

          <div style={{ marginLeft: 16, fontSize: 12, color: '#666' }}>
            {weekTasks.length} tasks this week
          </div>
        </div>
      </div>
    );
  },
};

export const ResourceView: Story = {
  name: 'Resource Utilization',
  render: () => {
    const [showResources, setShowResources] = useState(true);
    const [selectedTask, setSelectedTask] = useState<Task | null>(null);

    // Calculate resource totals by day
    const resourceByDay = useMemo(() => {
      const days: Record<string, { manHours: number; tasks: number; cost: number }> = {};

      demoTasks.forEach(task => {
        const dateKey = task.startDate.toISOString().split('T')[0];
        if (!days[dateKey]) {
          days[dateKey] = { manHours: 0, tasks: 0, cost: 0 };
        }
        days[dateKey].manHours += task.manHours;
        days[dateKey].tasks += 1;
        days[dateKey].cost += task.costAed;
      });

      return days;
    }, []);

    const totalManHours = demoTasks.reduce((sum, t) => sum + t.manHours, 0);
    const totalCost = demoTasks.reduce((sum, t) => sum + t.costAed, 0);
    const conflictTasks = demoTasks.filter(t => t.hasConflict).length;

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f8fafc' }}>
        <ExecutionLayer
          tasks={demoTasks}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight}
          cameraX={2345}
          zoom={3.5}
          showResources={showResources}
          selectedTaskId={selectedTask?.id}
          onTaskClick={setSelectedTask}
        />

        {/* Resource summary */}
        <Card
          style={{
            position: 'absolute',
            top: 60,
            left: 116,
            padding: 16,
            minWidth: 250,
          }}
        >
          <div style={{ fontWeight: 600, marginBottom: 12 }}>
            Resource Summary - June 2030
          </div>

          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
            <div style={{ textAlign: 'center', padding: 8, background: '#f0f9ff', borderRadius: 4 }}>
              <div style={{ fontSize: 20, fontWeight: 600, color: '#0369a1' }}>
                {demoTasks.length}
              </div>
              <div style={{ fontSize: 10, color: '#666' }}>Total Tasks</div>
            </div>

            <div style={{ textAlign: 'center', padding: 8, background: '#f0fdf4', borderRadius: 4 }}>
              <div style={{ fontSize: 20, fontWeight: 600, color: '#15803d' }}>
                {(totalManHours / 1000).toFixed(1)}K
              </div>
              <div style={{ fontSize: 10, color: '#666' }}>Man-Hours</div>
            </div>

            <div style={{ textAlign: 'center', padding: 8, background: '#fefce8', borderRadius: 4 }}>
              <div style={{ fontSize: 20, fontWeight: 600, color: '#a16207' }}>
                {(totalCost / 1000000).toFixed(2)}M
              </div>
              <div style={{ fontSize: 10, color: '#666' }}>AED Cost</div>
            </div>

            <div style={{ textAlign: 'center', padding: 8, background: conflictTasks > 0 ? '#fef2f2' : '#f0f9ff', borderRadius: 4 }}>
              <div style={{ fontSize: 20, fontWeight: 600, color: conflictTasks > 0 ? '#dc2626' : '#0369a1' }}>
                {conflictTasks}
              </div>
              <div style={{ fontSize: 10, color: '#666' }}>Conflicts</div>
            </div>
          </div>

          <div style={{ marginTop: 12 }}>
            <Button
              small
              fill
              icon={showResources ? 'eye-open' : 'eye-off'}
              onClick={() => setShowResources(!showResources)}
            >
              {showResources ? 'Hide' : 'Show'} Resource Details
            </Button>
          </div>
        </Card>
      </div>
    );
  },
};
