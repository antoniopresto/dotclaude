/**
 * TimelineHeader Component
 *
 * Adaptive timeline header that shows different granularity based on zoom level.
 * - Strategic: Years
 * - Tactical: Quarters
 * - Operational: Months
 * - Execution: Weeks/Days
 */

import React, { useMemo } from 'react';
import { TIME_RANGE, COLORS } from '../../data/mock-config';

// =============================================================================
// TYPES
// =============================================================================

export type TimelineGranularity = 'years' | 'quarters' | 'months' | 'weeks' | 'days';

export interface TimelineHeaderProps {
  /** Start date of visible range */
  startDate: Date;
  /** End date of visible range */
  endDate: Date;
  /** Width of the header in pixels */
  width: number;
  /** Height of the header */
  height?: number;
  /** Granularity level */
  granularity: TimelineGranularity;
  /** Pixels per day for positioning */
  pxPerDay: number;
  /** X offset from viewport */
  offsetX?: number;
  /** Show sub-labels (e.g., months under years) */
  showSubLabels?: boolean;
  /** Opacity for transitions */
  opacity?: number;
}

interface TimeMarker {
  label: string;
  subLabel?: string;
  x: number;
  width: number;
  isMinor?: boolean;
}

// =============================================================================
// STYLES
// =============================================================================

const containerStyle: React.CSSProperties = {
  position: 'relative',
  backgroundColor: '#f8fafc',
  borderBottom: '1px solid #e2e8f0',
  overflow: 'hidden',
  fontFamily: 'system-ui, -apple-system, sans-serif',
};

const markerStyle: React.CSSProperties = {
  position: 'absolute',
  top: 0,
  display: 'flex',
  flexDirection: 'column',
  justifyContent: 'center',
  alignItems: 'center',
  borderRight: '1px solid #e2e8f0',
  boxSizing: 'border-box',
};

const labelStyle: React.CSSProperties = {
  fontSize: '13px',
  fontWeight: 600,
  color: '#334155',
};

const subLabelStyle: React.CSSProperties = {
  fontSize: '10px',
  fontWeight: 400,
  color: '#94a3b8',
  marginTop: '2px',
};

const minorLabelStyle: React.CSSProperties = {
  fontSize: '11px',
  fontWeight: 500,
  color: '#64748b',
};

// =============================================================================
// HELPERS
// =============================================================================

const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const MONTHS_FULL = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

function daysBetween(start: Date, end: Date): number {
  return Math.floor((end.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}

function addDays(date: Date, days: number): Date {
  const result = new Date(date);
  result.setDate(result.getDate() + days);
  return result;
}

function getQuarterLabel(quarter: number): string {
  return `Q${quarter + 1}`;
}

function getWeekNumber(date: Date): number {
  const start = new Date(date.getFullYear(), 0, 1);
  const diff = date.getTime() - start.getTime();
  return Math.ceil((diff / (1000 * 60 * 60 * 24) + start.getDay() + 1) / 7);
}

// =============================================================================
// MARKER GENERATORS
// =============================================================================

function generateYearMarkers(
  startDate: Date,
  endDate: Date,
  pxPerDay: number,
  offsetX: number
): TimeMarker[] {
  const markers: TimeMarker[] = [];
  const startYear = startDate.getFullYear();
  const endYear = endDate.getFullYear();

  for (let year = startYear; year <= endYear; year++) {
    const yearStart = new Date(year, 0, 1);
    const yearEnd = new Date(year + 1, 0, 1);

    const startDays = Math.max(0, daysBetween(startDate, yearStart));
    const endDays = daysBetween(startDate, yearEnd);
    const x = startDays * pxPerDay - offsetX;
    const width = (endDays - startDays) * pxPerDay;

    if (x + width > 0) {
      markers.push({
        label: String(year),
        x: Math.max(0, x),
        width: width - Math.max(0, -x),
      });
    }
  }

  return markers;
}

function generateQuarterMarkers(
  startDate: Date,
  endDate: Date,
  pxPerDay: number,
  offsetX: number
): TimeMarker[] {
  const markers: TimeMarker[] = [];
  const current = new Date(startDate.getFullYear(), Math.floor(startDate.getMonth() / 3) * 3, 1);

  while (current <= endDate) {
    const year = current.getFullYear();
    const quarter = Math.floor(current.getMonth() / 3);
    const quarterStart = new Date(year, quarter * 3, 1);
    const quarterEnd = new Date(year, (quarter + 1) * 3, 1);

    const startDays = daysBetween(startDate, quarterStart);
    const endDays = daysBetween(startDate, quarterEnd);
    const x = startDays * pxPerDay - offsetX;
    const width = (endDays - startDays) * pxPerDay;

    if (x + width > 0 && x < 10000) {
      markers.push({
        label: getQuarterLabel(quarter),
        subLabel: String(year),
        x: Math.max(0, x),
        width: width - Math.max(0, -x),
      });
    }

    current.setMonth(current.getMonth() + 3);
  }

  return markers;
}

function generateMonthMarkers(
  startDate: Date,
  endDate: Date,
  pxPerDay: number,
  offsetX: number
): TimeMarker[] {
  const markers: TimeMarker[] = [];
  const current = new Date(startDate.getFullYear(), startDate.getMonth(), 1);

  while (current <= endDate) {
    const monthStart = new Date(current);
    const monthEnd = new Date(current.getFullYear(), current.getMonth() + 1, 1);

    const startDays = daysBetween(startDate, monthStart);
    const endDays = daysBetween(startDate, monthEnd);
    const x = startDays * pxPerDay - offsetX;
    const width = (endDays - startDays) * pxPerDay;

    if (x + width > 0 && x < 10000) {
      markers.push({
        label: MONTHS[current.getMonth()],
        subLabel: String(current.getFullYear()),
        x: Math.max(0, x),
        width: width - Math.max(0, -x),
        isMinor: current.getMonth() !== 0, // January is major
      });
    }

    current.setMonth(current.getMonth() + 1);
  }

  return markers;
}

function generateWeekMarkers(
  startDate: Date,
  endDate: Date,
  pxPerDay: number,
  offsetX: number
): TimeMarker[] {
  const markers: TimeMarker[] = [];
  // Start from the beginning of the week containing startDate
  const current = new Date(startDate);
  current.setDate(current.getDate() - current.getDay()); // Go to Sunday

  while (current <= endDate) {
    const weekStart = new Date(current);
    const weekEnd = addDays(current, 7);

    const startDays = daysBetween(startDate, weekStart);
    const endDays = daysBetween(startDate, weekEnd);
    const x = startDays * pxPerDay - offsetX;
    const width = (endDays - startDays) * pxPerDay;

    if (x + width > 0 && x < 10000) {
      markers.push({
        label: `W${getWeekNumber(weekStart)}`,
        subLabel: `${MONTHS[weekStart.getMonth()]} ${weekStart.getDate()}`,
        x: Math.max(0, x),
        width: width - Math.max(0, -x),
      });
    }

    current.setDate(current.getDate() + 7);
  }

  return markers;
}

function generateDayMarkers(
  startDate: Date,
  endDate: Date,
  pxPerDay: number,
  offsetX: number
): TimeMarker[] {
  const markers: TimeMarker[] = [];
  const current = new Date(startDate);

  const maxDays = Math.min(daysBetween(startDate, endDate), 60); // Limit to 60 days

  for (let i = 0; i <= maxDays; i++) {
    const x = i * pxPerDay - offsetX;

    if (x + pxPerDay > 0 && x < 10000) {
      const dayOfWeek = current.getDay();
      markers.push({
        label: String(current.getDate()),
        subLabel: MONTHS[current.getMonth()],
        x: Math.max(0, x),
        width: pxPerDay,
        isMinor: dayOfWeek !== 0 && dayOfWeek !== 1, // Sunday and Monday are major
      });
    }

    current.setDate(current.getDate() + 1);
  }

  return markers;
}

// =============================================================================
// COMPONENT
// =============================================================================

export const TimelineHeader: React.FC<TimelineHeaderProps> = ({
  startDate,
  endDate,
  width,
  height = 48,
  granularity,
  pxPerDay,
  offsetX = 0,
  showSubLabels = true,
  opacity = 1,
}) => {
  const markers = useMemo(() => {
    switch (granularity) {
      case 'years':
        return generateYearMarkers(startDate, endDate, pxPerDay, offsetX);
      case 'quarters':
        return generateQuarterMarkers(startDate, endDate, pxPerDay, offsetX);
      case 'months':
        return generateMonthMarkers(startDate, endDate, pxPerDay, offsetX);
      case 'weeks':
        return generateWeekMarkers(startDate, endDate, pxPerDay, offsetX);
      case 'days':
        return generateDayMarkers(startDate, endDate, pxPerDay, offsetX);
      default:
        return [];
    }
  }, [startDate, endDate, granularity, pxPerDay, offsetX]);

  return (
    <div
      style={{
        ...containerStyle,
        width,
        height,
        opacity,
      }}
    >
      {markers.map((marker, index) => (
        <div
          key={`${granularity}-${index}`}
          style={{
            ...markerStyle,
            left: marker.x,
            width: marker.width,
            height,
            backgroundColor: marker.isMinor ? 'transparent' : 'rgba(248,250,252,0.5)',
          }}
        >
          <span style={marker.isMinor ? minorLabelStyle : labelStyle}>
            {marker.label}
          </span>
          {showSubLabels && marker.subLabel && (
            <span style={subLabelStyle}>{marker.subLabel}</span>
          )}
        </div>
      ))}
    </div>
  );
};

// =============================================================================
// GRANULARITY SELECTOR
// =============================================================================

export function getGranularityForZoom(zoom: number): TimelineGranularity {
  if (zoom < 0.3) return 'years';
  if (zoom < 1.0) return 'quarters';
  if (zoom < 3.0) return 'months';
  if (zoom < 8.0) return 'weeks';
  return 'days';
}

export default TimelineHeader;
