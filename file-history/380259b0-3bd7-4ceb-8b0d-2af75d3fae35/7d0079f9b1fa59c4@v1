export const PerformanceTest: Story = {
  render: () => {
    const [frameTime, setFrameTime] = useState(0);
    const mockData = useMemo(() => generateMockData(), []);

    const cellData = useMemo(() => {
      const start = performance.now();
      const data = mockData.aggregatedByQuarter.map((cell) => ({
        ...cell,
        polygon: createCellPolygon(cell),
        color: getUtilizationColor(cell.utilizationPercent, cell.hasOverhaul),
      }));
      setFrameTime(performance.now() - start);
      return data;
    }, [mockData]);

    const layers = useMemo(() => {
      return [
        new SolidPolygonLayer({
          id: 'heatmap-cells',
          data: cellData,
          getPolygon: (d) => d.polygon,
          getFillColor: (d) => d.color,
          pickable: true,
          extruded: false,
        }),
      ];
    }, [cellData]);

    return (
      <div style={{ width: '100%', height: '100vh', position: 'relative' }}>
        <DeckGL
          views={new OrthographicView({ id: 'main' })}
          initialViewState={{ target: [GRID_WIDTH / 2, GRID_HEIGHT / 2], zoom: 0 }}
          controller={true}
          layers={layers}
        />
        <Card style={{ position: 'absolute', top: 10, left: 10, padding: 12 }}>
          <div style={{ fontWeight: 600, marginBottom: 8 }}>Performance Metrics</div>
          <div style={{ fontSize: 12, display: 'grid', gridTemplateColumns: 'auto auto', gap: '4px 16px' }}>
            <span>Cell Count:</span>
            <strong>{cellData.length.toLocaleString()}</strong>
            <span>Data Prep Time:</span>
            <Tag intent={frameTime < 100 ? Intent.SUCCESS : Intent.WARNING}>
              {frameTime.toFixed(1)}ms
            </Tag>
            <span>Render Mode:</span>
            <Tag intent={Intent.PRIMARY}>WebGL</Tag>
          </div>
        </Card>
      </div>
    );
  },
};
