import { generateMockData, type AggregatedCell } from '../../data/mock-generator';
import { COLORS, TOTAL_TRAINS, TIME_RANGE, FLEETS } from '../../data/mock-config';

// =============================================================================
// TYPES
// =============================================================================

interface TooltipInfo {
  x: number;
  y: number;
  cell: AggregatedCell | null;
}

interface ViewState {
  target: [number, number];
  zoom: number;
}

// =============================================================================
// CONSTANTS
// =============================================================================

const CELL_WIDTH = 30; // pixels per quarter
const CELL_HEIGHT = 8; // pixels per train
const GRID_WIDTH = TIME_RANGE.quarters * CELL_WIDTH; // 48 * 30 = 1440
const GRID_HEIGHT = TOTAL_TRAINS * CELL_HEIGHT; // 128 * 8 = 1024

// Color interpolation thresholds
const UTILIZATION_THRESHOLDS = {
  low: 20,
  medium: 50,
  high: 80,
};

// =============================================================================
// COLOR UTILITIES
// =============================================================================

function hexToRgb(hex: string): [number, number, number] {
  const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
  return result
    ? [
        parseInt(result[1], 16),
        parseInt(result[2], 16),
        parseInt(result[3], 16),
      ]
    : [128, 128, 128];
}

function interpolateColor(
  color1: [number, number, number],
  color2: [number, number, number],
  t: number
): [number, number, number, number] {
  return [
    Math.round(color1[0] + (color2[0] - color1[0]) * t),
    Math.round(color1[1] + (color2[1] - color1[1]) * t),
    Math.round(color1[2] + (color2[2] - color1[2]) * t),
    255,
  ];
}

function getUtilizationColor(utilization: number, hasOverhaul: boolean): [number, number, number, number] {
  // Overhaul cells get special color
  if (hasOverhaul) {
    return [251, 146, 60, 255]; // orange-400
  }

  const low = hexToRgb(COLORS.heatmap.low);
  const medium = hexToRgb(COLORS.heatmap.medium);
  const high = hexToRgb(COLORS.heatmap.high);
  const critical = hexToRgb(COLORS.heatmap.critical);

  if (utilization < UTILIZATION_THRESHOLDS.low) {
    const t = utilization / UTILIZATION_THRESHOLDS.low;
    return interpolateColor(low, medium, t);
  } else if (utilization < UTILIZATION_THRESHOLDS.medium) {
    const t = (utilization - UTILIZATION_THRESHOLDS.low) /
      (UTILIZATION_THRESHOLDS.medium - UTILIZATION_THRESHOLDS.low);
    return interpolateColor(medium, high, t);
  } else if (utilization < UTILIZATION_THRESHOLDS.high) {
    const t = (utilization - UTILIZATION_THRESHOLDS.medium) /
      (UTILIZATION_THRESHOLDS.high - UTILIZATION_THRESHOLDS.medium);
    return interpolateColor(high, critical, t);
  } else {
    return [...hexToRgb(COLORS.heatmap.critical), 255] as [number, number, number, number];
  }
}

// =============================================================================
// CELL POLYGON GENERATION
// =============================================================================

function createCellPolygon(cell: AggregatedCell): number[][] {
  const x = cell.periodIndex * CELL_WIDTH;
  const y = cell.trainIndex * CELL_HEIGHT;

  // Create rectangle polygon with small gap for grid effect
  const gap = 1;
  return [
    [x + gap, y + gap],
    [x + CELL_WIDTH - gap, y + gap],
    [x + CELL_WIDTH - gap, y + CELL_HEIGHT - gap],
    [x + gap, y + CELL_HEIGHT - gap],
  ];
}

// =============================================================================
// TOOLTIP COMPONENT
// =============================================================================

function CellTooltip({ info }: { info: TooltipInfo }) {
  if (!info.cell) return null;

  const quarterYear = Math.floor(info.cell.periodIndex / 4) + 2024;
  const quarter = (info.cell.periodIndex % 4) + 1;
  const trainIndex = info.cell.trainIndex;

  // Determine fleet
  const isKinki = trainIndex < 49;
  const fleetName = isKinki ? 'Kinki Sharyo' : 'Alstom';
  const fleetIndex = isKinki ? trainIndex + 1 : trainIndex - 49 + 1;
  const trainId = isKinki ? `K-${String(fleetIndex).padStart(3, '0')}` : `A-${String(fleetIndex).padStart(3, '0')}`;

  return (
    <div
      style={{
        position: 'absolute',
        left: info.x + 10,
        top: info.y + 10,
        pointerEvents: 'none',
        zIndex: 1000,
      }}
    >
      <Card elevation={2} style={{ padding: '8px 12px', minWidth: 200 }}>
        <div style={{ fontWeight: 600, marginBottom: 4 }}>
          {trainId} - {fleetName}
        </div>
        <div style={{ color: COLORS.text.secondary, fontSize: 12, marginBottom: 8 }}>
          Q{quarter} {quarterYear}
        </div>
        <Divider style={{ margin: '4px 0' }} />
        <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: 12 }}>
          <span>Tasks:</span>
          <strong>{info.cell.totalTasks}</strong>
        </div>
        <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: 12 }}>
          <span>Man-Hours:</span>
          <strong>{info.cell.totalManHours.toLocaleString()}</strong>
        </div>
        <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: 12 }}>
          <span>Utilization:</span>
          <Tag
            intent={
              info.cell.utilizationPercent > 80 ? Intent.DANGER :
              info.cell.utilizationPercent > 50 ? Intent.WARNING :
              Intent.SUCCESS
            }
            minimal
          >
            {info.cell.utilizationPercent.toFixed(0)}%
          </Tag>
        </div>
        {info.cell.hasOverhaul && (
          <Tag intent={Intent.WARNING} style={{ marginTop: 8 }}>
            Overhaul Scheduled
          </Tag>
        )}
      </Card>
    </div>
  );
}

