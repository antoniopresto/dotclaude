import type { Meta, StoryObj } from '@storybook/react';
import { useState, useCallback } from 'react';
import { UplotTimeScrubber } from './UplotTimeScrubber';
import {
  SMALL_TIME_SERIES,
  MOCK_TIME_SERIES,
  SMALL_MONTHLY_DATA,
  MOCK_MONTHLY_DATA,
} from './mockData';

const meta: Meta<typeof UplotTimeScrubber> = {
  title: 'Time Scrubber POC/uPlot',
  component: UplotTimeScrubber,
  parameters: {
    layout: 'centered',
    docs: {
      description: {
        component: `
## uPlot TimeScrubber

Canvas-based high-performance time scrubber - Grafana's choice.

### Performance Characteristics
- **~100,000 points/ms** after cold start
- **~50KB bundle size** (minimal footprint)
- **Canvas 2D rendering** (much faster than SVG)

### Pros
- **Exceptional performance** - handles massive datasets
- **Built-in zoom/selection** - native support for time range selection
- **Tiny bundle** - minimal impact on app size
- **Sync groups** - easy to sync multiple charts

### Cons
- **Less React-idiomatic** - imperative API
- **Steeper learning curve** - more complex configuration
- **Smaller community** - fewer examples than Recharts

### Recommended Use
**Best choice for production** when handling 60K+ points.
Use for the overview density chart, with deck.gl for main visualization.
        `,
      },
    },
  },
  tags: ['autodocs'],
  argTypes: {
    width: { control: { type: 'range', min: 200, max: 800 } },
    height: { control: { type: 'range', min: 50, max: 300 } },
    fillColor: { control: 'color' },
    strokeColor: { control: 'color' },
    showGrid: { control: 'boolean' },
  },
};

export default meta;
type Story = StoryObj<typeof UplotTimeScrubber>;

// Interactive wrapper to show selected range
const InteractiveWrapper = ({
  data,
  width,
  height,
  ...props
}: {
  data: typeof SMALL_TIME_SERIES;
  width: number;
  height: number;
  [key: string]: unknown;
}) => {
  const [selection, setSelection] = useState<[number, number] | null>(null);

  const handleSelectionChange = useCallback((range: [number, number] | null) => {
    setSelection(range);
  }, []);

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      <UplotTimeScrubber
        data={data}
        width={width}
        height={height}
        onSelectionChange={handleSelectionChange}
        {...props}
      />
      <div
        style={{
          marginTop: 16,
          padding: 12,
          background: '#f5f5f5',
          borderRadius: 4,
          fontSize: 12,
        }}
      >
        <strong>Selected Range:</strong>{' '}
        {selection
          ? `${new Date(selection[0]).toLocaleDateString()} - ${new Date(selection[1]).toLocaleDateString()}`
          : 'None (drag to select a range)'}
      </div>
      <div
        style={{
          marginTop: 8,
          padding: 8,
          background: '#e0f2fe',
          borderRadius: 4,
          fontSize: 11,
          color: '#0369a1',
        }}
      >
        💡 <strong>Tip:</strong> Drag horizontally to select a time range
      </div>
    </div>
  );
};

