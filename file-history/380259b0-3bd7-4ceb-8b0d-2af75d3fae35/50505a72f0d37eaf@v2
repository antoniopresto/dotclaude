/**
 * Mock data generator for Time Scrubber POCs
 * Generates maintenance task density data over 12 years
 */

export interface TimeSeriesPoint {
  date: Date;
  timestamp: number;
  value: number;
}

export interface MaintenanceEvent {
  id: string;
  timestamp: number;
  trainId: string;
  type: 'maintenance' | 'overhaul' | 'inspection';
  x: number; // day offset
  y: number; // train index
}

/**
 * Generate time series data for density visualization
 * @param startYear Start year for data
 * @param years Number of years of data
 * @param pointsPerDay Average points per day (density)
 */
export function generateTimeSeriesData(
  startYear: number = 2013,
  years: number = 12,
  pointsPerDay: number = 15
): TimeSeriesPoint[] {
  const data: TimeSeriesPoint[] = [];
  const startDate = new Date(startYear, 0, 1);
  const endDate = new Date(startYear + years, 0, 1);
  const totalDays = Math.floor((endDate.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));

  for (let day = 0; day < totalDays; day++) {
    const date = new Date(startDate.getTime() + day * 24 * 60 * 60 * 1000);
    const timestamp = date.getTime();

    // Create density pattern with seasonal variation and random noise
    const yearProgress = day / 365;
    const seasonalFactor = 1 + 0.3 * Math.sin(yearProgress * 2 * Math.PI); // Peak in summer
    const weekendFactor = date.getDay() === 0 || date.getDay() === 6 ? 0.3 : 1;
    const randomNoise = 0.5 + Math.random();

    const value = Math.round(pointsPerDay * seasonalFactor * weekendFactor * randomNoise);

    data.push({ date, timestamp, value });
  }

  return data;
}

/**
 * Generate detailed maintenance events (60,000+ points)
 */
export function generateMaintenanceEvents(
  trainCount: number = 50,
  startYear: number = 2013,
  years: number = 12
): MaintenanceEvent[] {
  const events: MaintenanceEvent[] = [];
  const startDate = new Date(startYear, 0, 1);
  const totalDays = years * 365;
  const types: Array<'maintenance' | 'overhaul' | 'inspection'> = ['maintenance', 'overhaul', 'inspection'];

  for (let trainIdx = 0; trainIdx < trainCount; trainIdx++) {
    const trainId = `TRAIN-${String(trainIdx + 1).padStart(3, '0')}`;

    // Each train has ~100 events per year
    const eventsPerTrain = Math.round(100 * years);

    for (let i = 0; i < eventsPerTrain; i++) {
      const dayOffset = Math.floor(Math.random() * totalDays);
      const date = new Date(startDate.getTime() + dayOffset * 24 * 60 * 60 * 1000);

      events.push({
        id: `${trainId}-${i}`,
        timestamp: date.getTime(),
        trainId,
        type: types[Math.floor(Math.random() * types.length)],
        x: dayOffset,
        y: trainIdx,
      });
    }
  }

  return events;
}

/**
 * Aggregate time series data by month for overview charts
 */
export function aggregateByMonth(data: TimeSeriesPoint[]): TimeSeriesPoint[] {
  const monthlyData = new Map<string, { date: Date; timestamp: number; sum: number; count: number }>();

  for (const point of data) {
    const key = `${point.date.getFullYear()}-${point.date.getMonth()}`;
    if (!monthlyData.has(key)) {
      const monthStart = new Date(point.date.getFullYear(), point.date.getMonth(), 1);
      monthlyData.set(key, {
        date: monthStart,
        timestamp: monthStart.getTime(),
        sum: 0,
        count: 0,
      });
    }
    const entry = monthlyData.get(key)!;
    entry.sum += point.value;
    entry.count++;
  }

  return Array.from(monthlyData.values())
    .map(({ date, timestamp, sum, count }) => ({
      date,
      timestamp,
      value: Math.round(sum / count),
    }))
    .sort((a, b) => a.timestamp - b.timestamp);
}

/**
 * Calculate data bounds for scales
 */
export function getDataBounds(data: TimeSeriesPoint[]): {
  minTime: number;
  maxTime: number;
  minValue: number;
  maxValue: number;
} {
  if (data.length === 0) {
    return { minTime: 0, maxTime: 1, minValue: 0, maxValue: 1 };
  }

  let minTime = data[0].timestamp;
  let maxTime = data[0].timestamp;
  let minValue = data[0].value;
  let maxValue = data[0].value;

  for (const point of data) {
    if (point.timestamp < minTime) minTime = point.timestamp;
    if (point.timestamp > maxTime) maxTime = point.timestamp;
    if (point.value < minValue) minValue = point.value;
    if (point.value > maxValue) maxValue = point.value;
  }

  return { minTime, maxTime, minValue, maxValue };
}

// Pre-generated datasets for consistent stories
export const MOCK_TIME_SERIES = generateTimeSeriesData(2013, 12, 15);
export const MOCK_MONTHLY_DATA = aggregateByMonth(MOCK_TIME_SERIES);
export const MOCK_MAINTENANCE_EVENTS = generateMaintenanceEvents(50, 2013, 12);
export const MOCK_BOUNDS = getDataBounds(MOCK_TIME_SERIES);

// Smaller dataset for development/testing
export const SMALL_TIME_SERIES = generateTimeSeriesData(2023, 2, 10);
export const SMALL_MONTHLY_DATA = aggregateByMonth(SMALL_TIME_SERIES);
export const SMALL_BOUNDS = getDataBounds(SMALL_TIME_SERIES);

/**
 * Generate a specific number of time series points (for LTTB demos)
 */
export function generateTimeSeries(count: number): TimeSeriesPoint[] {
  const data: TimeSeriesPoint[] = [];
  const startDate = new Date(2020, 0, 1);
  const interval = (5 * 365 * 24 * 60 * 60 * 1000) / count; // 5 years spread across count points

  for (let i = 0; i < count; i++) {
    const date = new Date(startDate.getTime() + i * interval);
    const timestamp = date.getTime();

    // Create interesting pattern with multiple frequencies
    const progress = i / count;
    const lowFreq = Math.sin(progress * 4 * Math.PI);
    const midFreq = 0.3 * Math.sin(progress * 20 * Math.PI);
    const highFreq = 0.1 * Math.sin(progress * 100 * Math.PI);
    const noise = 0.2 * (Math.random() - 0.5);
    const spike = Math.random() < 0.02 ? 0.5 * (Math.random() - 0.5) : 0;

    const value = 50 + 30 * (lowFreq + midFreq + highFreq + noise + spike);

    data.push({ date, timestamp, value: Math.max(0, value) });
  }

  return data;
}
