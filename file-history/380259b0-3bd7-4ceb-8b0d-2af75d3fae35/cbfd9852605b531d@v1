import type { Meta, StoryObj } from '@storybook/react';
import { useState, useCallback } from 'react';
import { VisxTimeScrubber } from './VisxTimeScrubber';
import { SMALL_MONTHLY_DATA, MOCK_MONTHLY_DATA, SMALL_BOUNDS, MOCK_BOUNDS } from './mockData';

const meta: Meta<typeof VisxTimeScrubber> = {
  title: 'Time Scrubber POC/visx',
  component: VisxTimeScrubber,
  parameters: {
    layout: 'centered',
    docs: {
      description: {
        component: `
## visx TimeScrubber

React-native brush component using @visx/brush with area chart density visualization.

### Pros
- **Excellent TypeScript support** - fully written in TypeScript
- **Maximum customization** - low-level primitives give full control
- **Clean React integration** - idiomatic React patterns

### Cons
- **SVG-based** - requires downsampling for 60K+ points
- **More code required** - compared to Recharts built-in

### Recommended Use
Best for projects that need maximum customization and already use visx elsewhere.
Use LTTB downsampling for the overview chart to handle 60K+ points.
        `,
      },
    },
  },
  tags: ['autodocs'],
  argTypes: {
    width: { control: { type: 'range', min: 200, max: 800 } },
    height: { control: { type: 'range', min: 50, max: 200 } },
    fillColor: { control: 'color' },
    strokeColor: { control: 'color' },
    brushColor: { control: 'color' },
  },
};

export default meta;
type Story = StoryObj<typeof VisxTimeScrubber>;

// Interactive wrapper to show selected range
const InteractiveWrapper = ({
  data,
  width,
  height,
  ...props
}: {
  data: typeof SMALL_MONTHLY_DATA;
  width: number;
  height: number;
  [key: string]: unknown;
}) => {
  const [selection, setSelection] = useState<[Date, Date] | null>(null);

  const handleBrushChange = useCallback((domain: [Date, Date] | null) => {
    setSelection(domain);
  }, []);

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      <VisxTimeScrubber
        data={data}
        width={width}
        height={height}
        onBrushChange={handleBrushChange}
        {...props}
      />
      <div
        style={{
          marginTop: 16,
          padding: 12,
          background: '#f5f5f5',
          borderRadius: 4,
          fontSize: 12,
        }}
      >
        <strong>Selected Range:</strong>{' '}
        {selection
          ? `${selection[0].toLocaleDateString()} - ${selection[1].toLocaleDateString()}`
          : 'None (drag to select)'}
      </div>
    </div>
  );
};

