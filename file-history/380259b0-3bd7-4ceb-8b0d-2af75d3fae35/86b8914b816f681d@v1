import type { Meta, StoryObj } from '@storybook/react';
import { useState, useCallback } from 'react';
import { D3BrushTimeScrubber } from './D3BrushTimeScrubber';
import { SMALL_MONTHLY_DATA, MOCK_MONTHLY_DATA } from './mockData';

const meta: Meta<typeof D3BrushTimeScrubber> = {
  title: 'Time Scrubber POC/D3 Brush',
  component: D3BrushTimeScrubber,
  parameters: {
    layout: 'centered',
    docs: {
      description: {
        component: `
## D3-Brush TimeScrubber

Direct D3 brush integration with React - maximum flexibility.

### Key Pattern: Bidirectional Sync
The critical pattern for D3-brush + React is checking \`event.sourceEvent\` to distinguish:
- **User-initiated** brush movements (has sourceEvent)
- **Programmatic** updates (no sourceEvent)

This prevents infinite update loops when syncing brush with external state.

### Pros
- **Maximum flexibility** - full control over brush behavior
- **Works with any chart** - can overlay on any visualization
- **Industry standard** - well documented, many examples

### Cons
- **Imperative API** - doesn't fit React paradigm naturally
- **Lifecycle management** - requires careful useEffect cleanup
- **Manual sync** - must implement bidirectional sync yourself

### Recommended Use
Use when you need custom brush behavior not available in visx or other libraries.
Best combined with uPlot for the density chart.
        `,
      },
    },
  },
  tags: ['autodocs'],
  argTypes: {
    width: { control: { type: 'range', min: 200, max: 800 } },
    height: { control: { type: 'range', min: 50, max: 200 } },
    fillColor: { control: 'color' },
    strokeColor: { control: 'color' },
    brushColor: { control: 'color' },
  },
};

export default meta;
type Story = StoryObj<typeof D3BrushTimeScrubber>;

// Interactive wrapper to show selected range
const InteractiveWrapper = ({
  data,
  width,
  height,
  ...props
}: {
  data: typeof SMALL_MONTHLY_DATA;
  width: number;
  height: number;
  [key: string]: unknown;
}) => {
  const [selection, setSelection] = useState<[Date, Date] | null>(null);

  const handleBrushChange = useCallback((domain: [Date, Date] | null) => {
    setSelection(domain);
  }, []);

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      <D3BrushTimeScrubber
        data={data}
        width={width}
        height={height}
        onBrushChange={handleBrushChange}
        selection={selection}
        {...props}
      />
      <div
        style={{
          marginTop: 16,
          padding: 12,
          background: '#f5f5f5',
          borderRadius: 4,
          fontSize: 12,
        }}
      >
        <strong>Selected Range:</strong>{' '}
        {selection
          ? `${selection[0].toLocaleDateString()} - ${selection[1].toLocaleDateString()}`
          : 'None (drag to select)'}
      </div>
    </div>
  );
};

// Controlled component demo
const ControlledWrapper = ({
  data,
  width,
  height,
  ...props
}: {
  data: typeof SMALL_MONTHLY_DATA;
  width: number;
  height: number;
  [key: string]: unknown;
}) => {
  const [selection, setSelection] = useState<[Date, Date] | null>([
    new Date('2023-03-01'),
    new Date('2023-09-01'),
  ]);

  const handleBrushChange = useCallback((domain: [Date, Date] | null) => {
    setSelection(domain);
  }, []);

  // Preset buttons for programmatic control
  const presets = [
    { label: 'Q1 2023', range: [new Date('2023-01-01'), new Date('2023-04-01')] as [Date, Date] },
    { label: 'Q2 2023', range: [new Date('2023-04-01'), new Date('2023-07-01')] as [Date, Date] },
    { label: 'H2 2023', range: [new Date('2023-07-01'), new Date('2024-01-01')] as [Date, Date] },
    { label: 'Clear', range: null },
  ];

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      <div style={{ marginBottom: 12, display: 'flex', gap: 8 }}>
        {presets.map((preset) => (
          <button
            key={preset.label}
            onClick={() => setSelection(preset.range)}
            style={{
              padding: '6px 12px',
              border: '1px solid #e5e7eb',
              borderRadius: 4,
              background: 'white',
              cursor: 'pointer',
              fontSize: 12,
            }}
          >
            {preset.label}
          </button>
        ))}
      </div>
      <D3BrushTimeScrubber
        data={data}
        width={width}
        height={height}
        onBrushChange={handleBrushChange}
        selection={selection}
        {...props}
      />
      <div
        style={{
          marginTop: 16,
          padding: 12,
          background: '#f5f5f5',
          borderRadius: 4,
          fontSize: 12,
        }}
      >
        <strong>Selected Range:</strong>{' '}
        {selection
          ? `${selection[0].toLocaleDateString()} - ${selection[1].toLocaleDateString()}`
          : 'None'}
      </div>
      <div
        style={{
          marginTop: 8,
          padding: 8,
          background: '#fef3c7',
          borderRadius: 4,
          fontSize: 11,
          color: '#92400e',
        }}
      >
        💡 <strong>Bidirectional Sync:</strong> Click the buttons to set the selection
        programmatically, or drag the brush handles.
      </div>
    </div>
  );
};

