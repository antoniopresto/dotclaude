/**
 * Tactical Layer Stories
 *
 * Demonstrates the monthly stacked bar view for tactical planning.
 * Shows workload distribution by maintenance type across trains.
 */

import type { Meta, StoryObj } from '@storybook/react';
import React, { useState } from 'react';
import { Card, Slider, Tag, Intent } from '@blueprintjs/core';
import { TacticalLayer } from './TacticalLayer';
import { generateMockData } from '../../data/mock-generator';
import type { AggregatedCell } from '../../data/mock-generator';

// =============================================================================
// META
// =============================================================================

const meta: Meta<typeof TacticalLayer> = {
  title: '02-Layers/Tactical',
  component: TacticalLayer,
  parameters: {
    layout: 'fullscreen',
  },
};

export default meta;
type Story = StoryObj<typeof TacticalLayer>;

// =============================================================================
// MOCK DATA
// =============================================================================

const mockData = generateMockData();

// =============================================================================
// STORIES
// =============================================================================

export const Default: Story = {
  name: 'Default View',
  render: () => {
    const [hoveredCell, setHoveredCell] = useState<AggregatedCell | null>(null);
    const [selectedCell, setSelectedCell] = useState<AggregatedCell | null>(null);

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f4f4f5' }}>
        <TacticalLayer
          cells={mockData.aggregatedByMonth}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight}
          hoveredCell={hoveredCell}
          onCellHover={setHoveredCell}
          onCellClick={setSelectedCell}
        />

        {/* Selected cell detail */}
        {selectedCell && (
          <div
            style={{
              position: 'absolute',
              bottom: 16,
              left: 16,
              background: 'white',
              padding: 16,
              borderRadius: 8,
              boxShadow: '0 4px 12px rgba(0,0,0,0.15)',
              maxWidth: 280,
            }}
          >
            <div style={{ fontWeight: 600, marginBottom: 8 }}>
              Selected: {mockData.trains[selectedCell.trainIndex]?.name}
            </div>
            <div style={{ fontSize: 12, color: '#666', marginBottom: 12 }}>
              {['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'][selectedCell.periodIndex % 12]} {2024 + Math.floor(selectedCell.periodIndex / 12)}
            </div>
            <div style={{ fontSize: 12 }}>
              <div>Tasks: {selectedCell.totalTasks}</div>
              <div>Man-Hours: {selectedCell.totalManHours.toLocaleString()}</div>
              <div>Cost: {(selectedCell.totalCostAed / 1000).toFixed(0)}K AED</div>
              <div>Utilization: {selectedCell.utilizationPercent.toFixed(0)}%</div>
            </div>
            <button
              onClick={() => setSelectedCell(null)}
              style={{
                marginTop: 12,
                padding: '4px 12px',
                cursor: 'pointer',
              }}
            >
              Close
            </button>
          </div>
        )}
      </div>
    );
  },
};

export const WithControls: Story = {
  name: 'With Pan/Zoom Controls',
  render: () => {
    const [cameraX, setCameraX] = useState(0);
    const [cameraY, setCameraY] = useState(0);
    const [zoom, setZoom] = useState(0.5);
    const [hoveredCell, setHoveredCell] = useState<AggregatedCell | null>(null);

    // Calculate bounds
    const maxX = 144 * 20; // months * cell width
    const maxY = 128 * 16; // trains * cell height

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f4f4f5' }}>
        <TacticalLayer
          cells={mockData.aggregatedByMonth}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight - 100}
          cameraX={cameraX}
          cameraY={cameraY}
          zoom={zoom}
          hoveredCell={hoveredCell}
          onCellHover={setHoveredCell}
        />

        {/* Controls */}
        <Card
          style={{
            position: 'absolute',
            top: 16,
            right: 16,
            width: 280,
            padding: 16,
          }}
        >
          <div style={{ marginBottom: 16 }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
              <span style={{ fontWeight: 500, fontSize: 12 }}>Horizontal Pan</span>
              <span style={{ fontSize: 11, color: '#666' }}>{cameraX.toFixed(0)}px</span>
            </div>
            <Slider
              min={-maxX / 2}
              max={maxX / 2}
              stepSize={10}
              value={cameraX}
              onChange={setCameraX}
              labelRenderer={false}
            />
          </div>

          <div style={{ marginBottom: 16 }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
              <span style={{ fontWeight: 500, fontSize: 12 }}>Vertical Pan</span>
              <span style={{ fontSize: 11, color: '#666' }}>{cameraY.toFixed(0)}px</span>
            </div>
            <Slider
              min={-maxY / 2}
              max={maxY / 2}
              stepSize={10}
              value={cameraY}
              onChange={setCameraY}
              labelRenderer={false}
            />
          </div>

          <div style={{ marginBottom: 16 }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
              <span style={{ fontWeight: 500, fontSize: 12 }}>Zoom</span>
              <Tag
                intent={zoom >= 0.3 && zoom <= 1.0 ? Intent.PRIMARY : Intent.NONE}
                minimal
              >
                {zoom.toFixed(2)}x {zoom >= 0.3 && zoom <= 1.0 ? '(Tactical)' : ''}
              </Tag>
            </div>
            <Slider
              min={0.1}
              max={2}
              stepSize={0.05}
              value={zoom}
              onChange={setZoom}
              labelRenderer={false}
            />
          </div>

          <div style={{ fontSize: 11, color: '#666' }}>
            <div>Data: {mockData.stats.totalTrains} trains × {144} months</div>
            <div>Cells: {mockData.aggregatedByMonth.length.toLocaleString()}</div>
          </div>
        </Card>
      </div>
    );
  },
};

export const MonthlyComparison: Story = {
  name: 'Monthly Comparison',
  render: () => {
    const [selectedYear, setSelectedYear] = useState(2026);
    const [hoveredCell, setHoveredCell] = useState<AggregatedCell | null>(null);

    // Filter cells for selected year
    const yearStartMonth = (selectedYear - 2024) * 12;
    const yearEndMonth = yearStartMonth + 11;

    const yearCells = mockData.aggregatedByMonth.filter(
      c => c.periodIndex >= yearStartMonth && c.periodIndex <= yearEndMonth
    );

    // Calculate monthly totals
    const monthlyTotals = Array.from({ length: 12 }, (_, i) => {
      const monthCells = yearCells.filter(c => c.periodIndex % 12 === i);
      return {
        month: i,
        totalTasks: monthCells.reduce((sum, c) => sum + c.totalTasks, 0),
        totalManHours: monthCells.reduce((sum, c) => sum + c.totalManHours, 0),
        avgUtilization: monthCells.reduce((sum, c) => sum + c.utilizationPercent, 0) / monthCells.length,
      };
    });

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f4f4f5' }}>
        <TacticalLayer
          cells={yearCells}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight - 160}
          zoom={0.8}
          hoveredCell={hoveredCell}
          onCellHover={setHoveredCell}
        />

        {/* Year selector */}
        <Card
          style={{
            position: 'absolute',
            top: 16,
            left: '50%',
            transform: 'translateX(-50%)',
            padding: 12,
            display: 'flex',
            alignItems: 'center',
            gap: 12,
          }}
        >
          <span style={{ fontWeight: 500, fontSize: 12 }}>Year:</span>
          <div style={{ display: 'flex', gap: 4 }}>
            {Array.from({ length: 12 }, (_, i) => 2024 + i).map((year) => (
              <button
                key={year}
                onClick={() => setSelectedYear(year)}
                style={{
                  padding: '4px 8px',
                  border: selectedYear === year ? '2px solid #1d4ed8' : '1px solid #e2e8f0',
                  borderRadius: 4,
                  background: selectedYear === year ? '#dbeafe' : 'white',
                  cursor: 'pointer',
                  fontSize: 11,
                  fontWeight: selectedYear === year ? 600 : 400,
                }}
              >
                {year}
              </button>
            ))}
          </div>
        </Card>

        {/* Monthly summary bar */}
        <div
          style={{
            position: 'absolute',
            bottom: 0,
            left: 0,
            right: 0,
            background: 'white',
            padding: 12,
            borderTop: '1px solid #e2e8f0',
            display: 'flex',
            justifyContent: 'center',
            gap: 8,
          }}
        >
          {monthlyTotals.map((m, i) => (
            <div
              key={i}
              style={{
                textAlign: 'center',
                padding: '4px 8px',
                borderRadius: 4,
                background: m.avgUtilization > 80 ? '#fef2f2' : m.avgUtilization > 60 ? '#fffbeb' : '#f0fdf4',
              }}
            >
              <div style={{ fontSize: 10, fontWeight: 500, color: '#666' }}>
                {['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'][i]}
              </div>
              <div style={{ fontSize: 14, fontWeight: 600 }}>{m.totalTasks}</div>
              <div style={{ fontSize: 9, color: '#666' }}>{m.avgUtilization.toFixed(0)}%</div>
            </div>
          ))}
        </div>
      </div>
    );
  },
};

export const HighUtilization: Story = {
  name: 'High Utilization Filter',
  render: () => {
    const [threshold, setThreshold] = useState(70);
    const [hoveredCell, setHoveredCell] = useState<AggregatedCell | null>(null);

    // Filter cells by utilization
    const highUtilCells = mockData.aggregatedByMonth.filter(
      c => c.utilizationPercent >= threshold
    );

    const stats = {
      totalCells: mockData.aggregatedByMonth.length,
      highUtilCells: highUtilCells.length,
      percentage: (highUtilCells.length / mockData.aggregatedByMonth.length * 100).toFixed(1),
    };

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f4f4f5' }}>
        <TacticalLayer
          cells={highUtilCells}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight - 100}
          zoom={0.5}
          hoveredCell={hoveredCell}
          onCellHover={setHoveredCell}
        />

        {/* Filter controls */}
        <Card
          style={{
            position: 'absolute',
            top: 16,
            left: '50%',
            transform: 'translateX(-50%)',
            padding: 16,
            minWidth: 300,
          }}
        >
          <div style={{ fontWeight: 600, marginBottom: 12 }}>
            High Utilization Filter
          </div>
          <div style={{ marginBottom: 12 }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
              <span style={{ fontSize: 12 }}>Minimum Utilization</span>
              <Tag intent={Intent.WARNING}>{threshold}%</Tag>
            </div>
            <Slider
              min={0}
              max={100}
              stepSize={5}
              value={threshold}
              onChange={setThreshold}
              labelRenderer={false}
            />
          </div>
          <div style={{ fontSize: 12, color: '#666' }}>
            <div>Showing: {stats.highUtilCells.toLocaleString()} of {stats.totalCells.toLocaleString()} cells</div>
            <div>({stats.percentage}% of all periods)</div>
          </div>
        </Card>
      </div>
    );
  },
};
