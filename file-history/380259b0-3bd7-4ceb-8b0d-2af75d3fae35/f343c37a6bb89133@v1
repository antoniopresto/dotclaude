const meta: Meta<typeof RechartsTimeScrubber> = {
  title: 'Time Scrubber POC/Recharts',
  component: RechartsTimeScrubber,
  parameters: {
    layout: 'padded',
    docs: {
      description: {
        component: `
## Recharts TimeScrubber

Built-in Brush component with Area chart - fastest implementation path.

### Pros
- **Minimal code** - works out of the box
- **Panorama feature** - mini chart embedded in brush area
- **Good community** - well documented, many examples

### Cons
- **Limited customization** - less flexible than visx
- **SVG-based** - struggles beyond ~8,000 points
- **Less TypeScript** - not fully typed like visx

### Recommended Use
Best for quick prototypes or dashboards with moderate data volumes.
Use LTTB downsampling for datasets larger than 8,000 points.
        `,
      },
    },
  },
  tags: ['autodocs'],
  argTypes: {
    mainChartHeight: { control: { type: 'range', min: 100, max: 400 } },
    brushHeight: { control: { type: 'range', min: 30, max: 80 } },
    fillColor: { control: 'color' },
    strokeColor: { control: 'color' },
    showMainChart: { control: 'boolean' },
  },
};

export default meta;
type Story = StoryObj<typeof RechartsTimeScrubber>;

// Interactive wrapper to show selected range
const InteractiveWrapper = ({
  data,
  ...props
}: {
  data: typeof SMALL_MONTHLY_DATA;
  [key: string]: unknown;
}) => {
  const [selection, setSelection] = useState<{
    startIndex: number;
    endIndex: number;
  } | null>(null);

  const handleBrushChange = useCallback(
    (range: { startIndex: number; endIndex: number } | null) => {
      setSelection(range);
    },
    []
  );

  return (
    <div style={{ width: '100%', fontFamily: 'system-ui, sans-serif' }}>
      <RechartsTimeScrubber data={data} onBrushChange={handleBrushChange} {...props} />
      <div
        style={{
          marginTop: 16,
          padding: 12,
          background: '#f5f5f5',
          borderRadius: 4,
          fontSize: 12,
        }}
      >
        <strong>Selected Range:</strong>{' '}
        {selection
          ? `Index ${selection.startIndex} - ${selection.endIndex} (${data[selection.startIndex]?.date.toLocaleDateString()} - ${data[selection.endIndex]?.date.toLocaleDateString()})`
          : 'None (drag handles to select)'}
      </div>
    </div>
  );
};

