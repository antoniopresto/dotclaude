// =============================================================================
// TIMELINE HEADER STORIES
// =============================================================================

export const TimelineHeaderDemo: StoryObj = {
  name: 'TimelineHeader',
  render: () => {
    const [zoom, setZoom] = useState(1.0);
    const [granularity, setGranularity] = useState<TimelineGranularity>('months');
    const [autoGranularity, setAutoGranularity] = useState(true);

    const effectiveGranularity = autoGranularity ? getGranularityForZoom(zoom) : granularity;

    // Calculate date range based on zoom
    const daysVisible = Math.floor(365 / zoom);
    const startDate = new Date(TIME_RANGE.start);
    const endDate = new Date(startDate);
    endDate.setDate(endDate.getDate() + daysVisible);

    // Pixels per day based on zoom
    const pxPerDay = 2 * zoom;

    return (
      <div style={{ padding: 24 }}>
        <h2 style={{ marginBottom: 16 }}>TimelineHeader Component</h2>
        <p style={{ color: '#666', marginBottom: 24 }}>
          Adaptive timeline that changes granularity based on zoom level.
        </p>

        {/* Controls */}
        <Card style={{ padding: 16, marginBottom: 24 }}>
          <div style={{ display: 'flex', gap: 24, alignItems: 'center' }}>
            <div style={{ flex: 1 }}>
              <label style={{ display: 'block', marginBottom: 8, fontWeight: 500 }}>
                Zoom Level: {zoom.toFixed(2)}x
              </label>
              <Slider
                min={0.1}
                max={10}
                stepSize={0.1}
                value={zoom}
                onChange={setZoom}
                labelRenderer={false}
              />
            </div>

            <div>
              <label style={{ display: 'block', marginBottom: 8, fontWeight: 500 }}>
                Granularity
              </label>
              <div style={{ display: 'flex', gap: 8 }}>
                <Button
                  active={autoGranularity}
                  onClick={() => setAutoGranularity(true)}
                  small
                >
                  Auto
                </Button>
                <HTMLSelect
                  value={granularity}
                  onChange={(e) => {
                    setGranularity(e.target.value as TimelineGranularity);
                    setAutoGranularity(false);
                  }}
                  disabled={autoGranularity}
                >
                  <option value="years">Years</option>
                  <option value="quarters">Quarters</option>
                  <option value="months">Months</option>
                  <option value="weeks">Weeks</option>
                  <option value="days">Days</option>
                </HTMLSelect>
              </div>
            </div>
          </div>

          <div style={{ marginTop: 16, fontSize: 12, color: '#666' }}>
            Showing: {daysVisible} days | Granularity: <strong>{effectiveGranularity}</strong> | px/day: {pxPerDay.toFixed(1)}
          </div>
        </Card>

        {/* Timeline Headers */}
        <div style={{ border: '1px solid #e2e8f0', borderRadius: 8, overflow: 'hidden' }}>
          <TimelineHeader
            startDate={startDate}
            endDate={endDate}
            width={800}
            height={48}
            granularity={effectiveGranularity}
            pxPerDay={pxPerDay}
          />
        </div>

        {/* Granularity examples */}
        <h3 style={{ marginTop: 32, marginBottom: 16 }}>All Granularity Levels</h3>
        <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
          {(['years', 'quarters', 'months', 'weeks', 'days'] as TimelineGranularity[]).map((g) => (
            <div key={g}>
              <div style={{ fontSize: 12, fontWeight: 500, marginBottom: 4, color: '#666' }}>
                {g.toUpperCase()}
              </div>
              <div style={{ border: '1px solid #e2e8f0', borderRadius: 4, overflow: 'hidden' }}>
                <TimelineHeader
                  startDate={TIME_RANGE.start}
                  endDate={new Date(TIME_RANGE.start.getTime() + 365 * 24 * 60 * 60 * 1000)}
                  width={800}
                  height={40}
                  granularity={g}
                  pxPerDay={g === 'days' ? 20 : g === 'weeks' ? 5 : g === 'months' ? 2 : g === 'quarters' ? 1 : 0.5}
                />
              </div>
            </div>
          ))}
        </div>
      </div>
    );
  },
};

