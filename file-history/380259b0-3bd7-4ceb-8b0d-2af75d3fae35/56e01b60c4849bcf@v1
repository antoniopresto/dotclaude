export const GanttBarDemo: StoryObj = {
  name: 'GanttBar',
  render: () => {
    const [selectedId, setSelectedId] = useState<string | null>(null);
    const [hoveredId, setHoveredId] = useState<string | null>(null);

    const bars: Array<{
      id: string;
      type: MaintenanceTypeId;
      status: TaskStatus;
      label: string;
    }> = [
      { id: '1', type: 'pm1', status: 'completed', label: 'PM1' },
      { id: '2', type: 'pm2', status: 'in-progress', label: 'PM2' },
      { id: '3', type: 'pm3', status: 'scheduled', label: 'PM3' },
      { id: '4', type: 'overhaul', status: 'scheduled', label: 'Overhaul' },
      { id: '5', type: 'corrective', status: 'overdue', label: 'Corrective' },
      { id: '6', type: 'pm1', status: 'conflict', label: 'Conflict' },
    ];

    return (
      <div style={{ padding: 24 }}>
        <h2 style={{ marginBottom: 16 }}>GanttBar Component</h2>
        <p style={{ color: '#666', marginBottom: 24 }}>
          Click to select, hover for highlight. Shows different maintenance types and statuses.
        </p>

        <svg width={800} height={300} style={{ background: '#f4f4f5', borderRadius: 8 }}>
          <GanttBarDefs />

          {/* Row labels */}
          {bars.map((bar, i) => (
            <text
              key={`label-${bar.id}`}
              x={10}
              y={30 + i * 44 + 12}
              fontSize={12}
              fill="#666"
            >
              {bar.label} ({bar.status})
            </text>
          ))}

          {/* Bars */}
          {bars.map((bar, i) => (
            <GanttBar
              key={bar.id}
              id={bar.id}
              type={bar.type}
              status={bar.status}
              x={150}
              y={20 + i * 44}
              width={200 + Math.random() * 100}
              height={32}
              label={bar.label}
              showLabel
              isSelected={selectedId === bar.id}
              isHovered={hoveredId === bar.id}
              hasConflict={bar.status === 'conflict'}
              onClick={setSelectedId}
              onMouseEnter={setHoveredId}
              onMouseLeave={() => setHoveredId(null)}
            />
          ))}
        </svg>

        <div style={{ marginTop: 16, fontSize: 14, color: '#666' }}>
          Selected: <strong>{selectedId ?? 'None'}</strong>
        </div>

        <h3 style={{ marginTop: 32, marginBottom: 16 }}>Maintenance Type Colors</h3>
        <div style={{ display: 'flex', gap: 16, flexWrap: 'wrap' }}>
          {MAINTENANCE_TYPES.map((mt) => (
            <div
              key={mt.id}
              style={{
                display: 'flex',
                alignItems: 'center',
                gap: 8,
              }}
            >
              <div
                style={{
                  width: 24,
                  height: 24,
                  backgroundColor: mt.color,
                  borderRadius: 4,
                }}
              />
              <span>{mt.name}</span>
            </div>
          ))}
        </div>
      </div>
    );
  },
};

