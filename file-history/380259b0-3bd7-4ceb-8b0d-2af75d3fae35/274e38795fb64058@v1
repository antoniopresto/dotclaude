/**
 * LTTB (Largest-Triangle-Three-Buckets) Downsampling Demo
 *
 * Demonstrates visual-shape-preserving downsampling for large time series.
 * Critical for maintaining visual fidelity when rendering millions of points.
 *
 * Pros:
 * - Preserves visual peaks and valleys (unlike simple averaging)
 * - O(n) algorithm - very fast
 * - Configurable output size
 * - Works with any time series data
 *
 * Cons:
 * - Loses exact data points (only representatives remain)
 * - Not suitable when exact values matter
 * - One-way transformation (cannot recover original)
 */

import React, { useMemo, useState } from 'react';
import { lttb } from './lttbAlgorithm';
import type { TimeSeriesPoint } from './mockData';

interface LTTBDownsampleDemoProps {
  /** Original time series data */
  data: TimeSeriesPoint[];
  /** Width of each chart */
  width: number;
  /** Height of each chart */
  height: number;
  /** Initial downsampling target */
  initialTarget?: number;
}

// Simple SVG line chart for comparison
const SimpleLineChart: React.FC<{
  data: TimeSeriesPoint[];
  width: number;
  height: number;
  color: string;
  label: string;
}> = ({ data, width, height, color, label }) => {
  const margin = { top: 20, right: 10, bottom: 30, left: 40 };
  const innerWidth = width - margin.left - margin.right;
  const innerHeight = height - margin.top - margin.bottom;

  const { path, xTicks, yTicks } = useMemo(() => {
    if (data.length === 0) return { path: '', xTicks: [], yTicks: [] };

    const minDate = data[0].date.getTime();
    const maxDate = data[data.length - 1].date.getTime();
    const maxValue = Math.max(...data.map((d) => d.value));
    const minValue = Math.min(...data.map((d) => d.value));
    const valueRange = maxValue - minValue || 1;

    const xScale = (date: Date) =>
      ((date.getTime() - minDate) / (maxDate - minDate)) * innerWidth;
    const yScale = (value: number) =>
      innerHeight - ((value - minValue) / valueRange) * innerHeight;

    const pathData = data
      .map((d, i) => {
        const x = xScale(d.date);
        const y = yScale(d.value);
        return `${i === 0 ? 'M' : 'L'} ${x} ${y}`;
      })
      .join(' ');

    // Generate axis ticks
    const xTickCount = 5;
    const xTickInterval = (maxDate - minDate) / xTickCount;
    const xTicks = Array.from({ length: xTickCount + 1 }, (_, i) => {
      const date = new Date(minDate + i * xTickInterval);
      return {
        x: xScale(date),
        label: date.toLocaleDateString('en-US', { month: 'short', year: '2-digit' }),
      };
    });

    const yTickCount = 4;
    const yTickInterval = valueRange / yTickCount;
    const yTicks = Array.from({ length: yTickCount + 1 }, (_, i) => {
      const value = minValue + i * yTickInterval;
      return {
        y: yScale(value),
        label: Math.round(value).toString(),
      };
    });

    return { path: pathData, xTicks, yTicks };
  }, [data, innerWidth, innerHeight]);

  return (
    <div style={{ position: 'relative' }}>
      <div
        style={{
          position: 'absolute',
          top: 4,
          left: margin.left,
          fontSize: 11,
          fontWeight: 600,
          color: '#334155',
        }}
      >
        {label} ({data.length.toLocaleString()} points)
      </div>
      <svg width={width} height={height}>
        <g transform={`translate(${margin.left},${margin.top})`}>
          {/* Y axis */}
          <line x1={0} y1={0} x2={0} y2={innerHeight} stroke="#e2e8f0" />
          {yTicks.map((tick, i) => (
            <g key={i} transform={`translate(0,${tick.y})`}>
              <line x1={-5} y1={0} x2={0} y2={0} stroke="#94a3b8" />
              <text x={-8} y={4} textAnchor="end" fontSize={9} fill="#64748b">
                {tick.label}
              </text>
              <line
                x1={0}
                y1={0}
                x2={innerWidth}
                y2={0}
                stroke="#f1f5f9"
                strokeDasharray="2,2"
              />
            </g>
          ))}

          {/* X axis */}
          <line x1={0} y1={innerHeight} x2={innerWidth} y2={innerHeight} stroke="#e2e8f0" />
          {xTicks.map((tick, i) => (
            <g key={i} transform={`translate(${tick.x},${innerHeight})`}>
              <line x1={0} y1={0} x2={0} y2={5} stroke="#94a3b8" />
              <text x={0} y={18} textAnchor="middle" fontSize={9} fill="#64748b">
                {tick.label}
              </text>
            </g>
          ))}

          {/* Data line */}
          <path d={path} fill="none" stroke={color} strokeWidth={1.5} />
        </g>
      </svg>
    </div>
  );
};

export const LTTBDownsampleDemo: React.FC<LTTBDownsampleDemoProps> = ({
  data,
  width,
  height,
  initialTarget = 100,
}) => {
  const [targetPoints, setTargetPoints] = useState(initialTarget);

  // Downsample using LTTB
  const downsampledData = useMemo(() => {
    if (data.length <= targetPoints) return data;
    return lttb(data, targetPoints);
  }, [data, targetPoints]);

  // Calculate compression ratio
  const compressionRatio = ((1 - downsampledData.length / data.length) * 100).toFixed(1);

  // Presets for quick selection
  const presets = [
    { label: '50 pts', value: 50 },
    { label: '100 pts', value: 100 },
    { label: '200 pts', value: 200 },
    { label: '500 pts', value: 500 },
    { label: 'All', value: data.length },
  ];

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      {/* Controls */}
      <div
        style={{
          marginBottom: 16,
          padding: 16,
          background: '#f8fafc',
          borderRadius: 8,
        }}
      >
        <div style={{ marginBottom: 12 }}>
          <label style={{ fontSize: 12, fontWeight: 600, color: '#334155' }}>
            Target Points: {targetPoints}
          </label>
          <input
            type="range"
            min={10}
            max={Math.min(data.length, 1000)}
            value={targetPoints}
            onChange={(e) => setTargetPoints(Number(e.target.value))}
            style={{ width: '100%', marginTop: 8 }}
          />
        </div>

        <div style={{ display: 'flex', gap: 8 }}>
          {presets.map((preset) => (
            <button
              key={preset.label}
              onClick={() => setTargetPoints(preset.value)}
              style={{
                padding: '6px 12px',
                border: '1px solid #e5e7eb',
                borderRadius: 4,
                background: targetPoints === preset.value ? '#3b82f6' : 'white',
                color: targetPoints === preset.value ? 'white' : '#334155',
                cursor: 'pointer',
                fontSize: 11,
              }}
            >
              {preset.label}
            </button>
          ))}
        </div>
      </div>

      {/* Stats */}
      <div
        style={{
          display: 'grid',
          gridTemplateColumns: 'repeat(4, 1fr)',
          gap: 12,
          marginBottom: 16,
        }}
      >
        <div style={{ padding: 12, background: '#eff6ff', borderRadius: 8, textAlign: 'center' }}>
          <div style={{ fontSize: 20, fontWeight: 700, color: '#1d4ed8' }}>
            {data.length.toLocaleString()}
          </div>
          <div style={{ fontSize: 10, color: '#64748b' }}>Original Points</div>
        </div>
        <div style={{ padding: 12, background: '#f0fdf4', borderRadius: 8, textAlign: 'center' }}>
          <div style={{ fontSize: 20, fontWeight: 700, color: '#16a34a' }}>
            {downsampledData.length.toLocaleString()}
          </div>
          <div style={{ fontSize: 10, color: '#64748b' }}>Downsampled Points</div>
        </div>
        <div style={{ padding: 12, background: '#fef3c7', borderRadius: 8, textAlign: 'center' }}>
          <div style={{ fontSize: 20, fontWeight: 700, color: '#d97706' }}>{compressionRatio}%</div>
          <div style={{ fontSize: 10, color: '#64748b' }}>Reduction</div>
        </div>
        <div style={{ padding: 12, background: '#fae8ff', borderRadius: 8, textAlign: 'center' }}>
          <div style={{ fontSize: 20, fontWeight: 700, color: '#a855f7' }}>
            {(data.length / downsampledData.length).toFixed(1)}x
          </div>
          <div style={{ fontSize: 10, color: '#64748b' }}>Compression Ratio</div>
        </div>
      </div>

      {/* Side-by-side comparison */}
      <div style={{ display: 'flex', gap: 16 }}>
        <div style={{ flex: 1, border: '1px solid #e2e8f0', borderRadius: 8, overflow: 'hidden' }}>
          <SimpleLineChart
            data={data}
            width={width / 2 - 8}
            height={height}
            color="#3b82f6"
            label="Original"
          />
        </div>
        <div style={{ flex: 1, border: '1px solid #e2e8f0', borderRadius: 8, overflow: 'hidden' }}>
          <SimpleLineChart
            data={downsampledData}
            width={width / 2 - 8}
            height={height}
            color="#16a34a"
            label="LTTB Downsampled"
          />
        </div>
      </div>

      {/* Explanation */}
      <div
        style={{
          marginTop: 16,
          padding: 12,
          background: '#f0f9ff',
          borderRadius: 8,
          fontSize: 11,
          color: '#0369a1',
        }}
      >
        <strong>LTTB (Largest-Triangle-Three-Buckets):</strong> Unlike simple averaging or
        skip-sampling, LTTB preserves visually significant peaks and valleys. Notice how the
        downsampled chart maintains the same visual shape even with far fewer points.
      </div>
    </div>
  );
};

export default LTTBDownsampleDemo;
