// Larger dataset demonstration
const generateLargeDataset = () => {
  const events = [];
  const startTs = new Date('2013-01-01').getTime();
  const yearMs = 365 * 24 * 60 * 60 * 1000;
  const types = ['maintenance', 'overhaul', 'inspection'] as const;

  for (let i = 0; i < 100000; i++) {
    const dayOffset = Math.floor(Math.random() * 12 * 365);
    events.push({
      id: `evt-${i}`,
      timestamp: startTs + dayOffset * 24 * 60 * 60 * 1000,
      trainId: `TRAIN-${String((i % 50) + 1).padStart(3, '0')}`,
      type: types[Math.floor(Math.random() * 3)],
      x: dayOffset,
      y: i % 50,
    });
  }
  return events;
};

export const LargeDataset: Story = {
  render: () => {
    const largeData = useMemo(() => generateLargeDataset(), []);
    return <InteractiveWrapper data={largeData} width={800} height={500} />;
  },
  parameters: {
    docs: {
      description: {
        story: `
**100,000 points** - demonstrates deck.gl's ability to handle very large datasets.
