import { DeckGLFilterDemo } from './DeckGLFilterDemo';
import { RangeSlider } from '@blueprintjs/core';
import { MOCK_MAINTENANCE_EVENTS, MOCK_BOUNDS } from './mockData';

const meta: Meta<typeof DeckGLFilterDemo> = {
  title: 'Time Scrubber POC/deck.gl DataFilter',
  component: DeckGLFilterDemo,
  parameters: {
    layout: 'padded',
    docs: {
      description: {
        component: `
## deck.gl DataFilterExtension

GPU-based time filtering for massive datasets (60,000+ points).

### Key Performance Characteristics
- **filterRange updates are essentially free** - uniform update only
- **No attribute regeneration** when changing time range
- **Handles millions of points** at 60 FPS
- **Soft edges available** for fade effects

### Critical: 32-bit Float Precision
For 12-year time ranges, you MUST subtract an origin timestamp:

\`\`\`typescript
const ORIGIN_TS = new Date('2013-01-01').getTime();
getFilterValue: d => d.timestamp - ORIGIN_TS,
filterRange: [rangeStart - ORIGIN_TS, rangeEnd - ORIGIN_TS]
\`\`\`

Without this, 32-bit floats lose precision for timestamps far from epoch.

### Recommended Architecture
1. **Overview chart**: uPlot with Canvas rendering (density visualization)
2. **Brush handles**: d3-brush or BlueprintJS RangeSlider
3. **Main visualization**: deck.gl with DataFilterExtension
4. **State sync**: React state → filterRange prop

### Integration Example
\`\`\`typescript
const [timeRange, setTimeRange] = useState<[number, number]>([...]);

// Scrubber updates deck.gl filter
const handleScrubberChange = (range: [number, number]) => {
  setTimeRange(range);
};

<ScatterplotLayer
  data={maintenanceData}
  getFilterValue={d => d.timestamp - ORIGIN_TS}
  filterRange={[timeRange[0] - ORIGIN_TS, timeRange[1] - ORIGIN_TS]}
  extensions={[new DataFilterExtension({ filterSize: 1 })]}
/>
\`\`\`
        `,
      },
    },
  },
  tags: ['autodocs'],
};

export default meta;
type Story = StoryObj<typeof DeckGLFilterDemo>;

// Interactive wrapper with time range slider
const InteractiveWrapper = ({
  data,
  width,
  height,
  useSoftRange,
}: {
  data: typeof MOCK_MAINTENANCE_EVENTS;
  width: number;
  height: number;
  useSoftRange?: boolean;
}) => {
  // Calculate bounds from data
  const bounds = useMemo(() => {
    let min = Infinity,
      max = -Infinity;
    for (const event of data) {
      if (event.timestamp < min) min = event.timestamp;
      if (event.timestamp > max) max = event.timestamp;
    }
    return { min, max };
  }, [data]);

  // Time range state
  const [timeRange, setTimeRange] = useState<[number, number]>([
    bounds.min + (bounds.max - bounds.min) * 0.3,
    bounds.min + (bounds.max - bounds.min) * 0.7,
  ]);

  const handleRangeChange = useCallback((value: [number, number]) => {
    setTimeRange(value);
  }, []);

  // Format timestamp for display
  const formatDate = (ts: number) => {
    return new Date(ts).toLocaleDateString('en-US', {
      month: 'short',
      year: 'numeric',
    });
  };

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      {/* Time range slider */}
      <div
        style={{
          marginBottom: 16,
          padding: 16,
          background: '#f8fafc',
          borderRadius: 8,
        }}
      >
        <div
          style={{
            display: 'flex',
            justifyContent: 'space-between',
            marginBottom: 8,
            fontSize: 12,
            color: '#64748b',
          }}
        >
          <span>{formatDate(bounds.min)}</span>
          <span style={{ fontWeight: 600, color: '#334155' }}>
            {formatDate(timeRange[0])} - {formatDate(timeRange[1])}
          </span>
          <span>{formatDate(bounds.max)}</span>
        </div>
        <RangeSlider
          min={bounds.min}
          max={bounds.max}
          value={timeRange}
          onChange={handleRangeChange}
          stepSize={(bounds.max - bounds.min) / 1000}
          labelRenderer={false}
        />
      </div>

      {/* deck.gl canvas */}
      <DeckGLFilterDemo
        data={data}
        width={width}
        height={height}
        timeRange={timeRange}
        useSoftRange={useSoftRange}
      />

      {/* Performance note */}
      <div
        style={{
          marginTop: 16,
          padding: 12,
          background: '#ecfdf5',
          borderRadius: 4,
          fontSize: 11,
          color: '#065f46',
        }}
      >
        <strong>Performance Note:</strong> Drag the slider to filter{' '}
        {data.length.toLocaleString()} points in real-time. GPU-based filtering keeps this
        smooth even with massive datasets.
      </div>
    </div>
  );
};

