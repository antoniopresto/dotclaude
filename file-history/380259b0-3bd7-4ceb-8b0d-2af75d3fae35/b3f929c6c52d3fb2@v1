/**
 * OperationalLayer Component
 *
 * Displays individual tasks as colored blocks in a Gantt-style view.
 * Shows the classic "DNA double helix" pattern of maintenance tasks.
 *
 * LOD: Operational (1.0x - 3.0x zoom)
 */

import React, { useMemo, useState } from 'react';
import DeckGL from '@deck.gl/react';
import { OrthographicView } from '@deck.gl/core';
import { SolidPolygonLayer } from '@deck.gl/layers';
import type { PickingInfo } from '@deck.gl/core';
import type { Task, Train } from '../../data/mock-generator';
import { MAINTENANCE_TYPES, MAINTENANCE_TYPE_MAP, TIME_RANGE, COLORS } from '../../data/mock-config';

// =============================================================================
// TYPES
// =============================================================================

export interface OperationalLayerProps {
  /** Task data */
  tasks: Task[];
  /** Train data for row labels */
  trains: Train[];
  /** Width of the viewport */
  width: number;
  /** Height of the viewport */
  height: number;
  /** Camera X position (pan) - days from start */
  cameraX?: number;
  /** Camera Y position (pan) - train index */
  cameraY?: number;
  /** Zoom level */
  zoom?: number;
  /** Opacity for crossfade transitions */
  opacity?: number;
  /** Callback when a task is clicked */
  onTaskClick?: (task: Task) => void;
  /** Callback when a task is hovered */
  onTaskHover?: (task: Task | null) => void;
  /** Currently hovered task ID */
  hoveredTaskId?: string | null;
  /** Currently selected task ID */
  selectedTaskId?: string | null;
  /** Show today line */
  showTodayLine?: boolean;
}

interface TaskPolygon {
  polygon: [number, number][];
  task: Task;
  color: [number, number, number, number];
}

// =============================================================================
// CONSTANTS
// =============================================================================

const PX_PER_DAY = 8;
const PX_PER_TRAIN = 28;
const TASK_HEIGHT = 20;
const TASK_GAP = 4;

// Parse hex to RGBA
function hexToRgba(hex: string, alpha: number = 255): [number, number, number, number] {
  const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
  if (result) {
    return [
      parseInt(result[1], 16),
      parseInt(result[2], 16),
      parseInt(result[3], 16),
      alpha,
    ];
  }
  return [128, 128, 128, alpha];
}

// =============================================================================
// HELPERS
// =============================================================================

function daysBetween(start: Date, end: Date): number {
  return Math.floor((end.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}

function createTaskPolygons(tasks: Task[]): TaskPolygon[] {
  const startDate = TIME_RANGE.start;

  return tasks.map((task) => {
    const startDay = daysBetween(startDate, task.startDate);
    const endDay = daysBetween(startDate, task.endDate);
    const duration = Math.max(1, endDay - startDay);

    const x = startDay * PX_PER_DAY;
    const y = task.trainIndex * PX_PER_TRAIN + TASK_GAP;
    const w = duration * PX_PER_DAY - 1;
    const h = TASK_HEIGHT;

    const mt = MAINTENANCE_TYPE_MAP.get(task.type);
    const baseColor = mt?.color ?? COLORS.task.default;

    // Adjust color based on status
    let alpha = 255;
    if (task.status === 'completed') alpha = 180;
    if (task.status === 'overdue') alpha = 255;

    return {
      polygon: [
        [x, y],
        [x + w, y],
        [x + w, y + h],
        [x, y + h],
      ],
      task,
      color: hexToRgba(baseColor, alpha),
    };
  });
}

// =============================================================================
// COMPONENT
// =============================================================================

export const OperationalLayer: React.FC<OperationalLayerProps> = ({
  tasks,
  trains,
  width,
  height,
  cameraX = 0,
  cameraY = 0,
  zoom = 1,
  opacity = 1,
  onTaskClick,
  onTaskHover,
  hoveredTaskId,
  selectedTaskId,
  showTodayLine = true,
}) => {
  // Calculate dimensions
  const totalDays = TIME_RANGE.years * 365;
  const totalWidth = totalDays * PX_PER_DAY;
  const totalHeight = trains.length * PX_PER_TRAIN;

  // Calculate "today" position (mid-2030 for demo)
  const today = new Date('2030-06-15');
  const todayX = daysBetween(TIME_RANGE.start, today) * PX_PER_DAY;

  // Create task polygons
  const taskPolygons = useMemo(() => createTaskPolygons(tasks), [tasks]);

  // Create deck.gl layers
  const layers = useMemo(() => {
    const layerList = [];

    // Background alternating rows
    layerList.push(
      new SolidPolygonLayer<{ polygon: [number, number][]; trainIndex: number }>({
        id: 'operational-grid',
        data: trains.map((_, i) => ({
          polygon: [
            [0, i * PX_PER_TRAIN],
            [totalWidth, i * PX_PER_TRAIN],
            [totalWidth, (i + 1) * PX_PER_TRAIN - 1],
            [0, (i + 1) * PX_PER_TRAIN - 1],
          ] as [number, number][],
          trainIndex: i,
        })),
        getPolygon: (d) => d.polygon,
        getFillColor: (d) => d.trainIndex % 2 === 0
          ? [250, 250, 250, 255] as [number, number, number, number]
          : [245, 245, 245, 255] as [number, number, number, number],
        pickable: false,
        opacity: opacity * 0.8,
      })
    );

    // Task bars
    layerList.push(
      new SolidPolygonLayer<TaskPolygon>({
        id: 'operational-tasks',
        data: taskPolygons,
        getPolygon: (d) => d.polygon,
        getFillColor: (d) => {
          // Selected state
          if (d.task.id === selectedTaskId) {
            return [59, 130, 246, 255] as [number, number, number, number]; // blue-500
          }
          // Hovered state
          if (d.task.id === hoveredTaskId) {
            return [
              Math.min(255, d.color[0] + 30),
              Math.min(255, d.color[1] + 30),
              Math.min(255, d.color[2] + 30),
              255,
            ] as [number, number, number, number];
          }
          // Conflict state
          if (d.task.hasConflict) {
            return [239, 68, 68, 255] as [number, number, number, number]; // red-500
          }
          return d.color;
        },
        getLineColor: (d) => {
          if (d.task.id === selectedTaskId) {
            return [30, 64, 175, 255] as [number, number, number, number]; // blue-800
          }
          if (d.task.hasConflict) {
            return [153, 27, 27, 255] as [number, number, number, number]; // red-900
          }
          return [0, 0, 0, 0] as [number, number, number, number];
        },
        getLineWidth: (d) => (d.task.id === selectedTaskId || d.task.hasConflict) ? 2 : 0,
        pickable: true,
        opacity,
        updateTriggers: {
          getFillColor: [hoveredTaskId, selectedTaskId],
          getLineColor: [selectedTaskId],
          getLineWidth: [selectedTaskId],
        },
      })
    );

    // Today line
    if (showTodayLine) {
      layerList.push(
        new SolidPolygonLayer({
          id: 'today-line',
          data: [{
            polygon: [
              [todayX - 1, 0],
              [todayX + 1, 0],
              [todayX + 1, totalHeight],
              [todayX - 1, totalHeight],
            ],
          }],
          getPolygon: (d) => d.polygon,
          getFillColor: [239, 68, 68, 200], // red-500
          pickable: false,
          opacity,
        })
      );
    }

    return layerList;
  }, [taskPolygons, trains, totalWidth, totalHeight, hoveredTaskId, selectedTaskId, showTodayLine, todayX, opacity]);

  // Handle picking
  const handleClick = (info: PickingInfo) => {
    if (info.object && onTaskClick) {
      const poly = info.object as TaskPolygon;
      if (poly.task) {
        onTaskClick(poly.task);
      }
    }
  };

  const handleHover = (info: PickingInfo) => {
    if (onTaskHover) {
      if (info.object) {
        const poly = info.object as TaskPolygon;
        if (poly.task) {
          onTaskHover(poly.task);
        }
      } else {
        onTaskHover(null);
      }
    }
  };

  // Create orthographic view
  const views = new OrthographicView({
    id: 'operational-view',
    flipY: false,
    controller: false,
  });

  const viewState = {
    target: [cameraX * PX_PER_DAY + width / 2, cameraY * PX_PER_TRAIN + height / 2, 0],
    zoom: Math.log2(zoom),
  };

  return (
    <div style={{ width, height, position: 'relative' }}>
      <DeckGL
        width={width}
        height={height}
        views={views}
        viewState={viewState}
        layers={layers}
        onClick={handleClick}
        onHover={handleHover}
        getCursor={() => 'pointer'}
      />

      {/* Legend */}
      <div
        style={{
          position: 'absolute',
          bottom: 16,
          right: 16,
          background: 'white',
          padding: '8px 12px',
          borderRadius: 8,
          boxShadow: '0 2px 8px rgba(0,0,0,0.15)',
          fontSize: 11,
          opacity,
        }}
      >
        <div style={{ fontWeight: 600, marginBottom: 6 }}>Maintenance Types</div>
        <div style={{ display: 'flex', flexDirection: 'column', gap: 3 }}>
          {MAINTENANCE_TYPES.map((mt) => (
            <div key={mt.id} style={{ display: 'flex', alignItems: 'center', gap: 6 }}>
              <div
                style={{
                  width: 16,
                  height: 10,
                  backgroundColor: mt.color,
                  borderRadius: 2,
                }}
              />
              <span>{mt.name}</span>
            </div>
          ))}
        </div>
        <div style={{ marginTop: 8, paddingTop: 6, borderTop: '1px solid #eee' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 6 }}>
            <div
              style={{
                width: 16,
                height: 10,
                backgroundColor: '#ef4444',
                borderRadius: 2,
              }}
            />
            <span>Conflict</span>
          </div>
        </div>
      </div>

      {/* Info box for viewing stats */}
      <div
        style={{
          position: 'absolute',
          top: 16,
          right: 16,
          background: 'white',
          padding: '8px 12px',
          borderRadius: 8,
          boxShadow: '0 2px 8px rgba(0,0,0,0.15)',
          fontSize: 11,
          opacity,
        }}
      >
        <div style={{ fontWeight: 600, marginBottom: 4 }}>View Stats</div>
        <div>Tasks: {tasks.length.toLocaleString()}</div>
        <div>Trains: {trains.length}</div>
        <div>Days: {totalDays.toLocaleString()}</div>
      </div>
    </div>
  );
};

export default OperationalLayer;
