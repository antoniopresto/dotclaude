// Integration example
const IntegrationExample = () => {
  const [range, setRange] = useState<[Date, Date] | null>(null);

  const filterRangeForDeckGL = range
    ? {
        start: range[0].getTime(),
        end: range[1].getTime(),
        // For deck.gl DataFilterExtension:
        // filterRange: [range[0].getTime() - ORIGIN_TS, range[1].getTime() - ORIGIN_TS]
      }
    : null;

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      <BlueprintRangeSlider
        data={SMALL_MONTHLY_DATA}
        width={500}
        selection={range}
        onRangeChange={setRange}
      />

      <div
        style={{
          marginTop: 16,
          padding: 16,
          background: '#1e293b',
          borderRadius: 8,
          color: '#e2e8f0',
          fontFamily: 'monospace',
          fontSize: 11,
        }}
      >
        <div style={{ color: '#94a3b8', marginBottom: 8 }}>
          // Output for deck.gl integration
        </div>
        <pre style={{ margin: 0 }}>
          {filterRangeForDeckGL
            ? `filterRange: [
  ${filterRangeForDeckGL.start} - ORIGIN_TS,
  ${filterRangeForDeckGL.end} - ORIGIN_TS
]`
            : 'filterRange: null // No selection'}
        </pre>
      </div>

      <div
        style={{
          marginTop: 12,
          padding: 12,
          background: '#ecfdf5',
          borderRadius: 4,
          fontSize: 11,
          color: '#065f46',
        }}
      >
        <strong>Integration Pattern:</strong> The RangeSlider emits Date objects. Convert to
        timestamps and subtract ORIGIN_TS for deck.gl DataFilterExtension compatibility.
      </div>
    </div>
  );
};

