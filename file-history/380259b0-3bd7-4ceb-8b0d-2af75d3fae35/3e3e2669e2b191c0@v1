type Story = StoryObj<typeof BlueprintRangeSlider>;

// Interactive wrapper
const InteractiveWrapper = ({
  data,
  width,
  ...props
}: {
  data: typeof SMALL_MONTHLY_DATA;
  width: number;
  [key: string]: unknown;
}) => {
  const [selection, setSelection] = useState<[Date, Date] | null>(null);

  const handleRangeChange = useCallback((range: [Date, Date]) => {
    setSelection(range);
  }, []);

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      <BlueprintRangeSlider
        data={data}
        width={width}
        selection={selection}
        onRangeChange={handleRangeChange}
        {...props}
      />
      <div
        style={{
          marginTop: 16,
          padding: 12,
          background: '#f5f5f5',
          borderRadius: 4,
          fontSize: 12,
        }}
      >
        <strong>Selected:</strong>{' '}
        {selection
          ? `${selection[0].toLocaleDateString()} - ${selection[1].toLocaleDateString()}`
          : 'Drag the slider handles to select a range'}
      </div>
    </div>
  );
};

