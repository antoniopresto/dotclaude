export const WithControls: Story = {
  name: 'With Pan/Zoom Controls',
  render: () => {
    const [cameraX, setCameraX] = useState(0);
    const [cameraY, setCameraY] = useState(0);
    const [zoom, setZoom] = useState(1);
    const [hoveredCell, setHoveredCell] = useState<AggregatedCell | null>(null);

    // Calculate bounds
    const maxX = 48 * 30; // quarters * cell width
    const maxY = 128 * 20; // trains * cell height

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f4f4f5' }}>
        <StrategicLayer
          cells={mockData.aggregatedByQuarter}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight - 100}
          cameraX={cameraX}
          cameraY={cameraY}
          zoom={zoom}
          hoveredCell={hoveredCell}
          onCellHover={setHoveredCell}
        />

        {/* Controls */}
        <Card
          style={{
            position: 'absolute',
            top: 16,
            right: 16,
            width: 280,
            padding: 16,
          }}
        >
          <div style={{ marginBottom: 16 }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
              <span style={{ fontWeight: 500, fontSize: 12 }}>Horizontal Pan</span>
              <span style={{ fontSize: 11, color: '#666' }}>{cameraX.toFixed(0)}px</span>
            </div>
            <Slider
              min={-maxX / 2}
              max={maxX / 2}
              stepSize={10}
              value={cameraX}
              onChange={setCameraX}
              labelRenderer={false}
            />
          </div>

          <div style={{ marginBottom: 16 }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
              <span style={{ fontWeight: 500, fontSize: 12 }}>Vertical Pan</span>
              <span style={{ fontSize: 11, color: '#666' }}>{cameraY.toFixed(0)}px</span>
            </div>
            <Slider
              min={-maxY / 2}
              max={maxY / 2}
              stepSize={10}
              value={cameraY}
              onChange={setCameraY}
              labelRenderer={false}
            />
          </div>

          <div style={{ marginBottom: 16 }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>
              <span style={{ fontWeight: 500, fontSize: 12 }}>Zoom</span>
              <Tag intent={zoom < 0.3 ? Intent.SUCCESS : Intent.NONE} minimal>
                {zoom.toFixed(2)}x {zoom < 0.3 ? '(Strategic)' : ''}
              </Tag>
            </div>
            <Slider
              min={0.1}
              max={2}
              stepSize={0.05}
              value={zoom}
              onChange={setZoom}
              labelRenderer={false}
            />
          </div>

          <div style={{ fontSize: 11, color: '#666' }}>
            <div>Data: {mockData.stats.totalTrains} trains × {48} quarters</div>
            <div>Cells: {mockData.aggregatedByQuarter.length.toLocaleString()}</div>
            <div>Total Tasks: {mockData.stats.totalTasks.toLocaleString()}</div>
          </div>
        </Card>
      </div>
    );
  },
};

export const FleetComparison: Story = {
  name: 'Fleet Comparison',
  render: () => {
    const [hoveredCell, setHoveredCell] = useState<AggregatedCell | null>(null);

    // Split data by fleet
    const kinkiTrainIndices = new Set(
      mockData.trains
        .filter(t => t.fleetId === 'kinki')
        .map(t => t.index)
    );

    const alstomTrainIndices = new Set(
      mockData.trains
        .filter(t => t.fleetId === 'alstom')
        .map(t => t.index)
    );

    const kinkiCells = mockData.aggregatedByQuarter.filter(
      c => kinkiTrainIndices.has(c.trainIndex)
    );

    const alstomCells = mockData.aggregatedByQuarter.filter(
      c => alstomTrainIndices.has(c.trainIndex)
    );

    // Calculate fleet stats
    const kinkiStats = {
      totalManHours: kinkiCells.reduce((sum, c) => sum + c.totalManHours, 0),
      totalCost: kinkiCells.reduce((sum, c) => sum + c.totalCostAed, 0),
      overhaulCount: kinkiCells.filter(c => c.hasOverhaul).length,
    };

    const alstomStats = {
      totalManHours: alstomCells.reduce((sum, c) => sum + c.totalManHours, 0),
      totalCost: alstomCells.reduce((sum, c) => sum + c.totalCostAed, 0),
      overhaulCount: alstomCells.filter(c => c.hasOverhaul).length,
    };

    return (
      <div style={{ display: 'flex', height: '100vh' }}>
        {/* Kinki Fleet */}
        <div style={{ flex: 1, position: 'relative', borderRight: '2px solid #e2e8f0' }}>
          <div
            style={{
              position: 'absolute',
              top: 8,
              left: 8,
              background: 'white',
              padding: '4px 12px',
              borderRadius: 4,
              fontWeight: 600,
              zIndex: 10,
            }}
          >
            Kinki Fleet (49 trains)
          </div>
          <StrategicLayer
            cells={kinkiCells}
            trains={mockData.trains.filter(t => t.fleetId === 'kinki')}
            width={window.innerWidth / 2 - 1}
            height={window.innerHeight - 80}
            hoveredCell={hoveredCell}
            onCellHover={setHoveredCell}
          />
          <div
            style={{
              position: 'absolute',
              bottom: 80,
              left: 8,
              background: 'white',
              padding: 8,
              borderRadius: 4,
              fontSize: 11,
            }}
          >
            <div>Man-Hours: {(kinkiStats.totalManHours / 1000000).toFixed(2)}M</div>
            <div>Cost: {(kinkiStats.totalCost / 1000000).toFixed(2)}M AED</div>
            <div>Overhauls: {kinkiStats.overhaulCount}</div>
          </div>
        </div>

        {/* Alstom Fleet */}
        <div style={{ flex: 1, position: 'relative' }}>
          <div
            style={{
              position: 'absolute',
              top: 8,
              left: 8,
              background: 'white',
              padding: '4px 12px',
              borderRadius: 4,
              fontWeight: 600,
              zIndex: 10,
            }}
          >
            Alstom Fleet (79 trains)
          </div>
          <StrategicLayer
            cells={alstomCells}
            trains={mockData.trains.filter(t => t.fleetId === 'alstom')}
            width={window.innerWidth / 2 - 1}
            height={window.innerHeight - 80}
            hoveredCell={hoveredCell}
            onCellHover={setHoveredCell}
          />
          <div
            style={{
              position: 'absolute',
              bottom: 80,
              left: 8,
              background: 'white',
              padding: 8,
              borderRadius: 4,
              fontSize: 11,
            }}
          >
            <div>Man-Hours: {(alstomStats.totalManHours / 1000000).toFixed(2)}M</div>
            <div>Cost: {(alstomStats.totalCost / 1000000).toFixed(2)}M AED</div>
            <div>Overhauls: {alstomStats.overhaulCount}</div>
          </div>
        </div>
      </div>
    );
  },
};

export const YearHighlight: Story = {
  name: 'Year Highlight',
  render: () => {
    const [selectedYear, setSelectedYear] = useState(2027);
    const [hoveredCell, setHoveredCell] = useState<AggregatedCell | null>(null);

    // Calculate quarters for selected year
    const yearStartQuarter = (selectedYear - 2024) * 4;
    const yearEndQuarter = yearStartQuarter + 3;

    // Filter cells for selected year
    const yearCells = mockData.aggregatedByQuarter.filter(
      c => c.periodIndex >= yearStartQuarter && c.periodIndex <= yearEndQuarter
    );

    // Calculate year stats
    const yearStats = {
      totalTasks: yearCells.reduce((sum, c) => sum + c.totalTasks, 0),
      totalManHours: yearCells.reduce((sum, c) => sum + c.totalManHours, 0),
      totalCost: yearCells.reduce((sum, c) => sum + c.totalCostAed, 0),
      avgUtilization: yearCells.reduce((sum, c) => sum + c.utilizationPercent, 0) / yearCells.length,
    };

    return (
      <div style={{ width: '100%', height: '100vh', background: '#f4f4f5' }}>
        <StrategicLayer
          cells={mockData.aggregatedByQuarter}
          trains={mockData.trains}
          width={window.innerWidth}
          height={window.innerHeight - 100}
          hoveredCell={hoveredCell}
          onCellHover={setHoveredCell}
        />

        {/* Year selector */}
        <Card
          style={{
            position: 'absolute',
            top: 16,
            left: '50%',
            transform: 'translateX(-50%)',
            padding: 16,
            display: 'flex',
            alignItems: 'center',
            gap: 16,
          }}
        >
          <span style={{ fontWeight: 500 }}>Year:</span>
          <div style={{ display: 'flex', gap: 4 }}>
            {Array.from({ length: 12 }, (_, i) => 2024 + i).map((year) => (
              <button
                key={year}
                onClick={() => setSelectedYear(year)}
                style={{
                  padding: '4px 8px',
                  border: selectedYear === year ? '2px solid #1d4ed8' : '1px solid #e2e8f0',
                  borderRadius: 4,
                  background: selectedYear === year ? '#dbeafe' : 'white',
                  cursor: 'pointer',
                  fontSize: 11,
                  fontWeight: selectedYear === year ? 600 : 400,
                }}
              >
                {year}
              </button>
            ))}
          </div>
        </Card>

        {/* Year stats */}
        <Card
          style={{
            position: 'absolute',
            bottom: 80,
            left: '50%',
            transform: 'translateX(-50%)',
            padding: 16,
          }}
        >
          <div style={{ fontWeight: 600, marginBottom: 8, textAlign: 'center' }}>
            {selectedYear} Summary
          </div>
          <div style={{ display: 'flex', gap: 24 }}>
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontSize: 20, fontWeight: 600 }}>{yearStats.totalTasks.toLocaleString()}</div>
              <div style={{ fontSize: 11, color: '#666' }}>Tasks</div>
            </div>
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontSize: 20, fontWeight: 600 }}>{(yearStats.totalManHours / 1000).toFixed(0)}K</div>
              <div style={{ fontSize: 11, color: '#666' }}>Man-Hours</div>
            </div>
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontSize: 20, fontWeight: 600 }}>{(yearStats.totalCost / 1000000).toFixed(1)}M</div>
              <div style={{ fontSize: 11, color: '#666' }}>AED Cost</div>
            </div>
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontSize: 20, fontWeight: 600 }}>{yearStats.avgUtilization.toFixed(0)}%</div>
              <div style={{ fontSize: 11, color: '#666' }}>Avg Util</div>
            </div>
          </div>
        </Card>
      </div>
    );
  },
};
