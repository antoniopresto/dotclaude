/**
 * TodayLine Component
 *
 * A vertical line indicator showing "today" position on the timeline.
 * Supports different visual styles for each LOD level.
 */

import React from 'react';
import { COLORS } from '../../data/mock-config';

// =============================================================================
// TYPES
// =============================================================================

export type TodayLineStyle = 'minimal' | 'standard' | 'detailed';

export interface TodayLineProps {
  /** X position in pixels */
  x: number;
  /** Height of the line */
  height: number;
  /** Visual style based on zoom level */
  style?: TodayLineStyle;
  /** Optional label (e.g., "Today", "Jun 15") */
  label?: string;
  /** Show pulsing animation */
  animate?: boolean;
  /** Opacity for transitions */
  opacity?: number;
  /** Z-index for layering */
  zIndex?: number;
}

// =============================================================================
// STYLES
// =============================================================================

const containerStyle: React.CSSProperties = {
  position: 'absolute',
  top: 0,
  pointerEvents: 'none',
  display: 'flex',
  flexDirection: 'column',
  alignItems: 'center',
};

const labelStyle: React.CSSProperties = {
  position: 'absolute',
  top: '-24px',
  backgroundColor: COLORS.today,
  color: 'white',
  padding: '2px 8px',
  borderRadius: '4px',
  fontSize: '11px',
  fontWeight: 600,
  whiteSpace: 'nowrap',
  boxShadow: '0 2px 4px rgba(0,0,0,0.2)',
};

const detailedLabelStyle: React.CSSProperties = {
  ...labelStyle,
  top: '-28px',
  padding: '4px 12px',
  fontSize: '12px',
  borderRadius: '6px',
};

// =============================================================================
// COMPONENT
// =============================================================================

export const TodayLine: React.FC<TodayLineProps> = ({
  x,
  height,
  style = 'standard',
  label = 'Today',
  animate = true,
  opacity = 1,
  zIndex = 100,
}) => {
  const lineWidth = style === 'minimal' ? 1 : style === 'detailed' ? 3 : 2;
  const showLabel = style !== 'minimal';
  const showGlow = style === 'detailed';

  return (
    <div
      style={{
        ...containerStyle,
        left: x,
        height,
        opacity,
        zIndex,
      }}
    >
      {/* Label */}
      {showLabel && (
        <div style={style === 'detailed' ? detailedLabelStyle : labelStyle}>
          {label}
        </div>
      )}

      {/* SVG Line */}
      <svg
        width={showGlow ? 20 : 10}
        height={height}
        style={{ overflow: 'visible' }}
      >
        {/* Glow effect for detailed view */}
        {showGlow && (
          <>
            <defs>
              <filter id="today-glow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="3" result="coloredBlur" />
                <feMerge>
                  <feMergeNode in="coloredBlur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
            </defs>
            <line
              x1={10}
              y1={0}
              x2={10}
              y2={height}
              stroke={COLORS.today}
              strokeWidth={6}
              opacity={0.3}
              filter="url(#today-glow)"
            />
          </>
        )}

        {/* Main line */}
        <line
          x1={showGlow ? 10 : 5}
          y1={0}
          x2={showGlow ? 10 : 5}
          y2={height}
          stroke={COLORS.today}
          strokeWidth={lineWidth}
          strokeDasharray={style === 'minimal' ? '4,4' : undefined}
        />

        {/* Animated pulse dot */}
        {animate && style !== 'minimal' && (
          <circle
            cx={showGlow ? 10 : 5}
            cy={0}
            r={style === 'detailed' ? 6 : 4}
            fill={COLORS.today}
          >
            <animate
              attributeName="r"
              values={style === 'detailed' ? '6;10;6' : '4;7;4'}
              dur="2s"
              repeatCount="indefinite"
            />
            <animate
              attributeName="opacity"
              values="1;0.5;1"
              dur="2s"
              repeatCount="indefinite"
            />
          </circle>
        )}
      </svg>
    </div>
  );
};

// =============================================================================
// SVG VERSION (for use inside SVG containers)
// =============================================================================

export interface TodayLineSVGProps {
  /** X position */
  x: number;
  /** Start Y position */
  y1: number;
  /** End Y position */
  y2: number;
  /** Visual style */
  style?: TodayLineStyle;
  /** Opacity */
  opacity?: number;
}

export const TodayLineSVG: React.FC<TodayLineSVGProps> = ({
  x,
  y1,
  y2,
  style = 'standard',
  opacity = 1,
}) => {
  const lineWidth = style === 'minimal' ? 1 : style === 'detailed' ? 3 : 2;

  return (
    <g opacity={opacity}>
      {/* Glow for detailed */}
      {style === 'detailed' && (
        <line
          x1={x}
          y1={y1}
          x2={x}
          y2={y2}
          stroke={COLORS.today}
          strokeWidth={8}
          opacity={0.2}
        />
      )}

      {/* Main line */}
      <line
        x1={x}
        y1={y1}
        x2={x}
        y2={y2}
        stroke={COLORS.today}
        strokeWidth={lineWidth}
        strokeDasharray={style === 'minimal' ? '4,4' : undefined}
      />

      {/* Top marker */}
      {style !== 'minimal' && (
        <circle
          cx={x}
          cy={y1}
          r={style === 'detailed' ? 5 : 3}
          fill={COLORS.today}
        />
      )}
    </g>
  );
};

export default TodayLine;
