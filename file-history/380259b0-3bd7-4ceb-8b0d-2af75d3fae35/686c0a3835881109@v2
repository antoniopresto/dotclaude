/**
 * PerfMonitor - Performance monitoring hooks and types
 *
 * NOTE: This is a simplified version after deck.gl migration.
 * The r3f-perf integration was removed since it's R3F-specific.
 *
 * Features:
 * - usePerfMonitorToggle hook for visibility toggle
 * - PerfEvent type for performance event categorization
 *
 * @see docs/PERFORMANCE_LOGGING.md for detailed documentation
 */

import { useEffect, useCallback, useState } from 'react';

// ─────────────────────────────────────────────────────────────
// TYPES
// ─────────────────────────────────────────────────────────────

/**
 * Event type for performance logging
 */
export type PerfEvent = 'idle' | 'panning' | 'zooming' | 'animating' | 'lod_transition' | 'unknown';

// ─────────────────────────────────────────────────────────────
// TOGGLE HOOK
// ─────────────────────────────────────────────────────────────

/**
 * Hook to toggle perf monitor visibility with keyboard shortcut
 *
 * @example
 * const { visible, toggle } = usePerfMonitorToggle();
 */
export function usePerfMonitorToggle(initialVisible = false) {
  const [visible, setVisible] = useState(initialVisible);

  useEffect(() => {
    const handleKeyDown = (e: KeyboardEvent) => {
      // Toggle on 'P' key (not when typing in input)
      if (
        e.key === 'p' &&
        !e.ctrlKey &&
        !e.metaKey &&
        !e.altKey &&
        !(e.target instanceof HTMLInputElement) &&
        !(e.target instanceof HTMLTextAreaElement)
      ) {
        setVisible((v) => !v);
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, []);

  const toggle = useCallback(() => setVisible((v) => !v), []);

  return { visible, toggle, setVisible };
}
