/**
 * Recharts TimeScrubber POC
 *
 * Uses Recharts built-in Brush component with Area chart.
 * Fastest implementation path - works out of the box.
 *
 * Pros:
 * - Minimal code required
 * - Built-in "Panorama" feature (mini chart in brush)
 * - Good documentation and community
 *
 * Cons:
 * - Limited customization
 * - SVG-based (struggles beyond 8,000 points without downsampling)
 * - Less TypeScript coverage than visx
 */

import React, { useState, useCallback } from 'react';
import {
  AreaChart,
  Area,
  Brush,
  ResponsiveContainer,
  XAxis,
  YAxis,
  Tooltip,
  CartesianGrid,
} from 'recharts';
import type { TimeSeriesPoint } from './mockData';

interface RechartsTimeScrubberProps {
  /** Time series data for density visualization */
  data: TimeSeriesPoint[];
  /** Height of the main chart area */
  mainChartHeight?: number;
  /** Height of the brush area */
  brushHeight?: number;
  /** Callback when brush selection changes */
  onBrushChange?: (domain: { startIndex: number; endIndex: number } | null) => void;
  /** Initial brush indices */
  initialBrushIndices?: { startIndex: number; endIndex: number };
  /** Area fill color */
  fillColor?: string;
  /** Stroke color */
  strokeColor?: string;
  /** Show main chart with zoomed data */
  showMainChart?: boolean;
}

// Transform data for Recharts format
const transformData = (data: TimeSeriesPoint[]) =>
  data.map((point) => ({
    ...point,
    dateStr: point.date.toLocaleDateString('en-US', { month: 'short', year: '2-digit' }),
    timestamp: point.timestamp,
  }));

export const RechartsTimeScrubber: React.FC<RechartsTimeScrubberProps> = ({
  data,
  mainChartHeight = 200,
  brushHeight = 40,
  onBrushChange,
  initialBrushIndices,
  fillColor = '#6366f1',
  strokeColor = '#4f46e5',
  showMainChart = true,
}) => {
  const [brushRange, setBrushRange] = useState<{ startIndex: number; endIndex: number } | null>(
    initialBrushIndices || null
  );

  const chartData = React.useMemo(() => transformData(data), [data]);

  const handleBrushChange = useCallback(
    (newRange: { startIndex?: number; endIndex?: number } | null) => {
      if (!newRange || newRange.startIndex === undefined || newRange.endIndex === undefined) {
        setBrushRange(null);
        onBrushChange?.(null);
        return;
      }

      const range = {
        startIndex: newRange.startIndex,
        endIndex: newRange.endIndex,
      };
      setBrushRange(range);
      onBrushChange?.(range);
    },
    [onBrushChange]
  );

  const formatXAxis = (timestamp: number) => {
    return new Date(timestamp).toLocaleDateString('en-US', { month: 'short', year: '2-digit' });
  };

  // Get visible data based on brush selection
  const visibleData =
    brushRange && showMainChart
      ? chartData.slice(brushRange.startIndex, brushRange.endIndex + 1)
      : chartData;

  return (
    <div style={{ width: '100%', fontFamily: 'system-ui, sans-serif' }}>
      {/* Main Chart (zoomed view) */}
      {showMainChart && (
        <ResponsiveContainer width="100%" height={mainChartHeight}>
          <AreaChart data={visibleData} margin={{ top: 10, right: 10, left: 0, bottom: 0 }}>
            <defs>
              <linearGradient id="recharts-gradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="5%" stopColor={fillColor} stopOpacity={0.4} />
                <stop offset="95%" stopColor={fillColor} stopOpacity={0.1} />
              </linearGradient>
            </defs>
            <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
            <XAxis
              dataKey="timestamp"
              tickFormatter={formatXAxis}
              tick={{ fontSize: 10, fill: '#666' }}
              tickLine={false}
              axisLine={{ stroke: '#e5e7eb' }}
            />
            <YAxis
              tick={{ fontSize: 10, fill: '#666' }}
              tickLine={false}
              axisLine={false}
              width={40}
            />
            <Tooltip
              labelFormatter={(timestamp) =>
                new Date(timestamp as number).toLocaleDateString('en-US', {
                  month: 'long',
                  day: 'numeric',
                  year: 'numeric',
                })
              }
              formatter={(value: number) => [value, 'Tasks']}
              contentStyle={{
                background: 'white',
                border: '1px solid #e5e7eb',
                borderRadius: 4,
                fontSize: 12,
              }}
            />
            <Area
              type="monotone"
              dataKey="value"
              stroke={strokeColor}
              strokeWidth={2}
              fill="url(#recharts-gradient)"
            />
          </AreaChart>
        </ResponsiveContainer>
      )}

      {/* Brush with mini chart */}
      <ResponsiveContainer width="100%" height={brushHeight + 30}>
        <AreaChart
          data={chartData}
          margin={{ top: 0, right: 10, left: 0, bottom: 0 }}
        >
          <defs>
            <linearGradient id="recharts-brush-gradient" x1="0" y1="0" x2="0" y2="1">
              <stop offset="5%" stopColor="#94a3b8" stopOpacity={0.4} />
              <stop offset="95%" stopColor="#94a3b8" stopOpacity={0.1} />
            </linearGradient>
          </defs>
          <Area
            type="monotone"
            dataKey="value"
            stroke="#94a3b8"
            strokeWidth={1}
            fill="url(#recharts-brush-gradient)"
          />
          <Brush
            dataKey="timestamp"
            height={brushHeight}
            stroke={strokeColor}
            fill="rgba(99, 102, 241, 0.1)"
            tickFormatter={formatXAxis}
            startIndex={initialBrushIndices?.startIndex}
            endIndex={initialBrushIndices?.endIndex}
            onChange={handleBrushChange}
          >
            {/* Mini chart inside brush (Panorama feature) */}
            <AreaChart data={chartData}>
              <Area
                type="monotone"
                dataKey="value"
                stroke="#94a3b8"
                strokeWidth={0.5}
                fill="#e2e8f0"
              />
            </AreaChart>
          </Brush>
        </AreaChart>
      </ResponsiveContainer>
    </div>
  );
};

export default RechartsTimeScrubber;
