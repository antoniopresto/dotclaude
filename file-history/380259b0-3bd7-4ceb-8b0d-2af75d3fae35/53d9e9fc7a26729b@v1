/**
 * GanttBar Component
 *
 * A reusable bar component for task visualization in Gantt charts.
 * Supports different maintenance types with color coding.
 */

import React from 'react';
import type { MaintenanceTypeId, TaskStatus } from '../../data/mock-config';
import { COLORS, MAINTENANCE_TYPE_MAP } from '../../data/mock-config';

// =============================================================================
// TYPES
// =============================================================================

export interface GanttBarProps {
  /** Unique task identifier */
  id: string;
  /** Maintenance type for color coding */
  type: MaintenanceTypeId;
  /** Task status */
  status: TaskStatus;
  /** X position in pixels */
  x: number;
  /** Y position in pixels */
  y: number;
  /** Bar width in pixels */
  width: number;
  /** Bar height in pixels */
  height: number;
  /** Optional label text */
  label?: string;
  /** Show label inside bar */
  showLabel?: boolean;
  /** Is this task selected */
  isSelected?: boolean;
  /** Is this task hovered */
  isHovered?: boolean;
  /** Has conflict with other tasks */
  hasConflict?: boolean;
  /** Click handler */
  onClick?: (id: string) => void;
  /** Hover enter handler */
  onMouseEnter?: (id: string) => void;
  /** Hover leave handler */
  onMouseLeave?: () => void;
  /** Opacity for crossfade transitions */
  opacity?: number;
}

// =============================================================================
// STYLES
// =============================================================================

const getBarColor = (type: MaintenanceTypeId): string => {
  const maintenanceType = MAINTENANCE_TYPE_MAP.get(type);
  return maintenanceType?.color ?? COLORS.task.default;
};

const getStatusOpacity = (status: TaskStatus): number => {
  switch (status) {
    case 'completed':
      return 0.7;
    case 'in-progress':
      return 1.0;
    case 'scheduled':
      return 0.9;
    case 'overdue':
      return 1.0;
    case 'conflict':
      return 1.0;
    default:
      return 0.9;
  }
};

const getStatusPattern = (status: TaskStatus): string | undefined => {
  if (status === 'overdue') {
    return 'url(#overdue-pattern)';
  }
  return undefined;
};

// =============================================================================
// COMPONENT
// =============================================================================

export const GanttBar: React.FC<GanttBarProps> = ({
  id,
  type,
  status,
  x,
  y,
  width,
  height,
  label,
  showLabel = false,
  isSelected = false,
  isHovered = false,
  hasConflict = false,
  onClick,
  onMouseEnter,
  onMouseLeave,
  opacity = 1,
}) => {
  const baseColor = getBarColor(type);
  const statusOpacity = getStatusOpacity(status);
  const pattern = getStatusPattern(status);

  // Calculate visual properties
  const borderRadius = Math.min(4, height / 4);
  const borderWidth = isSelected ? 2 : isHovered ? 1.5 : 0;
  const borderColor = isSelected
    ? COLORS.selection
    : isHovered
      ? COLORS.hover
      : 'transparent';

  // Conflict styling
  const conflictBorder = hasConflict ? `2px solid ${COLORS.conflict}` : undefined;

  // Combined opacity
  const finalOpacity = opacity * statusOpacity;

  const handleClick = () => {
    onClick?.(id);
  };

  const handleMouseEnter = () => {
    onMouseEnter?.(id);
  };

  return (
    <g
      className="gantt-bar"
      onClick={handleClick}
      onMouseEnter={handleMouseEnter}
      onMouseLeave={onMouseLeave}
      style={{ cursor: onClick ? 'pointer' : 'default' }}
    >
      {/* Shadow for depth */}
      {isHovered && (
        <rect
          x={x + 2}
          y={y + 2}
          width={width}
          height={height}
          rx={borderRadius}
          ry={borderRadius}
          fill="rgba(0,0,0,0.15)"
        />
      )}

      {/* Conflict glow */}
      {hasConflict && (
        <rect
          x={x - 3}
          y={y - 3}
          width={width + 6}
          height={height + 6}
          rx={borderRadius + 2}
          ry={borderRadius + 2}
          fill="none"
          stroke={COLORS.conflict}
          strokeWidth={2}
          opacity={0.6}
        />
      )}

      {/* Main bar */}
      <rect
        x={x}
        y={y}
        width={width}
        height={height}
        rx={borderRadius}
        ry={borderRadius}
        fill={pattern ?? baseColor}
        opacity={finalOpacity}
        stroke={borderColor}
        strokeWidth={borderWidth}
      />

      {/* Selection ring */}
      {isSelected && (
        <rect
          x={x - 2}
          y={y - 2}
          width={width + 4}
          height={height + 4}
          rx={borderRadius + 2}
          ry={borderRadius + 2}
          fill="none"
          stroke={COLORS.selection}
          strokeWidth={2}
          opacity={0.8}
        />
      )}

      {/* Label */}
      {showLabel && label && width > 40 && (
        <text
          x={x + width / 2}
          y={y + height / 2}
          textAnchor="middle"
          dominantBaseline="central"
          fill="white"
          fontSize={Math.min(12, height - 4)}
          fontWeight={500}
          style={{ pointerEvents: 'none' }}
        >
          {width > 80 ? label : label.substring(0, 3)}
        </text>
      )}

      {/* Status indicator dot */}
      {status === 'in-progress' && (
        <circle
          cx={x + 6}
          cy={y + height / 2}
          r={3}
          fill="white"
          opacity={0.9}
        />
      )}
    </g>
  );
};

// =============================================================================
// SVG DEFS (Patterns)
// =============================================================================

export const GanttBarDefs: React.FC = () => (
  <defs>
    {/* Overdue diagonal stripes pattern */}
    <pattern
      id="overdue-pattern"
      patternUnits="userSpaceOnUse"
      width="8"
      height="8"
    >
      <rect width="8" height="8" fill={COLORS.conflict} />
      <path
        d="M-2,2 l4,-4 M0,8 l8,-8 M6,10 l4,-4"
        stroke="rgba(255,255,255,0.3)"
        strokeWidth="2"
      />
    </pattern>

    {/* Gradient for completed tasks */}
    <linearGradient id="completed-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stopColor="rgba(255,255,255,0.2)" />
      <stop offset="100%" stopColor="rgba(0,0,0,0.1)" />
    </linearGradient>
  </defs>
);

export default GanttBar;
