/**
 * LTTB (Largest-Triangle-Three-Buckets) Downsampling Algorithm
 *
 * Implementation based on the paper:
 * "Downsampling Time Series for Visual Representation"
 * by Sveinn Steinarsson (2013)
 *
 * This algorithm preserves visual peaks and valleys much better than
 * simple averaging or skip-sampling approaches.
 */

import type { TimeSeriesPoint } from './mockData';

/**
 * Downsample a time series using the LTTB algorithm.
 *
 * @param data - The original time series data (must be sorted by date)
 * @param targetPoints - The desired number of output points
 * @returns Downsampled array preserving visual shape
 */
export function lttb(data: TimeSeriesPoint[], targetPoints: number): TimeSeriesPoint[] {
  // Return as-is if already small enough
  if (data.length <= targetPoints || targetPoints < 3) {
    return data;
  }

  const result: TimeSeriesPoint[] = [];
  const bucketSize = (data.length - 2) / (targetPoints - 2);

  // Always keep the first point
  result.push(data[0]);

  let a = 0; // Point index before current bucket

  for (let i = 0; i < targetPoints - 2; i++) {
    // Calculate point average for next bucket (used as target)
    const avgRangeStart = Math.floor((i + 1) * bucketSize) + 1;
    const avgRangeEnd = Math.min(Math.floor((i + 2) * bucketSize) + 1, data.length);

    let avgX = 0;
    let avgY = 0;
    const avgRangeLength = avgRangeEnd - avgRangeStart;

    for (let j = avgRangeStart; j < avgRangeEnd; j++) {
      avgX += data[j].date.getTime();
      avgY += data[j].value;
    }
    avgX /= avgRangeLength;
    avgY /= avgRangeLength;

    // Get the range for this bucket
    const rangeOffs = Math.floor(i * bucketSize) + 1;
    const rangeTo = Math.floor((i + 1) * bucketSize) + 1;

    // Point A (previous selected point)
    const pointAX = data[a].date.getTime();
    const pointAY = data[a].value;

    // Find the point in this bucket that forms the largest triangle
    let maxArea = -1;
    let maxAreaIndex = rangeOffs;

    for (let j = rangeOffs; j < rangeTo; j++) {
      // Calculate triangle area using cross product formula
      const area = Math.abs(
        (pointAX - avgX) * (data[j].value - pointAY) -
          (pointAX - data[j].date.getTime()) * (avgY - pointAY)
      );

      if (area > maxArea) {
        maxArea = area;
        maxAreaIndex = j;
      }
    }

    result.push(data[maxAreaIndex]);
    a = maxAreaIndex; // This point is now A for the next iteration
  }

  // Always keep the last point
  result.push(data[data.length - 1]);

  return result;
}

/**
 * Simple downsampling using skip-sampling (for comparison).
 * Just picks every Nth point - loses visual peaks/valleys.
 */
export function skipSample(data: TimeSeriesPoint[], targetPoints: number): TimeSeriesPoint[] {
  if (data.length <= targetPoints) {
    return data;
  }

  const step = data.length / targetPoints;
  const result: TimeSeriesPoint[] = [];

  for (let i = 0; i < targetPoints; i++) {
    const index = Math.floor(i * step);
    result.push(data[index]);
  }

  // Ensure last point is included
  if (result[result.length - 1] !== data[data.length - 1]) {
    result[result.length - 1] = data[data.length - 1];
  }

  return result;
}

/**
 * Simple downsampling using averaging within buckets.
 * Smooths out peaks and valleys.
 */
export function averageSample(data: TimeSeriesPoint[], targetPoints: number): TimeSeriesPoint[] {
  if (data.length <= targetPoints) {
    return data;
  }

  const bucketSize = data.length / targetPoints;
  const result: TimeSeriesPoint[] = [];

  for (let i = 0; i < targetPoints; i++) {
    const start = Math.floor(i * bucketSize);
    const end = Math.floor((i + 1) * bucketSize);

    let sumValue = 0;
    let sumTime = 0;
    const count = end - start;

    for (let j = start; j < end; j++) {
      sumValue += data[j].value;
      sumTime += data[j].date.getTime();
    }

    result.push({
      date: new Date(sumTime / count),
      value: sumValue / count,
    });
  }

  return result;
}
