// Algorithm comparison component
const AlgorithmComparison = () => {
  const data = MOCK_TIME_SERIES;
  const targetPoints = 50;

  const lttbData = useMemo(() => lttb(data, targetPoints), []);
  const skipData = useMemo(() => skipSample(data, targetPoints), []);
  const avgData = useMemo(() => averageSample(data, targetPoints), []);

  const margin = { top: 20, right: 10, bottom: 30, left: 40 };
  const width = 280;
  const height = 150;
  const innerWidth = width - margin.left - margin.right;
  const innerHeight = height - margin.top - margin.bottom;

  const createPath = (points: typeof data) => {
    if (points.length === 0) return '';

    const minDate = data[0].date.getTime();
    const maxDate = data[data.length - 1].date.getTime();
    const maxValue = Math.max(...data.map((d) => d.value));
    const minValue = Math.min(...data.map((d) => d.value));
    const valueRange = maxValue - minValue || 1;

    return points
      .map((d, i) => {
        const x = ((d.date.getTime() - minDate) / (maxDate - minDate)) * innerWidth;
        const y = innerHeight - ((d.value - minValue) / valueRange) * innerHeight;
        return `${i === 0 ? 'M' : 'L'} ${x} ${y}`;
      })
      .join(' ');
  };

  const charts = [
    { label: 'Original', data: data, color: '#64748b', points: data.length },
    { label: 'LTTB', data: lttbData, color: '#16a34a', points: lttbData.length },
    { label: 'Skip Sample', data: skipData, color: '#dc2626', points: skipData.length },
    { label: 'Average', data: avgData, color: '#d97706', points: avgData.length },
  ];

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      <div style={{ marginBottom: 16, fontSize: 14, fontWeight: 600 }}>
        Algorithm Comparison (Target: {targetPoints} points)
      </div>
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: 16 }}>
        {charts.map(({ label, data: chartData, color, points }) => (
          <div
            key={label}
            style={{
              border: '1px solid #e2e8f0',
              borderRadius: 8,
              overflow: 'hidden',
              background: 'white',
            }}
          >
            <div
              style={{
                padding: '8px 12px',
                background: '#f8fafc',
                borderBottom: '1px solid #e2e8f0',
                fontSize: 11,
                fontWeight: 600,
              }}
            >
              <span style={{ color }}>{label}</span>
              <span style={{ color: '#64748b', fontWeight: 400, marginLeft: 8 }}>
                ({points.toLocaleString()} pts)
              </span>
            </div>
            <svg width={width} height={height}>
              <g transform={`translate(${margin.left},${margin.top})`}>
                <path d={createPath(chartData)} fill="none" stroke={color} strokeWidth={1.5} />
              </g>
            </svg>
          </div>
        ))}
      </div>
      <div
        style={{
          marginTop: 16,
          padding: 12,
          background: '#fef3c7',
          borderRadius: 8,
          fontSize: 11,
          color: '#92400e',
        }}
      >
        <strong>Key Observation:</strong> Notice how LTTB (green) preserves the peaks and valleys of
        the original data, while Skip Sample (red) misses important features and Average (orange)
        smooths them out.
      </div>
    </div>
  );
};

