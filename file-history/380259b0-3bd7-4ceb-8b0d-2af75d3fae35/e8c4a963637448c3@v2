// Performance benchmark component
const PerformanceBenchmark = () => {
  const runBenchmark = (dataSize: number, targetPoints: number) => {
    const data = generateTimeSeries(dataSize);

    const start = performance.now();
    lttb(data, targetPoints);
    const duration = performance.now() - start;

    return {
      dataSize,
      targetPoints,
      duration: duration.toFixed(2),
      throughput: (dataSize / duration).toFixed(0),
    };
  };

  const benchmarks = [
    runBenchmark(1000, 100),
    runBenchmark(5000, 200),
    runBenchmark(10000, 200),
    runBenchmark(50000, 500),
  ];

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      <div style={{ marginBottom: 16, fontSize: 14, fontWeight: 600 }}>
        LTTB Performance Benchmark
      </div>
      <table
        style={{
          width: '100%',
          borderCollapse: 'collapse',
          fontSize: 12,
        }}
      >
        <thead>
          <tr style={{ background: '#f8fafc' }}>
            <th style={{ padding: 8, textAlign: 'left', borderBottom: '1px solid #e2e8f0' }}>
              Input Points
            </th>
            <th style={{ padding: 8, textAlign: 'left', borderBottom: '1px solid #e2e8f0' }}>
              Target Points
            </th>
            <th style={{ padding: 8, textAlign: 'left', borderBottom: '1px solid #e2e8f0' }}>
              Duration (ms)
            </th>
            <th style={{ padding: 8, textAlign: 'left', borderBottom: '1px solid #e2e8f0' }}>
              Throughput (pts/ms)
            </th>
          </tr>
        </thead>
        <tbody>
          {benchmarks.map((b, i) => (
            <tr key={i}>
              <td style={{ padding: 8, borderBottom: '1px solid #e2e8f0' }}>
                {b.dataSize.toLocaleString()}
              </td>
              <td style={{ padding: 8, borderBottom: '1px solid #e2e8f0' }}>{b.targetPoints}</td>
              <td style={{ padding: 8, borderBottom: '1px solid #e2e8f0' }}>{b.duration}ms</td>
              <td style={{ padding: 8, borderBottom: '1px solid #e2e8f0' }}>
                ~{b.throughput} pts/ms
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      <div
        style={{
          marginTop: 16,
          padding: 12,
          background: '#ecfdf5',
          borderRadius: 8,
          fontSize: 11,
          color: '#065f46',
        }}
      >
        <strong>Performance Note:</strong> LTTB is O(n) and can process tens of thousands of points
        in milliseconds. Safe to run on UI thread for typical datasets.
      </div>
    </div>
  );
};

