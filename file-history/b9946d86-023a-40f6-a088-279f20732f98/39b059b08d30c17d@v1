{
  "$schema": "./keybindingsSchema.json",
  "keybindings": [
    {
      "key": "cmd+t",
      "command": "tab.new",
      "description": "Create new tab"
    },
    {
      "key": "cmd+w",
      "command": "tab.close",
      "description": "Close current tab"
    },
    {
      "key": "cmd+shift+[",
      "command": "tab.previous",
      "description": "Switch to previous tab"
    },
    {
      "key": "cmd+shift+]",
      "command": "tab.next",
      "description": "Switch to next tab"
    },
    {
      "key": "cmd+1",
      "command": "tab.goto",
      "args": { "index": 0 },
      "description": "Go to first tab"
    },
    {
      "key": "cmd+2",
      "command": "tab.goto",
      "args": { "index": 1 },
      "description": "Go to second tab"
    },
    {
      "key": "cmd+3",
      "command": "tab.goto",
      "args": { "index": 2 },
      "description": "Go to third tab"
    },
    {
      "key": "cmd+,",
      "command": "settings.open",
      "description": "Open settings"
    },
    {
      "key": "cmd+k",
      "command": "commandPalette.open",
      "description": "Open command palette"
    },
    {
      "key": "cmd+\\",
      "command": "sidebar.toggle",
      "description": "Toggle sidebar"
    },
    {
      "key": "cmd+j",
      "command": "logs.toggle",
      "description": "Toggle log panel"
    },
    {
      "key": "cmd+o",
      "command": "project.open",
      "description": "Open project"
    },
    {
      "key": "escape",
      "command": "modal.close",
      "when": "modalOpen",
      "description": "Close modal"
    },
    {
      "key": "cmd+enter",
      "command": "terminal.toggle",
      "description": "Toggle terminal panel"
    },
    {
      "key": "cmd+shift+f",
      "command": "search.focus",
      "description": "Focus search"
    },
    {
      "key": "cmd+r",
      "command": "app.reload",
      "when": "debug",
      "description": "Reload application (debug only)"
    }
  ]
}
