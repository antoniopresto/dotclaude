import { formatDate } from '../date-utils';

describe('date-utils', () => {
  test('formatDate M', () => {
    const sut = formatDate('2025-09-25T20:49:09.645Z', 'M');
    expect(sut).toEqual('9');
  });

  test('formatDate MMM', () => {
    const sut = formatDate('2025-09-25T20:49:09.645Z', 'MMM');
    expect(sut).toEqual('set');
  });

  test('handle invalid date', () => {
    expect(() => formatDate('banana', 'MMM')).toThrow(
      'Expected value to match type "date"; found an invalid "Invalid Date" instead',
    );
  });
});
