/**
 * ConstraintDeck Component
 *
 * Displays resource constraints and utilization metrics:
 * - Man-Hours (weekly/monthly capacity)
 * - Track Occupancy (depot tracks)
 * - Budget (quarterly/annual)
 * - Compliance (train status)
 */

import React from 'react';
import { Card, ProgressBar, Tag, Intent, Icon, Collapse, Button } from '@blueprintjs/core';

// =============================================================================
// TYPES
// =============================================================================

export interface ResourceMetric {
  label: string;
  current: number;
  max: number;
  unit: string;
  icon: string;
  thresholds?: {
    warning: number; // Percentage
    danger: number;  // Percentage
  };
}

export interface ComplianceStatus {
  ok: number;
  warning: number;
  critical: number;
  total: number;
}

export interface ConstraintDeckProps {
  /** Man-hours metric */
  manHours: ResourceMetric;
  /** Track occupancy metric */
  trackOccupancy: ResourceMetric;
  /** Budget metric */
  budget: ResourceMetric;
  /** Compliance status */
  compliance: ComplianceStatus;
  /** Whether deck is collapsed */
  collapsed?: boolean;
  /** Toggle collapse callback */
  onToggleCollapse?: () => void;
  /** Width of the deck */
  width?: number | string;
  /** Additional CSS class */
  className?: string;
}

// =============================================================================
// HELPERS
// =============================================================================

function getProgressIntent(
  current: number,
  max: number,
  thresholds?: { warning: number; danger: number }
): Intent {
  const percent = (current / max) * 100;
  if (!thresholds) {
    if (percent >= 90) return Intent.DANGER;
    if (percent >= 75) return Intent.WARNING;
    return Intent.SUCCESS;
  }
  if (percent >= thresholds.danger) return Intent.DANGER;
  if (percent >= thresholds.warning) return Intent.WARNING;
  return Intent.SUCCESS;
}

function formatNumber(num: number): string {
  if (num >= 1_000_000) return `${(num / 1_000_000).toFixed(1)}M`;
  if (num >= 1_000) return `${(num / 1_000).toFixed(1)}K`;
  return num.toLocaleString();
}

// =============================================================================
// SUB-COMPONENTS
// =============================================================================

interface MetricCardProps {
  metric: ResourceMetric;
}

const MetricCard: React.FC<MetricCardProps> = ({ metric }) => {
  const percent = (metric.current / metric.max) * 100;
  const intent = getProgressIntent(metric.current, metric.max, metric.thresholds);

  return (
    <div style={{ flex: 1, minWidth: 180 }}>
      <div
        style={{
          display: 'flex',
          alignItems: 'center',
          gap: 8,
          marginBottom: 8,
        }}
      >
        <Icon icon={metric.icon as any} size={14} />
        <span style={{ fontWeight: 600, fontSize: 12 }}>{metric.label}</span>
      </div>
      <ProgressBar
        value={percent / 100}
        intent={intent}
        stripes={false}
        animate={false}
      />
      <div
        style={{
          display: 'flex',
          justifyContent: 'space-between',
          marginTop: 4,
          fontSize: 11,
          color: '#64748b',
        }}
      >
        <span>
          {formatNumber(metric.current)} / {formatNumber(metric.max)} {metric.unit}
        </span>
        <Tag minimal intent={intent} style={{ fontSize: 10 }}>
          {percent.toFixed(0)}%
        </Tag>
      </div>
    </div>
  );
};

interface ComplianceCardProps {
  compliance: ComplianceStatus;
}

const ComplianceCard: React.FC<ComplianceCardProps> = ({ compliance }) => {
  const okPercent = (compliance.ok / compliance.total) * 100;

  return (
    <div style={{ flex: 1, minWidth: 180 }}>
      <div
        style={{
          display: 'flex',
          alignItems: 'center',
          gap: 8,
          marginBottom: 8,
        }}
      >
        <Icon icon="shield" size={14} />
        <span style={{ fontWeight: 600, fontSize: 12 }}>Compliance</span>
      </div>
      <div style={{ display: 'flex', gap: 8 }}>
        <Tag intent={Intent.SUCCESS} minimal>
          <Icon icon="tick" size={10} /> {compliance.ok} OK
        </Tag>
        {compliance.warning > 0 && (
          <Tag intent={Intent.WARNING} minimal>
            <Icon icon="warning-sign" size={10} /> {compliance.warning}
          </Tag>
        )}
        {compliance.critical > 0 && (
          <Tag intent={Intent.DANGER} minimal>
            <Icon icon="error" size={10} /> {compliance.critical}
          </Tag>
        )}
      </div>
      <div
        style={{
          marginTop: 8,
          fontSize: 11,
          color: '#64748b',
        }}
      >
        {okPercent.toFixed(0)}% of {compliance.total} trains compliant
      </div>
    </div>
  );
};

// =============================================================================
// MAIN COMPONENT
// =============================================================================

export const ConstraintDeck: React.FC<ConstraintDeckProps> = ({
  manHours,
  trackOccupancy,
  budget,
  compliance,
  collapsed = false,
  onToggleCollapse,
  width = '100%',
  className,
}) => {
  return (
    <Card
      style={{
        width,
        borderRadius: 0,
        padding: 0,
        borderTop: '1px solid #e2e8f0',
      }}
      className={className}
    >
      {/* Header */}
      <div
        style={{
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'space-between',
          padding: '8px 16px',
          borderBottom: collapsed ? 'none' : '1px solid #e2e8f0',
          background: '#f8fafc',
        }}
      >
        <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
          <Icon icon="dashboard" size={14} />
          <span style={{ fontWeight: 600, fontSize: 13 }}>Constraint Deck</span>
        </div>
        {onToggleCollapse && (
          <Button
            minimal
            small
            icon={collapsed ? 'chevron-up' : 'chevron-down'}
            onClick={onToggleCollapse}
          />
        )}
      </div>

      {/* Content */}
      <Collapse isOpen={!collapsed}>
        <div
          style={{
            display: 'flex',
            flexWrap: 'wrap',
            gap: 24,
            padding: 16,
          }}
        >
          <MetricCard metric={manHours} />
          <MetricCard metric={trackOccupancy} />
          <MetricCard metric={budget} />
          <ComplianceCard compliance={compliance} />
        </div>
      </Collapse>
    </Card>
  );
};

