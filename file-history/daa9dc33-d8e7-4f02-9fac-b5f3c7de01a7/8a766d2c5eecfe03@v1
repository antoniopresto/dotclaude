/**
 * TimeScrubber Component
 *
 * Time range selector with density visualization showing task distribution.
 * Uses uPlot for Canvas-based rendering (high performance) and BlueprintJS
 * for the range slider handles.
 */

import React, { useMemo, useCallback, useRef, useEffect } from 'react';
import { Card, RangeSlider, Tag, Intent } from '@blueprintjs/core';

// =============================================================================
// TYPES
// =============================================================================

export interface DensityDataPoint {
  timestamp: number; // Unix timestamp (ms)
  value: number;     // Task count or man-hours
}

export interface TimeScrubberProps {
  /** Density data for the visualization */
  data: DensityDataPoint[];
  /** Start of selectable range (timestamp) */
  rangeStart: number;
  /** End of selectable range (timestamp) */
  rangeEnd: number;
  /** Currently selected start (timestamp) */
  selectionStart: number;
  /** Currently selected end (timestamp) */
  selectionEnd: number;
  /** Callback when selection changes */
  onSelectionChange: (start: number, end: number) => void;
  /** Width of the component */
  width: number;
  /** Height of the component */
  height?: number;
  /** Label for the value axis */
  valueLabel?: string;
  /** Opacity for transitions */
  opacity?: number;
}

// =============================================================================
// HELPERS
// =============================================================================

function formatDate(timestamp: number): string {
  const date = new Date(timestamp);
  const month = date.toLocaleString('en-US', { month: 'short' });
  const year = date.getFullYear();
  return `${month} ${year}`;
}

function formatDateShort(timestamp: number): string {
  const date = new Date(timestamp);
  return `${date.getMonth() + 1}/${date.getFullYear().toString().slice(2)}`;
}

// LTTB downsampling for large datasets
function downsampleLTTB(
  data: DensityDataPoint[],
  targetPoints: number
): DensityDataPoint[] {
  if (data.length <= targetPoints) return data;

  const sampled: DensityDataPoint[] = [];
  const bucketSize = (data.length - 2) / (targetPoints - 2);

  // Always keep first point
  sampled.push(data[0]);

  for (let i = 0; i < targetPoints - 2; i++) {
    const bucketStart = Math.floor((i + 0) * bucketSize) + 1;
    const bucketEnd = Math.floor((i + 1) * bucketSize) + 1;

    // Average point in next bucket
    const nextBucketStart = Math.floor((i + 1) * bucketSize) + 1;
    const nextBucketEnd = Math.min(Math.floor((i + 2) * bucketSize) + 1, data.length);

    let avgX = 0, avgY = 0;
    for (let j = nextBucketStart; j < nextBucketEnd; j++) {
      avgX += data[j].timestamp;
      avgY += data[j].value;
    }
    const count = nextBucketEnd - nextBucketStart;
    avgX /= count;
    avgY /= count;

    // Find point in current bucket with largest triangle area
    const prevPoint = sampled[sampled.length - 1];
    let maxArea = -1;
    let maxIndex = bucketStart;

    for (let j = bucketStart; j < bucketEnd; j++) {
      const area = Math.abs(
        (prevPoint.timestamp - avgX) * (data[j].value - prevPoint.value) -
        (prevPoint.timestamp - data[j].timestamp) * (avgY - prevPoint.value)
      );
      if (area > maxArea) {
        maxArea = area;
        maxIndex = j;
      }
    }

    sampled.push(data[maxIndex]);
  }

  // Always keep last point
  sampled.push(data[data.length - 1]);

  return sampled;
}

// =============================================================================
// DENSITY CHART (Canvas-based)
// =============================================================================

interface DensityChartProps {
  data: DensityDataPoint[];
  width: number;
  height: number;
  rangeStart: number;
  rangeEnd: number;
  selectionStart: number;
  selectionEnd: number;
}

const DensityChart: React.FC<DensityChartProps> = ({
  data,
  width,
  height,
  rangeStart,
  rangeEnd,
  selectionStart,
  selectionEnd,
}) => {
  const canvasRef = useRef<HTMLCanvasElement>(null);

  // Downsample data for performance
  const sampledData = useMemo(() => {
    const targetPoints = Math.min(width, 500);
    return downsampleLTTB(data, targetPoints);
  }, [data, width]);

  // Draw chart
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    canvas.width = width * dpr;
    canvas.height = height * dpr;
    ctx.scale(dpr, dpr);

    // Clear
    ctx.clearRect(0, 0, width, height);

    if (sampledData.length === 0) return;

    // Calculate scales
    const minVal = Math.min(...sampledData.map(d => d.value));
    const maxVal = Math.max(...sampledData.map(d => d.value));
    const valueRange = maxVal - minVal || 1;
    const timeRange = rangeEnd - rangeStart;

    const xScale = (t: number) => ((t - rangeStart) / timeRange) * width;
    const yScale = (v: number) => height - ((v - minVal) / valueRange) * (height - 4) - 2;

    // Draw area
    ctx.beginPath();
    ctx.moveTo(xScale(sampledData[0].timestamp), height);
    ctx.lineTo(xScale(sampledData[0].timestamp), yScale(sampledData[0].value));

    for (const point of sampledData) {
      ctx.lineTo(xScale(point.timestamp), yScale(point.value));
    }

    ctx.lineTo(xScale(sampledData[sampledData.length - 1].timestamp), height);
    ctx.closePath();

    // Gradient fill
    const gradient = ctx.createLinearGradient(0, 0, 0, height);
    gradient.addColorStop(0, 'rgba(59, 130, 246, 0.4)');
    gradient.addColorStop(1, 'rgba(59, 130, 246, 0.05)');
    ctx.fillStyle = gradient;
    ctx.fill();

    // Draw line
    ctx.beginPath();
    ctx.moveTo(xScale(sampledData[0].timestamp), yScale(sampledData[0].value));
    for (const point of sampledData) {
      ctx.lineTo(xScale(point.timestamp), yScale(point.value));
    }
    ctx.strokeStyle = '#3b82f6';
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Highlight selected region
    const selX1 = xScale(selectionStart);
    const selX2 = xScale(selectionEnd);

    // Dim non-selected regions
    ctx.fillStyle = 'rgba(255, 255, 255, 0.6)';
    ctx.fillRect(0, 0, selX1, height);
    ctx.fillRect(selX2, 0, width - selX2, height);

    // Selection border
    ctx.strokeStyle = '#1d4ed8';
    ctx.lineWidth = 2;
    ctx.strokeRect(selX1, 0, selX2 - selX1, height);

  }, [sampledData, width, height, rangeStart, rangeEnd, selectionStart, selectionEnd]);

  return (
    <canvas
      ref={canvasRef}
      style={{
        width,
        height,
        display: 'block',
      }}
    />
  );
};

// =============================================================================
// MAIN COMPONENT
// =============================================================================

export const TimeScrubber: React.FC<TimeScrubberProps> = ({
  data,
  rangeStart,
  rangeEnd,
  selectionStart,
  selectionEnd,
  onSelectionChange,
  width,
  height = 80,
  valueLabel = 'Tasks',
  opacity = 1,
}) => {
  // Convert timestamps to slider values (0-1 range)
  const sliderValue = useMemo((): [number, number] => {
    const range = rangeEnd - rangeStart;
    return [
      (selectionStart - rangeStart) / range,
      (selectionEnd - rangeStart) / range,
    ];
  }, [rangeStart, rangeEnd, selectionStart, selectionEnd]);

  // Handle slider change
  const handleSliderChange = useCallback(
    (values: [number, number]) => {
      const range = rangeEnd - rangeStart;
      const newStart = rangeStart + values[0] * range;
      const newEnd = rangeStart + values[1] * range;
      onSelectionChange(newStart, newEnd);
    },
    [rangeStart, rangeEnd, onSelectionChange]
  );

  // Calculate stats for selected range
  const selectedStats = useMemo(() => {
    const inRange = data.filter(
      d => d.timestamp >= selectionStart && d.timestamp <= selectionEnd
    );
    const total = inRange.reduce((sum, d) => sum + d.value, 0);
    const avg = inRange.length > 0 ? total / inRange.length : 0;
    return { total: Math.round(total), avg: Math.round(avg), count: inRange.length };
  }, [data, selectionStart, selectionEnd]);

  return (
    <Card
      style={{
        width,
        borderRadius: 0,
        padding: 0,
        opacity,
        borderTop: '1px solid #e2e8f0',
      }}
    >
      {/* Header */}
      <div
        style={{
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'space-between',
          padding: '8px 16px',
          borderBottom: '1px solid #e2e8f0',
          background: '#f8fafc',
        }}
      >
        <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
          <span style={{ fontWeight: 600, fontSize: 12 }}>Time Range</span>
          <Tag minimal intent={Intent.PRIMARY}>
            {formatDate(selectionStart)} - {formatDate(selectionEnd)}
          </Tag>
        </div>
        <div style={{ display: 'flex', alignItems: 'center', gap: 8, fontSize: 11, color: '#64748b' }}>
          <span>{selectedStats.total.toLocaleString()} {valueLabel}</span>
          <span>|</span>
          <span>Avg: {selectedStats.avg.toLocaleString()}/period</span>
        </div>
      </div>

      {/* Chart */}
      <div style={{ position: 'relative', padding: '8px 16px' }}>
        <DensityChart
          data={data}
          width={width - 32}
          height={height - 40}
          rangeStart={rangeStart}
          rangeEnd={rangeEnd}
          selectionStart={selectionStart}
          selectionEnd={selectionEnd}
        />
      </div>

      {/* Slider */}
      <div style={{ padding: '0 16px 12px' }}>
        <RangeSlider
          min={0}
          max={1}
          stepSize={0.001}
          value={sliderValue}
          onChange={handleSliderChange}
          labelRenderer={(val) => formatDateShort(rangeStart + val * (rangeEnd - rangeStart))}
          labelStepSize={0.25}
        />
      </div>
    </Card>
  );
};

// =============================================================================
// GENERATE DEMO DATA
// =============================================================================

export function generateDensityData(
  startDate: Date,
  endDate: Date,
  pointsPerMonth: number = 4
): DensityDataPoint[] {
  const data: DensityDataPoint[] = [];
  const current = new Date(startDate);
  const interval = Math.floor(30 / pointsPerMonth); // Days between points

  while (current <= endDate) {
    // Simulate seasonal variation + random noise
    const monthOfYear = current.getMonth();
    const yearFactor = (current.getFullYear() - 2024) * 0.05; // Slight increase over years

    // Higher workload in Q1 and Q4, lower in summer
    const seasonalFactor = monthOfYear >= 3 && monthOfYear <= 8
      ? 0.7 + Math.random() * 0.3
      : 0.9 + Math.random() * 0.4;

    const baseValue = 150 + yearFactor * 100;
    const value = Math.round(baseValue * seasonalFactor * (0.8 + Math.random() * 0.4));

    data.push({
      timestamp: current.getTime(),
      value,
    });

    current.setDate(current.getDate() + interval);
  }

  return data;
}

export default TimeScrubber;
