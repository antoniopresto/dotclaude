/**
 * Demo: Finder Navigation
 * Navega o Finder por várias pastas para demonstrar a integração
 */

import { $ } from "bun";

async function navigateFinderTo(path: string): Promise<boolean> {
  try {
    const result = await $`osascript -e '
      tell application "Finder"
        activate
        try
          set targetFolder to POSIX file "${path}" as alias
          if (count of windows) > 0 then
            set target of front window to targetFolder
          else
            make new Finder window
            set target of front window to targetFolder
          end if
          return "ok"
        on error errMsg
          return "error: " & errMsg
        end try
      end tell
    '`.text();

    return result.trim() === "ok";
  } catch (e) {
    console.error("Erro:", e);
    return false;
  }
}

async function getFinderPath(): Promise<string | null> {
  try {
    const result = await $`osascript -e '
      tell application "Finder"
        if (count of windows) > 0 then
          return POSIX path of (target of front window as alias)
        else
          return ""
        end if
      end tell
    '`.text();
    return result.trim() || null;
  } catch {
    return null;
  }
}

async function demo() {
  console.log("\n🎬 DEMO: Controlando o Finder via Terminal\n");

  const paths = [
    "/Applications",
    "/Users",
    "/System",
    process.env.HOME || "/Users",
    "/tmp",
  ];

  console.log("Observe a janela do Finder...\n");

  for (const path of paths) {
    console.log(`➡️  Navegando para: ${path}`);
    const ok = await navigateFinderTo(path);

    if (ok) {
      const current = await getFinderPath();
      console.log(`   ✅ Finder está em: ${current}`);
    } else {
      console.log(`   ❌ Falhou`);
    }

    await Bun.sleep(1500); // Pausa para visualizar
  }

  console.log("\n✨ Demo concluída!\n");
}

demo();
