version: '3.8'

services:
  postgres:
    image: postgres:16-alpine
    container_name: mms-postgres
    environment:
      POSTGRES_USER: mms
      POSTGRES_PASSWORD: mms
      POSTGRES_DB: mms
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U mms"]
      interval: 5s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: mms-redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5

  solver:
    build:
      context: ./apps/solver
      dockerfile: Dockerfile
    container_name: mms-solver
    environment:
      DATABASE_URL: postgresql://mms:mms@postgres:5432/mms
    ports:
      - "8000:8000"
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 10s
      timeout: 5s
      retries: 3

volumes:
  postgres_data:
  redis_data:
