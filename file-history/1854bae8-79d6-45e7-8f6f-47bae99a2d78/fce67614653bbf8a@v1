import { airlineMilesApi, AirlineMilesApi } from '../../../src/services/airlineMiles/api';
import axios from '../../../src/settings/axios';

jest.mock('../../../src/settings/axios', () => ({
  get: jest.fn(),
}));

describe('AirlineMilesApi', () => {
  beforeEach(() => {
    jest.clearAllMocks();
  });

  describe('getToken', () => {
    it('should call correct endpoint with params', async () => {
      const mockResponse = {
        data: {
          status: { codigoRetorno: 0, mensagem: 'Success' },
          dados: { redirectURL: 'https://vertem.com/marketplace?token=abc' },
        },
      };

      (axios.get as jest.Mock).mockResolvedValue(mockResponse);

      const params = { redirectTo: 'MARKETPLACE', catalog: 'MILEAGE' };
      await airlineMilesApi.getToken(params);

      expect(axios.get).toHaveBeenCalledWith('/marketplace/v1/vertem/getToken', {
        params,
      });
    });

    it('should return response data', async () => {
      const mockData = {
        status: { codigoRetorno: 0, mensagem: 'Success' },
        dados: { redirectURL: 'https://vertem.com/marketplace?token=abc' },
      };

      (axios.get as jest.Mock).mockResolvedValue({ data: mockData });

      const params = { redirectTo: 'MARKETPLACE', catalog: 'MILEAGE' };
      const result = await airlineMilesApi.getToken(params);

      expect(result).toEqual(mockData);
    });

    it('should handle API errors', async () => {
      const mockError = new Error('Network Error');
      (axios.get as jest.Mock).mockRejectedValue(mockError);

      const params = { redirectTo: 'MARKETPLACE', catalog: 'MILEAGE' };

      await expect(airlineMilesApi.getToken(params)).rejects.toThrow('Network Error');
    });
  });

  describe('singleton pattern', () => {
    it('should return the same instance', () => {
      const instance1 = AirlineMilesApi.getInstance();
      const instance2 = AirlineMilesApi.getInstance();

      expect(instance1).toBe(instance2);
    });
  });
});
