import { useCallback } from 'react';
import { useWindowDimensions } from 'react-native';
import type { WebViewScreenProps, UseWebViewScreenReturn } from './Models';

export function useWebViewScreen(props: WebViewScreenProps): UseWebViewScreenReturn {
  const { onError } = props;
  const { width, height } = useWindowDimensions();

  const handleError = useCallback(
    (event: Parameters<NonNullable<WebViewScreenProps['onError']>>[0]) => {
      onError(event);
    },
    [onError]
  );

  return { width, height, handleError };
}

export { default as WebViewScreen } from './view';
export type { WebViewScreenProps } from './Models';
