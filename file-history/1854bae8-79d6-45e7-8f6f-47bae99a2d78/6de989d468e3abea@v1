import React from 'react';
import { render } from '@testing-library/react-native';
import { WebViewScreen } from '../../../../src/atomic/templates/WebViewScreen';
import { TestProvider } from '../../../__mocks__/utils/test-provider';

jest.mock('react-native-webview', () => {
  const { View } = require('react-native');
  return {
    WebView: (props: any) => <View testID="webview" {...props} />,
  };
});

jest.mock('react-native', () => {
  const RN = jest.requireActual('react-native');
  return {
    ...RN,
    useWindowDimensions: () => ({ width: 375, height: 812 }),
    BackHandler: {
      addEventListener: jest.fn(() => ({ remove: jest.fn() })),
    },
  };
});

jest.mock('@react-navigation/native', () => ({
  useNavigation: jest.fn(() => ({ goBack: jest.fn() })),
  useNavigationState: jest.fn(() => 'WebViewScreen'),
}));

describe('WebViewScreen', () => {
  const mockWebViewRef = { current: null };
  const mockOnBackPress = jest.fn();
  const mockOnError = jest.fn();
  const mockOnRetry = jest.fn();

  const defaultProps = {
    uri: 'https://example.com',
    title: 'Test Title',
    webViewRef: mockWebViewRef,
    onBackPress: mockOnBackPress,
    onError: mockOnError,
    onRetry: mockOnRetry,
  };

  beforeEach(() => {
    jest.clearAllMocks();
  });

  it('should render correctly with all props', () => {
    const { getByTestId, getByText } = render(
      <TestProvider>
        <WebViewScreen {...defaultProps} />
      </TestProvider>
    );

    expect(getByTestId('webview')).toBeTruthy();
    expect(getByText('Test Title')).toBeTruthy();
  });

  it('should pass correct uri to WebView', () => {
    const { getByTestId } = render(
      <TestProvider>
        <WebViewScreen {...defaultProps} />
      </TestProvider>
    );

    const webView = getByTestId('webview');
    expect(webView.props.source).toEqual({ uri: 'https://example.com' });
  });

  it('should render with different title', () => {
    const { getByText } = render(
      <TestProvider>
        <WebViewScreen {...defaultProps} title="Custom Title" />
      </TestProvider>
    );

    expect(getByText('Custom Title')).toBeTruthy();
  });

  it('should render loading state', () => {
    const { getByTestId } = render(
      <TestProvider>
        <WebViewScreen {...defaultProps} />
      </TestProvider>
    );

    const webView = getByTestId('webview');
    expect(webView.props.startInLoadingState).toBe(true);
  });
});
