describe('Default Configuration Templates', () => {
  describe('defaultDevelopmentSettings', () => {
    it('should have valid structure', () => {
      expect(defaultDevelopmentSettings.cleanupPeriodDays).toBe(30);
      expect(defaultDevelopmentSettings.includeCoAuthoredBy).toBe(true);
      expect(defaultDevelopmentSettings.permissions?.allow).toContain('Bash(git:*)');
      expect(defaultDevelopmentSettings.permissions?.defaultMode).toBe('default');
    });

    it('should pass partial validation', () => {
      const partial = {
        permissions: defaultDevelopmentSettings.permissions,
      };
      expect(ClaudeCodeSettings.isValid(partial)).toBe(true);
    });
  });

  describe('restrictiveSettings', () => {
    it('should have restrictive permissions', () => {
      expect(restrictiveSettings.permissions?.deny).toContain('Bash');
      expect(restrictiveSettings.permissions?.deny).toContain('Write');
      expect(restrictiveSettings.permissions?.deny).toContain('Edit');
      expect(restrictiveSettings.permissions?.defaultMode).toBe('plan');
    });

    it('should have sandbox enabled', () => {
      expect(restrictiveSettings.sandbox?.enabled).toBe(true);
      expect(restrictiveSettings.sandbox?.allowUnsandboxedCommands).toBe(false);
    });
  });
});

// ============================================================================
// List/Array Parsing Tests
// ============================================================================

describe('List Parsing', () => {
  it('should parse list of hooks', () => {
    const hooks = [
      { type: 'command', command: 'echo 1' },
      { type: 'command', command: 'echo 2' },
      { type: 'prompt', prompt: 'check' },
    ];

    const parsed = HookCommand.parseList(hooks);
    expect(parsed).toHaveLength(3);
    expect(parsed[0]).toEqual({ type: 'command', command: 'echo 1' });
  });

  it('should use list() for array type', () => {
    const hookList = HookCommand.list();
    expect(
      hookList.isValid([
        { type: 'command', command: 'test' },
        { type: 'prompt', prompt: 'test' },
      ]),
    ).toBe(true);
  });
});

