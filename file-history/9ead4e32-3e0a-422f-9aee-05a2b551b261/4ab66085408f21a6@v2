import { useCallback, useRef } from 'react';
import { useRootStore } from '../../../store';
import { airlineMilesApi } from '../api';
import { AIRLINE_MILES_PARAMS } from '../models';
import type { AirlineMilesSlice } from '../store';

export const useAirlineMiles = () => {
  // Seletores separados para evitar re-renders desnecessários
  // (padrão do projeto - ver AdditionalCardAge/index.ts)
  const airlineMiles = useRootStore((state: AirlineMilesSlice) => state.airlineMiles);
  const airlineMilesActions = useRootStore(
    (state: AirlineMilesSlice) => state.airlineMilesActions
  );

  // Ref para controlar cancelamento de operações async
  const abortControllerRef = useRef<AbortController | null>(null);

  const fetchAirlineMilesToken = useCallback(async () => {
    // Cancela requisição anterior se existir
    if (abortControllerRef.current) {
      abortControllerRef.current.abort();
    }

    // Cria novo controller para esta requisição
    abortControllerRef.current = new AbortController();
    const { signal } = abortControllerRef.current;

    try {
      airlineMilesActions.setLoading(true);

      const response = await airlineMilesApi.getToken(AIRLINE_MILES_PARAMS);

      // Verifica se a operação foi cancelada antes de atualizar o estado
      if (signal.aborted) {
        return;
      }

      if (response.status.codigoRetorno === 0) {
        airlineMilesActions.setRedirectURL(response.dados.redirectURL);
      } else {
        airlineMilesActions.setError(response.status.mensagem || 'Failed to get token');
      }
    } catch (error) {
      // Ignora erros de cancelamento
      if (signal.aborted) {
        return;
      }
      airlineMilesActions.setError('Failed to load airline miles marketplace');
    }
  }, [airlineMilesActions]);

  const cancelFetch = useCallback(() => {
    if (abortControllerRef.current) {
      abortControllerRef.current.abort();
      abortControllerRef.current = null;
    }
  }, []);

  const reset = useCallback(() => {
    cancelFetch();
    airlineMilesActions.reset();
  }, [airlineMilesActions, cancelFetch]);

  return {
    ...airlineMiles,
    fetchAirlineMilesToken,
    cancelFetch,
    reset,
  };
};
