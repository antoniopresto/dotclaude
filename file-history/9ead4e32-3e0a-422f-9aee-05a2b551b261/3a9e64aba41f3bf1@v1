import type { RefObject } from 'react';
import type { WebViewProps } from 'react-native-webview';
import type { WebViewErrorEvent } from 'react-native-webview/lib/WebViewTypes';

export interface GenericWebViewScreenProps {
  uri: string;
  title: string;
  webViewRef: RefObject<WebViewProps | null>;
  onBackPress: () => void;
  onError: (event: WebViewErrorEvent) => void;
  onRetry: () => void;
}

export interface GenericWebViewScreenState {
  width: number;
  height: number;
}

export interface GenericWebViewScreenHandlers {
  handleError: (event: WebViewErrorEvent) => void;
}

export type UseGenericWebViewScreenReturn = GenericWebViewScreenState &
  GenericWebViewScreenHandlers;
