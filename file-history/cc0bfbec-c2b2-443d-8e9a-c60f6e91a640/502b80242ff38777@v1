{
  "name": "belt",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript utility library with runtime type validation, state management, and common helpers",
  "repository": {
    "type": "git",
    "url": "https://github.com/antoniopresto/belt"
  },
  "author": "@antoniopresto <antoniopresto@gmail.com>",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/node": "^25.0.3",
    "husky": "9.1.7",
    "turbo": "^2.7.2",
    "typescript": "^5.9.3"
  }
}
