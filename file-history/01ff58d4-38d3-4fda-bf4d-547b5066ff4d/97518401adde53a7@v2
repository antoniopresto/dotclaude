                { id: 19, name: 'Bogie Overhaul Campaign | T145, T146, T147', x: 720, y: 170, width: 230, color: 'orange', hasConflict: true, row: 5 },
                { id: 20, name: 'Bogie Overhaul Campaign | T145, T146, T147', x: 760, y: 200, width: 220, color: 'blue', row: 6 },
                { id: 21, name: 'Bogie Overhaul Campaign | T145, T146', x: 800, y: 230, width: 200, color: 'orange', row: 7 },
                { id: 22, name: 'Bogie Overhaul Campaign | T145, T146, T147', x: 840, y: 260, width: 230, color: 'orange', hasConflict: true, row: 8 },
                { id: 23, name: 'Bogie Overhaul Campaign | T145, T146', x: 880, y: 290, width: 200, color: 'blue', row: 9 },

                // Right section
                { id: 24, name: 'Bogie Overhaul Campaign | T145, T146', x: 1050, y: 20, width: 200, color: 'orange', row: 0 },
