            // Render header
            ganttHeader.innerHTML = dates.map(d => {
                const day = d.getDate();
                const month = d.toLocaleDateString('en', { month: 'short' });
                return `<div class="gantt-header-cell">
                    <span>${day} ${month}</span>
                    <span class="month">March 2032</span>
                </div>`;
            }).join('');

            // Task data
            const tasks = [
                { id: 1, name: 'Bogie Overhaul Campaign | T145, T146', x: 20, y: 20, width: 200, color: 'orange', row: 0 },
                { id: 2, name: 'Bogie Overhaul Campaign', x: 60, y: 50, width: 180, color: 'blue', row: 1 },
                { id: 3, name: 'Heavy Lift Crane', x: 100, y: 80, width: 120, color: 'gray', row: 2 },
                { id: 4, name: 'Techs Pit 1 & 3', x: 120, y: 110, width: 100, color: 'blue', row: 3 },
                { id: 5, name: 'Bogie Overhaul Campaign | T145', x: 180, y: 140, width: 170, color: 'blue', row: 4 },
                { id: 6, name: 'Bogie Overhaul Campaign', x: 220, y: 170, width: 160, color: 'blue', row: 5 },
                { id: 7, name: 'Bogie Overhaul Campaign', x: 260, y: 200, width: 150, color: 'blue', row: 6 },
                { id: 8, name: 'Bogie Overhaul Campaign', x: 300, y: 230, width: 160, color: 'blue', row: 7 },
                { id: 9, name: 'Bogie Overhaul Campaign', x: 340, y: 260, width: 150, color: 'blue', row: 8 },
                { id: 10, name: 'Techs Pit Campaign', x: 380, y: 290, width: 130, color: 'gray', row: 9 },
                { id: 11, name: 'Techs Pit Full snape', x: 420, y: 320, width: 140, color: 'blue', row: 10 },
                { id: 12, name: 'Techs Pit & &', x: 460, y: 350, width: 100, color: 'blue', row: 11 },
                { id: 13, name: 'Techs Pit Sick saips', x: 500, y: 380, width: 130, color: 'orange', row: 12 },

                // Middle section
                { id: 14, name: 'Heavy Lift Crane', x: 520, y: 20, width: 120, color: 'gray', row: 0 },
                { id: 15, name: 'Bogie Overhaul Campaign', x: 540, y: 50, width: 180, color: 'blue', row: 1 },
                { id: 16, name: 'Bogie Overhaul Campaign | T145, T146', x: 600, y: 80, width: 200, color: 'blue', row: 2 },
                { id: 17, name: 'Bogie Overhaul Campaign | T145, T146, T147', x: 640, y: 110, width: 220, color: 'blue', row: 3 },
