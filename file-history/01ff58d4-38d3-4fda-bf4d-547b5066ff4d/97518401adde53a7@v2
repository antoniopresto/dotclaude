            <span class="tooltip-label">Status:</span>
            <span class="tooltip-value" id="tooltipStatus">Critical Path</span>
        </div>
        <div class="tooltip-alert" id="tooltipAlert">
            <strong>Conflict Alert:</strong> Overlapping with Signaling Upgrade
        </div>
    </div>

    <script>
        // ========================================
        // MACRO LAYER - Heatmap
        // ========================================
        function initMacroLayer() {
            const canvas = document.getElementById('macroCanvas');
            const ctx = canvas.getContext('2d');
            const container = canvas.parentElement;

            // Set canvas size
            function resize() {
                canvas.width = container.clientWidth;
                canvas.height = container.clientHeight - 20;
                renderMacro();
            }

            // Generate heatmap data
            const years = ['Jan 2021', 'Mey 2021', 'Jan 2031', 'Jan 2031', 'Nov 2032', 'Jan 2032', 'Mar 2032', 'Jun 2030', 'Dec 2031', 'Jan 2032', 'Mar 2033', 'Jul 2033'];
            const trains = ['2039', '2030', '2031', '2032', '2033', '2034', '2035', '2036', '2037', '2038', '2039', '2032'];

            // Populate axes
            document.getElementById('macroYAxis').innerHTML = trains.map(t => `<span>${t}</span>`).join('');
            document.getElementById('macroXAxis').innerHTML = years.map(y => `<span>${y}</span>`).join('');

            // Noise function for organic heatmap
            function noise(x, y, seed) {
                const n = Math.sin(x * 12.9898 + y * 78.233 + seed) * 43758.5453;
                return n - Math.floor(n);
            }

            function smoothNoise(x, y, seed) {
                const x0 = Math.floor(x), y0 = Math.floor(y);
                const fx = x - x0, fy = y - y0;
                const v00 = noise(x0, y0, seed);
                const v10 = noise(x0 + 1, y0, seed);
                const v01 = noise(x0, y0 + 1, seed);
                const v11 = noise(x0 + 1, y0 + 1, seed);
                const i1 = v00 * (1 - fx) + v10 * fx;
                const i2 = v01 * (1 - fx) + v11 * fx;
                return i1 * (1 - fy) + i2 * fy;
            }

            function fbm(x, y, seed) {
                let value = 0, amplitude = 0.5;
                for (let i = 0; i < 4; i++) {
                    value += amplitude * smoothNoise(x, y, seed);
                    x *= 2; y *= 2;
                    amplitude *= 0.5;
                }
                return value;
            }

            // Color interpolation
            function getHeatColor(value) {
                // Yellow -> Orange -> Red gradient
                if (value < 0.3) {
                    return `rgb(255, ${Math.floor(243 - value * 100)}, ${Math.floor(196 - value * 300)})`;
                } else if (value < 0.6) {
                    const t = (value - 0.3) / 0.3;
                    return `rgb(255, ${Math.floor(180 - t * 80)}, ${Math.floor(100 - t * 80)})`;
                } else {
                    const t = (value - 0.6) / 0.4;
                    return `rgb(${Math.floor(255 - t * 55)}, ${Math.floor(100 - t * 70)}, ${Math.floor(20 + t * 20)})`;
                }
            }

            function renderMacro() {
                const w = canvas.width;
                const h = canvas.height;
                const cellW = 8;
                const cellH = 8;

                // Create hotspots for the dark red areas
                const hotspots = [
                    { x: 0.75, y: 0.3, intensity: 1.2 },
                    { x: 0.85, y: 0.5, intensity: 1.3 },
                    { x: 0.78, y: 0.7, intensity: 1.0 },
                ];

                for (let x = 0; x < w; x += cellW) {
                    for (let y = 0; y < h; y += cellH) {
                        const nx = x / w;
                        const ny = y / h;

                        // Base noise
                        let value = fbm(nx * 8, ny * 6, 42) * 0.4;

                        // Add hotspot influence
                        hotspots.forEach(hs => {
                            const dx = nx - hs.x;
                            const dy = ny - hs.y;
                            const dist = Math.sqrt(dx * dx + dy * dy);
                            const influence = Math.max(0, 1 - dist * 4) * hs.intensity;
                            value += influence * 0.6;
                        });

                        // Add some randomness
                        value += noise(x, y, 123) * 0.15;
                        value = Math.min(1, Math.max(0, value));

                        ctx.fillStyle = getHeatColor(value);
                        ctx.fillRect(x, y, cellW - 1, cellH - 1);
                    }
                }

                // Draw selection rectangle
                ctx.strokeStyle = '#64748b';
                ctx.lineWidth = 2;
                ctx.strokeRect(w * 0.68, 10, w * 0.25, h - 20);
            }

            resize();
            window.addEventListener('resize', resize);
        }

        // ========================================
        // MESO LAYER - DNA Strip
        // ========================================
        function initMesoLayer() {
            const canvas = document.getElementById('mesoCanvas');
            const ctx = canvas.getContext('2d');
            const container = canvas.parentElement;

            // Months for x-axis
            const months = ['Jul 1', 'Sep', 'Oct', 'Nov', 'Dec', '2032', 'Feb', 'Mar', 'Apr', 'May', 'Jun', '2032', 'Mar', 'Sep', 'SiO3'];

            document.getElementById('mesoXAxis').innerHTML = months.map((m, i) =>
                `<span class="${m === '2032' ? 'highlight' : ''}">${m}</span>`
            ).join('');

            function resize() {
                canvas.width = container.clientWidth;
                canvas.height = container.clientHeight - 24;
                renderMeso();
            }

            function renderMeso() {
                const w = canvas.width;
                const h = canvas.height;

                ctx.fillStyle = '#f8f9fa';
                ctx.fillRect(0, 0, w, h);

                // Draw diagonal DNA strips
                const stripHeight = 12;
                const stripGap = 2;
                const numRows = Math.floor(h / (stripHeight + stripGap));
                const stripWidth = 60;
                const angle = -30 * Math.PI / 180;

                for (let row = 0; row < numRows; row++) {
                    const y = row * (stripHeight + stripGap) + 30;

                    // Stagger start position based on row
                    const startOffset = (row * 25) % 100;

                    for (let x = -100 + startOffset; x < w + 200; x += stripWidth + 15) {
                        // Alternate colors - orange and blue
                        const isOrange = (Math.floor(x / 80) + row) % 3 !== 0;

                        ctx.save();
                        ctx.translate(x, y);
                        ctx.rotate(angle);

                        // Draw strip
                        const gradient = ctx.createLinearGradient(0, 0, stripWidth, 0);
                        if (isOrange) {
                            gradient.addColorStop(0, '#f59e0b');
                            gradient.addColorStop(1, '#d97706');
                        } else {
                            gradient.addColorStop(0, '#3b82f6');
                            gradient.addColorStop(1, '#1d4ed8');
                        }

                        ctx.fillStyle = gradient;
                        ctx.beginPath();
                        ctx.roundRect(0, 0, stripWidth, stripHeight, 2);
                        ctx.fill();

                        ctx.restore();
                    }
                }

                // Draw highlighted selection area
                ctx.strokeStyle = '#93c5fd';
                ctx.lineWidth = 2;
                ctx.fillStyle = 'rgba(147, 197, 253, 0.1)';
                ctx.fillRect(w * 0.35, 0, w * 0.15, h);
                ctx.strokeRect(w * 0.35, 0, w * 0.15, h);
            }

            resize();
            window.addEventListener('resize', resize);
        }

        // ========================================
