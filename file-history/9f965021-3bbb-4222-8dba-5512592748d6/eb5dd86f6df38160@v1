import { test, expect } from '@playwright/test';

test.describe('Allocation Page', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/allocation');
  });

  test('should render allocation page', async ({ page }) => {
    await expect(page).toHaveTitle(/MMS/);
  });

  test('should display allocation heading', async ({ page }) => {
    await expect(page.getByRole('heading', { name: /Allocation/i })).toBeVisible();
  });

  test('should show pending services section', async ({ page }) => {
    await page.waitForTimeout(2000);
    // Page should have some content about services or pending allocations
    const content = page.locator('main');
    await expect(content).toBeVisible();
  });
});
