import { test, expect } from '@playwright/test';

test.describe('Balancing Page', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/balancing');
  });

  test('should render balancing page', async ({ page }) => {
    await expect(page).toHaveTitle(/MMS/);
  });

  test('should display balancing heading', async ({ page }) => {
    await expect(page.getByRole('heading', { name: /Km Balancing/i })).toBeVisible();
  });

  test('should display KPI metrics when API is available', async ({ page }) => {
    await page.waitForTimeout(3000);

    // Check for Fleet Average or similar KPI
    const fleetAverage = page.locator('text=/Fleet Average|Average|km/i');
    await expect(fleetAverage.first()).toBeVisible({ timeout: 5000 }).catch(() => {
      // May not be visible without API
    });
  });

  test('should display What-If Simulation panel', async ({ page }) => {
    await page.waitForTimeout(2000);
    await expect(page.getByRole('heading', { name: /What-If Simulation/i })).toBeVisible();
  });

  test('should allow creating a scenario', async ({ page }) => {
    await page.waitForTimeout(2000);

    const input = page.getByPlaceholder(/Scenario name/i);
    if (await input.isVisible()) {
      await input.fill('Test Scenario');
      const createButton = page.getByRole('button', { name: /Create Scenario/i });
      await expect(createButton).toBeEnabled();
    }
  });
});
