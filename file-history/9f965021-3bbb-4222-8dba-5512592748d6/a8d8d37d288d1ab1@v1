import { test, expect } from '@playwright/test';

test.describe('Dashboard Page', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/');
  });

  test('should render page title', async ({ page }) => {
    await expect(page).toHaveTitle(/MMS/);
  });

  test('should display navigation menu', async ({ page }) => {
    await expect(page.getByRole('link', { name: /Dashboard/ })).toBeVisible();
    await expect(page.getByRole('link', { name: /Map/ })).toBeVisible();
    await expect(page.getByRole('link', { name: /Allocation/ })).toBeVisible();
    await expect(page.getByRole('link', { name: /Fleet/ })).toBeVisible();
    await expect(page.getByRole('link', { name: /Balancing/ })).toBeVisible();
    await expect(page.getByRole('link', { name: /Schedule/ })).toBeVisible();
    await expect(page.getByRole('link', { name: /Maintenance/ })).toBeVisible();
  });

  test('should display KPI cards when API is available', async ({ page }) => {
    // Wait for content to load
    await page.waitForTimeout(2000);

    // Check for heading
    await expect(page.getByRole('heading', { name: /Dashboard|Fleet Overview/i })).toBeVisible();
  });

  test('should have theme toggle button', async ({ page }) => {
    await expect(page.getByRole('button', { name: /Switch to Light Mode|Switch to Dark Mode/i })).toBeVisible();
  });
});
