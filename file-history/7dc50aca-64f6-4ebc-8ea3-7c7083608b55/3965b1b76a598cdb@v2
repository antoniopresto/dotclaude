📊 CURRENT STATUS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Progress: $completed/$total features complete
Next feature: ${next:-"All complete!"}

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
⚠️  REMINDER: If you find yourself editing files outside
    packages/harness-orchestrator/, STOP and reconsider.
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    # Show what Claude will receive
    print_section "Isolation Prompt (sent to Claude)"
    echo -e "${DIM}─────────────────────────────────────────────────────────────────${NC}"
    echo -e "${DIM}$isolation_prompt${NC}" | head -30
    echo -e "${DIM}... (truncated for display)${NC}"
    echo -e "${DIM}─────────────────────────────────────────────────────────────────${NC}"
    echo ""

    print_info "Starting Claude Code with package isolation..."
    echo ""

    # Start Claude with isolation prompt
    # Change to package directory so Claude's context is focused there
    cd "$PACKAGE_DIR"
    claude --append-system-prompt="$isolation_prompt"
}

cmd_quick() {
    # One-liner for shell prompt integration
    check_package 2>/dev/null || { echo "⚠ no pkg"; exit 0; }
    read total completed pending <<< $(count_features)
    local percent=$((completed * 100 / total))
    echo "🔧 orchestrator: $completed/$total ($percent%)"
}

# ─────────────────────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────────────────────

main() {
    local command="${1:-claude}"
    shift 2>/dev/null || true

    case "$command" in
        status|s)
            cmd_status
            ;;
        next|n)
            cmd_next
            ;;
        build|b)
            cmd_build
            ;;
        dev|d)
            cmd_dev
            ;;
        test|t)
            cmd_test
            ;;
        claude|c)
            cmd_claude
            ;;
        log|l)
            cmd_log "$@"
            ;;
        commit)
            cmd_commit
            ;;
        quick|q)
            cmd_quick
            ;;
        help|h|--help|-h)
            cmd_help
            ;;
        *)
            print_error "Unknown command: $command"
            echo "Run './harness-package-01.sh help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
