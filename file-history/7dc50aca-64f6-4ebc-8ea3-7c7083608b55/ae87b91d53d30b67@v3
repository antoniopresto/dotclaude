cmd_quick() {
    # One-liner for shell prompt integration
    check_root 2>/dev/null || { echo "⚠ no root"; exit 0; }
    read total completed pending <<< $(count_features)
    local percent=0
    if [[ $total -gt 0 ]]; then
        percent=$((completed * 100 / total))
    fi
    echo "🏠 mms-root: $completed/$total ($percent%)"
}

# ─────────────────────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────────────────────

main() {
    local command="${1:-claude}"
    shift 2>/dev/null || true

    case "$command" in
        status|s)
            cmd_status
            ;;
        next|n)
            cmd_next
            ;;
        dev|d)
            cmd_dev
            ;;
        build|b)
            cmd_build
            ;;
        typecheck|tc)
            cmd_typecheck
            ;;
        claude|c)
            cmd_claude
            ;;
        log|l)
            cmd_log "$@"
            ;;
        commit)
            cmd_commit
            ;;
        packages|p)
            cmd_packages
            ;;
        quick|q)
            cmd_quick
            ;;
        help|h|--help|-h)
            cmd_help
            ;;
        *)
            print_error "Unknown command: $command"
            echo "Run './harness-root.sh help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
