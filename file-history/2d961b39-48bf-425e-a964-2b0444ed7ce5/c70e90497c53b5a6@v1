{
  "name": "@belt/plugin-sync-types",
  "version": "0.1.0",
  "description": "Belt plugin for syncing TypeScript declarations from external projects",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/antoniopresto/belt",
    "directory": "packages/plugins/sync-types"
  },
  "homepage": "https://github.com/antoniopresto/belt#readme",
  "bugs": "https://github.com/antoniopresto/belt/issues",
  "author": "Antonio Presto <antoniopresto@gmail.com>",
  "license": "MIT",
  "keywords": [
    "belt",
    "typescript",
    "declarations",
    "dts",
    "sync",
    "types"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@belt/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
