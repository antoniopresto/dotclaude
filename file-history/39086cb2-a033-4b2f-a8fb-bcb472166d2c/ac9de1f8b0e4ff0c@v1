import puppeteer from 'puppeteer';
import path from 'path';
import { fileURLToPath } from 'url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));

async function takeScreenshot(pageName) {
    const browser = await puppeteer.launch({
        headless: true,
        args: ['--no-sandbox', '--disable-setuid-sandbox']
    });

    const page = await browser.newPage();
    await page.setViewport({ width: 1920, height: 1080 });

    await page.goto(`http://localhost:3333/${pageName}`, {
        waitUntil: 'networkidle0',
        timeout: 30000
    });

    await new Promise(r => setTimeout(r, 1500));

    const baseName = pageName.replace('.html', '');
    const screenshotPath = path.join(__dirname, 'screenshots', `${baseName}-${Date.now()}.png`);
    await page.screenshot({
        path: screenshotPath,
        fullPage: false
    });

    console.log(`Screenshot saved: ${screenshotPath}`);
    await browser.close();
    return screenshotPath;
}

const pageName = process.argv[2] || 'index.html';
takeScreenshot(pageName).catch(console.error);
