import { createMachine, createSlice } from '@zazcart/toolkit';

export interface Particle {
  id: number;
  x: number;
  y: number;
  vx: number;
  vy: number;
  radius: number;
  color: [number, number, number];
}

export interface ParticlesState {
  particles: Particle[];
  running: boolean;
  fps: number;
  frameCount: number;
  lastFrameTime: number;
  dispatchTime: number;
  renderTime: number;
}

export interface StatsState {
  totalDispatches: number;
  avgDispatchTime: number;
  maxDispatchTime: number;
  minDispatchTime: number;
  particleCount: number;
}

const particlesSlice = createSlice({
  id: 'particles',
  cache: { policy: 'session' },
  initial: {
    particles: [],
    running: false,
    fps: 0,
    frameCount: 0,
    lastFrameTime: performance.now(),
    dispatchTime: 0,
    renderTime: 0,
  },
  reducers: {
    init: (draft: ParticlesState, payload: { count: number; width: number; height: number }) => {
      const { count, width, height } = payload;
      draft.particles = Array.from({ length: count }, (_, i) => ({
        id: i,
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * 4,
        vy: (Math.random() - 0.5) * 4,
        radius: 2 + Math.random() * 3,
        color: [
          Math.floor(Math.random() * 255),
          Math.floor(Math.random() * 255),
          Math.floor(Math.random() * 255),
        ] as [number, number, number],
      }));
      draft.running = true;
      draft.frameCount = 0;
      draft.lastFrameTime = performance.now();
    },
    update: (
      draft: ParticlesState,
      payload: { width: number; height: number; dispatchTime: number },
    ) => {
      const { width, height, dispatchTime } = payload;
      const now = performance.now();
      const deltaFrame = now - draft.lastFrameTime;

      draft.frameCount++;
      if (deltaFrame >= 1000) {
        draft.fps = Math.round((draft.frameCount * 1000) / deltaFrame);
        draft.frameCount = 0;
        draft.lastFrameTime = now;
      }

      draft.dispatchTime = dispatchTime;

      for (const p of draft.particles) {
        p.x += p.vx;
        p.y += p.vy;

        if (p.x <= p.radius || p.x >= width - p.radius) {
          p.vx *= -1;
          p.x = Math.max(p.radius, Math.min(width - p.radius, p.x));
        }
        if (p.y <= p.radius || p.y >= height - p.radius) {
          p.vy *= -1;
          p.y = Math.max(p.radius, Math.min(height - p.radius, p.y));
        }
      }
    },
    setRunning: (draft: ParticlesState, running: boolean) => {
      draft.running = running;
    },
    setRenderTime: (draft: ParticlesState, renderTime: number) => {
      draft.renderTime = renderTime;
    },
    addParticles: (
      draft: ParticlesState,
      payload: { count: number; width: number; height: number },
    ) => {
      const { count, width, height } = payload;
      const baseId = draft.particles.length;
      for (let i = 0; i < count; i++) {
        draft.particles.push({
          id: baseId + i,
          x: Math.random() * width,
          y: Math.random() * height,
          vx: (Math.random() - 0.5) * 4,
          vy: (Math.random() - 0.5) * 4,
          radius: 2 + Math.random() * 3,
          color: [
            Math.floor(Math.random() * 255),
            Math.floor(Math.random() * 255),
            Math.floor(Math.random() * 255),
          ],
        });
      }
    },
    clear: (draft: ParticlesState) => {
      draft.particles = [];
      draft.running = false;
      draft.fps = 0;
      draft.frameCount = 0;
    },
  },
});

const statsSlice = createSlice({
  id: 'stats',
  cache: { policy: 'session' },
  initial: {
    totalDispatches: 0,
    avgDispatchTime: 0,
    maxDispatchTime: 0,
    minDispatchTime: Infinity,
    particleCount: 0,
  },
  reducers: {
    record: (
      draft: StatsState,
      payload: { dispatchTime: number; particleCount: number },
    ) => {
      draft.totalDispatches++;
      draft.particleCount = payload.particleCount;
      draft.maxDispatchTime = Math.max(
        draft.maxDispatchTime,
        payload.dispatchTime,
      );
      draft.minDispatchTime = Math.min(
        draft.minDispatchTime,
        payload.dispatchTime,
      );
      draft.avgDispatchTime =
        (draft.avgDispatchTime * (draft.totalDispatches - 1) +
          payload.dispatchTime) /
        draft.totalDispatches;
    },
    reset: (draft: StatsState) => {
      draft.totalDispatches = 0;
      draft.avgDispatchTime = 0;
      draft.maxDispatchTime = 0;
      draft.minDispatchTime = Infinity;
      draft.particleCount = 0;
    },
  },
});

interface RootState {
  particles: ParticlesState;
  stats: StatsState;
}

export const particlesMachine = createMachine({
  id: 'stressTest',
  trackMetadata: true,
  slices: {
    particles: particlesSlice,
    stats: statsSlice,
  },
  selectors: {
    isRunning: (state: RootState) => state.particles.running,
    particleCount: (state: RootState) => state.particles.particles.length,
    currentFps: (state: RootState) => state.particles.fps,
  },
});

export type ParticlesMachine = typeof particlesMachine;
