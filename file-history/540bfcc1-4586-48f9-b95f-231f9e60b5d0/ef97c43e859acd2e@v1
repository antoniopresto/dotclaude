import React, { useCallback, useEffect, useRef, useState } from 'react';

import { particlesMachine } from './particles-machine';
import { createWebGLRenderer, type WebGLRenderer } from './webgl-renderer';

const CANVAS_WIDTH = 800;
const CANVAS_HEIGHT = 600;

interface StressTestProps {
  initialParticleCount?: number;
  showStats?: boolean;
}

export function ParticleStressTest({
  initialParticleCount = 1000,
  showStats = true,
}: StressTestProps) {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const rendererRef = useRef<WebGLRenderer | null>(null);
  const animationRef = useRef<number>(0);

  const [particleCount, setParticleCount] = useState(initialParticleCount);

  const { state: particlesState, actions: particleActions } =
    particlesMachine.useMachine('particles');
  const { state: statsState, actions: statsActions } =
    particlesMachine.useMachine('stats');

  useEffect(() => {
    if (!canvasRef.current) return;

    rendererRef.current = createWebGLRenderer(canvasRef.current);

    return () => {
      if (animationRef.current) {
        cancelAnimationFrame(animationRef.current);
      }
      rendererRef.current?.destroy();
    };
  }, []);

  const gameLoop = useCallback(() => {
    if (!particlesState.running || !rendererRef.current) return;

    const dispatchStart = performance.now();
    particleActions.update({
      width: CANVAS_WIDTH,
      height: CANVAS_HEIGHT,
      dispatchTime: 0,
    });
    const dispatchTime = performance.now() - dispatchStart;

    const state = particlesMachine.getState();
    const renderTime = rendererRef.current.render(
      state.particles.particles,
    );

    particleActions.setRenderTime(renderTime);
    statsActions.record({
      dispatchTime,
      particleCount: state.particles.particles.length,
    });

    animationRef.current = requestAnimationFrame(gameLoop);
  }, [particlesState.running, particleActions, statsActions]);

  useEffect(() => {
    if (particlesState.running) {
      animationRef.current = requestAnimationFrame(gameLoop);
    }
    return () => {
      if (animationRef.current) {
        cancelAnimationFrame(animationRef.current);
      }
    };
  }, [particlesState.running, gameLoop]);

  const handleStart = () => {
    statsActions.reset();
    particleActions.init({
      count: particleCount,
      width: CANVAS_WIDTH,
      height: CANVAS_HEIGHT,
    });
  };

  const handleStop = () => {
    particleActions.setRunning(false);
  };

  const handleAddParticles = (count: number) => {
    particleActions.addParticles({
      count,
      width: CANVAS_WIDTH,
      height: CANVAS_HEIGHT,
    });
  };

  const handleClear = () => {
    particleActions.clear();
    statsActions.reset();
  };

  return (
    <div style={{ fontFamily: 'system-ui, sans-serif' }}>
      <h2 style={{ margin: '0 0 16px 0', color: '#333' }}>
        State Machine WebGL Stress Test
      </h2>

      <div style={{ marginBottom: 16, display: 'flex', gap: 8, flexWrap: 'wrap' }}>
        <label style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
          Initial Count:
          <input
            type="number"
            value={particleCount}
            onChange={e => setParticleCount(Number(e.target.value))}
            min={100}
            max={100000}
            step={1000}
            style={{ width: 100, padding: '4px 8px' }}
          />
        </label>

        <button
          onClick={handleStart}
          disabled={particlesState.running}
          style={{
            padding: '8px 16px',
            background: particlesState.running ? '#ccc' : '#4CAF50',
            color: 'white',
            border: 'none',
            borderRadius: 4,
            cursor: particlesState.running ? 'not-allowed' : 'pointer',
          }}
        >
          Start
        </button>

        <button
          onClick={handleStop}
          disabled={!particlesState.running}
          style={{
            padding: '8px 16px',
            background: !particlesState.running ? '#ccc' : '#f44336',
            color: 'white',
            border: 'none',
            borderRadius: 4,
            cursor: !particlesState.running ? 'not-allowed' : 'pointer',
          }}
        >
          Stop
        </button>

        <button
          onClick={() => handleAddParticles(1000)}
          disabled={!particlesState.running}
          style={{
            padding: '8px 16px',
            background: !particlesState.running ? '#ccc' : '#2196F3',
            color: 'white',
            border: 'none',
            borderRadius: 4,
            cursor: !particlesState.running ? 'not-allowed' : 'pointer',
          }}
        >
          +1000
        </button>

        <button
          onClick={() => handleAddParticles(10000)}
          disabled={!particlesState.running}
          style={{
            padding: '8px 16px',
            background: !particlesState.running ? '#ccc' : '#9C27B0',
            color: 'white',
            border: 'none',
            borderRadius: 4,
            cursor: !particlesState.running ? 'not-allowed' : 'pointer',
          }}
        >
          +10000
        </button>

        <button
          onClick={handleClear}
          style={{
            padding: '8px 16px',
            background: '#757575',
            color: 'white',
            border: 'none',
            borderRadius: 4,
            cursor: 'pointer',
          }}
        >
          Clear
        </button>
      </div>

      <div style={{ display: 'flex', gap: 16 }}>
        <canvas
          ref={canvasRef}
          width={CANVAS_WIDTH}
          height={CANVAS_HEIGHT}
          style={{
            border: '2px solid #333',
            borderRadius: 4,
            background: '#0d0d1a',
          }}
        />

        {showStats && (
          <div
            style={{
              padding: 16,
              background: '#f5f5f5',
              borderRadius: 4,
              minWidth: 250,
            }}
          >
            <h3 style={{ margin: '0 0 12px 0', color: '#333' }}>
              Performance Stats
            </h3>

            <div style={{ marginBottom: 16 }}>
              <h4 style={{ margin: '0 0 8px 0', color: '#666', fontSize: 14 }}>
                Real-time
              </h4>
              <StatRow label="Particles" value={particlesState.particles.length} />
              <StatRow label="FPS" value={particlesState.fps} unit="" />
              <StatRow
                label="Dispatch Time"
                value={particlesState.dispatchTime.toFixed(2)}
                unit="ms"
              />
              <StatRow
                label="Render Time"
                value={particlesState.renderTime.toFixed(2)}
                unit="ms"
              />
            </div>

            <div>
              <h4 style={{ margin: '0 0 8px 0', color: '#666', fontSize: 14 }}>
                Aggregated Stats
              </h4>
              <StatRow label="Total Dispatches" value={statsState.totalDispatches} />
              <StatRow
                label="Avg Dispatch"
                value={statsState.avgDispatchTime.toFixed(3)}
                unit="ms"
              />
              <StatRow
                label="Max Dispatch"
                value={statsState.maxDispatchTime.toFixed(3)}
                unit="ms"
              />
              <StatRow
                label="Min Dispatch"
                value={
                  statsState.minDispatchTime === Infinity
                    ? '-'
                    : statsState.minDispatchTime.toFixed(3)
                }
                unit="ms"
              />
            </div>

            <div style={{ marginTop: 16, fontSize: 12, color: '#999' }}>
              <p style={{ margin: '4px 0' }}>
                State updates via @zazcart/toolkit state-machine
              </p>
              <p style={{ margin: '4px 0' }}>
                Rendering via WebGL (hardware accelerated)
              </p>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

function StatRow({
  label,
  value,
  unit = '',
}: {
  label: string;
  value: string | number;
  unit?: string;
}) {
  return (
    <div
      style={{
        display: 'flex',
        justifyContent: 'space-between',
        marginBottom: 4,
        fontSize: 14,
      }}
    >
      <span style={{ color: '#666' }}>{label}:</span>
      <span style={{ fontWeight: 'bold', fontFamily: 'monospace' }}>
        {value}
        {unit && <span style={{ color: '#999', marginLeft: 2 }}>{unit}</span>}
      </span>
    </div>
  );
}
