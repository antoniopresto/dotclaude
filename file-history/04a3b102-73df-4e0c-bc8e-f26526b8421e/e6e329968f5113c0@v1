// =============================================================================
// TESTS
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;
    use crate::db::connection::open_in_memory;

    // -------------------------------------------------------------------------
    // Create tests
    // -------------------------------------------------------------------------

    #[test]
    fn test_start_session() {
        let conn = open_in_memory().expect("Failed to open in-memory db");

        let session = start_session(&conn, None).expect("Failed to start session");

        assert_eq!(session.id.len(), 26);
        assert!(session.summary.is_none());
        assert!(session.ended_at.is_none());
    }

    #[test]
    fn test_start_session_with_summary() {
        let conn = open_in_memory().expect("Failed to open in-memory db");

        let session = start_session(&conn, Some("Initial setup")).expect("Failed to start session");

        assert_eq!(session.summary, Some("Initial setup".to_string()));
    }

    // -------------------------------------------------------------------------
    // Read tests
    // -------------------------------------------------------------------------

    #[test]
    fn test_get_session() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let session = start_session(&conn, Some("Test")).expect("Start session");

        let retrieved = get_session(&conn, &session.id).expect("Get session").unwrap();

        assert_eq!(retrieved.id, session.id);
        assert_eq!(retrieved.summary, Some("Test".to_string()));
    }

    #[test]
    fn test_get_session_not_found() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let result = get_session(&conn, "01ARZ3NDEKTSV4RRFFQ69G5FAV").expect("Query failed");
        assert!(result.is_none());
    }

    #[test]
    fn test_get_current_session() {
        let conn = open_in_memory().expect("Failed to open in-memory db");

        // No current session initially
        let current = get_current_session(&conn).expect("Get current");
        assert!(current.is_none());

        // Start a session
        let session = start_session(&conn, None).expect("Start session");

        // Now there is a current session
        let current = get_current_session(&conn).expect("Get current").unwrap();
        assert_eq!(current.id, session.id);
    }

    #[test]
    fn test_get_current_session_after_end() {
        let conn = open_in_memory().expect("Failed to open in-memory db");

        let session = start_session(&conn, None).expect("Start session");
        end_session(&conn, &session.id, None).expect("End session");

        let current = get_current_session(&conn).expect("Get current");
        assert!(current.is_none());
    }

    #[test]
    fn test_list_sessions_empty() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let result = list_sessions(&conn, None, None).expect("List sessions");

        assert!(result.items.is_empty());
        assert!(!result.has_next);
        assert!(!result.has_prev);
    }

    #[test]
    fn test_list_sessions_ordered_by_recent() {
        let conn = open_in_memory().expect("Failed to open in-memory db");

        let s1 = start_session(&conn, Some("First")).expect("Start session 1");
        std::thread::sleep(std::time::Duration::from_millis(2));
        let s2 = start_session(&conn, Some("Second")).expect("Start session 2");
        std::thread::sleep(std::time::Duration::from_millis(2));
        let s3 = start_session(&conn, Some("Third")).expect("Start session 3");

        let result = list_sessions(&conn, None, None).expect("List sessions");

        assert_eq!(result.items.len(), 3);
        // Most recent first
        assert_eq!(result.items[0].id, s3.id);
        assert_eq!(result.items[1].id, s2.id);
        assert_eq!(result.items[2].id, s1.id);
    }

    #[test]
    fn test_count_sessions() {
        let conn = open_in_memory().expect("Failed to open in-memory db");

        start_session(&conn, None).expect("Start session");
        start_session(&conn, None).expect("Start session");

        let count = count_sessions(&conn).expect("Count sessions");
        assert_eq!(count, 2);
    }

    #[test]
    fn test_count_active_sessions() {
        let conn = open_in_memory().expect("Failed to open in-memory db");

        let s1 = start_session(&conn, None).expect("Start session");
        start_session(&conn, None).expect("Start session");

        // End one session
        end_session(&conn, &s1.id, None).expect("End session");

        let active = count_active_sessions(&conn).expect("Count active");
        assert_eq!(active, 1);
    }

    // -------------------------------------------------------------------------
    // Update tests
    // -------------------------------------------------------------------------

    #[test]
    fn test_end_session() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let session = start_session(&conn, None).expect("Start session");

        assert!(session.ended_at.is_none());

        let ended = end_session(&conn, &session.id, None).expect("End session");
        assert!(ended);

        let retrieved = get_session(&conn, &session.id).expect("Get session").unwrap();
        assert!(retrieved.ended_at.is_some());
    }

    #[test]
    fn test_end_session_with_summary() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let session = start_session(&conn, None).expect("Start session");

        end_session(&conn, &session.id, Some("Completed work")).expect("End session");

        let retrieved = get_session(&conn, &session.id).expect("Get session").unwrap();
        assert_eq!(retrieved.summary, Some("Completed work".to_string()));
        assert!(retrieved.ended_at.is_some());
    }

    #[test]
    fn test_end_session_already_ended() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let session = start_session(&conn, None).expect("Start session");

        end_session(&conn, &session.id, None).expect("End session first time");
        let ended_again = end_session(&conn, &session.id, None).expect("End session second time");

        assert!(!ended_again); // Already ended, no rows affected
    }

    #[test]
    fn test_end_current_session() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let session = start_session(&conn, None).expect("Start session");

        let ended_id = end_current_session(&conn, Some("Done")).expect("End current").unwrap();
        assert_eq!(ended_id, session.id);

        // No more current session
        let current = get_current_session(&conn).expect("Get current");
        assert!(current.is_none());
    }

    #[test]
    fn test_end_current_session_none_active() {
        let conn = open_in_memory().expect("Failed to open in-memory db");

        let ended_id = end_current_session(&conn, None).expect("End current");
        assert!(ended_id.is_none());
    }

    #[test]
    fn test_update_session_summary() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let session = start_session(&conn, Some("Original")).expect("Start session");

        update_session_summary(&conn, &session.id, "Updated").expect("Update summary");

        let retrieved = get_session(&conn, &session.id).expect("Get session").unwrap();
        assert_eq!(retrieved.summary, Some("Updated".to_string()));
    }

    // -------------------------------------------------------------------------
    // Delete tests
    // -------------------------------------------------------------------------

    #[test]
    fn test_delete_session() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let session = start_session(&conn, None).expect("Start session");

        let deleted = delete_session(&conn, &session.id).expect("Delete session");
        assert!(deleted);

        let retrieved = get_session(&conn, &session.id).expect("Get session");
        assert!(retrieved.is_none());
    }

    #[test]
    fn test_delete_session_not_found() {
        let conn = open_in_memory().expect("Failed to open in-memory db");

        let deleted = delete_session(&conn, "01ARZ3NDEKTSV4RRFFQ69G5FAV").expect("Delete");
        assert!(!deleted);
    }
}
