{
  "$schema": "../schema/theme-schema.json",
  "name": "Dracula",
  "id": "dracula",
  "type": "dark",
  "author": "Theia Preview (based on Dracula Theme)",
  "version": "1.0.0",
  "colors": {
    "editor": {
      "background": "#282a36",
      "foreground": "#f8f8f2",
      "lineHighlight": "#44475a",
      "selection": "#44475a",
      "selectionHighlight": "#44475a80",
      "cursor": "#f8f8f2",
      "cursorLine": "#44475a"
    },
    "gutter": {
      "background": "#282a36",
      "foreground": "#6272a4",
      "activeForeground": "#f8f8f2"
    },
    "scrollbar": {
      "track": "#282a36",
      "thumb": "#44475a",
      "thumbHover": "#6272a4"
    },
    "bracket": {
      "match": "#ff79c6",
      "mismatch": "#ff5555"
    }
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6272a4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#f1fa8c"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#bd93f9"
      }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean"],
      "settings": {
        "foreground": "#bd93f9"
      }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#50fa7b"
      }
    },
    {
      "name": "Class",
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": {
        "foreground": "#8be9fd",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#f8f8f2"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#ffb86c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": ["variable.other.property", "support.type.property-name"],
      "settings": {
        "foreground": "#50fa7b"
      }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.other"],
      "settings": {
        "foreground": "#bd93f9"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#f8f8f2"
      }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "name": "Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#50fa7b"
      }
    },
    {
      "name": "Type",
      "scope": ["support.type", "entity.name.type"],
      "settings": {
        "foreground": "#8be9fd",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#ff5555"
      }
    },
    {
      "name": "Escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#bd93f9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#ffb86c",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#f1fa8c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#8be9fd"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#50fa7b"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#8be9fd",
    "type": { "foreground": "#8be9fd", "fontStyle": "italic" },
    "class": { "foreground": "#8be9fd", "fontStyle": "italic" },
    "enum": "#8be9fd",
    "interface": { "foreground": "#8be9fd", "fontStyle": "italic" },
    "struct": "#8be9fd",
    "parameter": { "foreground": "#ffb86c", "fontStyle": "italic" },
    "variable": "#f8f8f2",
    "property": "#50fa7b",
    "function": "#50fa7b",
    "method": "#50fa7b",
    "keyword": "#ff79c6",
    "string": "#f1fa8c",
    "number": "#bd93f9"
  }
}
