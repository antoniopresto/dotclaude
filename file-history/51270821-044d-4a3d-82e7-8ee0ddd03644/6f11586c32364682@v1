import Foundation

/// Represents a color theme for syntax highlighting
public struct Theme: Codable {
    public let name: String
    public let id: String?
    public let type: ThemeType
    public let author: String?
    public let version: String?
    public let colors: ThemeColors
    public let tokenColors: [TokenColorRule]
    public let semanticTokenColors: [String: SemanticTokenStyle]?

    public init(
        name: String,
        id: String? = nil,
        type: ThemeType,
        author: String? = nil,
        version: String? = nil,
        colors: ThemeColors,
        tokenColors: [TokenColorRule],
        semanticTokenColors: [String: SemanticTokenStyle]? = nil
    ) {
        self.name = name
        self.id = id
        self.type = type
        self.author = author
        self.version = version
        self.colors = colors
        self.tokenColors = tokenColors
        self.semanticTokenColors = semanticTokenColors
    }
}

/// Theme type for system appearance matching
public enum ThemeType: String, Codable {
    case dark
    case light
    case highContrast = "high-contrast"
}

/// Editor and UI colors
public struct ThemeColors: Codable {
    public let editor: EditorColors
    public let gutter: GutterColors?
    public let scrollbar: ScrollbarColors?
    public let bracket: BracketColors?
}

public struct EditorColors: Codable {
    public let background: String
    public let foreground: String
    public let lineHighlight: String?
    public let selection: String?
    public let selectionHighlight: String?
    public let cursor: String?
    public let cursorLine: String?
}

public struct GutterColors: Codable {
    public let background: String?
    public let foreground: String?
    public let activeForeground: String?
}

public struct ScrollbarColors: Codable {
    public let track: String?
    public let thumb: String?
    public let thumbHover: String?
}

public struct BracketColors: Codable {
    public let match: String?
    public let mismatch: String?
}

/// Token color rule for syntax highlighting
public struct TokenColorRule: Codable {
    public let name: String?
    public let scope: TokenScope
    public let settings: TokenSettings
}

/// Scope can be a single string or array of strings
public enum TokenScope: Codable {
    case single(String)
    case multiple([String])

    public init(from decoder: Decoder) throws {
        let container = try decoder.singleValueContainer()
        if let single = try? container.decode(String.self) {
            self = .single(single)
        } else if let multiple = try? container.decode([String].self) {
            self = .multiple(multiple)
        } else {
            throw DecodingError.typeMismatch(
                TokenScope.self,
                DecodingError.Context(codingPath: decoder.codingPath, debugDescription: "Expected String or [String]")
            )
        }
    }

    public func encode(to encoder: Encoder) throws {
        var container = encoder.singleValueContainer()
        switch self {
        case .single(let value):
            try container.encode(value)
        case .multiple(let values):
            try container.encode(values)
        }
    }

    public var scopes: [String] {
        switch self {
        case .single(let value): return [value]
        case .multiple(let values): return values
        }
    }
}

/// Token style settings
public struct TokenSettings: Codable {
    public let foreground: String?
    public let background: String?
    public let fontStyle: String?
}

/// Semantic token style (from LSP)
public enum SemanticTokenStyle: Codable {
    case color(String)
    case styled(SemanticTokenStyledValue)

    public init(from decoder: Decoder) throws {
        let container = try decoder.singleValueContainer()
        if let color = try? container.decode(String.self) {
            self = .color(color)
        } else if let styled = try? container.decode(SemanticTokenStyledValue.self) {
            self = .styled(styled)
        } else {
            throw DecodingError.typeMismatch(
                SemanticTokenStyle.self,
                DecodingError.Context(codingPath: decoder.codingPath, debugDescription: "Expected String or object")
            )
        }
    }

    public func encode(to encoder: Encoder) throws {
        var container = encoder.singleValueContainer()
        switch self {
        case .color(let value):
            try container.encode(value)
        case .styled(let value):
            try container.encode(value)
        }
    }
}

public struct SemanticTokenStyledValue: Codable {
    public let foreground: String?
    public let fontStyle: String?
}
