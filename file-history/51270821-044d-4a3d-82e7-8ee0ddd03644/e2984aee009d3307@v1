{
  "$schema": "../schema/theme-schema.json",
  "name": "One Dark",
  "id": "one-dark",
  "type": "dark",
  "author": "Theia Preview",
  "version": "1.0.0",
  "colors": {
    "editor": {
      "background": "#282c34",
      "foreground": "#abb2bf",
      "lineHighlight": "#2c313c",
      "selection": "#3e4451",
      "selectionHighlight": "#3e445180",
      "cursor": "#528bff",
      "cursorLine": "#2c313c"
    },
    "gutter": {
      "background": "#282c34",
      "foreground": "#4b5263",
      "activeForeground": "#abb2bf"
    },
    "scrollbar": {
      "track": "#282c34",
      "thumb": "#4b5263",
      "thumbHover": "#5c6370"
    },
    "bracket": {
      "match": "#528bff",
      "mismatch": "#e06c75"
    }
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#5c6370",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#c678dd"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#98c379"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean"],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#61afef"
      }
    },
    {
      "name": "Class",
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#abb2bf",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": ["variable.other.property", "support.type.property-name"],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.other"],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#abb2bf"
      }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "name": "Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "Type",
      "scope": ["support.type", "entity.name.type"],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "Escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#e06c75",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#d19a66",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#c678dd",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#98c379"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#e5c07b",
    "type": "#e5c07b",
    "class": "#e5c07b",
    "enum": "#e5c07b",
    "interface": "#e5c07b",
    "struct": "#e5c07b",
    "typeParameter": "#e5c07b",
    "parameter": { "foreground": "#abb2bf", "fontStyle": "italic" },
    "variable": "#e06c75",
    "property": "#e06c75",
    "enumMember": "#56b6c2",
    "function": "#61afef",
    "method": "#61afef",
    "macro": "#c678dd",
    "keyword": "#c678dd",
    "comment": { "foreground": "#5c6370", "fontStyle": "italic" },
    "string": "#98c379",
    "number": "#d19a66",
    "regexp": "#56b6c2",
    "operator": "#56b6c2"
  }
}
