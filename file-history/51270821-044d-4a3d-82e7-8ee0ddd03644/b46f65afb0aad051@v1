# BMAD Method Configuration for Theia Preview
# =============================================
# Hybrid methodology combining Anthropic Harness patterns with BMAD workflows

project:
  name: "Theia Preview"
  codename: "theia-preview"
  version: "0.1.0"
  description: "Native macOS Quick Look extension for developer file previews"

methodology:
  type: "hybrid"
  components:
    - anthropic-harness  # Feature list tracking, progress log
    - bmad-method        # Phase-based workflows, agent definitions

  feature_tracking:
    file: "features/feature-list.json"
    progress_log: "features/theia-progress.txt"

  workflow_track: "bmad-method"  # PRD + Architecture + UX

phases:
  - id: 1
    name: "Core Infrastructure"
    description: "Quick Look extension bundle, basic syntax highlighting, theme system foundation"
    deliverables:
      - "Working Quick Look extension skeleton"
      - "Basic syntax highlighting for JSON, YAML, Markdown"
      - "Theme JSON schema and loader"
      - "Main app bundle for hosting extension"

  - id: 2
    name: "Language Support & Themes"
    description: "Full language support, all themes, inline editing, settings app"
    deliverables:
      - "50+ language syntax highlighting"
      - "20+ built-in themes"
      - "Inline editing capability"
      - "Settings application"
      - "LSP integration for Swift and other languages"

  - id: 3
    name: "Advanced Features"
    description: "Performance optimization, accessibility, advanced editing"
    deliverables:
      - "Virtual scrolling for large files"
      - "VoiceOver support"
      - "Find and replace"
      - "Performance benchmarks passing"

  - id: 4
    name: "Distribution"
    description: "Packaging, signing, distribution channels"
    deliverables:
      - "Signed and notarized DMG"
      - "Homebrew cask formula"
      - "Auto-update mechanism"
      - "Universal binary"

agents:
  active:
    - analyst
    - architect
    - developer
    - ux-designer

scale_adaptive:
  enabled: true
  default_depth: "medium"

git:
  commit_style: "conventional"
  branch_prefix: "feature/"
  require_tests: true
