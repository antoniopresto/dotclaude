{
  "$schema": "../schema/theme-schema.json",
  "name": "GitHub Light",
  "id": "github-light",
  "type": "light",
  "author": "Theia Preview (based on GitHub Theme)",
  "version": "1.0.0",
  "colors": {
    "editor": {
      "background": "#ffffff",
      "foreground": "#24292f",
      "lineHighlight": "#f6f8fa",
      "selection": "#0969da33",
      "selectionHighlight": "#0969da1a",
      "cursor": "#24292f",
      "cursorLine": "#f6f8fa"
    },
    "gutter": {
      "background": "#ffffff",
      "foreground": "#8c959f",
      "activeForeground": "#24292f"
    },
    "scrollbar": {
      "track": "#f6f8fa",
      "thumb": "#8c959f40",
      "thumbHover": "#8c959f80"
    },
    "bracket": {
      "match": "#0969da",
      "mismatch": "#cf222e"
    }
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6e7781",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#cf222e"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#0a3069"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#0550ae"
      }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean"],
      "settings": {
        "foreground": "#0550ae"
      }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#8250df"
      }
    },
    {
      "name": "Class",
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": {
        "foreground": "#953800"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#24292f"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#953800"
      }
    },
    {
      "name": "Property",
      "scope": ["variable.other.property", "support.type.property-name"],
      "settings": {
        "foreground": "#0550ae"
      }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.other"],
      "settings": {
        "foreground": "#0550ae"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#24292f"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#24292f"
      }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#116329"
      }
    },
    {
      "name": "Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#0550ae"
      }
    },
    {
      "name": "Type",
      "scope": ["support.type", "entity.name.type"],
      "settings": {
        "foreground": "#953800"
      }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#0a3069"
      }
    },
    {
      "name": "Escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#0550ae"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#0550ae",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#24292f",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#24292f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#0969da"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#0a3069"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#953800",
    "type": "#953800",
    "class": "#953800",
    "function": "#8250df",
    "method": "#8250df",
    "parameter": "#953800",
    "variable": "#24292f",
    "property": "#0550ae",
    "keyword": "#cf222e",
    "string": "#0a3069",
    "number": "#0550ae"
  }
}
