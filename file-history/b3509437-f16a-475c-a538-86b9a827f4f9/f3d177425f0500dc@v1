#!/bin/bash
# MD Project Init Script
# Run this to set up the development environment

set -e

echo "=== MD - macOS DevTools Setup ==="

# Check prerequisites
command -v bun >/dev/null 2>&1 || { echo "Error: bun is required. Install: curl -fsSL https://bun.sh/install | bash"; exit 1; }
command -v cargo >/dev/null 2>&1 || { echo "Error: Rust/Cargo is required. Install: https://rustup.rs"; exit 1; }

# Install dependencies
echo "Installing dependencies..."
bun install

# Check Tauri CLI
if ! bun tauri --version >/dev/null 2>&1; then
  echo "Installing Tauri CLI..."
  bun add -d @tauri-apps/cli
fi

echo ""
echo "=== Setup Complete ==="
echo ""
echo "To run the app:"
echo "  bun run tauri dev"
echo ""
echo "To build for production:"
echo "  bun run tauri build"
echo ""
echo "Testing (via MCP automation):"
echo "  1. Ensure automation-mcp is configured in Claude"
echo "  2. Grant Accessibility + Screen Recording permissions"
echo "  3. Use mcp__automation__ tools for visual QA"
echo ""
