'use client';

import React from 'react';

interface KPICardProps {
  title: string;
  value: string | number;
  subtitle?: string;
  borderColor?: string;
  icon?: React.ReactNode;
  loading?: boolean;
}

/**
 * KPI Card Component
 *
 * Displays a single KPI metric with title, value, and optional subtitle.
 * Uses EN 15380 railway terminology.
 */
export function KPICard({
  title,
  value,
  subtitle,
  borderColor = 'border-primary-500',
  icon,
  loading = false,
}: KPICardProps) {
  return (
    <div
      className={`bg-white shadow rounded-lg p-4 border-l-4 ${borderColor} transition-all duration-200 hover:shadow-md`}
    >
      <div className="flex items-center justify-between">
        <div className="text-sm font-medium text-gray-500">{title}</div>
        {icon && <div className="text-gray-400">{icon}</div>}
      </div>
      <div className="mt-2">
        {loading ? (
          <div className="animate-pulse">
            <div className="h-8 bg-gray-200 rounded w-20"></div>
          </div>
        ) : (
          <div className="text-3xl font-bold text-gray-900">{value}</div>
        )}
      </div>
      {subtitle && !loading && (
        <div className="mt-1 text-sm text-gray-500">{subtitle}</div>
      )}
    </div>
  );
}
