// MMS - Metro Mileage Management System
// Shared TypeScript Types

// =============================================================================
// Core Domain Entities
// =============================================================================

export interface Fleet {
  id: string;
  name: string;
  manufacturer: string | null;
  pm1IntervalKm: number;
  pm2IntervalKm: number;
  hmIntervalKm: number;
  createdAt: Date;
}

export interface Depot {
  id: string;
  name: string;
  code: string;
  latitude: number | null;
  longitude: number | null;
  capacityTracks: number;
  capacityManhours: number;
  createdAt: Date;
}

export interface Train {
  id: string;
  trainId: string; // Business ID: UTE-3400-012
  fleetId: string;
  baseDepotId: string;
  currentKm: number;
  targetKm: number;
  fitnessStatus: 'fit' | 'unfit';
  lastMaintenanceDate: Date | null;
  nextMaintenanceKm: number | null;
  latitude: number | null;
  longitude: number | null;
  createdAt: Date;
  updatedAt: Date;
}

export interface Service {
  id: string;
  serviceCode: string; // IC 501
  origin: string;
  destination: string;
  distanceKm: number;
  departureTime: string; // HH:MM format
  arrivalTime: string;
  serviceType: 'regional' | 'intercity';
  createdAt: Date;
}

export type AllocationStatus = 'pending' | 'confirmed' | 'completed' | 'cancelled';

export interface Allocation {
  id: string;
  serviceId: string;
  trainId: string;
  allocationDate: Date;
  status: AllocationStatus;
  score: number | null;
  justifications: string[] | null;
  createdBy: string | null;
  createdAt: Date;
}

export interface MileageHistory {
  id: string;
  trainId: string;
  recordedDate: Date;
  kmValue: number;
  createdAt: Date;
}

export type MaintenanceType = 'PM1' | 'PM2' | 'HM' | 'OVH';
export type MaintenanceStatus = 'scheduled' | 'in_progress' | 'completed' | 'cancelled';

export interface MaintenanceSchedule {
  id: string;
  trainId: string;
  depotId: string;
  maintenanceType: MaintenanceType;
  scheduledDate: Date;
  durationDays: number;
  status: MaintenanceStatus;
  createdAt: Date;
}

// =============================================================================
// API Response Types
// =============================================================================

export type VarianceStatus = 'green' | 'yellow' | 'red';

export interface DashboardSummary {
  totalTrains: number;
  availableTrains: number;
  inMaintenanceCount: number;
  kmVariance: number;
  varianceStatus: VarianceStatus;
}

export interface DepotCapacity {
  id: string;
  name: string;
  code: string;
  currentOccupancy: number;
  maxCapacity: number;
  percentUsed: number;
}

export interface TrainWithDetails extends Train {
  fleet?: Fleet;
  depot?: Depot;
  deltaFromAverage?: number;
  deltaPercent?: number;
}

// =============================================================================
// Solver Types
// =============================================================================

export interface RecommendationRequest {
  serviceId: string;
  date: string; // ISO date
  constraints?: {
    prioritizeBalancing?: boolean;
    maxDeadRunningKm?: number;
  };
}

export interface TrainRecommendation {
  trainId: string;
  score: number;
  justifications: string[];
  deadRunningKm: number;
}

export interface RecommendationResponse {
  recommendations: TrainRecommendation[];
  solverTimeMs: number;
}

// =============================================================================
// Simulation Types
// =============================================================================

export interface SimulationScenario {
  id: string;
  name: string;
  baseDate: string;
  createdAt: Date;
}

export interface AllocationChange {
  serviceId: string;
  originalTrainId: string | null;
  newTrainId: string;
}

export interface SimulationResult {
  projectedVariance: number;
  projectedDeadRunning: number;
  comparison: {
    metric: string;
    current: number;
    projected: number;
    change: number;
    improved: boolean;
  }[];
}

// =============================================================================
// Balancing Types
// =============================================================================

export interface KmDistribution {
  average: number;
  variance: number;
  distribution: {
    kmRange: string;
    count: number;
  }[];
  outliers: {
    trainId: string;
    delta: number;
    status: 'over' | 'under';
  }[];
}

// =============================================================================
// Common Types
// =============================================================================

export interface ApiError {
  error: string;
  code: string;
  details?: Record<string, unknown>;
}

export interface PaginatedResponse<T> {
  data: T[];
  total: number;
  page: number;
  pageSize: number;
  hasMore: boolean;
}
