'use client';

import React, { useEffect, useState, useCallback } from 'react';
import {
  BarChart,
  Bar,
  XAxis,
  YAxis,
  CartesianGrid,
  Tooltip,
  ResponsiveContainer,
  ReferenceLine,
  Cell,
} from 'recharts';
import { apiFetch } from '@/lib/api';

interface DistributionBucket {
  kmRange: string;
  count: number;
}

interface Outlier {
  trainId: string;
  currentKm: number;
  delta: number;
  deltaPercent: number;
  status: 'over' | 'under';
}

interface DistributionResponse {
  average: number;
  variance: number;
  distribution: DistributionBucket[];
  outliers: Outlier[];
}

interface RankedTrain {
  id: string;
  trainId: string;
  fleetName: string;
  depotCode: string;
  currentKm: number;
  targetKm: number;
  delta: number;
  deltaPercent: number;
  status: 'over' | 'under' | 'balanced';
}

interface RankingResponse {
  average: number;
  trains: RankedTrain[];
}

/**
 * Balancing Dashboard Component
 *
 * Displays mileage distribution, train ranking, and outlier identification.
 */
export function BalancingDashboard() {
  const [distribution, setDistribution] = useState<DistributionResponse | null>(null);
  const [ranking, setRanking] = useState<RankingResponse | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  const fetchData = useCallback(async () => {
    setLoading(true);
    setError(null);

    const [distRes, rankRes] = await Promise.all([
      apiFetch<DistributionResponse>('/api/balancing/distribution'),
      apiFetch<RankingResponse>('/api/balancing/ranking'),
    ]);

    if (distRes.error) {
      setError(distRes.error);
    } else {
      setDistribution(distRes.data);
    }

    if (rankRes.error && !error) {
      setError(rankRes.error);
    } else {
      setRanking(rankRes.data);
    }

    setLoading(false);
  }, []);

  useEffect(() => {
    fetchData();
  }, [fetchData]);

  if (loading) {
    return (
      <div className="space-y-6">
        <div className="bg-white shadow rounded-lg p-6 animate-pulse">
          <div className="h-6 bg-gray-200 rounded w-1/3 mb-4"></div>
          <div className="h-64 bg-gray-200 rounded"></div>
        </div>
      </div>
    );
  }

  if (error) {
    return (
      <div className="bg-red-50 border border-red-200 rounded-lg p-6">
        <p className="text-red-800">
          <strong>Error:</strong> {error}
        </p>
      </div>
    );
  }

  // Prepare data for chart
  const chartData = distribution?.distribution.map((d, idx) => ({
    ...d,
    fill: idx === 4 || idx === 5 ? '#22c55e' : '#94a3b8', // Highlight middle buckets
  })) || [];

  // Top 5 over and under running trains
  const topOver = ranking?.trains.filter(t => t.status === 'over').slice(0, 5) || [];
  const topUnder = ranking?.trains.filter(t => t.status === 'under').slice(0, 5) || [];

  return (
    <div className="space-y-6">
      {/* Summary Stats */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div className="bg-white shadow rounded-lg p-4">
          <div className="text-sm font-medium text-gray-500">Fleet Average</div>
          <div className="text-2xl font-bold text-gray-900">
            {distribution?.average.toLocaleString()} km
          </div>
        </div>
        <div className="bg-white shadow rounded-lg p-4">
          <div className="text-sm font-medium text-gray-500">Variance</div>
          <div className={`text-2xl font-bold ${
            (distribution?.variance || 0) <= 10 ? 'text-green-600' :
            (distribution?.variance || 0) <= 20 ? 'text-yellow-600' : 'text-red-600'
          }`}>
            {distribution?.variance}%
          </div>
        </div>
        <div className="bg-white shadow rounded-lg p-4">
          <div className="text-sm font-medium text-gray-500">Outliers ({'>'}15% deviation)</div>
          <div className="text-2xl font-bold text-red-600">
            {distribution?.outliers.length || 0} trains
          </div>
        </div>
      </div>

      {/* Distribution Chart */}
      <div className="bg-white shadow rounded-lg p-6">
        <h2 className="text-lg font-semibold text-gray-900 mb-4">
          Mileage Distribution
        </h2>
        <div className="h-64">
          <ResponsiveContainer width="100%" height="100%">
            <BarChart data={chartData}>
              <CartesianGrid strokeDasharray="3 3" />
              <XAxis
                dataKey="kmRange"
                fontSize={10}
                angle={-45}
                textAnchor="end"
                height={60}
              />
              <YAxis />
              <Tooltip />
              <ReferenceLine
                x={4}
                stroke="#22c55e"
                strokeWidth={2}
                label={{ value: 'Target', position: 'top', fill: '#22c55e' }}
              />
              <Bar dataKey="count" name="Trains">
                {chartData.map((entry, index) => (
                  <Cell key={`cell-${index}`} fill={entry.fill} />
                ))}
              </Bar>
            </BarChart>
          </ResponsiveContainer>
        </div>
        <p className="mt-2 text-sm text-gray-500 text-center">
          Green bars indicate target mileage range (±10% of average)
        </p>
      </div>

      {/* Train Ranking */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {/* Over-Running Trains */}
        <div className="bg-white shadow rounded-lg overflow-hidden">
          <div className="p-4 border-b border-gray-200 bg-red-50">
            <h3 className="font-semibold text-red-800">
              Over-Running Trains (Top 5)
            </h3>
            <p className="text-sm text-red-600">
              These trains have higher than average mileage
            </p>
          </div>
          <div className="divide-y divide-gray-100">
            {topOver.length === 0 ? (
              <div className="p-4 text-center text-gray-500">
                No over-running trains
              </div>
            ) : (
              topOver.map((train) => (
                <div key={train.id} className="p-4 flex items-center justify-between">
                  <div>
                    <div className="font-mono font-semibold text-gray-900">
                      {train.trainId}
                    </div>
                    <div className="text-sm text-gray-500">
                      {train.fleetName} • {train.depotCode}
                    </div>
                  </div>
                  <div className="text-right">
                    <div className="text-lg font-semibold text-red-600">
                      +{train.deltaPercent}%
                    </div>
                    <div className="text-sm text-gray-500">
                      {train.currentKm.toLocaleString()} km
                    </div>
                  </div>
                </div>
              ))
            )}
          </div>
        </div>

        {/* Under-Running Trains */}
        <div className="bg-white shadow rounded-lg overflow-hidden">
          <div className="p-4 border-b border-gray-200 bg-blue-50">
            <h3 className="font-semibold text-blue-800">
              Under-Running Trains (Top 5)
            </h3>
            <p className="text-sm text-blue-600">
              Priority candidates for allocation
            </p>
          </div>
          <div className="divide-y divide-gray-100">
            {topUnder.length === 0 ? (
              <div className="p-4 text-center text-gray-500">
                No under-running trains
              </div>
            ) : (
              topUnder.map((train) => (
                <div key={train.id} className="p-4 flex items-center justify-between">
                  <div>
                    <div className="font-mono font-semibold text-gray-900">
                      {train.trainId}
                    </div>
                    <div className="text-sm text-gray-500">
                      {train.fleetName} • {train.depotCode}
                    </div>
                  </div>
                  <div className="text-right">
                    <div className="text-lg font-semibold text-blue-600">
                      {train.deltaPercent}%
                    </div>
                    <div className="text-sm text-gray-500">
                      {train.currentKm.toLocaleString()} km
                    </div>
                  </div>
                </div>
              ))
            )}
          </div>
        </div>
      </div>

      {/* Outliers Alert */}
      {distribution && distribution.outliers.length > 0 && (
        <div className="bg-amber-50 border border-amber-200 rounded-lg p-4">
          <h3 className="font-semibold text-amber-800 mb-2">
            ⚠️ Outlier Trains ({distribution.outliers.length})
          </h3>
          <div className="flex flex-wrap gap-2">
            {distribution.outliers.slice(0, 10).map((o) => (
              <span
                key={o.trainId}
                className={`px-2 py-1 text-sm rounded ${
                  o.status === 'over'
                    ? 'bg-red-100 text-red-700'
                    : 'bg-blue-100 text-blue-700'
                }`}
              >
                {o.trainId}: {o.deltaPercent > 0 ? '+' : ''}{o.deltaPercent}%
              </span>
            ))}
            {distribution.outliers.length > 10 && (
              <span className="px-2 py-1 text-sm text-gray-500">
                +{distribution.outliers.length - 10} more
              </span>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
