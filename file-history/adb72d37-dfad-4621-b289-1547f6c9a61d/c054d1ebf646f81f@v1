#!/bin/bash
# Hook: SessionStart - Informational only
# Exit 0 always (never block session start)

PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$(pwd)}"
cd "$PROJECT_DIR" 2>/dev/null || exit 0

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🚀 MMS-LAST-ATTEMPT | $(date '+%Y-%m-%d %H:%M')"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Check harness files
[ -f ".harness/progress.txt" ] && echo "✅ progress.txt" || echo "⚠️  progress.txt MISSING"
[ -f ".harness/features.json" ] && echo "✅ features.json" || echo "⚠️  features.json MISSING"

# Git status
UNCOMMITTED=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
[ "$UNCOMMITTED" -gt 0 ] && echo "⚠️  $UNCOMMITTED uncommitted files"

echo ""
echo "Protocol: READ progress.txt → features.json → WORK → COMMIT"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

exit 0
