import { useState, useEffect, useCallback } from 'react';
import {
  Modal,
  ModalBody,
  ModalHeader,
  ModalVariant,
  Button,
  Card,
  CardBody,
  Content,
  EmptyState,
  EmptyStateBody,
  EmptyStateFooter,
  EmptyStateActions,
  Split,
  SplitItem,
  Stack,
  StackItem,
  Label,
  Alert,
  AlertActionCloseButton,
  Spinner,
  Icon,
  TextInputGroup,
  TextInputGroupMain,
  TextInputGroupUtilities,
} from '@patternfly/react-core';
import {
  FolderIcon,
  FolderOpenIcon,
  TimesIcon,
  PlusCircleIcon,
} from '@patternfly/react-icons';
import { invoke, isTauri, waitForConnection } from '../lib/rpc';
import { motion, AnimatePresence } from 'motion/react';

// Dynamically import Tauri dialog plugin (only works in Tauri context)
async function openFolderDialog(): Promise<string | null> {
  try {
    const { open } = await import('@tauri-apps/plugin-dialog');
    const selected = await open({
      directory: true,
      multiple: false,
      title: 'Select Project Folder',
    });
    return typeof selected === 'string' ? selected : null;
  } catch (e) {
    console.error('Tauri dialog not available:', e);
    return null;
  }
}

// Local storage key for recent projects
const RECENT_PROJECTS_KEY = 'hq_recent_projects';
const MAX_RECENT_PROJECTS = 10;

export interface RecentProject {
  path: string;
  name: string;
  lastOpened: number;
  isValid?: boolean;
}

interface ProjectSelectorProps {
  isOpen: boolean;
  onClose: () => void;
  onSelectProject: (path: string, name: string) => void;
}

// Validate if a folder is a valid harness project (has .harness folder)
async function validateHarnessProject(path: string): Promise<boolean> {
  try {
    // Use Tauri invoke to check if .harness directory exists
    const exists = await invoke<boolean>('check_harness_exists', { path });
    return exists;
  } catch {
    // Fallback: assume valid if we can't check
    return true;
  }
}

// Get project name from path
function getProjectName(path: string): string {
  const parts = path.split(/[/\\]/);
  return parts[parts.length - 1] || 'Unknown Project';
}

// Load recent projects from localStorage
function loadRecentProjects(): RecentProject[] {
  try {
    const stored = localStorage.getItem(RECENT_PROJECTS_KEY);
    if (stored) {
      return JSON.parse(stored);
    }
  } catch (e) {
    console.error('Failed to load recent projects:', e);
  }
  return [];
}

// Save recent projects to localStorage
function saveRecentProjects(projects: RecentProject[]): void {
  try {
    localStorage.setItem(RECENT_PROJECTS_KEY, JSON.stringify(projects));
  } catch (e) {
    console.error('Failed to save recent projects:', e);
  }
}

// Add a project to recent projects
function addToRecentProjects(path: string, name: string): void {
  const projects = loadRecentProjects();

  // Remove if already exists
  const filtered = projects.filter((p) => p.path !== path);

  // Add to front
  filtered.unshift({
    path,
    name,
    lastOpened: Date.now(),
    isValid: true,
  });

  // Keep only MAX_RECENT_PROJECTS
  const trimmed = filtered.slice(0, MAX_RECENT_PROJECTS);

  saveRecentProjects(trimmed);
}

// Remove a project from recent projects
function removeFromRecentProjects(path: string): RecentProject[] {
  const projects = loadRecentProjects();
  const filtered = projects.filter((p) => p.path !== path);
  saveRecentProjects(filtered);
  return filtered;
}

export function ProjectSelector({
  isOpen,
  onClose,
  onSelectProject,
}: ProjectSelectorProps): React.JSX.Element {
  const [recentProjects, setRecentProjects] = useState<RecentProject[]>([]);
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [validatingProjects, setValidatingProjects] = useState(false);
  const [showManualInput, setShowManualInput] = useState(false);
  const [manualPath, setManualPath] = useState('');
  const [isDevBridgeMode, setIsDevBridgeMode] = useState(false);

  // Load recent projects on mount and detect mode
  useEffect(() => {
    if (isOpen) {
      const projects = loadRecentProjects();
      setRecentProjects(projects);
      setError(null);
      setManualPath('');
      setShowManualInput(false);

      // Detect if we're in browser mode (dev bridge)
      const browserMode = !isTauri();
      setIsDevBridgeMode(browserMode);

      // In dev bridge mode, show manual input by default
      if (browserMode) {
        setShowManualInput(true);
      }

      // Validate projects in background
      validateRecentProjects(projects);
    }
  }, [isOpen]);

  // Validate recent projects in background
  const validateRecentProjects = useCallback(async (projects: RecentProject[]) => {
    if (projects.length === 0) return;

    setValidatingProjects(true);

    const validated = await Promise.all(
      projects.map(async (project) => ({
        ...project,
        isValid: await validateHarnessProject(project.path),
      }))
    );

    setRecentProjects(validated);
    setValidatingProjects(false);
  }, []);

  // Handle browse folder (Tauri mode only)
  const handleBrowse = useCallback(async () => {
    // In dev bridge mode, use manual input instead
    if (isDevBridgeMode) {
      setShowManualInput(true);
      return;
    }

    setIsLoading(true);
    setError(null);

    try {
      const selected = await openFolderDialog();

      if (selected) {
        // Validate it's a harness project
        const isValid = await validateHarnessProject(selected);

        if (!isValid) {
          setError(`Selected folder does not contain a .harness directory. Please select a valid Harness project.`);
          setIsLoading(false);
          return;
        }

        const name = getProjectName(selected);
        addToRecentProjects(selected, name);
        onSelectProject(selected, name);
        onClose();
      }
    } catch (e) {
      console.error('Failed to open directory:', e);
      setError('Failed to open folder picker. Please try again.');
    } finally {
      setIsLoading(false);
    }
  }, [onSelectProject, onClose, isDevBridgeMode]);

  // Handle manual path submission (Dev Bridge mode)
  const handleManualPathSubmit = useCallback(async () => {
    if (!manualPath.trim()) {
      setError('Please enter a valid path');
      return;
    }

    setIsLoading(true);
    setError(null);

    try {
      // Wait for connection first
      if (!isTauri()) {
        const connected = await waitForConnection(5000);
        if (!connected) {
          setError('Unable to connect to Dev Bridge. Make sure the app is running with "bun tauri dev".');
          setIsLoading(false);
          return;
        }
      }

      const path = manualPath.trim();

      // Validate it's a harness project
      const isValid = await validateHarnessProject(path);

      if (!isValid) {
        setError(`Path does not contain a .harness directory. Please enter a valid Harness project path.`);
        setIsLoading(false);
        return;
      }

      const name = getProjectName(path);
      addToRecentProjects(path, name);
      onSelectProject(path, name);
      onClose();
    } catch (e) {
      console.error('Failed to validate path:', e);
      setError(`Failed to validate path: ${e instanceof Error ? e.message : 'Unknown error'}`);
    } finally {
      setIsLoading(false);
    }
  }, [manualPath, onSelectProject, onClose]);

  // Handle Enter key on manual input
  const handleManualKeyDown = useCallback((e: React.KeyboardEvent) => {
    if (e.key === 'Enter') {
      handleManualPathSubmit();
    }
  }, [handleManualPathSubmit]);

  // Handle select recent project
  const handleSelectRecent = useCallback(async (project: RecentProject) => {
    setError(null);

    // Re-validate before opening
    const isValid = await validateHarnessProject(project.path);

    if (!isValid) {
      setError(`Project "${project.name}" no longer contains a valid .harness directory.`);
      return;
    }

    addToRecentProjects(project.path, project.name);
    onSelectProject(project.path, project.name);
    onClose();
  }, [onSelectProject, onClose]);

  // Handle remove recent project
  const handleRemoveRecent = useCallback((e: React.MouseEvent, path: string) => {
    e.stopPropagation();
    const updated = removeFromRecentProjects(path);
    setRecentProjects(updated);
  }, []);

  // Format relative time
  const formatRelativeTime = (timestamp: number): string => {
    const diff = Date.now() - timestamp;
    const minutes = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);

    if (minutes < 1) return 'Just now';
    if (minutes < 60) return `${minutes}m ago`;
    if (hours < 24) return `${hours}h ago`;
    if (days < 7) return `${days}d ago`;
    return new Date(timestamp).toLocaleDateString();
  };

  return (
    <Modal
      isOpen={isOpen}
      onClose={onClose}
      variant={ModalVariant.medium}
      aria-label="Project Selector"
    >
      <ModalHeader title="Open Project" />
      <ModalBody>
        <Stack hasGutter>
          {/* Error Alert */}
          <AnimatePresence>
            {error && (
              <StackItem>
                <motion.div
                  initial={{ opacity: 0, height: 0 }}
                  animate={{ opacity: 1, height: 'auto' }}
                  exit={{ opacity: 0, height: 0 }}
                >
                  <Alert
                    variant="warning"
                    title="Invalid Project"
                    actionClose={
                      <AlertActionCloseButton onClose={() => setError(null)} />
                    }
                  >
                    {error}
                  </Alert>
                </motion.div>
              </StackItem>
            )}
          </AnimatePresence>

          {/* Dev Bridge Mode: Manual Path Input */}
          {isDevBridgeMode && showManualInput && (
            <StackItem>
              <Alert
                variant="info"
                title="Dev Bridge Mode"
                isInline
                style={{ marginBottom: 8 }}
              >
                Native folder picker is not available. Enter the project path manually.
              </Alert>
              <TextInputGroup>
                <TextInputGroupMain
                  value={manualPath}
                  onChange={(_e, val) => setManualPath(val)}
                  onKeyDown={handleManualKeyDown}
                  placeholder="/path/to/your/project"
                  aria-label="Project path"
                />
                <TextInputGroupUtilities>
                  <Button
                    variant="control"
                    onClick={handleManualPathSubmit}
                    isLoading={isLoading}
                    isDisabled={isLoading || !manualPath.trim()}
                  >
                    Open
                  </Button>
                </TextInputGroupUtilities>
              </TextInputGroup>
            </StackItem>
          )}

          {/* Browse Button (Tauri mode) */}
          {!isDevBridgeMode && (
            <StackItem>
              <Button
                variant="primary"
                icon={<FolderOpenIcon />}
                onClick={handleBrowse}
                isLoading={isLoading}
                isDisabled={isLoading}
                isBlock
              >
                {isLoading ? 'Opening...' : 'Browse for Folder...'}
              </Button>
            </StackItem>
          )}

          {/* Recent Projects */}
          <StackItem>
            <Content component="h3">
              Recent Projects
              {validatingProjects && (
                <Spinner size="sm" style={{ marginLeft: 8 }} />
              )}
            </Content>
          </StackItem>

          <StackItem>
            {recentProjects.length === 0 ? (
              <EmptyState
                titleText="No recent projects"
                headingLevel="h4"
                icon={FolderIcon}
              >
                <EmptyStateBody>
                  Open a project folder to get started. Projects with a .harness
                  directory will be shown here for quick access.
                </EmptyStateBody>
                <EmptyStateFooter>
                  <EmptyStateActions>
                    <Button
                      variant="primary"
                      icon={<PlusCircleIcon />}
                      onClick={handleBrowse}
                    >
                      Open Project
                    </Button>
                  </EmptyStateActions>
                </EmptyStateFooter>
              </EmptyState>
            ) : (
              <Stack hasGutter>
                <AnimatePresence>
                  {recentProjects.map((project, index) => (
                    <StackItem key={project.path}>
                      <motion.div
                        initial={{ opacity: 0, x: -20 }}
                        animate={{ opacity: 1, x: 0 }}
                        exit={{ opacity: 0, x: 20 }}
                        transition={{ delay: index * 0.05 }}
                      >
                        <Card
                          isClickable
                          isSelectable
                          onClick={() => handleSelectRecent(project)}
                          style={{
                            opacity: project.isValid === false ? 0.5 : 1,
                          }}
                        >
                          <CardBody>
                            <Split hasGutter>
                              <SplitItem>
                                <Icon
                                  status={project.isValid === false ? 'warning' : 'info'}
                                  size="lg"
                                >
                                  <FolderIcon />
                                </Icon>
                              </SplitItem>
                              <SplitItem isFilled>
                                <Content>
                                  <Content component="h4" style={{ marginBottom: 4 }}>
                                    {project.name}
                                  </Content>
                                  <Content
                                    component="small"
                                    style={{
                                      color: 'var(--pf-t--global--text--color--subtle)',
                                      wordBreak: 'break-all',
                                    }}
                                  >
                                    {project.path}
                                  </Content>
                                </Content>
                              </SplitItem>
                              <SplitItem>
                                <Split hasGutter>
                                  <SplitItem>
                                    <Label isCompact color="grey">
                                      {formatRelativeTime(project.lastOpened)}
                                    </Label>
                                  </SplitItem>
                                  {project.isValid === false && (
                                    <SplitItem>
                                      <Label isCompact color="orange">
                                        Invalid
                                      </Label>
                                    </SplitItem>
                                  )}
                                  <SplitItem>
                                    <Button
                                      variant="plain"
                                      aria-label="Remove from recent"
                                      onClick={(e) =>
                                        handleRemoveRecent(e, project.path)
                                      }
                                    >
                                      <TimesIcon />
                                    </Button>
                                  </SplitItem>
                                </Split>
                              </SplitItem>
                            </Split>
                          </CardBody>
                        </Card>
                      </motion.div>
                    </StackItem>
                  ))}
                </AnimatePresence>
              </Stack>
            )}
          </StackItem>
        </Stack>
      </ModalBody>
    </Modal>
  );
}

export default ProjectSelector;
