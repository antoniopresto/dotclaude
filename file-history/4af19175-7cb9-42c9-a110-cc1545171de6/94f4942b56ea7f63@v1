function App() {
  // Tab state management
  const [projects, setProjects] = useState<Project[]>([
    createMockProject('proj-1', 'HQ Dashboard'),
  ]);
  const [activeProjectId, setActiveProjectId] = useState('proj-1');
  const [showWelcome, setShowWelcome] = useState(true);

  // Project selector dialog state
  const [isProjectSelectorOpen, setIsProjectSelectorOpen] = useState(false);

  // Settings dialog state
  const [isSettingsOpen, setIsSettingsOpen] = useState(false);
  const [settings, setSettings] = useState<HQSettings>({
    theme: 'system',
    logBufferSize: 10000,
    defaultShell: '/bin/zsh',
    ptyRows: 24,
    ptyCols: 80,
    autoScrollLogs: true,
    showTimestamps: true,
  });

  // Theme state (from settings)
  const theme = settings.theme;
  const stats = { completed: 4, total: 10 }; // F001 + F002 + F009 + F010

  // Log state
  const [logs, setLogs] = useState<LogEntry[]>(createMockLogs);

  // Listen for menu events
  useEffect(() => {
    const listeners = [
      listen('menu:open_project', () => {
        setIsProjectSelectorOpen(true);
      }),
      listen('menu:new_tab', () => {
        handleAddProject();
      }),
      listen('menu:close_tab', () => {
        if (activeProjectId) {
          handleCloseProject(activeProjectId);
        }
      }),
      listen('menu:settings', () => {
        setIsSettingsOpen(true);
      }),
    ];

    return () => {
      listeners.forEach(async (unlistenPromise) => {
        const unlisten = await unlistenPromise;
        unlisten();
      });
    };
  }, [activeProjectId]);

  const handleClearLogs = useCallback(() => {
    setLogs([]);
  }, []);

  // Tab handlers
  const handleSelectProject = useCallback((projectId: string) => {
    setActiveProjectId(projectId);
  }, []);

  const handleCloseProject = useCallback((projectId: string) => {
    setProjects((prev) => {
      const filtered = prev.filter((p) => p.id !== projectId);
      // If closing active tab, switch to previous or next
      if (activeProjectId === projectId && filtered.length > 0) {
        const idx = prev.findIndex((p) => p.id === projectId);
        const newActive = filtered[Math.max(0, idx - 1)];
        setActiveProjectId(newActive.id);
      }
      return filtered;
    });
  }, [activeProjectId]);

  const handleAddProject = useCallback(() => {
    // Open the project selector dialog instead of creating mock project
    setIsProjectSelectorOpen(true);
  }, []);

  // Handle selecting a project from the project selector
  const handleSelectProjectFromDialog = useCallback((path: string, name: string) => {
    const id = `proj-${Date.now()}`;
    const newProject: Project = {
      id,
      path,
      name,
      harness: {
        progressFile: '.harness/progress.txt',
        featuresFile: '.harness/features.json',
      },
    };
    setProjects((prev) => [...prev, newProject]);
    setActiveProjectId(id);
  }, []);

  const handleReorderProjects = useCallback((order: string[]) => {
    setProjects((prev) => {
      const projectMap = new Map(prev.map((p) => [p.id, p]));
      return order.map((id) => projectMap.get(id)).filter(Boolean) as Project[];
    });
  }, []);

  // Get active project
  const activeProject = projects.find((p) => p.id === activeProjectId);

  const masthead = (
    <Masthead>
      <MastheadMain>
        <MastheadBrand>
          <Title headingLevel="h1" size="xl">HQ</Title>
        </MastheadBrand>
        <Label color="blue" isCompact>Harness Orchestrator</Label>
      </MastheadMain>
    </Masthead>
  );

  return (
    <Page masthead={masthead}>
      {/* Tab Bar */}
      <TabBar
        projects={projects}
        activeProjectId={activeProjectId}
        onSelect={handleSelectProject}
        onClose={handleCloseProject}
        onAdd={handleAddProject}
        onReorder={handleReorderProjects}
      />

      {/* Welcome Alert */}
      {showWelcome && (
        <PageSection padding={{ default: 'padding' }}>
          <Alert
            variant="info"
            title="Welcome to HQ - Harness Orchestrator"
            actionClose={<AlertActionCloseButton onClose={() => setShowWelcome(false)} />}
          >
            <Content component="p">
              Manage your AI agent development sessions with visual task boards and real-time logs.
            </Content>
          </Alert>
        </PageSection>
      )}

      {/* Project Content */}
      <PageSection>
        <Card>
          <CardTitle>
            {activeProject ? activeProject.name : 'No Project Selected'}
          </CardTitle>
          <CardBody>
            {activeProject ? (
              <>
                <Content component="p">
                  <strong>Path:</strong> {activeProject.path}
                </Content>
                <Content component="p">
                  <strong>Harness:</strong> {activeProject.harness.featuresFile}
                </Content>
                <Content component="p">
                  <strong>Theme:</strong> {theme}
                </Content>
                <Content component="p">
                  <strong>Features:</strong> {stats.completed}/{stats.total} complete
                </Content>
                <div style={{ marginTop: '16px', display: 'flex', gap: '8px' }}>
                  <Button
                    variant="secondary"
                    icon={<CogIcon />}
                    onClick={() => setIsSettingsOpen(true)}
                  >
                    Settings
                  </Button>
                  <Button
                    variant="secondary"
                    icon={<FolderOpenIcon />}
                    onClick={handleAddProject}
                  >
                    Open Another Project
                  </Button>
                </div>
              </>
            ) : (
              <>
                <Content component="p" style={{ marginBottom: 16 }}>
                  Open a project to get started.
                </Content>
                <Button
                  variant="primary"
                  icon={<FolderOpenIcon />}
                  onClick={handleAddProject}
                >
                  Open Project
                </Button>
              </>
            )}
          </CardBody>
        </Card>
      </PageSection>

      {/* Progress Card */}
      {activeProject && (
        <PageSection>
          <ProgressCard projectPath={activeProject.path} />
        </PageSection>
      )}

      {/* Kanban Board */}
      <PageSection>
        <Card>
          <CardTitle>Feature Board</CardTitle>
          <CardBody>
            <KanbanBoard features={MOCK_FEATURES} />
          </CardBody>
        </Card>
      </PageSection>

      {/* Log Panel */}
      <PageSection>
        <Card>
          <CardTitle>Process Logs</CardTitle>
          <CardBody>
            <LogPanel
              logs={logs}
              processes={MOCK_PROCESSES}
              onClear={handleClearLogs}
              height={300}
            />
          </CardBody>
        </Card>
      </PageSection>

      {/* Terminal Panel (PTY Test) */}
      <PageSection>
        <TerminalPanel height={250} />
      </PageSection>

      {/* Project Selector Dialog */}
      <ProjectSelector
        isOpen={isProjectSelectorOpen}
        onClose={() => setIsProjectSelectorOpen(false)}
        onSelectProject={handleSelectProjectFromDialog}
      />

      {/* Settings Dialog */}
      <Settings
        isOpen={isSettingsOpen}
        onClose={() => setIsSettingsOpen(false)}
        onSettingsChange={setSettings}
      />
    </Page>
  );
}

export default App;
