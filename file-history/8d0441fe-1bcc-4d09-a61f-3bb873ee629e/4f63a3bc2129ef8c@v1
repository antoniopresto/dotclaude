import type { Doc, Plugin, Printer } from 'prettier';
import { doc } from 'prettier';
import { printers as estreePrinters } from 'prettier/plugins/estree';

const originalEstreePrinter = estreePrinters.estree;
const { group, indent, line, softline, join, ifBreak } = doc.builders;

const DEFAULT_THRESHOLD = 1;
const DEFAULT_CONDITION_PRINT_WIDTH = 50;

const FUNCTION_NODE_TYPES = new Set([
  'FunctionDeclaration',
  'FunctionExpression',
  'ArrowFunctionExpression',
  'ObjectMethod',
  'ClassMethod',
  'TSDeclareMethod',
  'TSFunctionType',
  'TSMethodSignature',
]);

interface PluginOptions {
  multilineWrapThreshold?: number;
  objectWrapThreshold?: number;
  arrayWrapThreshold?: number;
  paramsPrintWidth?: number;
  trailingComma?: 'all' | 'es5' | 'none';
  originalText?: string;
}

interface AstNode {
  type: string;
  range?: [number, number];
  elements?: AstNode[];
  properties?: AstNode[];
  members?: AstNode[];
  params?: AstNode[];
  consequent?: AstNode;
  alternate?: AstNode;
  test?: AstNode;
  body?: AstNode;
  id?: AstNode;
  key?: AstNode;
  typeParameters?: AstNode;
  returnType?: AstNode;
  predicate?: AstNode;
  static?: boolean;
  accessibility?: string;
  abstract?: boolean;
  kind?: string;
  async?: boolean;
  generator?: boolean;
}

interface AstPath {
  getValue: () => AstNode;
  getParentNode: () => AstNode | null;
  call: <T>(fn: (path: AstPath) => T, key: string) => T;
  map: <T>(fn: (path: AstPath) => T, key: string) => T[];
}

type PrintFn = (path: AstPath) => Doc;

function asInt(value: unknown, defaultValue: number): number {
  const num = parseInt(String(value), 10);
  if (!Number.isNaN(num) && num >= 0) {
    return num;
  }
  return defaultValue;
}

function createWrappedPrinter(originalPrinter: Printer): Printer {
  return {
    ...originalPrinter,
    print(path: AstPath, options: PluginOptions, print: PrintFn): Doc {
      const node = path.getValue();

      const getText = (): string => {
        if (!node.range || !options.originalText) return '';
        return options.originalText.slice(node.range[0], node.range[1]);
      };

      const multilineWrapThreshold = asInt(options.multilineWrapThreshold, DEFAULT_THRESHOLD);
      const objectWrapThreshold = asInt(options.objectWrapThreshold, multilineWrapThreshold);
      const arrayWrapThreshold = asInt(options.arrayWrapThreshold, objectWrapThreshold);
      const paramsPrintWidth = asInt(options.paramsPrintWidth, DEFAULT_CONDITION_PRINT_WIDTH);

      const trailingComma =
        options.trailingComma === 'all' || options.trailingComma === 'es5'
          ? ifBreak(',', '')
          : '';

      if (
        node?.type === 'IfStatement' &&
        node.consequent &&
        node.consequent.type !== 'BlockStatement' &&
        getText().split(')')[0].length > paramsPrintWidth
      ) {
        const parts: Doc[] = [
          'if (',
          softline,
          path.call(print, 'test'),
          softline,
          ') ',
          '{',
          indent([line, path.call(print, 'consequent')]),
          line,
          '}',
        ];

        if (node.alternate) {
          parts.push(' else ', path.call(print, 'alternate'));
        }

        return parts;
      }

      if (
        node?.type === 'ArrayExpression' &&
        node.elements &&
        node.elements.length > arrayWrapThreshold
      ) {
        return group(
          [
            '[',
            indent([line, join([',', line], path.map(print, 'elements')), trailingComma]),
            line,
            ']',
          ],
          { shouldBreak: true },
        );
      }

      if (
        node?.type === 'ObjectExpression' &&
        node.properties &&
        node.properties.length > objectWrapThreshold
      ) {
        const objectDoc = group(
          [
            '{',
            indent([line, join([',', line], path.map(print, 'properties')), trailingComma]),
            line,
            '}',
          ],
          { shouldBreak: true },
        );

        const parentNode = path.getParentNode();
        if (parentNode?.type === 'ArrowFunctionExpression' && parentNode.body === node) {
          return ['(', objectDoc, ')'];
        }

        return objectDoc;
      }

      if (
        node?.type === 'TSTypeLiteral' &&
        node.members &&
        node.members.length > objectWrapThreshold
      ) {
        return group(
          ['{', indent([line, join(line, path.map(print, 'members'))]), line, '}'],
          { shouldBreak: true },
        );
      }

      const shouldBreakParams =
        FUNCTION_NODE_TYPES.has(node?.type) && node.params && node.params.length > 3;

      if (shouldBreakParams) {
        const result: Doc[] = [];

        if (
          node.type === 'ClassMethod' ||
          node.type === 'ObjectMethod' ||
          node.type === 'TSDeclareMethod'
        ) {
          if (node.static) result.push('static ');
          if (node.accessibility) result.push(node.accessibility, ' ');
          if (node.abstract) result.push('abstract ');
          if (node.kind === 'get' || node.kind === 'set') {
            result.push(node.kind, ' ');
          }
        }

        if (node.async) {
          result.push('async ');
        }

        if (node.type === 'FunctionDeclaration' || node.type === 'FunctionExpression') {
          if (getText().match(/^(async )?function/)) {
            result.push('function');
          }

          if (node.generator) {
            result.push('*');
          }
          if (node.id) {
            result.push(' ', path.call(print, 'id'));
          }
        } else if (node.key) {
          result.push(path.call(print, 'key'));
        }

        if (node.typeParameters) {
          result.push(path.call(print, 'typeParameters'));
        }

        result.push(
          group(
            [
              '(',
              indent([line, join([',', line], path.map(print, 'params'))]),
              line,
              ')',
            ],
            { shouldBreak: true },
          ),
        );

        if (node.returnType) {
          result.push(path.call(print, 'returnType'));
        } else if (node.predicate) {
          result.push(path.call(print, 'predicate'));
        }

        if (node.body) {
          const shouldAddBraces = node.body.type !== 'BlockStatement';

          if (node.type === 'ArrowFunctionExpression') {
            if (shouldAddBraces) {
              result.push('=> {', line, 'return ');
            } else {
              result.push('=>');
            }
          }

          result.push(' ', path.call(print, 'body'));
          if (shouldAddBraces) {
            result.push(line, '}', line);
          }
        }

        return result;
      }

      return (originalPrinter.print as typeof print)(path, options as never, print);
    },
  } as Printer;
}

const plugin: Plugin = {
  printers: {
    estree: createWrappedPrinter(originalEstreePrinter),
  },
};

export const printers = plugin.printers;
export default plugin;
