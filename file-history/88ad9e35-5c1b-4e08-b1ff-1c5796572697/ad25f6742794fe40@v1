import { createMachine, createSlice, createAsyncSlice, createModel, InferType } from '@zazcart/tools';

// ============================================================================
// SCHEMAS (validation)
// ============================================================================

export const ProjectSchema = createModel({
  id: 'string',
  path: 'string',
  name: 'string',
  harness: {
    properties: {
      progressFile: 'string',
      featuresFile: 'string',
    },
  },
});

export type Project = InferType<typeof ProjectSchema>;

export const FeatureSchema = createModel({
  id: 'string',
  description: 'string',
  category: 'string',
  priority: 'string',
  status: 'string',
  passes: 'boolean',
  steps: 'string[]',
});

export type Feature = InferType<typeof FeatureSchema>;

export const ProcessSchema = createModel({
  id: 'string',
  projectId: 'string',
  command: 'string',
  status: { enum: ['running', 'stopped', 'error'] },
  pid: 'number?',
});

export type Process = InferType<typeof ProcessSchema>;

export const LogEntrySchema = createModel({
  id: 'string',
  processId: 'string',
  timestamp: 'number',
  content: 'string',
  level: { enum: ['info', 'warn', 'error', 'debug'] },
});

export type LogEntry = InferType<typeof LogEntrySchema>;

// ============================================================================
// SLICES
// ============================================================================

// UI Slice - tab management, theme, layout
const uiSlice = createSlice({
  id: 'ui',
  cache: { policy: 'session' },
  initial: {
    activeTab: '' as string,
    theme: 'system' as 'light' | 'dark' | 'system',
    projectOrder: [] as string[],
    sidebarCollapsed: false,
    logPanelHeight: 200,
  },
  reducers: {
    setActiveTab: (state, tabId: string) => {
      state.activeTab = tabId;
    },
    setTheme: (state, theme: 'light' | 'dark' | 'system') => {
      state.theme = theme;
    },
    addProject: (state, projectId: string) => {
      if (!state.projectOrder.includes(projectId)) {
        state.projectOrder.push(projectId);
      }
      state.activeTab = projectId;
    },
    removeProject: (state, projectId: string) => {
      const idx = state.projectOrder.indexOf(projectId);
      state.projectOrder = state.projectOrder.filter((id) => id !== projectId);
      // Set next active tab
      if (state.activeTab === projectId) {
        state.activeTab = state.projectOrder[Math.max(0, idx - 1)] || '';
      }
    },
    reorderProjects: (state, order: string[]) => {
      state.projectOrder = order;
    },
    toggleSidebar: (state) => {
      state.sidebarCollapsed = !state.sidebarCollapsed;
    },
    setLogPanelHeight: (state, height: number) => {
      state.logPanelHeight = height;
    },
  },
});

// Projects Slice - project data
const projectsSlice = createSlice({
  id: 'projects',
  cache: { policy: 'private' },
  initial: {} as Record<string, Project>,
  reducers: {
    set: (state, project: Project) => {
      state[project.id] = project;
    },
    remove: (state, projectId: string) => {
      delete state[projectId];
    },
    update: (state, payload: { id: string; updates: Partial<Project> }) => {
      if (state[payload.id]) {
        Object.assign(state[payload.id], payload.updates);
      }
    },
  },
});

// Processes Slice - PTY process tracking
const processesSlice = createSlice({
  id: 'processes',
  cache: { policy: 'session' },
  initial: {} as Record<string, Process>,
  reducers: {
    spawn: (state, process: Process) => {
      state[process.id] = process;
    },
    updateStatus: (state, payload: { id: string; status: Process['status'] }) => {
      if (state[payload.id]) {
        state[payload.id].status = payload.status;
      }
    },
    updatePid: (state, payload: { id: string; pid: number }) => {
      if (state[payload.id]) {
        state[payload.id].pid = payload.pid;
      }
    },
    kill: (state, processId: string) => {
      delete state[processId];
    },
  },
});

// Logs Slice - process logs with ring buffer
const MAX_LOGS_PER_PROCESS = 10000;

const logsSlice = createSlice({
  id: 'logs',
  cache: { policy: 'session' },
  initial: {
    entries: {} as Record<string, LogEntry[]>,
    autoScroll: true,
    filter: '' as string,
  },
  reducers: {
    append: (state, entry: LogEntry) => {
      if (!state.entries[entry.processId]) {
        state.entries[entry.processId] = [];
      }
      state.entries[entry.processId].push(entry);
      // Ring buffer: keep last MAX_LOGS_PER_PROCESS entries
      if (state.entries[entry.processId].length > MAX_LOGS_PER_PROCESS) {
        state.entries[entry.processId] = state.entries[entry.processId].slice(-MAX_LOGS_PER_PROCESS);
      }
    },
    clear: (state, processId: string) => {
      state.entries[processId] = [];
    },
    clearAll: (state) => {
      state.entries = {};
    },
    setAutoScroll: (state, autoScroll: boolean) => {
      state.autoScroll = autoScroll;
    },
    setFilter: (state, filter: string) => {
      state.filter = filter;
    },
  },
});

// Features Slice - async slice for harness features
const featuresSlice = createAsyncSlice({
  id: 'features',
  cache: { policy: 'private' },
  context: {},
  async load(projectPath: string) {
    // TODO: Call Tauri backend to read features.json
    // For now, return mock data
    const response: Feature[] = [];
    return response;
  },
});

// ============================================================================
// APP MACHINE
// ============================================================================

export const appMachine = createMachine({
  id: 'hq',
  slices: {
    ui: uiSlice,
    projects: projectsSlice,
    processes: processesSlice,
    logs: logsSlice,
    features: featuresSlice,
  },
  context: {
    version: '0.1.0',
  },
});

// ============================================================================
// SELECTORS
// ============================================================================

export const selectors = {
  // Active project
  activeProject: (state: ReturnType<typeof appMachine.getState>) => {
    const activeTab = state.ui.activeTab;
    return activeTab ? state.projects[activeTab] : null;
  },

  // Projects as array (in order)
  projectsArray: (state: ReturnType<typeof appMachine.getState>) => {
    return state.ui.projectOrder.map((id) => state.projects[id]).filter(Boolean);
  },

  // Processes for active project
  activeProcesses: (state: ReturnType<typeof appMachine.getState>) => {
    const activeTab = state.ui.activeTab;
    return Object.values(state.processes).filter((p) => p.projectId === activeTab);
  },

  // Logs for a process (filtered)
  logsForProcess: (state: ReturnType<typeof appMachine.getState>, processId: string) => {
    const logs = state.logs.entries[processId] || [];
    const filter = state.logs.filter.toLowerCase();
    if (!filter) return logs;
    return logs.filter((log) => log.content.toLowerCase().includes(filter));
  },

  // Feature stats
  featureStats: (state: ReturnType<typeof appMachine.getState>) => {
    const features = state.features.value || [];
    const total = features.length;
    const completed = features.filter((f) => f.passes).length;
    return { total, completed, remaining: total - completed };
  },
};

// ============================================================================
// EXPORTS
// ============================================================================

export type AppState = ReturnType<typeof appMachine.getState>;
export type UIState = AppState['ui'];
export type ProjectsState = AppState['projects'];
export type ProcessesState = AppState['processes'];
export type LogsState = AppState['logs'];
