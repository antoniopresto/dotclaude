          <H2>Welcome to HQ</H2>
          <p>
            Your dashboard for managing AI agent development sessions.
          </p>
          <p>
            Click count: {count}
          </p>
          <Button
            intent="primary"
            icon="add"
            onClick={() => setCount((c) => c + 1)}
          >
            Increment
