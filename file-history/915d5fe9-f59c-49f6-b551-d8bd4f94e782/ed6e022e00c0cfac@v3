import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';

import { devAssert, devLog, setLogMode } from '../logs';

describe('logs', () => {
  beforeEach(() => {
    setLogMode('development');
  });

  afterEach(() => {
    vi.restoreAllMocks();
  });

  describe('devLog', () => {
    it('should log string messages with console.trace in development', () => {
      const traceSpy = vi.spyOn(console, 'trace').mockImplementation(() => {});

      devLog('test message', { extra: 'data' });

      expect(traceSpy).toHaveBeenCalledWith('test message', { extra: 'data' });
    });

    it('should not log in production mode', () => {
      setLogMode('production');
      const traceSpy = vi.spyOn(console, 'trace').mockImplementation(() => {});

      devLog('test message');

      expect(traceSpy).not.toHaveBeenCalled();
    });

    it('should log Error objects without throwing', () => {
      const errorSpy = vi.spyOn(console, 'error').mockImplementation(() => {});
      const error = new Error('test error');

      // Should NOT throw
      expect(() => devLog(error)).not.toThrow();

      // Should log to console.error
      expect(errorSpy).toHaveBeenCalled();
    });

    it('should handle Error objects in catch blocks safely', () => {
      const errorSpy = vi.spyOn(console, 'error').mockImplementation(() => {});
      let caughtError: Error | null = null;

      try {
        throw new Error('original error');
      } catch (e) {
        caughtError = e as Error;
        // This should NOT re-throw the error
        devLog(caughtError);
      }

      // Code after catch should execute
      expect(caughtError).not.toBeNull();
      expect(errorSpy).toHaveBeenCalled();
    });

    it('should not log Error objects in production mode', () => {
      setLogMode('production');
      const errorSpy = vi.spyOn(console, 'error').mockImplementation(() => {});
      const error = new Error('test error');

      expect(() => devLog(error)).not.toThrow();
      expect(errorSpy).not.toHaveBeenCalled();
    });
  });

  describe('devAssert', () => {
    it('should throw error in development mode', () => {
      const error = new Error('assertion failed');

      expect(() => devAssert(error)).toThrow('assertion failed');
    });

    it('should NOT throw error in production mode', () => {
      setLogMode('production');
      const error = new Error('assertion failed');

      expect(() => devAssert(error)).not.toThrow();
    });

    it('should capture stack trace pointing to caller', () => {
      const error = new Error('test');

      try {
        devAssert(error);
      } catch (e) {
        // Stack should not include devAssert itself
        expect((e as Error).stack).toBeDefined();
      }
    });
  });
});
