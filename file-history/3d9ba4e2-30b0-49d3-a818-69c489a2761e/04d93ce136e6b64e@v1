{
  "name": "@belt/tools",
  "version": "0.0.1",
  "description": "TypeScript utility library with runtime type validation, state management, and common helpers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zazcart/tools.git"
  },
  "keywords": [
    "typescript",
    "utilities",
    "validation",
    "state-management",
    "type-safe"
  ],
  "author": "@zazcart",
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "immer": "^11.1.3",
    "lodash": "^4.17.21",
    "lru-cache": "^11.2.4",
    "minimatch": "^10.1.1",
    "typebox": "^1.0.73"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.21",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
