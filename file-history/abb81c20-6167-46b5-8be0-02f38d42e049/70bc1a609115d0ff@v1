{
  "name": "mms",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --parallel dev:web dev:api",
    "dev:web": "bun --cwd apps/web run dev",
    "dev:api": "bun --cwd apps/api run dev",
    "build": "bun run --parallel build:web build:api",
    "build:web": "bun --cwd apps/web run build",
    "build:api": "bun --cwd apps/api run build",
    "typecheck": "bun run --parallel typecheck:web typecheck:api typecheck:types",
    "typecheck:web": "bun --cwd apps/web run typecheck",
    "typecheck:api": "bun --cwd apps/api run typecheck",
    "typecheck:types": "bun --cwd packages/types run typecheck",
    "lint": "eslint .",
    "test": "bun test",
    "db:migrate": "bun --cwd apps/api run db:migrate",
    "db:seed": "bun --cwd apps/api run db:seed",
    "solver:dev": "cd apps/solver && uvicorn src.main:app --reload --port 8000"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@zazcart/toolkit": "file:/usr/local/packages/toolkit",
    "typescript": "^5.3.0"
  }
}
