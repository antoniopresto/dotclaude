/**
 * Fleet List Page
 *
 * Displays list of trains with filtering capabilities.
 * Can be filtered by status (fit/unfit) or depot.
 */

import { Card, Elevation, Tag, Intent } from '@blueprintjs/core';

interface FleetPageProps {
  searchParams: Promise<{ status?: string; depot?: string }>;
}

export default async function FleetPage({ searchParams }: FleetPageProps) {
  const params = await searchParams;
  const { status, depot } = params;

  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 24 }}>
      <Card elevation={Elevation.ONE} style={{ padding: 24 }}>
        <h1 style={{ margin: 0, fontSize: 24, fontWeight: 700, color: '#182026' }}>Fleet Overview</h1>
        <p style={{ marginTop: 8, color: '#5c7080' }}>
          Train list with status and mileage information
        </p>
      </Card>

      {/* Filter Indicators */}
      <div style={{ display: 'flex', flexWrap: 'wrap', gap: 8 }}>
        {status && (
          <Tag intent={Intent.PRIMARY} round>
            Filter: Status = {status}
          </Tag>
        )}
        {depot && (
          <Tag intent={Intent.NONE} round style={{ backgroundColor: '#e9d5ff', color: '#7e22ce' }}>
            Filter: Depot = {depot}
          </Tag>
        )}
      </div>

      {/* Placeholder for train list - Epic 3 */}
      <Card elevation={Elevation.ZERO} style={{ padding: 32, textAlign: 'center', backgroundColor: '#f5f8fa' }}>
        <p style={{ marginBottom: 8, color: '#5c7080' }}>Train list will be implemented in Epic 3</p>
        <p style={{ fontSize: 14, color: '#8a9ba8' }}>Showing trains with filters: {JSON.stringify({ status, depot })}</p>
      </Card>
    </div>
  );
}
