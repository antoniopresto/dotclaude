import api from '../../api';
import { GetPermissionParams, PermissionDocument } from '../models';

class InvoiceCashbackPermissionApi {
  private client = api;

  async getPermission(params: GetPermissionParams): Promise<PermissionDocument> {
    const { accountNumber } = params;
    console.log('[DEBUG:API] getPermission - accountNumber:', accountNumber);
    const { data } = await this.client.get('/fintech/v1/rewardProgram/consult-permission', {
      headers: {
        codigoCliente: accountNumber,
        codigocanal: '11',
        empresa: 'CGMP',
      },
    });
    console.log('[DEBUG:API] getPermission - response:', data);
    return data;
  }

  async savePermission(document: PermissionDocument): Promise<PermissionDocument> {
    console.log('[DEBUG:API] savePermission - document:', document);
    const { data } = await this.client.post('/fintech/v1/rewardProgram/insert-permission', document, {
      headers: {
        codigocanal: '11',
        empresa: 'CGMP',
      },
    });
    console.log('[DEBUG:API] savePermission - response:', data);
    return data;
  }
}

export const invoiceCashbackPermissionApi = new InvoiceCashbackPermissionApi();
