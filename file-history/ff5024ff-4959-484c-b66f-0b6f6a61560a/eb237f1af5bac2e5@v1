import React, { useState } from 'react';
import { View, Text, TouchableOpacity, ScrollView, StyleSheet } from 'react-native';
import { api } from '@semparar/mf-app-user';
import { useSelector } from 'react-redux';
import { getAcountNumber } from '../../hooks/useSelectors';

interface TestResult {
  testName: string;
  request: any;
  response: any;
  timestamp: string;
}

const PermissionApiTest = () => {
  const accountId = useSelector(getAcountNumber);
  const [results, setResults] = useState<TestResult[]>([]);
  const [loading, setLoading] = useState(false);

  const addResult = (testName: string, request: any, response: any) => {
    setResults(prev => [...prev, {
      testName,
      request,
      response,
      timestamp: new Date().toISOString(),
    }]);
  };

  const clearResults = () => setResults([]);

  // Test 1: Consult permission (GET)
  const testConsult = async () => {
    const testName = 'GET consult-permission';
    const request = { accountNumber: accountId };
    try {
      const { data } = await api.get('fintech/v1/rewardProgram/consult-permission', {
        headers: { codigoCliente: accountId },
      });
      addResult(testName, request, data);
    } catch (error: any) {
      addResult(testName, request, { error: error?.message || error });
    }
  };

  // Test 2: Insert with value as STRING (current implementation)
  const testInsertValueString = async () => {
    const testName = 'POST insert-permission (value=string)';
    const body = {
      codigoCliente: accountId,
      status: 1,
      value: JSON.stringify({
        invoiceCashbackRedemption: {
          redeemedAtDate: new Date().toISOString(),
        },
      }),
    };
    try {
      const { data } = await api.post('fintech/v1/rewardProgram/insert-permission', body);
      addResult(testName, body, data);
    } catch (error: any) {
      addResult(testName, body, { error: error?.message || error });
    }
  };

  // Test 3: Insert with value as OBJECT
  const testInsertValueObject = async () => {
    const testName = 'POST insert-permission (value=object)';
    const body = {
      codigoCliente: accountId,
      status: 1,
      value: {
        invoiceCashbackRedemption: {
          redeemedAtDate: new Date().toISOString(),
        },
      },
    };
    try {
      const { data } = await api.post('fintech/v1/rewardProgram/insert-permission', body);
      addResult(testName, body, data);
    } catch (error: any) {
      addResult(testName, body, { error: error?.message || error });
    }
  };

  // Test 4: Insert with status 0 (like curl example)
  const testInsertStatus0 = async () => {
    const testName = 'POST insert-permission (status=0)';
    const body = {
      codigoCliente: accountId,
      status: 0,
      value: JSON.stringify({
        invoiceCashbackRedemption: {
          redeemedAtDate: new Date().toISOString(),
        },
      }),
    };
    try {
      const { data } = await api.post('fintech/v1/rewardProgram/insert-permission', body);
      addResult(testName, body, data);
    } catch (error: any) {
      addResult(testName, body, { error: error?.message || error });
    }
  };

  // Test 5: Insert minimal (like curl example)
  const testInsertMinimal = async () => {
    const testName = 'POST insert-permission (minimal like curl)';
    const body = {
      codigoCliente: accountId,
      value: JSON.stringify({ nrc: accountId }),
      status: 0,
    };
    try {
      const { data } = await api.post('fintech/v1/rewardProgram/insert-permission', body);
      addResult(testName, body, data);
    } catch (error: any) {
      addResult(testName, body, { error: error?.message || error });
    }
  };

  // Test 6: Update permission
  const testUpdate = async () => {
    const testName = 'POST update-permission';
    const body = {
      codigoCliente: accountId,
      status: 1,
      value: JSON.stringify({
        invoiceCashbackRedemption: {
          redeemedAtDate: new Date().toISOString(),
        },
      }),
    };
    try {
      const { data } = await api.post('fintech/v1/rewardProgram/update-permission', body);
      addResult(testName, body, data);
    } catch (error: any) {
      addResult(testName, body, { error: error?.message || error });
    }
  };

  // Test 7: Delete permission (to reset state)
  const testDelete = async () => {
    const testName = 'POST delete-permission';
    const body = {
      codigoCliente: accountId,
    };
    try {
      const { data } = await api.post('fintech/v1/rewardProgram/delete-permission', body);
      addResult(testName, body, data);
    } catch (error: any) {
      addResult(testName, body, { error: error?.message || error });
    }
  };

  const runAllTests = async () => {
    setLoading(true);
    clearResults();

    await testConsult();
    await testInsertValueString();
    await testInsertValueObject();
    await testInsertStatus0();
    await testInsertMinimal();
    await testUpdate();
    await testConsult(); // Check final state

    setLoading(false);
  };

  const copyResults = () => {
    const report = {
      accountId,
      timestamp: new Date().toISOString(),
      tests: results,
    };
    console.log('=== PERMISSION API TEST REPORT ===');
    console.log(JSON.stringify(report, null, 2));
    console.log('=== END REPORT ===');
  };

  return (
    <ScrollView style={styles.container}>
      <Text style={styles.title}>Permission API Test</Text>
      <Text style={styles.subtitle}>AccountId: {accountId}</Text>

      <View style={styles.buttonRow}>
        <TouchableOpacity style={styles.button} onPress={runAllTests} disabled={loading}>
          <Text style={styles.buttonText}>{loading ? 'Running...' : 'Run All Tests'}</Text>
        </TouchableOpacity>
        <TouchableOpacity style={styles.button} onPress={clearResults}>
          <Text style={styles.buttonText}>Clear</Text>
        </TouchableOpacity>
        <TouchableOpacity style={styles.button} onPress={copyResults}>
          <Text style={styles.buttonText}>Log Report</Text>
        </TouchableOpacity>
      </View>

      <View style={styles.buttonRow}>
        <TouchableOpacity style={styles.smallButton} onPress={testConsult}>
          <Text style={styles.smallButtonText}>Consult</Text>
        </TouchableOpacity>
        <TouchableOpacity style={styles.smallButton} onPress={testDelete}>
          <Text style={styles.smallButtonText}>Delete</Text>
        </TouchableOpacity>
      </View>

      <Text style={styles.resultsTitle}>Results ({results.length}):</Text>

      {results.map((result, index) => (
        <View key={index} style={styles.resultCard}>
          <Text style={styles.testName}>{result.testName}</Text>
          <Text style={styles.timestamp}>{result.timestamp}</Text>
          <Text style={styles.label}>Request:</Text>
          <Text style={styles.json}>{JSON.stringify(result.request, null, 2)}</Text>
          <Text style={styles.label}>Response:</Text>
          <Text style={[
            styles.json,
            result.response?.status?.returnCode === 0 ? styles.success : styles.error
          ]}>
            {JSON.stringify(result.response, null, 2)}
          </Text>
        </View>
      ))}
    </ScrollView>
  );
};

const styles = StyleSheet.create({
  container: {
    flex: 1,
    padding: 16,
    backgroundColor: '#f5f5f5',
  },
  title: {
    fontSize: 20,
    fontWeight: 'bold',
    marginBottom: 4,
  },
  subtitle: {
    fontSize: 12,
    color: '#666',
    marginBottom: 16,
  },
  buttonRow: {
    flexDirection: 'row',
    marginBottom: 12,
    gap: 8,
  },
  button: {
    flex: 1,
    backgroundColor: '#007AFF',
    padding: 12,
    borderRadius: 8,
    alignItems: 'center',
  },
  buttonText: {
    color: 'white',
    fontWeight: 'bold',
  },
  smallButton: {
    flex: 1,
    backgroundColor: '#666',
    padding: 8,
    borderRadius: 6,
    alignItems: 'center',
  },
  smallButtonText: {
    color: 'white',
    fontSize: 12,
  },
  resultsTitle: {
    fontSize: 16,
    fontWeight: 'bold',
    marginTop: 16,
    marginBottom: 8,
  },
  resultCard: {
    backgroundColor: 'white',
    padding: 12,
    borderRadius: 8,
    marginBottom: 12,
  },
  testName: {
    fontSize: 14,
    fontWeight: 'bold',
    marginBottom: 4,
  },
  timestamp: {
    fontSize: 10,
    color: '#999',
    marginBottom: 8,
  },
  label: {
    fontSize: 12,
    fontWeight: 'bold',
    marginTop: 8,
    marginBottom: 4,
  },
  json: {
    fontSize: 10,
    fontFamily: 'monospace',
    backgroundColor: '#f0f0f0',
    padding: 8,
    borderRadius: 4,
  },
  success: {
    backgroundColor: '#d4edda',
  },
  error: {
    backgroundColor: '#f8d7da',
  },
});

export default PermissionApiTest;
