import { invoiceCashbackPermissionApi } from '../api';
import { GetPermissionParams, PermissionDocument, PermissionValue } from '../models';

class InvoiceCashbackPermissionRepository {
  async getPermission(params: GetPermissionParams): Promise<PermissionValue | null> {
    console.log('[DEBUG:Repository] getPermission called with:', params);
    const result = await invoiceCashbackPermissionApi.getPermission(params);
    console.log('[DEBUG:Repository] API raw response:', JSON.stringify(result, null, 2));
    // API response: { status: {...}, data: { value: {...} } }
    const parsed = (result as any)?.data?.value ?? null;
    console.log('[DEBUG:Repository] Parsed value:', parsed);
    return parsed;
  }

  async savePermission(document: PermissionDocument): Promise<PermissionDocument> {
    return invoiceCashbackPermissionApi.savePermission(document);
  }
}

export const invoiceCashbackPermissionRepository = new InvoiceCashbackPermissionRepository();
