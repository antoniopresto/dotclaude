import { api } from '@semparar/mf-app-user';
import type { PermissionDocument } from '../models';
import { invoiceCashbackPermissionRepository } from '../repository';

// Teste de variações da API - remover após debug
export async function testPermissionApi(accountId: string) {
  const results: { test: string; input: any; output: any }[] = [];

  const run = async (test: string, method: 'get' | 'post', url: string, body?: any, headers?: any) => {
    const input = { method, url, ...(body && { body }), ...(headers && { headers }) };
    try {
      const res = method === 'get'
        ? await api.get(url, { headers })
        : await api.post(url, body);
      results.push({ test, input, output: res.data });
    } catch (e: any) {
      results.push({ test, input, output: { error: e?.data || e?.message } });
    }
  };

  // Testes
  await run('GET inicial', 'get', 'fintech/v1/rewardProgram/consult-permission', null, { codigoCliente: accountId });

  await run('INSERT doc exemplo (string)', 'post', 'fintech/v1/rewardProgram/insert-permission', {
    codigoCliente: accountId,
    value: "{\"nrc\":\"465681\"}",
    status: 0,
  });

  await run('INSERT nosso payload (string, status=1)', 'post', 'fintech/v1/rewardProgram/insert-permission', {
    codigoCliente: accountId,
    status: 1,
    value: JSON.stringify({ invoiceCashbackRedemption: { redeemedAtDate: new Date().toISOString() } }),
  });

  await run('INSERT nosso payload (string, status=0)', 'post', 'fintech/v1/rewardProgram/insert-permission', {
    codigoCliente: accountId,
    status: 0,
    value: JSON.stringify({ invoiceCashbackRedemption: { redeemedAtDate: new Date().toISOString() } }),
  });

  await run('INSERT nosso payload (object)', 'post', 'fintech/v1/rewardProgram/insert-permission', {
    codigoCliente: accountId,
    status: 0,
    value: { invoiceCashbackRedemption: { redeemedAtDate: new Date().toISOString() } },
  });

  await run('UPDATE', 'post', 'fintech/v1/rewardProgram/update-permission', {
    codigoCliente: accountId,
    status: 1,
    value: JSON.stringify({ invoiceCashbackRedemption: { redeemedAtDate: new Date().toISOString() } }),
  });

  await run('GET final', 'get', 'fintech/v1/rewardProgram/consult-permission', null, { codigoCliente: accountId });

  console.log('\n=== RESULTADO TESTES API PERMISSIONS ===');
  console.log(JSON.stringify(results, null, 2));
}

class InvoiceCashbackPermissionService {
  private readonly repository = invoiceCashbackPermissionRepository;

  async hasRedeemed(accountId: string): Promise<boolean> {
    console.log('[DEBUG:Service] hasRedeemed called with accountId:', accountId);
    const result = await this.repository.getPermission({ accountNumber: accountId });
    console.log('[DEBUG:Service] Repository result:', result);
    const redeemedAt = result?.invoiceCashbackRedemption?.redeemedAtDate;
    console.log('[DEBUG:Service] redeemedAt:', redeemedAt, '-> returning:', Boolean(redeemedAt));
    return Boolean(redeemedAt);
  }

  async markAsRedeemed(accountId: string): Promise<void> {
    console.log('[DEBUG:Service] markAsRedeemed called with accountId:', accountId);
    const document = {
      codigoCliente: accountId,
      status: 1,
      value: JSON.stringify({
        invoiceCashbackRedemption: {
          redeemedAtDate: new Date().toISOString(),
        },
      }),
    };
    console.log('[DEBUG:Service] markAsRedeemed document:', document);
    await this.repository.savePermission(document as any);
    console.log('[DEBUG:Service] markAsRedeemed completed');
  }
}

export const invoiceCashbackPermissionService = new InvoiceCashbackPermissionService();
