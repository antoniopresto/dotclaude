import { useCallback } from 'react';
import { useSelector } from 'react-redux';
import { getAcountNumber } from '../../../hooks/useSelectors';
import { invoiceCashbackPermissionService } from '../services';
import { useInvoiceCashbackPermissionStore } from './useInvoiceCashbackPermissionStore';

export function useInvoiceCashbackPermission() {
  const accountId = useSelector(getAcountNumber);

  const { hasRedeemed, isLoading, isError } = useInvoiceCashbackPermissionStore(
    (state) => state.invoiceCashbackPermission
  );

  const { setHasRedeemed, setLoading, setError } = useInvoiceCashbackPermissionStore(
    (state) => state.invoiceCashbackPermissionActions
  );

  const checkHasRedeemed = useCallback(
    async ({ showLoading = false, forceRefresh = false }: { showLoading?: boolean; forceRefresh?: boolean } = {}): Promise<boolean> => {
      console.log('[DEBUG:Hook] checkHasRedeemed called, accountId:', accountId, 'cached hasRedeemed:', hasRedeemed);

      // Return cached value if available and not forcing refresh
      if (hasRedeemed !== null && !forceRefresh) {
        console.log('[DEBUG:Hook] Returning cached value:', hasRedeemed);
        return hasRedeemed;
      }

      if (!accountId) {
        console.log('[DEBUG:Hook] No accountId, throwing error');
        throw new Error('Expected accountId to be defined.');
      }

      if (showLoading) {
        setLoading(true);
      }

      try {
        console.log('[DEBUG:Hook] Calling service.hasRedeemed...');
        const result = await invoiceCashbackPermissionService.hasRedeemed(accountId);
        console.log('[DEBUG:Hook] Service returned:', result);
        setHasRedeemed(result);
        return result;
      } catch (error) {
        console.log('[DEBUG:Hook] Error caught:', error);
        setError(true);
        return false;
      }
    },
    [accountId, hasRedeemed, setHasRedeemed, setLoading, setError]
  );

  const markAsRedeemed = useCallback(async (): Promise<boolean> => {
    console.log('[DEBUG:Hook] markAsRedeemed called, accountId:', accountId);
    if (!accountId) {
      console.log('[DEBUG:Hook] No accountId for markAsRedeemed, returning false');
      return false;
    }

    try {
      console.log('[DEBUG:Hook] Calling service.markAsRedeemed...');
      await invoiceCashbackPermissionService.markAsRedeemed(accountId);
      console.log('[DEBUG:Hook] markAsRedeemed succeeded');
      setHasRedeemed(true);
      return true;
    } catch (error) {
      console.log('[DEBUG:Hook] markAsRedeemed error:', error);
      return false;
    }
  }, [accountId, setHasRedeemed]);

  return {
    hasRedeemed,
    isLoading,
    isError,
    checkHasRedeemed,
    markAsRedeemed,
  };
}
