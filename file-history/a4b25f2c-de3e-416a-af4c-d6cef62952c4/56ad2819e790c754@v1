//! Screenshot CRUD operations (F015).
//!
//! This module provides Create, Read, Update, Delete operations for test screenshots.
//! Screenshots store metadata for visual test images with optional task/step associations.

use chrono::Utc;
use rusqlite::{params, Connection, OptionalExtension};

use super::types::TestScreenshot;
use super::DbResult;

/// Default page size for list operations.
pub const DEFAULT_PAGE_SIZE: usize = 50;

// =============================================================================
// CREATE
// =============================================================================

/// Create a new screenshot record.
pub fn create_screenshot(conn: &Connection, screenshot: &TestScreenshot) -> DbResult<()> {
    conn.execute(
        r#"
        INSERT INTO test_screenshots (id, task_id, step_id, file_name, caption, created_at)
        VALUES (?1, ?2, ?3, ?4, ?5, ?6)
        "#,
        params![
            screenshot.id,
            screenshot.task_id,
            screenshot.step_id,
            screenshot.file_name,
            screenshot.caption,
            screenshot.created_at.to_rfc3339(),
        ],
    )?;
    Ok(())
}

/// Add a screenshot (alias for create_screenshot).
pub fn add_screenshot(conn: &Connection, screenshot: &TestScreenshot) -> DbResult<()> {
    create_screenshot(conn, screenshot)
}

// =============================================================================
// READ
// =============================================================================

/// Get a screenshot by ID.
pub fn get_screenshot(conn: &Connection, id: &str) -> DbResult<Option<TestScreenshot>> {
    let result = conn
        .query_row(
            r#"
            SELECT id, task_id, step_id, file_name, caption, created_at
            FROM test_screenshots
            WHERE id = ?1
            "#,
            [id],
            |row| row_to_screenshot(row),
        )
        .optional()?;
    Ok(result)
}

/// List all screenshots, ordered by creation date (newest first).
pub fn list_screenshots(conn: &Connection, limit: Option<usize>) -> DbResult<Vec<TestScreenshot>> {
    let limit = limit.unwrap_or(DEFAULT_PAGE_SIZE);

    let mut stmt = conn.prepare(
        r#"
        SELECT id, task_id, step_id, file_name, caption, created_at
        FROM test_screenshots
        ORDER BY created_at DESC
        LIMIT ?1
        "#,
    )?;

    let rows = stmt.query_map([limit as i64], |row| row_to_screenshot(row))?;

    let mut screenshots = Vec::new();
    for row in rows {
        screenshots.push(row?);
    }

    Ok(screenshots)
}

/// List screenshots for a specific task.
pub fn list_screenshots_for_task(
    conn: &Connection,
    task_id: &str,
    limit: Option<usize>,
) -> DbResult<Vec<TestScreenshot>> {
    let limit = limit.unwrap_or(DEFAULT_PAGE_SIZE);

    let mut stmt = conn.prepare(
        r#"
        SELECT id, task_id, step_id, file_name, caption, created_at
        FROM test_screenshots
        WHERE task_id = ?1
        ORDER BY created_at DESC
        LIMIT ?2
        "#,
    )?;

    let rows = stmt.query_map(params![task_id, limit as i64], |row| row_to_screenshot(row))?;

    let mut screenshots = Vec::new();
    for row in rows {
        screenshots.push(row?);
    }

    Ok(screenshots)
}

/// Count total screenshots.
pub fn count_screenshots(conn: &Connection) -> DbResult<i64> {
    let count: i64 = conn.query_row(
        "SELECT COUNT(*) FROM test_screenshots",
        [],
        |row| row.get(0),
    )?;
    Ok(count)
}

/// Count screenshots for a specific task.
pub fn count_screenshots_for_task(conn: &Connection, task_id: &str) -> DbResult<i64> {
    let count: i64 = conn.query_row(
        "SELECT COUNT(*) FROM test_screenshots WHERE task_id = ?1",
        [task_id],
        |row| row.get(0),
    )?;
    Ok(count)
}

// =============================================================================
// UPDATE
// =============================================================================

/// Update screenshot caption.
pub fn update_screenshot_caption(
    conn: &Connection,
    id: &str,
    caption: Option<&str>,
) -> DbResult<bool> {
    let rows_affected = conn.execute(
        "UPDATE test_screenshots SET caption = ?1 WHERE id = ?2",
        params![caption, id],
    )?;
    Ok(rows_affected > 0)
}

/// Update screenshot task association.
pub fn update_screenshot_task(
    conn: &Connection,
    id: &str,
    task_id: Option<&str>,
) -> DbResult<bool> {
    let rows_affected = conn.execute(
        "UPDATE test_screenshots SET task_id = ?1 WHERE id = ?2",
        params![task_id, id],
    )?;
    Ok(rows_affected > 0)
}

// =============================================================================
// DELETE
// =============================================================================

/// Delete a screenshot by ID.
pub fn delete_screenshot(conn: &Connection, id: &str) -> DbResult<bool> {
    let rows_affected = conn.execute("DELETE FROM test_screenshots WHERE id = ?1", [id])?;
    Ok(rows_affected > 0)
}

/// Delete all screenshots for a task.
pub fn delete_screenshots_for_task(conn: &Connection, task_id: &str) -> DbResult<usize> {
    let rows_affected = conn.execute(
        "DELETE FROM test_screenshots WHERE task_id = ?1",
        [task_id],
    )?;
    Ok(rows_affected)
}

// =============================================================================
// HELPERS
// =============================================================================

fn row_to_screenshot(row: &rusqlite::Row) -> rusqlite::Result<TestScreenshot> {
    let created_at_str: String = row.get(5)?;

    Ok(TestScreenshot {
        id: row.get(0)?,
        task_id: row.get(1)?,
        step_id: row.get(2)?,
        file_name: row.get(3)?,
        caption: row.get(4)?,
        created_at: chrono::DateTime::parse_from_rfc3339(&created_at_str)
            .map(|dt| dt.with_timezone(&Utc))
            .unwrap_or_else(|_| Utc::now()),
    })
}

