    // -------------------------------------------------------------------------
    // Create tests
    // -------------------------------------------------------------------------

    #[test]
    fn test_create_screenshot() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let screenshot = create_test_screenshot("test-001.png");

        create_screenshot(&conn, &screenshot).expect("Failed to create screenshot");

        let retrieved = get_screenshot(&conn, &screenshot.id).expect("Failed to get screenshot");
        assert!(retrieved.is_some());

        let retrieved = retrieved.unwrap();
        assert_eq!(retrieved.file_name, "test-001.png");
        assert!(retrieved.task_id.is_none());
        assert!(retrieved.caption.is_none());
    }

    #[test]
    fn test_create_screenshot_with_all_fields() {
        let conn = open_in_memory().expect("Failed to open in-memory db");
        let screenshot = create_test_screenshot("test-002.png")
            .with_task_id("01ARZ3NDEKTSV4RRFFQ69G5FAV")
            .with_step_id("task#01ARZ3NDEKTSV4RRFFQ69G5FAV#01BSZ3NDEKTSV4RRFFQ69G5FBV")
            .with_caption("Login form rendered");

        create_screenshot(&conn, &screenshot).expect("Failed to create screenshot");

        let retrieved = get_screenshot(&conn, &screenshot.id).expect("Failed to get").unwrap();
        assert_eq!(retrieved.task_id, Some("01ARZ3NDEKTSV4RRFFQ69G5FAV".to_string()));
        assert_eq!(retrieved.caption, Some("Login form rendered".to_string()));
    }

