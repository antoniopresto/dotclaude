/**
 * HQ Animation Presets (F012 Phase 6)
 *
 * Spring-based animations for native feel.
 * Based on Linear, Notion, and native macOS apps.
 */

import type { Transition, Variant } from 'motion/react';

// =============================================================================
// Spring Presets
// =============================================================================

/**
 * Snappy spring for quick interactions (buttons, toggles)
 */
export const springSnappy: Transition = {
  type: 'spring',
  stiffness: 500,
  damping: 30,
  mass: 1,
};

/**
 * Bouncy spring for playful interactions (cards, modals)
 */
export const springBouncy: Transition = {
  type: 'spring',
  stiffness: 400,
  damping: 25,
  mass: 1,
};

/**
 * Smooth spring for subtle transitions (panels, sidebars)
 */
export const springSmooth: Transition = {
  type: 'spring',
  stiffness: 300,
  damping: 35,
  mass: 1,
};

/**
 * Gentle spring for slow, elegant movements
 */
export const springGentle: Transition = {
  type: 'spring',
  stiffness: 200,
  damping: 40,
  mass: 1,
};

