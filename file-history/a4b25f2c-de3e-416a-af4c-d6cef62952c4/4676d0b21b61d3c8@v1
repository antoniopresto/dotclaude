    // -------------------------------------------------------------------------
    // Semantic search tests
    // -------------------------------------------------------------------------

    #[test]
    fn test_semantic_search_finds_similar() {
        let conn = open_in_memory().unwrap();

        // Insert tasks
        let tasks = [
            ("01ARZ3NDEKTSV4RRFFQ69G5FAV", "Implement OAuth2 authentication"),
            ("01BSZ3NDEKTSV4RRFFQ69G5FBV", "Fix database connection pool"),
            ("01CSZ3NDEKTSV4RRFFQ69G5FCV", "Add user login functionality"),
        ];

        for (id, title) in &tasks {
            conn.execute(
                "INSERT INTO project_tasks (id, title, created_at, updated_at)
                 VALUES (?1, ?2, '2026-01-04T12:00:00Z', '2026-01-04T12:00:00Z')",
                params![id, title],
            ).unwrap();

            let rowid = get_task_rowid(&conn, id).unwrap().unwrap();
            let embedding = generate_embedding(title).unwrap();
            store_task_embedding(&conn, rowid, &embedding).unwrap();
        }

        // Search for "OAuth" - should find OAuth2 task first
        let results = search_tasks_semantic(&conn, "OAuth", Some(3)).unwrap();
        assert!(!results.is_empty());
        assert!(results[0].0.title.contains("OAuth"));

        // Search for "login" - should find login task
        let results = search_tasks_semantic(&conn, "login", Some(3)).unwrap();
        assert!(!results.is_empty());
        assert!(results[0].0.title.contains("login") || results[0].0.title.contains("OAuth"));
    }

