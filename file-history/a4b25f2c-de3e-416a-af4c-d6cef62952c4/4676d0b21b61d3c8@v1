//! Semantic search using vector embeddings.
//!
//! This module provides embedding generation and vector search using:
//! - **fastembed**: Local ONNX model for text embeddings (AllMiniLML6V2, 384 dims)
//! - **sqlite-vec**: SQLite extension for vector similarity search (KNN)
//!
//! Key features:
//! - Singleton EmbeddingService with lazy initialization
//! - Auto-sync with CRUD operations (create → embed, update → re-embed, delete → remove)
//! - Semantic search that finds conceptually similar content

use std::sync::OnceLock;

use fastembed::{EmbeddingModel, InitOptions, TextEmbedding};
use parking_lot::Mutex;
use rusqlite::{params, Connection};

use super::{DbError, DbResult, ProjectTask, ProgressEntry};

// =============================================================================
// EMBEDDING SERVICE (Singleton)
// =============================================================================

/// Global embedding service instance (lazy initialized).
static EMBEDDING_SERVICE: OnceLock<Mutex<TextEmbedding>> = OnceLock::new();

/// Get the global embedding service.
///
/// First call initializes the model (~3s on first load, downloads if needed).
/// Subsequent calls return the cached instance.
pub fn get_embedding_service() -> &'static Mutex<TextEmbedding> {
    EMBEDDING_SERVICE.get_or_init(|| {
        let model = TextEmbedding::try_new(
            InitOptions::new(EmbeddingModel::AllMiniLML6V2).with_show_download_progress(true),
        )
        .expect("Failed to load embedding model");
        Mutex::new(model)
    })
}

/// Check if the embedding service is initialized.
pub fn is_initialized() -> bool {
    EMBEDDING_SERVICE.get().is_some()
}

// =============================================================================
// EMBEDDING GENERATION
// =============================================================================

/// Generate embedding vector for text.
///
/// Returns a 384-dimensional vector (AllMiniLML6V2 model).
pub fn generate_embedding(text: &str) -> DbResult<Vec<f32>> {
    let model = get_embedding_service().lock();
    let embeddings = model
        .embed(vec![text], None)
        .map_err(|e| DbError::Embedding(e.to_string()))?;
    Ok(embeddings.into_iter().next().unwrap_or_default())
}

/// Convert embedding vector to bytes for sqlite-vec storage.
fn embedding_to_bytes(embedding: &[f32]) -> Vec<u8> {
    embedding
        .iter()
        .flat_map(|f| f.to_le_bytes())
        .collect()
}

/// Convert bytes from sqlite-vec back to embedding vector.
#[allow(dead_code)]
fn bytes_to_embedding(bytes: &[u8]) -> Vec<f32> {
    bytes
        .chunks_exact(4)
        .map(|chunk| f32::from_le_bytes(chunk.try_into().unwrap()))
        .collect()
}

// =============================================================================
// TASK EMBEDDINGS
// =============================================================================

/// Store embedding for a task (by rowid).
pub fn store_task_embedding(conn: &Connection, task_rowid: i64, embedding: &[f32]) -> DbResult<()> {
    let bytes = embedding_to_bytes(embedding);
    conn.execute(
        "INSERT INTO task_embeddings(rowid, embedding) VALUES (?1, ?2)",
        params![task_rowid, bytes],
    )?;
    Ok(())
}

/// Update embedding for a task (delete + insert).
pub fn update_task_embedding(
    conn: &Connection,
    task_rowid: i64,
    embedding: &[f32],
) -> DbResult<()> {
    delete_task_embedding(conn, task_rowid)?;
    store_task_embedding(conn, task_rowid, embedding)
}

/// Delete embedding for a task.
pub fn delete_task_embedding(conn: &Connection, task_rowid: i64) -> DbResult<()> {
    conn.execute(
        "DELETE FROM task_embeddings WHERE rowid = ?1",
        params![task_rowid],
    )?;
    Ok(())
}

/// Get rowid for a task by ID.
pub fn get_task_rowid(conn: &Connection, task_id: &str) -> DbResult<Option<i64>> {
    let result = conn.query_row(
        "SELECT rowid FROM project_tasks WHERE id = ?1",
        [task_id],
        |row| row.get::<_, i64>(0),
    );

    match result {
        Ok(rowid) => Ok(Some(rowid)),
        Err(rusqlite::Error::QueryReturnedNoRows) => Ok(None),
        Err(e) => Err(e.into()),
    }
}

/// Semantic search for tasks using vector similarity (KNN).
///
/// Returns tasks ordered by semantic similarity to the query.
pub fn search_tasks_semantic(
    conn: &Connection,
    query: &str,
    limit: Option<usize>,
) -> DbResult<Vec<(ProjectTask, f32)>> {
    let query_embedding = generate_embedding(query)?;
    let query_bytes = embedding_to_bytes(&query_embedding);
    let limit = limit.unwrap_or(20);

    let mut stmt = conn.prepare(
        r#"
        SELECT
            p.id, p.title, p.description, p.status, p.category,
            p.sort_order, p.is_passed, p.created_at, p.updated_at,
            e.distance
        FROM project_tasks p
        JOIN task_embeddings e ON p.rowid = e.rowid
        WHERE e.embedding MATCH ?1
        ORDER BY e.distance
        LIMIT ?2
        "#,
    )?;

    let rows = stmt.query_map(params![query_bytes, limit as i64], |row| {
        let task = ProjectTask {
            id: row.get(0)?,
            title: row.get(1)?,
            description: row.get(2)?,
            status: row.get::<_, String>(3)?.parse().unwrap_or_default(),
            category: row.get(4)?,
            sort_order: row.get(5)?,
            is_passed: row.get::<_, String>(6)? == "true",
            created_at: row.get(7)?,
            updated_at: row.get(8)?,
        };
        let distance: f32 = row.get(9)?;
        Ok((task, distance))
    })?;

    rows.collect::<Result<Vec<_>, _>>().map_err(Into::into)
}

