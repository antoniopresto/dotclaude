/// Semantic search for progress entries using vector similarity (KNN).
///
/// Returns progress entries ordered by semantic similarity to the query.
pub fn search_progress_semantic(
    conn: &Connection,
    query: &str,
    limit: Option<usize>,
) -> DbResult<Vec<(ProgressEntry, f32)>> {
    let query_embedding = generate_embedding(query)?;
    let query_bytes = embedding_to_bytes(&query_embedding);
    let limit = limit.unwrap_or(20);

    let mut stmt = conn.prepare(
        r#"
        SELECT
            p.id, p.content, p.created_at,
            e.distance
        FROM project_progress p
        JOIN progress_embeddings e ON p.rowid = e.rowid
        WHERE e.embedding MATCH ?1
        ORDER BY e.distance
        LIMIT ?2
        "#,
    )?;

    let rows = stmt.query_map(params![query_bytes, limit as i64], |row| {
        let entry = ProgressEntry {
            id: row.get(0)?,
            content: row.get(1)?,
            created_at: row.get(2)?,
        };
        let distance: f32 = row.get(3)?;
        Ok((entry, distance))
    })?;

    rows.collect::<Result<Vec<_>, _>>().map_err(Into::into)
}

// =============================================================================
// EMBEDDING STATISTICS
// =============================================================================

/// Statistics about embeddings in the database.
#[derive(Debug, Clone, Default)]
pub struct EmbeddingStats {
    /// Number of task embeddings.
    pub task_embeddings: i64,
    /// Number of progress embeddings.
    pub progress_embeddings: i64,
    /// Whether the embedding service is loaded.
    pub service_loaded: bool,
}

impl EmbeddingStats {
    /// Collect embedding statistics.
    pub fn collect(conn: &Connection) -> DbResult<Self> {
        let task_embeddings: i64 = conn.query_row(
            "SELECT COUNT(*) FROM task_embeddings",
            [],
            |row| row.get(0),
        )?;

        let progress_embeddings: i64 = conn.query_row(
            "SELECT COUNT(*) FROM progress_embeddings",
            [],
            |row| row.get(0),
        )?;

        Ok(EmbeddingStats {
            task_embeddings,
            progress_embeddings,
            service_loaded: is_initialized(),
        })
    }
}

// =============================================================================
// REBUILD EMBEDDINGS
// =============================================================================

/// Rebuild all task embeddings from scratch.
///
/// Useful after model changes or to fix corrupted embeddings.
pub fn rebuild_task_embeddings(conn: &Connection) -> DbResult<usize> {
    // Clear existing embeddings
    conn.execute("DELETE FROM task_embeddings", [])?;

    // Get all tasks
    let mut stmt = conn.prepare(
        "SELECT rowid, title, description FROM project_tasks",
    )?;

    let tasks: Vec<(i64, String, Option<String>)> = stmt
        .query_map([], |row| {
            Ok((row.get(0)?, row.get(1)?, row.get(2)?))
        })?
        .collect::<Result<Vec<_>, _>>()?;

    let count = tasks.len();

    // Generate and store embeddings
    for (rowid, title, description) in tasks {
        let text = format!("{} {}", title, description.as_deref().unwrap_or(""));
        let embedding = generate_embedding(&text)?;
        store_task_embedding(conn, rowid, &embedding)?;
    }

    Ok(count)
}

/// Rebuild all progress embeddings from scratch.
pub fn rebuild_progress_embeddings(conn: &Connection) -> DbResult<usize> {
    // Clear existing embeddings
    conn.execute("DELETE FROM progress_embeddings", [])?;

    // Get all progress entries
    let mut stmt = conn.prepare(
        "SELECT rowid, content FROM project_progress",
    )?;

    let entries: Vec<(i64, String)> = stmt
        .query_map([], |row| {
            Ok((row.get(0)?, row.get(1)?))
        })?
        .collect::<Result<Vec<_>, _>>()?;

    let count = entries.len();

    // Generate and store embeddings
    for (rowid, content) in entries {
        let embedding = generate_embedding(&content)?;
        store_progress_embedding(conn, rowid, &embedding)?;
    }

    Ok(count)
}

