#[cfg(test)]
mod tests {
    use super::*;
    use crate::db::connection::open_in_memory;

    // -------------------------------------------------------------------------
    // Embedding generation tests
    // -------------------------------------------------------------------------

    #[test]
    fn test_generate_embedding_returns_384_dims() {
        let embedding = generate_embedding("Hello world").unwrap();
        assert_eq!(embedding.len(), 384);
    }

    #[test]
    fn test_generate_embedding_normalized() {
        let embedding = generate_embedding("Test text").unwrap();
        // Check it's normalized (length ~= 1.0)
        let length: f32 = embedding.iter().map(|x| x * x).sum::<f32>().sqrt();
        assert!((length - 1.0).abs() < 0.01);
    }

    #[test]
    fn test_embedding_bytes_roundtrip() {
        let original = vec![1.0f32, 2.0, 3.0, 4.0];
        let bytes = embedding_to_bytes(&original);
        let recovered = bytes_to_embedding(&bytes);
        assert_eq!(original, recovered);
    }

    // -------------------------------------------------------------------------
    // Task embedding tests
    // -------------------------------------------------------------------------

    #[test]
    fn test_store_task_embedding() {
        let conn = open_in_memory().unwrap();

        // Insert a task first
        conn.execute(
            "INSERT INTO project_tasks (id, title, created_at, updated_at)
             VALUES ('01ARZ3NDEKTSV4RRFFQ69G5FAV', 'Test task', '2026-01-04T12:00:00Z', '2026-01-04T12:00:00Z')",
            [],
        ).unwrap();

        // Get rowid and store embedding
        let rowid = get_task_rowid(&conn, "01ARZ3NDEKTSV4RRFFQ69G5FAV").unwrap().unwrap();
        let embedding = generate_embedding("Test task").unwrap();
        store_task_embedding(&conn, rowid, &embedding).unwrap();

        // Verify stored
        let count: i64 = conn.query_row(
            "SELECT COUNT(*) FROM task_embeddings",
            [],
            |row| row.get(0),
        ).unwrap();
        assert_eq!(count, 1);
    }

    #[test]
    fn test_delete_task_embedding() {
        let conn = open_in_memory().unwrap();

        // Insert task and embedding
        conn.execute(
            "INSERT INTO project_tasks (id, title, created_at, updated_at)
             VALUES ('01ARZ3NDEKTSV4RRFFQ69G5FAV', 'Test', '2026-01-04T12:00:00Z', '2026-01-04T12:00:00Z')",
            [],
        ).unwrap();

        let rowid = get_task_rowid(&conn, "01ARZ3NDEKTSV4RRFFQ69G5FAV").unwrap().unwrap();
