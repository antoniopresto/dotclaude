    #[test]
    fn test_rebuild_task_embeddings() {
        let conn = open_in_memory().unwrap();

        // Insert tasks without embeddings
        for i in 1..=3 {
            conn.execute(
                &format!(
                    "INSERT INTO project_tasks (id, title, created_at, updated_at)
                     VALUES ('01ARZ3NDEKTSV4RRFFQ69G5FA{}', 'Task {}', '2026-01-04T12:00:00Z', '2026-01-04T12:00:00Z')",
                    i, i
                ),
                [],
            ).unwrap();
        }

        // Verify no embeddings
        let count: i64 = conn.query_row(
            "SELECT COUNT(*) FROM task_embeddings",
            [],
            |row| row.get(0),
        ).unwrap();
        assert_eq!(count, 0);

        // Rebuild
        let rebuilt = rebuild_task_embeddings(&conn).unwrap();
        assert_eq!(rebuilt, 3);

        // Verify embeddings exist
        let count: i64 = conn.query_row(
            "SELECT COUNT(*) FROM task_embeddings",
            [],
            |row| row.get(0),
        ).unwrap();
        assert_eq!(count, 3);
    }
