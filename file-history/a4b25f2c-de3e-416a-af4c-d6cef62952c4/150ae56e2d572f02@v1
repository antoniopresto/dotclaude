    // -------------------------------------------------------------------------
    // Rebuild embeddings tests
    // -------------------------------------------------------------------------

    #[test]
    fn test_rebuild_task_embeddings() {
        let conn = db::open_in_memory().unwrap();

        // Create tasks (embeddings auto-generated)
        for i in 1..=5 {
            let task = db::ProjectTask::new(format!("Task {}", i));
            db::create_task(&conn, &task).unwrap();
        }

        // Verify embeddings exist
        let stats = db::EmbeddingStats::collect(&conn).unwrap();
        assert_eq!(stats.task_embeddings, 5);

        // Manually delete embeddings to simulate corruption
        conn.execute("DELETE FROM task_embeddings", []).unwrap();

        // Verify embeddings are gone
        let stats = db::EmbeddingStats::collect(&conn).unwrap();
        assert_eq!(stats.task_embeddings, 0);

        // Rebuild
        let count = db::rebuild_task_embeddings(&conn).unwrap();
        assert_eq!(count, 5);

        // Verify embeddings are back
        let stats = db::EmbeddingStats::collect(&conn).unwrap();
        assert_eq!(stats.task_embeddings, 5);
    }

    #[test]
    fn test_rebuild_progress_embeddings() {
        let conn = db::open_in_memory().unwrap();

        // Create session with progress entries
        let session = db::start_session(&conn, None).unwrap();
        for i in 1..=3 {
            db::add_progress(&conn, &session.id, &format!("Progress {}", i)).unwrap();
        }

        // Manually delete embeddings
        conn.execute("DELETE FROM progress_embeddings", []).unwrap();

        // Rebuild
        let count = db::rebuild_progress_embeddings(&conn).unwrap();
        assert_eq!(count, 3);

        // Verify embeddings are back
        let stats = db::EmbeddingStats::collect(&conn).unwrap();
        assert_eq!(stats.progress_embeddings, 3);
    }
