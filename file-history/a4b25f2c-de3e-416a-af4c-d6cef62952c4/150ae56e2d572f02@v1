//! Integration tests for semantic search.
//!
//! These tests verify the full flow of:
//! - Creating data with auto-generated embeddings
//! - Searching with semantic similarity
//! - Updating data and regenerating embeddings
//! - Deleting data and cleaning up embeddings

#[cfg(test)]
mod tests {
    use crate::db;

    // -------------------------------------------------------------------------
    // Task CRUD with auto-embeddings
    // -------------------------------------------------------------------------

    #[test]
    fn test_create_task_auto_generates_embedding() {
        let conn = db::open_in_memory().unwrap();

        // Create a task
        let task = db::ProjectTask::new("Implement OAuth2 authentication")
            .with_description("Add support for Google and GitHub login");
        db::create_task(&conn, &task).unwrap();

        // Verify embedding was created
        let stats = db::EmbeddingStats::collect(&conn).unwrap();
        assert_eq!(stats.task_embeddings, 1);
    }

    #[test]
    fn test_update_task_regenerates_embedding() {
        let conn = db::open_in_memory().unwrap();

        // Create a task
        let task = db::ProjectTask::new("Fix login bug");
        db::create_task(&conn, &task).unwrap();

        // Update the title
        let update = db::TaskUpdate {
            title: Some("Fix authentication error".to_string()),
            ..Default::default()
        };
        db::update_task(&conn, &task.id, update).unwrap();

        // Search for "authentication" should find it
        let results = db::search_tasks_semantic(&conn, "authentication", Some(5)).unwrap();
        assert!(!results.is_empty());
        assert_eq!(results[0].0.id, task.id);
    }

    #[test]
    fn test_delete_task_removes_embedding() {
        let conn = db::open_in_memory().unwrap();

        // Create a task
        let task = db::ProjectTask::new("Temporary task");
        db::create_task(&conn, &task).unwrap();

        // Verify embedding exists
        let stats = db::EmbeddingStats::collect(&conn).unwrap();
        assert_eq!(stats.task_embeddings, 1);

        // Delete the task
        db::delete_task(&conn, &task.id).unwrap();

        // Verify embedding was removed
        let stats = db::EmbeddingStats::collect(&conn).unwrap();
        assert_eq!(stats.task_embeddings, 0);
    }

    // -------------------------------------------------------------------------
    // Semantic search quality tests
    // -------------------------------------------------------------------------

    #[test]
    fn test_semantic_search_finds_synonyms() {
        let conn = db::open_in_memory().unwrap();

        // Create tasks with related concepts
        let tasks = [
            ("OAuth2 authentication implementation", "Add Google and GitHub login"),
            ("Fix database connection pool", "Handle connection timeout errors"),
            ("User login functionality", "Allow users to sign in with email"),
        ];

        for (title, desc) in &tasks {
            let task = db::ProjectTask::new(*title).with_description(*desc);
            db::create_task(&conn, &task).unwrap();
        }

        // Search for "OAuth" should find OAuth2 task first
        let results = db::search_tasks_semantic(&conn, "OAuth", Some(3)).unwrap();
        assert!(!results.is_empty());
        assert!(results[0].0.title.contains("OAuth"));

        // Search for "login" should find login-related tasks
        let results = db::search_tasks_semantic(&conn, "login", Some(3)).unwrap();
        assert!(!results.is_empty());
        // Should find OAuth or User login task
        let titles: Vec<_> = results.iter().map(|(t, _)| &t.title).collect();
        assert!(
            titles.iter().any(|t| t.contains("login") || t.contains("OAuth")),
            "Expected login-related tasks, got: {:?}",
            titles
        );

        // Search for "error" should find database task
        let results = db::search_tasks_semantic(&conn, "error handling", Some(3)).unwrap();
        assert!(!results.is_empty());
    }

    #[test]
    fn test_semantic_search_orders_by_relevance() {
        let conn = db::open_in_memory().unwrap();

        // Create tasks with varying relevance
        let tasks = [
            "Implement user authentication with OAuth2",
            "Add database migration scripts",
            "OAuth login button styling",
        ];

        for title in &tasks {
            let task = db::ProjectTask::new(*title);
            db::create_task(&conn, &task).unwrap();
        }

        // Search for "OAuth authentication"
        let results = db::search_tasks_semantic(&conn, "OAuth authentication", Some(3)).unwrap();
        assert!(!results.is_empty());

        // First result should be the most relevant (contains both OAuth and authentication)
        assert!(results[0].0.title.contains("OAuth"));

        // Distances should be in ascending order (lower = more similar)
        for i in 1..results.len() {
            assert!(
                results[i - 1].1 <= results[i].1,
                "Results should be ordered by distance (ascending)"
            );
        }
    }

