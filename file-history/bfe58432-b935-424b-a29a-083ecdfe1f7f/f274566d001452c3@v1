### Test Categories

#### 1. Navigation Tests
```typescript
test.describe('Navigation', () => {
  test('all nav links work', async ({ page }) => {
    const navLinks = ['Dashboard', 'Map', 'Allocation', 'Balancing', 'Schedule', 'Fleet'];
    for (const link of navLinks) {
      await page.click(`nav >> text=${link}`);
      await expect(page).toHaveURL(new RegExp(link.toLowerCase()));
    }
  });
});
```

#### 2. Canvas Interaction Tests
```typescript
test.describe('Canvas Interactions', () => {
  test('pan by dragging', async ({ page }) => {
    await page.goto('/schedule');
    const canvas = page.locator('canvas');
    const box = await canvas.boundingBox();

    await page.mouse.move(box.x + 100, box.y + 100);
    await page.mouse.down();
    await page.mouse.move(box.x + 200, box.y + 200);
    await page.mouse.up();

    // Verify content moved (compare screenshots)
    await expect(page).toHaveScreenshot('canvas-after-pan.png');
  });

  test('zoom with scroll wheel', async ({ page }) => {
    await page.goto('/schedule');
    const canvas = page.locator('canvas');

    await canvas.hover();
    await page.mouse.wheel(0, -100); // Zoom in

    await expect(page.locator('.lod-indicator')).toContainText('MICRO');
  });
});
```

#### 3. Drag-Drop Tests
```typescript
test.describe('Drag and Drop', () => {
  test('reschedule maintenance block', async ({ page }) => {
    await page.goto('/schedule');

    const block = page.locator('[data-testid="maintenance-block-1"]');
    const target = page.locator('[data-testid="week-3"]');

    await block.dragTo(target);

    await expect(page.locator('.toast')).toContainText('Rescheduled');
  });
});
```

#### 4. Form Input Tests
```typescript
test.describe('Form Inputs', () => {
  test('create what-if scenario', async ({ page }) => {
    await page.goto('/balancing');

    await page.click('button:has-text("New Scenario")');
    await page.fill('input[name="scenarioName"]', 'Test Scenario');
    await page.click('button:has-text("Create")');

    await expect(page.locator('.scenario-badge')).toBeVisible();
  });
});
```

### CI Pipeline Configuration
```yaml
# .github/workflows/e2e.yml
name: E2E Tests
on: [push, pull_request]
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
      - run: npm ci
      - run: npx playwright install
      - run: npm run dev &
      - run: npx playwright test
      - uses: actions/upload-artifact@v4
        if: failure()
        with:
          name: playwright-report
          path: playwright-report/
```

## Implementation Notes
- Use Playwright for all interaction tests
- Tests should be stable (no flaky tests)
- Screenshot comparisons for visual regression
