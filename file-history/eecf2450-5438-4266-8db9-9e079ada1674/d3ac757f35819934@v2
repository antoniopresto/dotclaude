{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/harness-enforcement.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-deps.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/quality-check.sh" }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(find ~:*)",
      "Bash(find /Users:*)",
      "Bash(ls ~/Desktop:*)",
      "Bash(ls ~/Documents:*)",
      "Bash(ls ~/Downloads:*)",
      "Read(path:~/Desktop)",
      "Read(path:~/Documents)",
      "Read(path:~/Downloads)",
      "Edit(path:~/Desktop)",
      "Edit(path:~/Documents)",
      "Edit(path:~/Downloads)",
      "Write(path:~/Desktop)",
      "Write(path:~/Documents)",
      "Write(path:~/Downloads)"
    ],
    "allow": [
      "Bash(bun:*)",
      "Bash(cargo:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(pwd)",
      "Bash(date:*)",
      "Bash(jq:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "WebSearch",
      "WebFetch"
    ]
  }
}
